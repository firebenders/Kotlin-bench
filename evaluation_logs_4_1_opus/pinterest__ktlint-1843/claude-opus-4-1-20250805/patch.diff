package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.ElementType.COLON
import com.pinterest.ktlint.rule.engine.core.api.ElementType.FUN
import com.pinterest.ktlint.rule.engine.core.api.ElementType.WHITE_SPACE
import com.pinterest.ktlint.rule.engine.core.api.Rule
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.EditorConfig
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY_OFF
import com.pinterest.ktlint.rule.engine.core.api.nextLeaf
import com.pinterest.ktlint.rule.engine.core.api.prevLeaf
import com.pinterest.ktlint.rule.engine.core.api.upsertWhitespaceAfterMe
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.com.intellij.psi.PsiWhiteSpace
import org.jetbrains.kotlin.psi.psiUtil.endOffset

public class FunctionReturnTypeSpacingRule :
    StandardRule(
        id = "function-return-type-spacing",
        usesEditorConfigProperties = setOf(MAX_LINE_LENGTH_PROPERTY),
    ),
    Rule.Experimental {
    private var maxLineLength = MAX_LINE_LENGTH_PROPERTY_OFF

    override fun beforeFirstNode(editorConfig: EditorConfig) {
        maxLineLength = editorConfig[MAX_LINE_LENGTH_PROPERTY]
    }

    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        node.firstChildNode
        node
            .takeIf { node.elementType == FUN }
            ?.let { node.findChildByType(COLON) }
            ?.let { colonNode ->
                removeWhiteSpaceBetweenClosingParenthesisAndColon(colonNode, emit, autoCorrect)
                fixWhiteSpaceBetweenColonAndReturnType(colonNode, emit, autoCorrect)
            }
    }

    private fun removeWhiteSpaceBetweenClosingParenthesisAndColon(
        node: ASTNode,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
        autoCorrect: Boolean,
    ) {
        require(node.elementType == COLON)
        node
            .prevLeaf()
            ?.takeIf { it.elementType == WHITE_SPACE }
            ?.let { whitespaceBeforeColonNode ->
                emit(whitespaceBeforeColonNode.startOffset, "Unexpected whitespace", true)
                if (autoCorrect) {
                    whitespaceBeforeColonNode.treeParent?.removeChild(whitespaceBeforeColonNode)
                }
            }
    }

    private fun fixWhiteSpaceBetweenColonAndReturnType(
        node: ASTNode,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
        autoCorrect: Boolean,
    ) {
        require(node.elementType == COLON)
        val whiteSpaceAfterColon = node.nextLeaf()?.takeIf { it.elementType == WHITE_SPACE }
        
        // Check if we should allow a newline to avoid exceeding max line length
        if (shouldAllowNewlineAfterColon(node, whiteSpaceAfterColon)) {
            // Allow the existing whitespace (which likely contains a newline) to remain
            return
        }
        
        if (whiteSpaceAfterColon?.text != " ") {
            emit(node.startOffset, "Single space expected between colon and return type", true)
            if (autoCorrect) {
                node.upsertWhitespaceAfterMe(" ")
            }
        }
    }

    private fun shouldAllowNewlineAfterColon(colonNode: ASTNode, whiteSpaceAfterColon: ASTNode?): Boolean {
        // If max line length is not set, don't allow newlines
        if (maxLineLength == MAX_LINE_LENGTH_PROPERTY_OFF) {
            return false
        }
        
        // Check if whitespace contains a newline
        val hasNewline = whiteSpaceAfterColon?.text?.contains('\n') == true
        if (!hasNewline) {
            return false
        }
        
        // Find the start of the current line
        val lineStartOffset = findLineStartOffset(colonNode)
        
        // Find the end of the return type (or at least the next significant token)
        val nextNonWhitespace = whiteSpaceAfterColon?.nextLeaf { it.elementType != WHITE_SPACE }
        if (nextNonWhitespace == null) {
            return false
        }
        
        // Calculate what the line length would be if we put everything on one line
        val potentialLineLength = if (nextNonWhitespace.text.contains('\n')) {
            // If the return type itself contains newlines, just check up to the first newline
            val firstNewlineIndex = nextNonWhitespace.text.indexOf('\n')
            nextNonWhitespace.startOffset + firstNewlineIndex - lineStartOffset
        } else {
            // Find the next token that would end this "line" (either a newline or opening brace)
            var endNode = nextNonWhitespace
            var nextNode = endNode.nextLeaf()
            while (nextNode != null && !nextNode.text.contains('\n') && nextNode.text != "{") {
                endNode = nextNode
                nextNode = nextNode.nextLeaf()
            }
            endNode.endOffset - lineStartOffset
        }
        
        // Allow newline if putting it on one line would exceed max length
        return potentialLineLength > maxLineLength
    }
    
    private fun findLineStartOffset(node: ASTNode): Int {
        var current = node.prevLeaf()
        while (current != null) {
            if (current.elementType == WHITE_SPACE && current.text.contains('\n')) {
                // Found a newline, the line starts after it
                val lastNewlineIndex = current.text.lastIndexOf('\n')
                return current.startOffset + lastNewlineIndex + 1
            }
            current = current.prevLeaf()
        }
        // No newline found, must be the first line
        return 0
    }
}

public val FUNCTION_RETURN_TYPE_SPACING_RULE_ID: RuleId = FunctionReturnTypeSpacingRule().ruleId
