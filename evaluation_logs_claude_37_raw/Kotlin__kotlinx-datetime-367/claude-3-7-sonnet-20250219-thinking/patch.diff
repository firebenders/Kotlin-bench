package kotlinx.datetime

/**
 * The enumeration class representing the days of the week.
 *
 * This enum follows the ISO-8601 standard, where Monday is the first day of the week (value 1)
 * and Sunday is the last day of the week (value 7).
 *
 * Instances of [DayOfWeek] can be obtained in several ways:
 * - Direct reference to one of the enum constants, e.g., [MONDAY]
 * - From the [DayOfWeek] function with an ISO day-of-week number (1-7)
 * - From a [LocalDate] or [LocalDateTime] using the [dayOfWeek] property
 *
 * Example:
 * ```kotlin
 * // Direct reference
 * val monday = DayOfWeek.MONDAY
 *
 * // From ISO day number (1-7)
 * val tuesday = DayOfWeek(2)
 *
 * // From a LocalDate
 * val today = Clock.System.todayIn(TimeZone.currentSystemDefault())
 * val dayOfWeek = today.dayOfWeek
 *
 * // Converting to ISO day number
 * val dayNumber = dayOfWeek.isoDayNumber // 1 for Monday, 7 for Sunday
 * ```
 */
public expect enum class DayOfWeek {
    MONDAY,
    TUESDAY,
    WEDNESDAY,
    THURSDAY,
    FRIDAY,
    SATURDAY,
    SUNDAY;
}

/**
 * The ISO-8601 number of the given day of the week. Monday is 1, Sunday is 7.
 *
 * This property provides the numeric representation of the day of the week according to ISO-8601,
 * where Monday is represented by 1 and Sunday by 7.
 *
 * Example:
 * ```kotlin
 * DayOfWeek.MONDAY.isoDayNumber // 1
 * DayOfWeek.SUNDAY.isoDayNumber // 7
 * ```
 */
public val DayOfWeek.isoDayNumber: Int get() = ordinal + 1

/**
 * Returns the [DayOfWeek] instance for the given ISO-8601 week day number. Monday is 1, Sunday is 7.
 *
 * This function provides a way to get a [DayOfWeek] enum value from its ISO-8601 numeric representation.
 *
 * Example:
 * ```kotlin
 * DayOfWeek(1) // MONDAY
 * DayOfWeek(7) // SUNDAY
 * ```
 * 
 * @param isoDayNumber an integer from 1 (Monday) to 7 (Sunday)
 * @throws IllegalArgumentException if [isoDayNumber] is not in the range 1..7
 */
public fun DayOfWeek(isoDayNumber: Int): DayOfWeek {
    require(isoDayNumber in 1..7) { "Expected ISO day-of-week number in 1..7, got $isoDayNumber" }
    return DayOfWeek.entries[isoDayNumber - 1]
}
