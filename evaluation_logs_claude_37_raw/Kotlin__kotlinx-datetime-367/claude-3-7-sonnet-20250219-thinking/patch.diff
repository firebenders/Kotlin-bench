 * ```kotlin
 * val now = Clock.System.now()
 * val timeZone = TimeZone.currentSystemDefault()
 * 
 * // Subtract 1 year, 2 months, and 3 days from the current time
 * val past = now.minus(DateTimePeriod(years = 1, months = 2, days = 3), timeZone)
 * 
 * // Subtract mixed date and time components
 * val mixed = now.minus(DateTimePeriod(months = 1, hours = 2, minutes = 30), timeZone)
 * ```
 *
