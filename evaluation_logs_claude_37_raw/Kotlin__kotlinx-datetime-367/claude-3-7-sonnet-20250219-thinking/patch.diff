package kotlinx.datetime

import kotlinx.datetime.serializers.*
import kotlinx.serialization.Serializable

/**
 * A time zone, provides the conversion between [Instant] and [LocalDateTime] values
 * using a collection of rules specifying which [LocalDateTime] value corresponds to each [Instant].
 *
 * Time zones define how the civil time in a particular region relates to the 
 * absolute time scale represented by [Instant]. This includes adjustments like 
 * daylight saving time (DST), historical changes, and regional policies.
 *
 * [TimeZone] instances can be obtained in several ways:
 * - [TimeZone.currentSystemDefault] - the time zone configured in the operating system
 * - [TimeZone.of] with a zone identifier, like "Europe/Berlin" or "America/New_York"
 * - [TimeZone.UTC] - the UTC time zone with zero offset
 * - [UtcOffset.asTimeZone] - a fixed offset time zone from a [UtcOffset]
 *
 * Example usage:
 * ```kotlin
 * // Get the current system time zone
 * val systemTz = TimeZone.currentSystemDefault()
 * 
 * // Get a specific time zone by ID
 * val berlinTz = TimeZone.of("Europe/Berlin")
 * val tokyoTz = TimeZone.of("Asia/Tokyo")
 * val utcPlus3 = TimeZone.of("UTC+3")
 * 
 * // Convert between Instant and LocalDateTime
 * val now = Clock.System.now()
 * val localInBerlin = now.toLocalDateTime(berlinTz)
 * val localInTokyo = now.toLocalDateTime(tokyoTz)
 * 
 * // Convert back to an Instant
 * val sameInstant = localInBerlin.toInstant(berlinTz)
 * 
 * // Find UTC offset at a particular instant
 * val berlinOffset = berlinTz.offsetAt(now) // or now.offsetIn(berlinTz)
 * ```
 *
 * Note that the conversion between [Instant] and [LocalDateTime] is not always 
 * straightforward due to time zone transitions like daylight saving time. When
 * a time zone "springs forward," some local times don't exist, and when it 
 * "falls back," some local times occur twice. See [LocalDateTime.toInstant] for 
 * details on how these cases are handled.
 */
@Serializable(with = TimeZoneSerializer::class)
public expect open class TimeZone {
    /**
     * Returns the identifier string of the time zone.
     *
     * This identifier can be used later for finding this time zone with [TimeZone.of] function.
     * Identifiers generally follow these patterns:
     * - Region-based identifiers, usually in the form `area/city`, e.g., "Europe/Berlin" or "America/New_York"
     * - Fixed-offset identifiers, e.g., "UTC+01:00" or "+01:00"
     * - Special identifiers like "UTC", "GMT", "Z" for the UTC time zone
     */
    public val id: String

    // TODO: Declare and document toString/equals/hashCode

    public companion object {
        /**
         * Queries the current system time zone.
         *
         * This function returns the time zone configured in the operating system settings.
         * If the current system time zone changes, this function will reflect that change
         * on the next invocation.
         *
         * Example:
         * ```kotlin
         * val systemTz = TimeZone.currentSystemDefault()
         * println("Current time zone: ${systemTz.id}")
         * ```
         *
         * Note that on some platforms, especially in browser JavaScript environments, the
         * system time zone information might be limited to just the offset, without historical
         * or future DST transition rules.
         */
        public fun currentSystemDefault(): TimeZone

        /**
         * Returns the time zone with the fixed UTC+0 offset.
         *
         * This is a constant representing the UTC (Coordinated Universal Time) time zone.
         * In this time zone, the local date and time directly corresponds to the UTC time
         * with no offset or daylight saving time adjustments.
         *
         * Example:
         * ```kotlin
         * val utcTimeZone = TimeZone.UTC
         * val nowUtc = Clock.System.now().toLocalDateTime(utcTimeZone)
         * ```
         */
        public val UTC: FixedOffsetTimeZone

        /**
         * Returns the time zone identified by the provided [zoneId].
         *
         * The supported variants of time zone identifiers:
         * - `Z`, 'UTC', 'UT' or 'GMT' — identifies the fixed-offset time zone [TimeZone.UTC],
         * - a string starting with '+', '-', `UTC+`, `UTC-`, `UT+`, `UT-`, `GMT+`, `GMT-` — identifiers the time zone
         *   with the fixed offset specified after `+` or `-`,
         * - all other strings are treated as region-based zone identifiers.
         * In the IANA Time Zone Database (TZDB) which is used as the default source of time zones,
         * these ids are usually in the form `area/city`, for example, `Europe/Berlin` or `America/Los_Angeles`.
         *
         * Example:
         * ```kotlin
         * val berlinTz = TimeZone.of("Europe/Berlin")
         * val tokyoTz = TimeZone.of("Asia/Tokyo")
         * val utcPlus3 = TimeZone.of("UTC+3")
         * val fixedOffset = TimeZone.of("+05:30") // India
         * ```
         *
         * @throws IllegalTimeZoneException if [zoneId] has an invalid format or a time-zone with the name [zoneId]
         * is not found.
         */
        public fun of(zoneId: String): TimeZone

        /**
         * Queries the set of identifiers of time zones available in the system.
         *
         * This property returns all available time zone identifiers that can be used with [TimeZone.of].
         * The returned set includes region-based time zone identifiers, but not fixed offset identifiers
         * (like "+01:00") which can be constructed dynamically.
         *
         * Example:
         * ```kotlin
         * for (zoneId in TimeZone.availableZoneIds.sorted()) {
         *     println(zoneId)
         * }
         * ```
         */
        public val availableZoneIds: Set<String>
    }

    /**
     * Return the civil date/time value that this instant has in the time zone provided as an implicit receiver.
     *
     * Note that while this conversion is unambiguous, the inverse ([LocalDateTime.toInstant])
     * is not necessary so.
     *
     * @see LocalDateTime.toInstant
     * @see Instant.offsetIn
     * @throws DateTimeArithmeticException if this value is too large to fit in [LocalDateTime].
     */
    public fun Instant.toLocalDateTime(): LocalDateTime

    /**
     * Returns an instant that corresponds to this civil date/time value in the time zone provided as an implicit receiver.
     *
     * Note that the conversion is not always unambiguous. There can be the following possible situations:
     * - There's only one instant that has this date/time value in the time zone. In this case
     * the conversion is unambiguous.
     * - There's no instant that has this date/time value in the time zone. Such situation appears when
     * the time zone experiences a transition from a lesser to a greater offset. In this case the conversion is performed with
     * the lesser offset.
     * - There are two possible instants that can have this date/time components in the time zone. In this case the earlier
     * instant is returned.
     *
     * @see Instant.toLocalDateTime
     */
    public fun LocalDateTime.toInstant(): Instant
}

/**
 * A time zone that is known to always have the same offset from UTC.
 *
 * Fixed offset time zones represent a constant, specific offset from UTC,
 * unlike regular [TimeZone] instances which may have varying offsets due to
 * daylight saving time or other rules.
 *
 * Instances of [FixedOffsetTimeZone] can be obtained in several ways:
 * - Using the [UtcOffset.asTimeZone] extension function
 * - From [TimeZone.of] for string identifiers starting with "+" or "-", or "Z", "UTC", etc.
 *
 * Examples:
 * ```kotlin
 * // From a UTC offset
 * val offset = UtcOffset(hours = 5, minutes = 30)
 * val timeZone = offset.asTimeZone()
 *
 * // From TimeZone.of
 * val utcPlus2 = TimeZone.of("+02:00")
 * val utcMinus5 = TimeZone.of("-05:00")
 * val utc = TimeZone.of("Z") // or "UTC" or "GMT"
 * ```
 *
 * A fixed offset time zone is useful for representing times in a specific offset
 * without having to account for daylight saving time changes. It's particularly
 * useful for:
 * - Working with time in contexts where the offset is fixed and known
 * - Simplifying calculations where DST transitions aren't a concern
 * - Dealing with historical dates before time zones were standardized
 */
@Serializable(with = FixedOffsetTimeZoneSerializer::class)
public expect class FixedOffsetTimeZone : TimeZone {
    public constructor(offset: UtcOffset)

    /**
     * The constant offset from UTC that this time zone has.
     *
     * This offset is used for all conversions between [Instant] and [LocalDateTime],
     * regardless of the date/time being converted. Unlike regular time zones,
     * fixed offset time zones never adjust for daylight saving time.
     *
     * Example:
     * ```kotlin
     * val fixedZone = TimeZone.of("+05:30")
     * val offsetSeconds = (fixedZone as FixedOffsetTimeZone).offset.totalSeconds // 19800
     * val offsetHours = offsetSeconds / 3600.0 // 5.5
     * ```
     */
    public val offset: UtcOffset

    @Deprecated("Use offset.totalSeconds", ReplaceWith("offset.totalSeconds"))
    public val totalSeconds: Int
}

@Deprecated("Use FixedOffsetTimeZone of UtcOffset instead", ReplaceWith("FixedOffsetTimeZone"))
public typealias ZoneOffset = FixedOffsetTimeZone

/**
 * Finds the offset from UTC this time zone has at the specified [instant] of physical time.
 *
 * This function returns the UTC offset that applies in this time zone at the given instant.
 * For fixed offset time zones, this will always be the same offset regardless of the instant.
 * For region-based time zones, the offset may vary due to daylight saving time or historical changes.
 *
 * Example:
 * ```kotlin
 * val berlinTz = TimeZone.of("Europe/Berlin")
 * val summerTime = Instant.parse("2023-07-01T12:00:00Z") 
 * val winterTime = Instant.parse("2023-01-01T12:00:00Z")
 * 
 * println(berlinTz.offsetAt(summerTime)) // +02:00
 * println(berlinTz.offsetAt(winterTime)) // +01:00
 * ```
 *
 * @see Instant.toLocalDateTime
 * @see TimeZone.offsetAt
 */
public expect fun TimeZone.offsetAt(instant: Instant): UtcOffset

/**
 * Returns a civil date/time value that this instant has in the specified [timeZone].
 *
 * This function converts an [Instant] (absolute point in time) to a [LocalDateTime]
 * (wall-clock time) in the context of the specified time zone.
 *
 * Example:
 * ```kotlin
 * val now = Clock.System.now()
 * val berlinTz = TimeZone.of("Europe/Berlin")
 * val tokyoTz = TimeZone.of("Asia/Tokyo")
 * 
 * val berlinTime = now.toLocalDateTime(berlinTz)
 * val tokyoTime = now.toLocalDateTime(tokyoTz)
 * // Tokyo is typically 7-8 hours ahead of Berlin
 * ```
 *
 * Note that while this conversion is unambiguous, the inverse ([LocalDateTime.toInstant])
 * is not necessarily so due to time zone transitions.
 *
 * @see LocalDateTime.toInstant
 * @see Instant.offsetIn
 * @throws DateTimeArithmeticException if this value is too large to fit in [LocalDateTime].
 */
public expect fun Instant.toLocalDateTime(timeZone: TimeZone): LocalDateTime

/**
 * Returns a civil date/time value that this instant has in the specified [UTC offset][offset].
 *
 * @see LocalDateTime.toInstant
 * @see Instant.offsetIn
 */
internal expect fun Instant.toLocalDateTime(offset: UtcOffset): LocalDateTime

/**
 * Finds the offset from UTC the specified [timeZone] has at this instant of physical time.
 *
 * This function is an extension function variant of [TimeZone.offsetAt] with the receiver
 * and parameter swapped. It returns the UTC offset that applies in the given time zone
 * at this instant.
 *
 * Example:
 * ```kotlin
 * val now = Clock.System.now()
 * val berlinTz = TimeZone.of("Europe/Berlin")
 * 
 * val offset = now.offsetIn(berlinTz)
 * println("Current offset in Berlin: $offset")
 * ```
 *
 * @see Instant.toLocalDateTime
 * @see TimeZone.offsetAt
 */
public fun Instant.offsetIn(timeZone: TimeZone): UtcOffset =
        timeZone.offsetAt(this)

/**
 * Returns an instant that corresponds to this civil date/time value in the specified [timeZone].
 *
 * This function converts a [LocalDateTime] (wall-clock time) to an [Instant] (absolute point in time)
 * in the context of the specified time zone.
 *
 * Note that the conversion is not always unambiguous. There can be the following possible situations:
 * - There's only one instant that has this date/time value in the [timeZone]. In this case
 * the conversion is unambiguous.
 * - There's no instant that has this date/time value in the [timeZone]. Such situation appears when
 * the time zone experiences a transition from a lesser to a greater offset (typically a "spring forward"
 * DST transition). In this case the conversion is performed with the lesser offset.
 * - There are two possible instants that can have this date/time components in the [timeZone] (typically
 * during a "fall back" DST transition). In this case the earlier instant is returned.
 *
 * Example:
 * ```kotlin
 * val dateTime = LocalDateTime(2023, 3, 26, 2, 30) // During "spring forward" in many European zones
 * val berlinTz = TimeZone.of("Europe/Berlin")
 * 
 * // In Berlin, clocks jump from 2:00 to 3:00 on this date, so 2:30 doesn't exist
 * // The function will use the offset before the transition (UTC+1)
 * val instant = dateTime.toInstant(berlinTz)
 * val actualDateTime = instant.toLocalDateTime(berlinTz) // Will be 3:30, not 2:30
 * ```
 *
 * @see Instant.toLocalDateTime
 */
public expect fun LocalDateTime.toInstant(timeZone: TimeZone): Instant

/**
 * Returns an instant that corresponds to this civil date/time value that happens at the specified [UTC offset][offset].
 *
 * This function converts a [LocalDateTime] (wall-clock time) to an [Instant] (absolute point in time)
 * with the specified UTC offset.
 *
 * Since a fixed offset is used, this conversion is always unambiguous, unlike [toInstant(TimeZone)]
 * which must handle time zone transitions.
 *
 * Example:
 * ```kotlin
 * val dateTime = LocalDateTime(2023, 1, 1, 12, 0)
 * val offset = UtcOffset(hours = 5, minutes = 30) // UTC+5:30 (India)
 * 
 * val instant = dateTime.toInstant(offset)
 * // This represents 12:00 India time, which is 06:30 UTC
 * ```
 *
 * @see Instant.toLocalDateTime
 */
public expect fun LocalDateTime.toInstant(offset: UtcOffset): Instant

/**
 * Returns an instant that corresponds to the start of this date in the specified [timeZone].
 *
 * Note that it's not equivalent to `atTime(0, 0).toInstant(timeZone)`
 * because a day does not always start at the fixed time 0:00:00.
 * For example, if due do daylight saving time, clocks were shifted from 23:30
 * of one day directly to 00:30 of the next day, skipping the midnight, then
 * `atStartOfDayIn` would return the `Instant` corresponding to 00:30, whereas
 * `atTime(0, 0).toInstant(timeZone)` would return the `Instant` corresponding
 * to 01:00.
 *
 * This function properly handles cases where midnight doesn't exist due to time zone transitions.
 * When a day starts with a "spring forward" DST transition where the clock jumps from
 * a time before midnight to a time after midnight (skipping midnight itself),
 * this function returns the instant corresponding to the time right after the transition.
 *
 * Example:
 * ```kotlin
 * val date = LocalDate(2023, 3, 26) // Date of DST transition in Europe
 * val berlinTz = TimeZone.of("Europe/Berlin")
 * 
 * val startOfDay = date.atStartOfDayIn(berlinTz)
 * val localDateTime = startOfDay.toLocalDateTime(berlinTz)
 * println(localDateTime) // 00:00 (no transition at midnight in this case)
 * ```
 */
public expect fun LocalDate.atStartOfDayIn(timeZone: TimeZone): Instant
