package kotlinx.datetime

import kotlin.time.*

/**
 * A source of [Instant] values.
 *
 * The primary purpose of this interface is to provide a way to access the current time
 * that can be reliably tested and controlled in a testing environment. Instead of hardcoding
 * calls to obtain the current time, code can depend on a [Clock] instance, making
 * it possible to test time-dependent code by providing a custom clock implementation.
 *
 * The standard implementation [Clock.System] provides access to the system clock, which is the
 * operating system's best estimate of the current time. When writing time-dependent code,
 * consider accepting a [Clock] parameter rather than using [Clock.System] directly to improve
 * testability.
 *
 * A [Clock] instance can be used to obtain the current:
 * - Instant using [now]
 * - LocalDate for a given time zone using [todayIn]
 * - TimeSource for duration measurements using [asTimeSource]
 *
 * Example:
 * ```kotlin
 * class TimeLogger(private val clock: Clock = Clock.System) {
 *     fun logEvent(event: String) {
 *         val now = clock.now()
 *         println("[$now] $event")
 *     }
 * }
 * 
 * // For testing:
 * class FixedClock(private val fixedInstant: Instant) : Clock {
 *     override fun now(): Instant = fixedInstant
 * }
 * 
 * // Test with a fixed time
 * val fixedClock = FixedClock(Instant.parse("2023-01-01T12:00:00Z"))
 * val logger = TimeLogger(fixedClock)
 * ```
 *
 * See [Clock.System][Clock.System] for the clock instance that queries the operating system.
 */
public interface Clock {
    /**
     * Returns the [Instant] corresponding to the current time, according to this clock.
     *
     * This method is the primary way to obtain the current time from a [Clock]. The returned
     * [Instant] represents a specific moment on the UTC-SLS time scale.
     *
     * When using the [Clock.System] implementation, this method is equivalent to
     * what would have been provided by the now-deprecated `Instant.now()` function.
     *
     * Example:
     * ```kotlin
     * val now = Clock.System.now()
     * println("Current time: $now")
     * ```
     */
    public fun now(): Instant

    /**
     * The [Clock] instance that queries the operating system as its source of knowledge of time.
     *
     * This is the standard clock implementation that provides access to the system's current time.
     * It is typically used as the default clock implementation when one is not explicitly provided.
     *
     * The actual precision and accuracy of this clock depend on the underlying operating system
     * and hardware. In most cases, it provides millisecond or microsecond precision.
     *
     * Example:
     * ```kotlin
     * val now = Clock.System.now()
     * val today = Clock.System.todayIn(TimeZone.currentSystemDefault())
     * ```
     */
    public object System : Clock {
        override fun now(): Instant = @Suppress("DEPRECATION_ERROR") Instant.now()
    }

    public companion object {

    }
}

/**
 * Returns the current date at the given [time zone][timeZone], according to [this Clock][this].
 *
 * This is a shorthand for calling [now] and then converting the resulting [Instant]
 * to a [LocalDate] in the specified time zone.
 *
 * Example:
 * ```kotlin
 * val systemTz = TimeZone.currentSystemDefault()
 * val today = Clock.System.todayIn(systemTz)
 * val todayInTokyo = Clock.System.todayIn(TimeZone.of("Asia/Tokyo"))
 * ```
 *
 * Note that the date depends on the time zone: at the same instant, different places
 * in the world can have different dates.
 */
public fun Clock.todayIn(timeZone: TimeZone): LocalDate =
    now().toLocalDateTime(timeZone).date

/**
 * Returns a [TimeSource] that uses this [Clock] to mark a time instant and to find the amount of time elapsed since that mark.
 *
 * This converts a [Clock], which provides absolute time, into a [TimeSource], which
 * measures elapsed time. The created [TimeSource] uses the [Clock] to establish reference
 * points for time measurement.
 *
 * Example:
 * ```kotlin
 * @OptIn(ExperimentalTime::class)
 * fun measureOperation(clock: Clock = Clock.System) {
 *     val timeSource = clock.asTimeSource()
 *     val mark = timeSource.markNow()
 *     
 *     // perform operation
 *     
 *     val elapsed = mark.elapsedNow()
 *     println("Operation took $elapsed")
 * }
 * ```
 */
@ExperimentalTime
public fun Clock.asTimeSource(): TimeSource.WithComparableMarks = object : TimeSource.WithComparableMarks {
    override fun markNow(): ComparableTimeMark = InstantTimeMark(now(), this@asTimeSource)
}

@ExperimentalTime
private class InstantTimeMark(private val instant: Instant, private val clock: Clock) : ComparableTimeMark {
    override fun elapsedNow(): Duration = saturatingDiff(clock.now(), instant)

    override fun plus(duration: Duration): ComparableTimeMark = InstantTimeMark(instant.saturatingAdd(duration), clock)
    override fun minus(duration: Duration): ComparableTimeMark = InstantTimeMark(instant.saturatingAdd(-duration), clock)

    override fun minus(other: ComparableTimeMark): Duration {
        if (other !is InstantTimeMark || other.clock != this.clock) {
            throw IllegalArgumentException("Subtracting or comparing time marks from different time sources is not possible: $this and $other")
        }
        return saturatingDiff(this.instant, other.instant)
    }

    override fun equals(other: Any?): Boolean {
        return other is InstantTimeMark && this.clock == other.clock && this.instant == other.instant
    }

    override fun hashCode(): Int = instant.hashCode()

    override fun toString(): String = "InstantTimeMark($instant, $clock)"

    private fun Instant.isSaturated() = this == Instant.MAX || this == Instant.MIN
    private fun Instant.saturatingAdd(duration: Duration): Instant {
        if (isSaturated()) {
            if (duration.isInfinite() && duration.isPositive() != this.isDistantFuture) {
                throw IllegalArgumentException("Summing infinities of different signs")
            }
            return this
        }
        return this + duration
    }
    private fun saturatingDiff(instant1: Instant, instant2: Instant): Duration = when {
        instant1 == instant2 ->
            Duration.ZERO
        instant1.isSaturated() || instant2.isSaturated() ->
            (instant1 - instant2) * Double.POSITIVE_INFINITY
        else ->
            instant1 - instant2
    }
}

@Deprecated("Use Clock.todayIn instead", ReplaceWith("this.todayIn(timeZone)"), DeprecationLevel.WARNING)
public fun Clock.todayAt(timeZone: TimeZone): LocalDate = todayIn(timeZone)
