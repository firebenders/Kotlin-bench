package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.logger.api.initKtLintKLogger
import com.pinterest.ktlint.rule.engine.core.api.ElementType.BLOCK_COMMENT
import com.pinterest.ktlint.rule.engine.core.api.ElementType.EOL_COMMENT
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.isRoot
import com.pinterest.ktlint.ruleset.standard.StandardRule
import mu.KotlinLogging
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.com.intellij.psi.PsiComment
import org.jetbrains.kotlin.com.intellij.psi.PsiElement
import org.jetbrains.kotlin.com.intellij.psi.PsiWhiteSpace
import org.jetbrains.kotlin.com.intellij.psi.impl.source.tree.LeafPsiElement
import org.jetbrains.kotlin.psi.KtAnnotated
import org.jetbrains.kotlin.psi.KtAnnotationEntry
import org.jetbrains.kotlin.psi.KtFile
import org.jetbrains.kotlin.psi.KtPsiFactory
import org.jetbrains.kotlin.psi.psiUtil.nextSibling

/**
 * Rule to convert ktlint-disable/ktlint-enable directives to @Suppress annotations.
 * This rule cannot be suppressed.
 */
public class DirectiveToAnnotationRule : 
    StandardRule(
        id = "directive-to-annotation",
        visitorModifiers = setOf(VisitorModifier.SkipSuppression)
    ) {
    
    private companion object {
        private val LOGGER = KotlinLogging.logger {}.initKtLintKLogger()
        private const val KTLINT_DISABLE = "ktlint-disable"
        private const val KTLINT_ENABLE = "ktlint-enable"
        private val DIRECTIVE_REGEX = "$KTLINT_DISABLE\\s*(.*)".toRegex()
    }

    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit
    ) {
        if (node.isRoot()) {
            // Process all comments in the file to handle directive pairs
            return
        }

        if (node.elementType == EOL_COMMENT) {
            processEolComment(node, autoCorrect, emit)
        } else if (node.elementType == BLOCK_COMMENT) {
            processBlockComment(node, autoCorrect, emit)
        }
    }

    private fun processEolComment(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit
    ) {
        val commentText = node.text
        
        if (commentText.contains(KTLINT_DISABLE)) {
            val ruleIds = extractRuleIds(commentText)
            val canBeAutoCorrected = true
            
            emit(
                node.startOffset,
                "Use @Suppress annotation instead of ktlint-disable directive",
                canBeAutoCorrected
            )
            
            if (autoCorrect) {
                convertEolDisableDirective(node, ruleIds)
            }
        }
    }

    private fun processBlockComment(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit
    ) {
        val commentText = node.text
        
        when {
            commentText.contains(KTLINT_DISABLE) -> {
                val ruleIds = extractRuleIds(commentText)
                val canBeAutoCorrected = true
                
                emit(
                    node.startOffset,
                    "Use @Suppress annotation instead of ktlint-disable directive",
                    canBeAutoCorrected
                )
                
                if (autoCorrect) {
                    convertBlockDisableDirective(node, ruleIds)
                }
            }
            commentText.contains(KTLINT_ENABLE) -> {
                emit(
                    node.startOffset,
                    "Remove ktlint-enable directive as @Suppress annotations define their own scope",
                    true
                )
                
                if (autoCorrect) {
                    // Remove the enable directive
                    (node.psi as? LeafPsiElement)?.rawRemove()
                }
            }
        }
    }

    private fun convertEolDisableDirective(node: ASTNode, ruleIds: List<String>) {
        val comment = node.psi as PsiComment
        
        try {
            val target = findNextAnnotatableElement(comment)
            
            if (target != null) {
                addSuppressAnnotation(target, ruleIds)
                // Remove the original directive
                (comment as? LeafPsiElement)?.rawRemove()
            }
        } catch (e: Exception) {
            LOGGER.error(e) { "Error converting EOL ktlint-disable directive to @Suppress annotation" }
        }
    }

    private fun convertBlockDisableDirective(node: ASTNode, ruleIds: List<String>) {
        val comment = node.psi as PsiComment
        
        try {
            val target = findNextAnnotatableElement(comment)
            
            if (target != null) {
                addSuppressAnnotation(target, ruleIds)
                // Remove the original directive
                (comment as? LeafPsiElement)?.rawRemove()
            }
        } catch (e: Exception) {
            LOGGER.error(e) { "Error converting block ktlint-disable directive to @Suppress annotation" }
        }
    }

    private fun addSuppressAnnotation(element: PsiElement, ruleIds: List<String>) {
        if (element is KtAnnotated) {
            val psiFactory = KtPsiFactory(element.project)
            val annotationText = createSuppressAnnotation(ruleIds)
            
            try {
                // Create the annotation
                val annotation = psiFactory.createAnnotationEntry(annotationText)
                
                // Add it to the element
                when (element) {
                    is KtFile -> {
                        // File-level annotation
                        element.addAnnotationEntry(annotation)
                    }
                    else -> {
                        // Element-level annotation
                        (element as KtAnnotated).addAnnotationEntry(annotation)
                    }
                }
            } catch (e: Exception) {
                LOGGER.error(e) { "Failed to add annotation to ${element.javaClass.simpleName}" }
            }
        }
    }

    private fun findNextAnnotatableElement(comment: PsiComment): KtAnnotated? {
        // Try to find the next annotatable element
        var current = comment.nextSibling
        
        while (current != null) {
            if (current is KtAnnotated && current !is PsiWhiteSpace && current !is PsiComment) {
                return current
            }
            current = current.nextSibling
        }
        
        // If no direct element found, use the file
        return comment.containingFile as? KtFile
    }

    private fun extractRuleIds(commentText: String): List<String> {
        val matchResult = DIRECTIVE_REGEX.find(commentText) ?: return emptyList()
        
        val rulesText = matchResult.groupValues[1].trim()
        return if (rulesText.isEmpty()) {
            emptyList()
        } else {
            rulesText.split("\\s+".toRegex()).map { it.trim() }
        }
    }

    private fun createSuppressAnnotation(ruleIds: List<String>): String {
        return if (ruleIds.isEmpty()) {
            "@Suppress(\"ktlint\")"
        } else {
            val annotationRules = ruleIds.joinToString(", ") { "\"ktlint:$it\"" }
            "@Suppress($annotationRules)"
        }
    }
}

public val DIRECTIVE_TO_ANNOTATION_RULE_ID: RuleId = DirectiveToAnnotationRule().ruleId
