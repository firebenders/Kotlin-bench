package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.ElementType.ARROW
import com.pinterest.ktlint.rule.engine.core.api.ElementType.BLOCK
import com.pinterest.ktlint.rule.engine.core.api.ElementType.DOT_QUALIFIED_EXPRESSION
import com.pinterest.ktlint.rule.engine.core.api.ElementType.ELSE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.ELSE_KEYWORD
import com.pinterest.ktlint.rule.engine.core.api.ElementType.EXPRESSION_BODY
import com.pinterest.ktlint.rule.engine.core.api.ElementType.IF
import com.pinterest.ktlint.rule.engine.core.api.ElementType.LBRACE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.OPERATION_REFERENCE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.RBRACE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.RPAR
import com.pinterest.ktlint.rule.engine.core.api.ElementType.SAFE_ACCESS_EXPRESSION
import com.pinterest.ktlint.rule.engine.core.api.ElementType.THEN
import com.pinterest.ktlint.rule.engine.core.api.ElementType.WHITE_SPACE
import com.pinterest.ktlint.rule.engine.core.api.Rule
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.SinceKtlint
import com.pinterest.ktlint.rule.engine.core.api.SinceKtlint.Status.EXPERIMENTAL
import com.pinterest.ktlint.rule.engine.core.api.SinceKtlint.Status.STABLE
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.EditorConfig
import com.pinterest.ktlint.rule.engine.core.api.isWhiteSpace
import com.pinterest.ktlint.rule.engine.core.api.isWhiteSpaceWithNewline
import com.pinterest.ktlint.rule.engine.core.api.nextLeaf
import com.pinterest.ktlint.rule.engine.core.api.nextSibling
import com.pinterest.ktlint.rule.engine.core.api.prevLeaf
import com.pinterest.ktlint.rule.engine.core.api.prevSibling
import com.pinterest.ktlint.rule.engine.core.api.upsertWhitespaceAfterMe
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.lexer.KtTokens
import org.jetbrains.kotlin.psi.psiUtil.leaves

/**
 * Ensures that multi-line if-else statements contain braces.
 */
@SinceKtlint("0.49.0", STABLE)
public class MultiLineIfElseRule :
    StandardRule("multiline-if-else"),
    Rule.OfficialCodeStyle {
    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        if (node.elementType == ELSE_KEYWORD) {
            val nextLeaf = node.nextLeaf()
            if (nextLeaf != null && !nextLeaf.isWhiteSpaceWithNewline()) {
                val elseParent = node.treeParent
                val elseBlockOrIf = elseParent.findChildByType(IF) ?: elseParent.lastChildNode
                if (elseBlockOrIf.elementType != IF &&
                    // Check if the ELSE block has the required newline inside. This can have blocks, but also expression bodies
                    elseBlockOrIf != null && !elseBlockOrIf.textContains('\n')
                ) {
                    val prevIf = elseParent.treeParent
                    val thenBlock = prevIf.findChildByType(THEN)
                    val thenBody = thenBlock?.lastChildNode
                    if (thenBody != null && thenBody.elementType == BLOCK && thenBody.textContains('\n')) {
                        emit(
                            node.startOffset,
                            "Missing newline after '}'",
                            true,
                        )
                        if (autoCorrect) {
                            val prevRbrace = node.prevLeaf { it.elementType == RBRACE }
                            if (prevRbrace != null) {
                                prevRbrace.upsertWhitespaceAfterMe("\n")
                            }
                        }
                    }
                }
            }
        } else if (node.elementType == THEN) {
            // Check if the THEN block has a newline inside. This doesn't cover blocks.
            val firstChild = node.firstChildNode
            // Add null check to prevent NullPointerException
            if (firstChild != null && firstChild.elementType != BLOCK) {
                val hasElse = node.treeParent.findChildByType(ELSE) != null
                if (hasElse && firstChild.textContains('\n')) {
                    val nextKeyword = node.treeParent.findChildByType(ELSE)?.findChildByType(ELSE_KEYWORD)
                    if (nextKeyword != null) {
                        val nextLeaf = nextKeyword.prevLeaf { it != null }
                        if (nextLeaf != null) {
                            if (nextLeaf.elementType == WHITE_SPACE && !nextLeaf.textContains('\n')) {
                                // missing newline before the else
                                emit(
                                    nextKeyword.startOffset,
                                    "Missing newline before 'else'",
                                    true,
                                )
                                if (autoCorrect) {
                                    nextLeaf.treeParent.replaceChild(
                                        nextLeaf,
                                        nextLeaf.clone().apply { chars = "\n" },
                                    )
                                }
                            } else if (nextLeaf.elementType != WHITE_SPACE) {
                                // missing newline before the else, and not even whitespace
                                emit(
                                    nextKeyword.startOffset,
                                    "Missing newline before 'else'",
                                    true,
                                )
                                if (autoCorrect) {
                                    nextLeaf.treeParent.addChild(
                                        com.pinterest.ktlint.rule.engine.core.api.createNewLine(),
                                        nextKeyword,
                                    )
                                }
                            }
                        }
                    }
                }
            }

            val elseKeyword = node.treeParent.findChildByType(ELSE)?.findChildByType(ELSE_KEYWORD)
            if (elseKeyword != null) {
                val prevLeaf = elseKeyword.prevLeaf { !it.isWhiteSpace() }
                if (prevLeaf?.elementType == RBRACE) {
                    // ensure newline after '}'
                    val isEmptyBlock = isEmptyBlock(prevLeaf.treeParent)

                    val rbracePrev = prevLeaf.prevLeaf()
                    val isMultilineEmpty = rbracePrev != null && rbracePrev.elementType == WHITE_SPACE && rbracePrev.textContains('\n')
                    val hasOtherStatementsOrComments = !isEmptyBlock && !isMultilineEmpty

                    val isElseIf = elseKeyword.nextSibling { !it.isWhiteSpace() }?.elementType == IF
                    if (hasOtherStatementsOrComments && !isElseIf) {
                        val whiteSpaceAfterBrace = prevLeaf.nextLeaf()
                        if (whiteSpaceAfterBrace != null && whiteSpaceAfterBrace.elementType == WHITE_SPACE && !whiteSpaceAfterBrace.textContains('\n')) {
                            emit(
                                prevLeaf.startOffset,
                                "Missing newline after '}'",
                                true,
                            )
                            if (autoCorrect) {
                                prevLeaf.upsertWhitespaceAfterMe("\n")
                            }
                        }
                    }
                } else {
                    // "} else" expected
                    val prev = elseKeyword.prevSibling { !it.isWhiteSpace() }
                    if (prev?.elementType != RBRACE) {
                        val firstLeaf = node.nextLeaf()
                        if (firstLeaf != null && firstLeaf.elementType != BLOCK && firstLeaf.textContains('\n')) {
                            // check last element in the THEN branch
                            val isLhsMultiline =
                                firstLeaf
                                    .leaves(forward = true)
                                    .takeWhile { leaf ->
                                        leaf.elementType != OPERATION_REFERENCE || (
                                            leaf.elementType == OPERATION_REFERENCE && leaf.text != ":" && leaf.text != "::"
                                            )
                                    }
                                    .takeWhile { leaf -> leaf.elementType != ARROW }
                                    .takeWhile { leaf ->
                                        val isMultilineStringTopMostParent =
                                            leaf.treeParent?.treeParent?.elementType == BLOCK ||
                                                leaf.treeParent?.treeParent?.treeParent?.elementType == BLOCK ||
                                                leaf.treeParent?.treeParent?.treeParent?.treeParent?.elementType == BLOCK ||
                                                leaf.treeParent?.treeParent?.treeParent?.treeParent?.treeParent?.elementType == BLOCK
                                        isMultilineStringTopMostParent &&
                                            node.treeParent.findChildByType(ELSE)?.findChildByType(IF) == null &&
                                            leaf.elementType != DOT_QUALIFIED_EXPRESSION &&
                                            leaf.elementType != SAFE_ACCESS_EXPRESSION
                                    }
                                    .count { it.isWhiteSpaceWithNewline() } > 0

                            if (!isLhsMultiline) {
                                // handle then block with if
                                val isNestedIf = node.lastChildNode?.elementType == IF
                                val emitError =
                                    if (isNestedIf) {
                                        val thenChildIf = node.lastChildNode
                                        val thenChildIfThen = thenChildIf?.findChildByType(THEN)
                                        thenChildIfThen?.lastChildNode?.elementType == BLOCK &&
                                            thenChildIfThen.lastChildNode.textContains('\n')
                                    } else {
                                        node.firstChildNode?.elementType != BLOCK
                                    }
                                if (emitError) {
                                    emit(
                                        elseKeyword.startOffset,
                                        "Missing braces",
                                        false,
                                    )
                                }
                            }
                        }
                    }
                }
            }
        } else if (node.elementType == RPAR && node.treeParent.elementType == IF) {
            val nextLeaf = node.nextLeaf { !it.isWhiteSpace() }
            val body = node.treeParent.findChildByType(THEN)?.firstChildNode
            if (nextLeaf != null && nextLeaf.elementType == LBRACE &&
                (body == null || body?.elementType != BLOCK)
            ) {
                emit(
                    node.startOffset,
                    "Missing braces",
                    false,
                )
            }
        }
    }

    private fun isEmptyBlock(node: ASTNode?): Boolean {
        val leftBrace = node?.findChildByType(LBRACE) ?: return false
        val rightBrace = node.findChildByType(RBRACE) ?: return false
        val children = node.getChildren(null)
        return leftBrace.nextSibling { !it.isWhiteSpace() } == rightBrace ||
            children.filter { it.elementType != LBRACE && it.elementType != RBRACE && !it.isWhiteSpace() }.isEmpty()
    }

    // This allows using EditorConfig if needed in the future
    override fun beforeFirstNode(editorConfig: EditorConfig) = Unit
}

public val MULTILINE_IF_ELSE_RULE_ID: RuleId = MultiLineIfElseRule().ruleId
