package com.fsck.k9.settings

import android.content.Context
import app.k9mail.legacy.account.Account
import com.fsck.k9.AccountPreferenceSerializer
import com.fsck.k9.K9
import com.fsck.k9.Preferences
import com.fsck.k9.mailstore.FolderRepositoryManager
import com.fsck.k9.preferences.Storage
import com.fsck.k9.preferences.StoragePersister
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.withContext
import timber.log.Timber
import java.io.InputStream
import java.util.UUID

class ImportSettings(
    private val context: Context,
    private val preferences: Preferences,
    private val folderRepositoryManager: FolderRepositoryManager,
    private val storagePersister: StoragePersister,
    private val accountPreferenceSerializer: AccountPreferenceSerializer
) {
    suspend fun importSettings(inputStream: InputStream): Boolean {
        return withContext(Dispatchers.IO) {
            try {
                val importedStorage = storagePersister.loadValues(inputStream)
                importSettings(importedStorage)
                true
            } catch (e: Exception) {
                Timber.e(e, "Exception while importing settings")
                false
            }
        }
    }

    private suspend fun importSettings(storage: Storage) {
        val accountUuids = storage.getString("accountUuids", null)
        if (accountUuids.isNullOrEmpty()) return

        val accounts = accountUuids.split(",")
            .mapNotNull { uuid -> 
                createAccountFromImport(uuid, storage)
            }

        // Import folder settings for each account
        accounts.forEach { account ->
            folderRepositoryManager.importFolderSettings(account, storage)
        }
    }

    private fun createAccountFromImport(uuid: String, storage: Storage): Account? {
        try {
            // For K-9 Mail to K-9 Mail import, use the same UUID
            // For other imports, generate a new UUID to avoid conflicts
            val accountUuid = if (isK9Import(storage)) uuid else UUID.randomUUID().toString()
            
            val account = preferences.newAccount(accountUuid)
            accountPreferenceSerializer.loadAccount(account, storage)
            preferences.saveAccount(account)
            return account
        } catch (e: Exception) {
            Timber.e(e, "Error while importing account settings")
            return null
        }
    }
    
    private fun isK9Import(storage: Storage): Boolean {
        // Check if this is a K-9 Mail import by looking for K-9 specific settings
        val k9Version = storage.getString("k9.version", null)
        return !k9Version.isNullOrEmpty()
    }
}
