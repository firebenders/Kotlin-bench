package com.fsck.k9.mailstore

import app.k9mail.legacy.account.Account
import com.fsck.k9.mail.FolderType
import com.fsck.k9.preferences.Storage
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.firstOrNull

/**
 * Provides access to the folder repository for an account.
 */
class FolderRepositoryManager(
    private val localStoreProvider: LocalStoreProvider,
    private val folderRepositoryProvider: FolderRepositoryProvider,
) {
    fun getFolderRepository(account: Account): FolderRepository {
        return folderRepositoryProvider.getFolderRepository(account)
    }

    suspend fun importFolderSettings(account: Account, sourceStorage: Storage) {
        val repository = getFolderRepository(account)
        val folders = repository.getRemoteFolders().firstOrNull() ?: return

        // Get mappings from the source storage
        val folderMap = mutableMapOf<String, FolderType>()
        val folderServerIds = getFolderServerIds(sourceStorage, account.uuid)
        
        folderServerIds.forEach { serverId ->
            val folderTypeString = sourceStorage.getString("$serverId.folderType", null)
            val folderDisplayClass = sourceStorage.getString("$serverId.displayMode", null)
            
            // Convert old folder display class to folder type if available, otherwise use folderType directly
            val folderType = when {
                folderTypeString != null -> try {
                    FolderType.valueOf(folderTypeString)
                } catch (e: IllegalArgumentException) {
                    FolderType.REGULAR
                }
                folderDisplayClass != null -> {
                    convertDisplayClassToFolderType(folderDisplayClass)
                }
                else -> FolderType.REGULAR
            }
            
            folderMap[serverId] = folderType
        }

        // Apply the saved folder types to the imported folders
        folders.forEach { folder ->
            val savedType = folderMap[folder.serverId]
            if (savedType != null) {
                repository.setFolderType(folder.serverId, savedType)
                // Set this explicitly as NOT automatic since we're using the imported value
                repository.setFolderAutomaticType(folder.serverId, false)
            }
        }
    }
    
    private fun getFolderServerIds(storage: Storage, accountUuid: String): List<String> {
        val folderIds = storage.getString("$accountUuid.folderServerIds", null) ?: return emptyList()
        return folderIds.split(',').filter { it.isNotEmpty() }
    }
    
    private fun convertDisplayClassToFolderType(displayClass: String): FolderType {
        return when (displayClass) {
            "com.fsck.k9.activity.setup.FolderDisplayMode:FIRST_CLASS" -> FolderType.INBOX
            "com.fsck.k9.activity.setup.FolderDisplayMode:SECOND_CLASS" -> FolderType.ARCHIVE
            "com.fsck.k9.activity.setup.FolderDisplayMode:NOT_SECOND_CLASS" -> FolderType.SENT
            else -> FolderType.REGULAR
        }
    }
}
