package com.fsck.k9.activity.setup

import android.content.Context
import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.AdapterView
import android.widget.ArrayAdapter
import android.widget.Spinner
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import androidx.lifecycle.lifecycleScope
import app.k9mail.legacy.account.Account
import com.fsck.k9.Preferences
import com.fsck.k9.mail.FolderType
import com.fsck.k9.mailstore.FolderRepository
import com.fsck.k9.mailstore.FolderRepositoryManager
import com.fsck.k9.mailstore.RemoteFolder
import com.fsck.k9.ui.R
import com.fsck.k9.ui.base.extensions.setDisplayHomeAsUpEnabled
import kotlinx.coroutines.flow.first
import kotlinx.coroutines.launch
import org.koin.android.ext.android.inject

class FolderSettings : AppCompatActivity() {
    private val preferences: Preferences by inject()
    private val folderRepositoryManager: FolderRepositoryManager by inject()
    
    private lateinit var account: Account
    private lateinit var folderRepository: FolderRepository
    private lateinit var folderContainer: ViewGroup
    private var folders = listOf<RemoteFolder>()

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.folder_settings)
        setDisplayHomeAsUpEnabled(true)
        
        val accountUuid = intent.getStringExtra(EXTRA_ACCOUNT) ?: return finish()
        account = preferences.getAccount(accountUuid) ?: return finish()
        
        folderRepository = folderRepositoryManager.getFolderRepository(account)
        folderContainer = findViewById(R.id.folder_list_container)
        
        loadFolders()
    }
    
    private fun loadFolders() {
        lifecycleScope.launch {
            folders = folderRepository.getRemoteFolders().first()
            populateFolderList()
        }
    }
    
    private fun populateFolderList() {
        folderContainer.removeAllViews()
        
        folders.forEach { folder ->
            val folderView = LayoutInflater.from(this)
                .inflate(R.layout.folder_settings_item, folderContainer, false)
            
            val nameView = folderView.findViewById<TextView>(R.id.folder_name)
            nameView.text = folder.name
            
            val typeSpinner = folderView.findViewById<Spinner>(R.id.folder_type)
            setupFolderTypeSpinner(typeSpinner, folder)
            
            folderContainer.addView(folderView)
        }
    }
    
    private fun setupFolderTypeSpinner(spinner: Spinner, folder: RemoteFolder) {
        // Create array of all folder types, including INBOX which was missing
        val folderTypes = FolderType.values().toList()
        
        val adapter = FolderTypeAdapter(this, folderTypes)
        spinner.adapter = adapter
        
        // Set current selection
        val position = folderTypes.indexOf(folder.type)
        spinner.setSelection(position)
        
        spinner.onItemSelectedListener = object : AdapterView.OnItemSelectedListener {
            override fun onItemSelected(parent: AdapterView<*>, view: View?, position: Int, id: Long) {
                val selectedType = folderTypes[position]
                if (selectedType != folder.type) {
                    folderRepository.setFolderType(folder.serverId, selectedType)
                    folderRepository.setFolderAutomaticType(folder.serverId, false)
                }
            }
            
            override fun onNothingSelected(parent: AdapterView<*>) {
                // Do nothing
            }
        }
    }
    
    private class FolderTypeAdapter(
        context: Context,
        private val folderTypes: List<FolderType>
    ) : ArrayAdapter<FolderType>(context, android.R.layout.simple_spinner_item, folderTypes) {
        
        init {
            setDropDownViewResource(android.R.layout.simple_spinner_dropdown_item)
        }
        
        override fun getView(position: Int, convertView: View?, parent: ViewGroup): View {
            val view = super.getView(position, convertView, parent)
            val textView = view.findViewById<TextView>(android.R.id.text1)
            textView.text = getFolderTypeDisplayName(folderTypes[position])
            return view
        }
        
        override fun getDropDownView(position: Int, convertView: View?, parent: ViewGroup): View {
            val view = super.getDropDownView(position, convertView, parent)
            val textView = view.findViewById<TextView>(android.R.id.text1)
            textView.text = getFolderTypeDisplayName(folderTypes[position])
            return view
        }
        
        private fun getFolderTypeDisplayName(folderType: FolderType): String {
            return when (folderType) {
                FolderType.INBOX -> "Inbox"
                FolderType.OUTBOX -> "Outbox"
                FolderType.SENT -> "Sent"
                FolderType.TRASH -> "Trash"
                FolderType.DRAFTS -> "Drafts"
                FolderType.ARCHIVE -> "Archive"
                FolderType.SPAM -> "Spam"
                else -> "Regular"
            }
        }
    }
    
    companion object {
        const val EXTRA_ACCOUNT = "account"
    }
}
