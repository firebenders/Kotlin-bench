package com.fsck.k9.mailstore

import com.fsck.k9.mail.FolderType
import kotlinx.coroutines.flow.Flow

interface FolderRepository {
    fun getRemoteFolders(): Flow<List<RemoteFolder>>
    fun getFolderType(serverId: String): FolderType
    fun setFolderType(serverId: String, folderType: FolderType)
    fun isFolderTypeAutomatic(serverId: String): Boolean
    fun setFolderAutomaticType(serverId: String, automatic: Boolean)
}

data class RemoteFolder(
    val serverId: String,
    val name: String,
    val type: FolderType,
    val isAutomatic: Boolean
)
