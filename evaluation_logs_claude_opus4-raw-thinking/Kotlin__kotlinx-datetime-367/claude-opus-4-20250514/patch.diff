package kotlinx.datetime

import kotlinx.datetime.serializers.*
import kotlinx.serialization.Serializable

/**
 * A time zone, provides the conversion between [Instant] and [LocalDateTime] values
 * using a collection of rules specifying which [LocalDateTime] value corresponds to each [Instant].
 *
 * Time zones represent the regional variations in time caused by the Earth's rotation and political decisions.
 * They define the offset from UTC and any daylight saving time transitions for a particular region.
 *
 * ## Types of Time Zones
 *
 * There are two main types of time zones:
 * 1. **Region-based zones** (e.g., "America/New_York") - These follow the rules for a specific region,
 *    including daylight saving time transitions.
 * 2. **Fixed-offset zones** (e.g., "+02:00", "UTC") - These maintain a constant offset from UTC.
 *
 * ## Obtaining Time Zones
 *
 * ```
 * // Get the system's current time zone
 * val systemTZ = TimeZone.currentSystemDefault()
 * 
 * // Get a specific time zone by ID
 * val newYork = TimeZone.of("America/New_York")
 * val utcPlus3 = TimeZone.of("+03:00")
 * 
 * // Get UTC time zone
 * val utc = TimeZone.UTC
 * 
 * // Create from UtcOffset
 * val offsetTZ = UtcOffset(hours = 5, minutes = 30).asTimeZone()
 * ```
 *
 * ## Usage with Instant and LocalDateTime
 *
 * ```
 * val timeZone = TimeZone.of("Europe/Berlin")
 * val instant = Clock.System.now()
 * 
 * // Convert Instant to LocalDateTime
 * val localDateTime = instant.toLocalDateTime(timeZone)
 * // or using member function
 * val localDateTime2 = timeZone.run { instant.toLocalDateTime() }
 * 
 * // Convert LocalDateTime to Instant
 * val instant2 = localDateTime.toInstant(timeZone)
 * // or using member function
 * val instant3 = timeZone.run { localDateTime.toInstant() }
 * ```
 *
 * ## Time Zone Database
 *
 * The time zone database used depends on the platform:
 * - **JVM**: Uses the JVM's built-in time zone database (usually IANA TZDB)
 * - **JS**: Uses the @js-joda/timezone npm package which includes IANA TZDB
 * - **Native**: Uses the IANA Time Zone Database
 *
 * ## Important Considerations
 *
 * - Time zone rules can change due to political decisions. Always keep your runtime updated.
 * - During daylight saving time transitions, some local times may not exist (spring forward)
 *   or may occur twice (fall back).
 * - When converting a [LocalDateTime] that falls in a transition gap, the result is adjusted forward.
 * - When converting a [LocalDateTime] that falls in an overlap, the earlier offset is used.
 *
 * ## Performance Notes
 *
 * - Creating time zone instances is relatively expensive. Consider caching frequently used zones.
 * - Fixed offset time zones are more efficient than region-based zones.
 *
 * @see Instant for representing moments in time
 * @see LocalDateTime for representing date and time without a time zone
 * @see FixedOffsetTimeZone for time zones with a constant offset
 * @see UtcOffset for representing just the offset from UTC
 */
@Serializable(with = TimeZoneSerializer::class)
public expect open class TimeZone {
    /**
     * Returns the identifier string of the time zone.
     *
     * This identifier can be used later for finding this time zone with [TimeZone.of] function.
     * 
     * For region-based zones, this is typically in the format "Area/City" (e.g., "Europe/Paris").
     * For fixed-offset zones, this is the offset string (e.g., "+02:00", "Z" for UTC).
     *
     * @see TimeZone.of for parsing these identifiers
     */
    public val id: String

    // TODO: Declare and document toString/equals/hashCode

    public companion object {
        /**
         * Queries the current system time zone.
         *
         * The returned time zone represents the system's default time zone at the time of the call.
         * If the current system time zone changes, this function can reflect this change on the next invocation.
         *
         * ## Platform Behavior
         * - **JVM**: Uses `java.util.TimeZone.getDefault()`
         * - **JS**: Uses the browser's or Node.js's default time zone
         * - **Native**: Uses the system's configured time zone
         *
         * ## Example
         * ```
         * val systemTimeZone = TimeZone.currentSystemDefault()
         * println("Current time zone: ${systemTimeZone.id}")
         * ```
         *
         * @return The current system time zone
         */
        public fun currentSystemDefault(): TimeZone

        /**
         * Returns the time zone with the fixed UTC+0 offset.
         *
         * This is the most commonly used fixed time zone, representing Coordinated Universal Time.
         * It has no daylight saving time transitions and always has zero offset from UTC.
         *
         * ## Example
         * ```
         * val utcTime = Clock.System.now().toLocalDateTime(TimeZone.UTC)
         * ```
         *
         * @see FixedOffsetTimeZone for other fixed offset zones
         */
        public val UTC: FixedOffsetTimeZone

        /**
         * Returns the time zone identified by the provided [zoneId].
         *
         * The supported variants of time zone identifiers:
         * - `Z`, 'UTC', 'UT' or 'GMT' — identifies the fixed-offset time zone [TimeZone.UTC],
         * - a string starting with '+', '-', `UTC+`, `UTC-`, `UT+`, `UT-`, `GMT+`, `GMT-` — identifiers the time zone
         *   with the fixed offset specified after `+` or `-`,
         * - all other strings are treated as region-based zone identifiers.
         * In the IANA Time Zone Database (TZDB) which is used as the default source of time zones,
         * these ids are usually in the form `area/city`, for example, `Europe/Berlin` or `America/Los_Angeles`.
         *
         * ## Examples
         * ```
         * // Region-based zones
         * val berlin = TimeZone.of("Europe/Berlin")
         * val newYork = TimeZone.of("America/New_York")
         * 
         * // Fixed offset zones
         * val utcPlus5 = TimeZone.of("+05:00")
         * val utcMinus3 = TimeZone.of("-03:00")
         * val utc = TimeZone.of("UTC")
         * ```
         *
         * @param zoneId The time zone identifier
         * @return The [TimeZone] corresponding to the given identifier
         * @throws IllegalTimeZoneException if [zoneId] has an invalid format or a time-zone with the name [zoneId]
         * is not found.
         * @see availableZoneIds for the list of available zone identifiers
         */
        public fun of(zoneId: String): TimeZone

        /**
         * Queries the set of identifiers of time zones available in the system.
         *
         * This returns all time zone identifiers that can be passed to [TimeZone.of].
         * The set typically includes:
         * - Region-based identifiers like "America/New_York", "Europe/Berlin"
         * - UTC aliases: "UTC", "GMT", "UT", "Z"
         * - Some fixed offsets (implementation-dependent)
         *
         * ## Example
         * ```
         * val allZones = TimeZone.availableZoneIds
         * println("Total zones available: ${allZones.size}")
         * 
         * // Find all zones for a specific region
         * val europeanZones = allZones.filter { it.startsWith("Europe/") }
         * ```
         *
         * @return An immutable set of available time zone identifiers
         */
        public val availableZoneIds: Set<String>
    }

    /**
     * Return the civil date/time value that this instant has in the time zone provided as an implicit receiver.
     *
     * This is a member extension function that allows for a more fluent API when working within
     * a specific time zone context.
     *
     * Note that while this conversion is unambiguous, the inverse ([LocalDateTime.toInstant])
     * is not necessary so.
     *
     * ## Example
     * ```
     * val zone = TimeZone.of("Asia/Tokyo")
     * zone.run {
     *     val currentTimeInTokyo = Clock.System.now().toLocalDateTime()
     *     println("Current time in Tokyo: $currentTimeInTokyo")
     * }
     * ```
     *
     * @receiver The instant to convert
     * @return The local date and time in this time zone
     * @throws DateTimeArithmeticException if this value is too large to fit in [LocalDateTime].
     * @see LocalDateTime.toInstant for the inverse operation
     * @see Instant.toLocalDateTime for the standalone function
     * @see Instant.offsetIn for just getting the offset
     */
    public fun Instant.toLocalDateTime(): LocalDateTime

    /**
     * Returns an instant that corresponds to this civil date/time value in the time zone provided as an implicit receiver.
     *
     * This is a member extension function that allows for a more fluent API when working within
     * a specific time zone context.
     *
     * Note that the conversion is not always unambiguous. There can be the following possible situations:
     * - There's only one instant that has this date/time value in the time zone. In this case
     * the conversion is unambiguous.
     * - There's no instant that has this date/time value in the time zone. Such situation appears when
     * the time zone experiences a transition from a lesser to a greater offset. In this case the conversion is performed with
     * the lesser offset.
     * - There are two possible instants that can have this date/time components in the time zone. In this case the earlier
     * instant is returned.
     *
     * ## Example
     * ```
     * val zone = TimeZone.of("America/New_York")
     * zone.run {
     *     val dateTime = LocalDateTime(2023, 3, 12, 2, 30)
     *     // This time doesn't exist due to DST transition
     *     val instant = dateTime.toInstant()
     *     // The result will be adjusted forward
     * }
     * ```
     *
     * @receiver The local date-time to convert
     * @return The instant corresponding to this date-time in this time zone
     * @see Instant.toLocalDateTime for the inverse operation
     * @see LocalDateTime.toInstant for the standalone function
     */
    public fun LocalDateTime.toInstant(): Instant
}

/**
 * A time zone that is known to always have the same offset from UTC.
 *
 * For such time zones, all instants are mapped to [LocalDateTime] simply by adding the offset.
 * There are no daylight saving time transitions or other complications.
 *
 * ## Creating Fixed Offset Time Zones
 *
 * ```
 * // From a UTC offset
 * val plus5Hours = UtcOffset(hours = 5).asTimeZone()
 * val minus3Hours = UtcOffset(hours = -3).asTimeZone()
 * 
 * // From a string
 * val plus0530 = TimeZone.of("+05:30") as FixedOffsetTimeZone
 * 
 * // UTC is a special case
 * val utc = TimeZone.UTC
 * ```
 *
 * ## Usage Considerations
 *
 * Fixed offset time zones are simpler and more performant than region-based zones:
 * - No daylight saving time transitions
 * - Conversions are simple arithmetic operations
 * - No ambiguous local times
 *
 * However, they don't account for historical or future offset changes that
 * region-based zones handle.
 *
 * @see TimeZone for the general time zone abstraction
 * @see UtcOffset for representing just the offset value
 */
@Serializable(with = FixedOffsetTimeZoneSerializer::class)
public expect class FixedOffsetTimeZone : TimeZone {
    /**
     * Constructs a fixed-offset time zone with the given [offset].
     *
     * The [id] of the resulting time zone is the string representation of the [offset].
     *
     * @param offset The constant offset from UTC
     */
    public constructor(offset: UtcOffset)

    /**
     * The constant offset from UTC that this time zone has.
     *
     * This offset is applied to all instants equally - there are no variations
     * due to daylight saving time or historical changes.
     *
     * @see UtcOffset for offset representation details
     */
    public val offset: UtcOffset

    @Deprecated("Use offset.totalSeconds", ReplaceWith("offset.totalSeconds"))
    public val totalSeconds: Int
}

@Deprecated("Use FixedOffsetTimeZone of UtcOffset instead", ReplaceWith("FixedOffsetTimeZone"))
public typealias ZoneOffset = FixedOffsetTimeZone

/**
 * Finds the offset from UTC this time zone has at the specified [instant] of physical time.
 *
 * The offset returned may vary over time due to daylight saving time transitions
 * or other changes in the time zone rules.
 *
 * ## Example
 * ```
 * val zone = TimeZone.of("America/New_York")
 * val summerInstant = Instant.parse("2023-07-01T12:00:00Z")
 * val winterInstant = Instant.parse("2023-01-01T12:00:00Z")
 * 
 * println(zone.offsetAt(summerInstant)) // -04:00 (EDT)
 * println(zone.offsetAt(winterInstant)) // -05:00 (EST)
 * ```
 *
 * @param instant The instant to find the offset for
 * @return The UTC offset at the given instant
 * @see Instant.offsetIn for a more convenient syntax
 * @see Instant.toLocalDateTime for converting with the offset
 */
public expect fun TimeZone.offsetAt(instant: Instant): UtcOffset

/**
 * Returns a civil date/time value that this instant has in the specified [timeZone].
 *
 * The returned [LocalDateTime] represents the local time in the given time zone
 * at this instant. The conversion is always unambiguous.
 *
 * Note that while this conversion is unambiguous, the inverse ([LocalDateTime.toInstant])
 * is not necessary so.
 *
 * ## Example
 * ```
 * val instant = Clock.System.now()
 * val tokyo = instant.toLocalDateTime(TimeZone.of("Asia/Tokyo"))
 * val newYork = instant.toLocalDateTime(TimeZone.of("America/New_York"))
 * // tokyo and newYork represent the same moment but with different local times
 * ```
 *
 * @param timeZone The time zone to use for conversion
 * @return The local date and time in the specified time zone
 * @throws DateTimeArithmeticException if this value is too large to fit in [LocalDateTime].
 * @see LocalDateTime.toInstant for the inverse operation
 * @see Instant.offsetIn for just getting the offset
 */
public expect fun Instant.toLocalDateTime(timeZone: TimeZone): LocalDateTime

/**
 * Returns a civil date/time value that this instant has in the specified [UTC offset][offset].
 *
 * @param offset The UTC offset to use for conversion
 * @return The local date and time at the specified offset
 * @see LocalDateTime.toInstant for the inverse operation
 * @see Instant.offsetIn for finding the offset in a time zone
 */
internal expect fun Instant.toLocalDateTime(offset: UtcOffset): LocalDateTime

/**
 * Finds the offset from UTC the specified [timeZone] has at this instant of physical time.
 *
 * This is a shorthand for `timeZone.offsetAt(this)`.
 *
 * ## Example
 * ```
 * val instant = Clock.System.now()
 * val offset = instant.offsetIn(TimeZone.of("Europe/London"))
 * println("London offset: $offset")
 * ```
 *
 * @param timeZone The time zone to find the offset for
 * @return The UTC offset at this instant in the given time zone
 * @see Instant.toLocalDateTime for the full conversion
 * @see TimeZone.offsetAt for the same operation
 */
public fun Instant.offsetIn(timeZone: TimeZone): UtcOffset =
        timeZone.offsetAt(this)

/**
 * Returns an instant that corresponds to this civil date/time value in the specified [timeZone].
 *
 * Note that the conversion is not always unambiguous. There can be the following possible situations:
 * - There's only one instant that has this date/time value in the [timeZone]. In this case
 * the conversion is unambiguous.
 * - There's no instant that has this date/time value in the [timeZone]. Such situation appears when
 * the time zone experiences a transition from a lesser to a greater offset. In this case the conversion is performed with
 * the lesser offset.
 * - There are two possible instants that can have this date/time components in the [timeZone]. In this case the earlier
 * instant is returned.
 *
 * ## Handling Daylight Saving Time
 *
 * ```
 * val zone = TimeZone.of("America/New_York")
 * 
 * // Spring forward - this time doesn't exist
 * val springForward = LocalDateTime(2023, 3, 12, 2, 30)
 * val instant1 = springForward.toInstant(zone)
 * // The time is adjusted to 3:30 AM
 * 
 * // Fall back - this time exists twice
 * val fallBack = LocalDateTime(2023, 11, 5, 1, 30)
 * val instant2 = fallBack.toInstant(zone)
 * // The earlier occurrence (EDT) is chosen
 * ```
 *
 * @param timeZone The time zone to use for conversion
 * @return The instant corresponding to this date-time in the given time zone
 * @see Instant.toLocalDateTime for the inverse operation
 */
public expect fun LocalDateTime.toInstant(timeZone: TimeZone): Instant

/**
 * Returns an instant that corresponds to this civil date/time value that happens at the specified [UTC offset][offset].
 *
 * This conversion is always unambiguous since the offset is fixed.
 *
 * ## Example
 * ```
 * val dateTime = LocalDateTime(2023, 12, 31, 23, 59, 59)
 * val offset = UtcOffset(hours = 5, minutes = 30)
 * val instant = dateTime.toInstant(offset)
 * ```
 *
 * @param offset The UTC offset for this date-time
 * @return The instant corresponding to this date-time at the given offset
 * @see Instant.toLocalDateTime for the inverse operation
 */
public expect fun LocalDateTime.toInstant(offset: UtcOffset): Instant

/**
 * Returns an instant that corresponds to the start of this date in the specified [timeZone].
 *
 * Note that it's not equivalent to `atTime(0, 0).toInstant(timeZone)`
 * because a day does not always start at the fixed time 0:00:00.
 * For example, if due do daylight saving time, clocks were shifted from 23:30
 * of one day directly to 00:30 of the next day, skipping the midnight, then
 * `atStartOfDayIn` would return the `Instant` corresponding to 00:30, whereas
 * `atTime(0, 0).toInstant(timeZone)` would return the `Instant` corresponding
 * to 01:00.
 *
 * ## Example
 * ```
 * val date = LocalDate(2023, 3, 12) // DST starts this day in America/New_York
 * val zone = TimeZone.of("America/New_York")
 * 
 * val startOfDay = date.atStartOfDayIn(zone)
 * val localTime = startOfDay.toLocalDateTime(zone).time
 * // localTime might not be 00:00:00 due to DST
 * ```
 *
 * @param timeZone The time zone to find the start of day in
 * @return The instant when this date starts in the given time zone
 * @see LocalDate.atTime for creating a specific time on this date
 */
public expect fun LocalDate.atStartOfDayIn(timeZone: TimeZone): Instant

