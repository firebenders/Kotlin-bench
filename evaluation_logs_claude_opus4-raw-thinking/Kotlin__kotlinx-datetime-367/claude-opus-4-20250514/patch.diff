package kotlinx.datetime

/**
 * The enumeration class representing the days of the week.
 *
 * This enum follows the ISO-8601 standard where Monday is the first day of the week
 * and Sunday is the last day (day 7).
 *
 * ## Obtaining DayOfWeek
 *
 * You can obtain a [DayOfWeek] in several ways:
 * ```
 * // From a LocalDate
 * val date = LocalDate(2023, 12, 25)
 * val dayOfWeek = date.dayOfWeek // MONDAY
 * 
 * // From an ISO day number (1-7)
 * val friday = DayOfWeek(5) // FRIDAY
 * 
 * // Using enum constants directly
 * val sunday = DayOfWeek.SUNDAY
 * ```
 *
 * ## ISO-8601 Compliance
 *
 * This enum strictly follows ISO-8601:
 * - Week starts on Monday (day 1)
 * - Week ends on Sunday (day 7)
 *
 * ## Common Operations
 *
 * ```
 * val day = DayOfWeek.WEDNESDAY
 * 
 * // Get ISO day number
 * val dayNumber = day.isoDayNumber // 3
 * 
 * // Check weekend (example)
 * val isWeekend = day == DayOfWeek.SATURDAY || day == DayOfWeek.SUNDAY
 * 
 * // Iterate through days
 * for (day in DayOfWeek.values()) {
 *     println("$day is day ${day.isoDayNumber}")
 * }
 * ```
 *
 * ## Platform Specifics
 *
 * - **JVM**: Maps to `java.time.DayOfWeek`
 * - **JS**: Custom implementation
 * - **Native**: Custom implementation
 *
 * @see LocalDate.dayOfWeek for obtaining the day of week from a date
 * @see isoDayNumber for the numeric representation
 */
public expect enum class DayOfWeek {
    /** Monday, the first day of the week according to ISO-8601. ISO day number: 1. */
    MONDAY,
    /** Tuesday, the second day of the week. ISO day number: 2. */
    TUESDAY,
    /** Wednesday, the third day of the week. ISO day number: 3. */
    WEDNESDAY,
    /** Thursday, the fourth day of the week. ISO day number: 4. */
    THURSDAY,
    /** Friday, the fifth day of the week. ISO day number: 5. */
    FRIDAY,
    /** Saturday, the sixth day of the week. ISO day number: 6. */
    SATURDAY,
    /** Sunday, the seventh and last day of the week according to ISO-8601. ISO day number: 7. */
    SUNDAY;
}

/**
 * The ISO-8601 number of the given day of the week.
 * 
 * Monday is 1, Sunday is 7, as specified by ISO-8601.
 * This is different from some other conventions (like Java's Calendar.DAY_OF_WEEK)
 * where Sunday is 1.
 *
 * ## Example
 * ```
 * println(DayOfWeek.MONDAY.isoDayNumber)    // 1
 * println(DayOfWeek.SUNDAY.isoDayNumber)    // 7
 * ```
 *
 * @see DayOfWeek for the enumeration
 */
public val DayOfWeek.isoDayNumber: Int get() = ordinal + 1

/**
 * Returns the [DayOfWeek] instance for the given ISO-8601 week day number.
 * 
 * Monday is 1, Sunday is 7.
 *
 * ## Example
 * ```
 * val monday = DayOfWeek(1)    // MONDAY
 * val friday = DayOfWeek(5)    // FRIDAY
 * val sunday = DayOfWeek(7)    // SUNDAY
 * ```
 *
 * @param isoDayNumber The ISO-8601 day number, must be in range 1..7
 * @return The corresponding [DayOfWeek]
 * @throws IllegalArgumentException if [isoDayNumber] is not in range 1..7
 * @see DayOfWeek.isoDayNumber for the reverse operation
 */
public fun DayOfWeek(isoDayNumber: Int): DayOfWeek {
    require(isoDayNumber in 1..7) { "Expected ISO day-of-week number in 1..7, got $isoDayNumber" }
    return DayOfWeek.entries[isoDayNumber - 1]
}

