package kotlinx.datetime

/**
 * The enumeration class representing the 12 months of the year.
 *
 * This enum follows the ISO-8601 standard and the Gregorian calendar system.
 * Months are numbered from 1 (January) to 12 (December).
 *
 * ## Obtaining Month
 *
 * You can obtain a [Month] in several ways:
 * ```
 * // From a LocalDate or LocalDateTime
 * val date = LocalDate(2023, 12, 25)
 * val month = date.month // DECEMBER
 * 
 * // From a month number (1-12)
 * val july = Month(7) // JULY
 * 
 * // Using enum constants directly
 * val january = Month.JANUARY
 * ```
 *
 * ## Common Operations
 *
 * ```
 * val month = Month.FEBRUARY
 * 
 * // Get month number
 * val monthNumber = month.number // 2
 * 
 * // Check properties
 * val days = when {
 *     month == Month.FEBRUARY -> if (isLeapYear) 29 else 28
 *     month in listOf(Month.APRIL, Month.JUNE, Month.SEPTEMBER, Month.NOVEMBER) -> 30
 *     else -> 31
 * }
 * 
 * // Iterate through months
 * for (m in Month.values()) {
 *     println("${m.name} is month ${m.number}")
 * }
 * ```
 *
 * ## ISO-8601 Compliance
 *
 * This enum strictly follows ISO-8601 and Gregorian calendar conventions:
 * - January is month 1
 * - December is month 12
 * - Month lengths follow the standard calendar rules
 *
 * ## Platform Specifics
 *
 * - **JVM**: Maps to `java.time.Month`
 * - **JS**: Custom implementation
 * - **Native**: Custom implementation
 *
 * @see LocalDate.month for obtaining the month from a date
 * @see LocalDate.monthNumber for the numeric representation
 * @see number for converting month to its numeric value
 */
public expect enum class Month {
    /** January, month #01, with 31 days. The first month of the year in the Gregorian calendar. */
    JANUARY,

    /** February, month #02, with 28 days, or 29 in leap years. The shortest month of the year. */
    FEBRUARY,

    /** March, month #03, with 31 days. */
    MARCH,

    /** April, month #04, with 30 days. */
    APRIL,

    /** May, month #05, with 31 days. */
    MAY,

    /** June, month #06, with 30 days. */
    JUNE,

    /** July, month #07, with 31 days. */
    JULY,

    /** August, month #08, with 31 days. */
    AUGUST,

    /** September, month #09, with 30 days. */
    SEPTEMBER,

    /** October, month #10, with 31 days. */
    OCTOBER,

    /** November, month #11, with 30 days. */
    NOVEMBER,

    /** December, month #12, with 31 days. The last month of the year in the Gregorian calendar. */
    DECEMBER;

//    val value: Int // member missing in java.time.Month has to be an extension
}

/**
 * The number of the [Month].
 * 
 * January is 1, December is 12, following ISO-8601 conventions.
 *
 * ## Example
 * ```
 * println(Month.JANUARY.number)   // 1
 * println(Month.DECEMBER.number)  // 12
 * ```
 *
 * @see Month for the enumeration
 * @see Month(Int) for creating a month from its number
 */
public val Month.number: Int get() = ordinal + 1

/**
 * Returns the [Month] instance for the given month number.
 * 
 * January is 1, December is 12.
 *
 * ## Example
 * ```
 * val january = Month(1)    // JANUARY
 * val july = Month(7)       // JULY
 * val december = Month(12)  // DECEMBER
 * ```
 *
 * @param number The month number, must be in range 1..12
 * @return The corresponding [Month]
 * @throws IllegalArgumentException if [number] is not in range 1..12
 * @see Month.number for the reverse operation
 */
public fun Month(number: Int): Month {
    require(number in 1..12)
    return Month.entries[number - 1]
}


