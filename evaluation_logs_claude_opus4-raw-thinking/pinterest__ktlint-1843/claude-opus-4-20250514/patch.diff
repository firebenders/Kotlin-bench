package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.EditorConfig
import com.pinterest.ktlint.rule.engine.core.api.ElementType.COLON
import com.pinterest.ktlint.rule.engine.core.api.ElementType.FUN
import com.pinterest.ktlint.rule.engine.core.api.ElementType.VALUE_PARAMETER_LIST
import com.pinterest.ktlint.rule.engine.core.api.ElementType.WHITE_SPACE
import com.pinterest.ktlint.rule.engine.core.api.Rule
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.EditorConfigProperty
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY_OFF
import com.pinterest.ktlint.rule.engine.core.api.nextLeaf
import com.pinterest.ktlint.rule.engine.core.api.prevLeaf
import com.pinterest.ktlint.rule.engine.core.api.upsertWhitespaceAfterMe
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.com.intellij.psi.PsiWhiteSpace
import org.jetbrains.kotlin.psi.psiUtil.endOffset
import org.jetbrains.kotlin.psi.psiUtil.startOffset

public class FunctionReturnTypeSpacingRule :
    StandardRule(
        id = "function-return-type-spacing",
        usesEditorConfigProperties = setOf(MAX_LINE_LENGTH_PROPERTY),
    ),
    Rule.Experimental {
    
    private var maxLineLength = MAX_LINE_LENGTH_PROPERTY_OFF

    override fun beforeFirstNode(editorConfig: EditorConfig) {
        maxLineLength = editorConfig[MAX_LINE_LENGTH_PROPERTY]
    }

    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        node.firstChildNode
        node
            .takeIf { node.elementType == FUN }
            ?.let { node.findChildByType(COLON) }
            ?.let { colonNode ->
                removeWhiteSpaceBetweenClosingParenthesisAndColon(colonNode, emit, autoCorrect)
                fixWhiteSpaceBetweenColonAndReturnType(colonNode, emit, autoCorrect)
            }
    }

    private fun removeWhiteSpaceBetweenClosingParenthesisAndColon(
        node: ASTNode,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
        autoCorrect: Boolean,
    ) {
        require(node.elementType == COLON)
        node
            .prevLeaf()
            ?.takeIf { it.elementType == WHITE_SPACE }
            ?.let { whitespaceBeforeColonNode ->
                emit(whitespaceBeforeColonNode.startOffset, "Unexpected whitespace", true)
                if (autoCorrect) {
                    whitespaceBeforeColonNode.treeParent?.removeChild(whitespaceBeforeColonNode)
                }
            }
    }

    private fun fixWhiteSpaceBetweenColonAndReturnType(
        node: ASTNode,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
        autoCorrect: Boolean,
    ) {
        require(node.elementType == COLON)
        node
            .nextLeaf()
            ?.takeIf { it.elementType == WHITE_SPACE }
            .let { whiteSpaceAfterColon ->
                if (whiteSpaceAfterColon?.text != " ") {
                    // Check if formatting would exceed max line length
                    if (!wouldExceedMaxLineLength(node, whiteSpaceAfterColon)) {
                        emit(node.startOffset, "Single space expected between colon and return type", true)
                        if (autoCorrect) {
                            node.upsertWhitespaceAfterMe(" ")
                        }
                    }
                }
            }
    }

    private fun wouldExceedMaxLineLength(colonNode: ASTNode, currentWhiteSpace: ASTNode?): Boolean {
        if (maxLineLength == MAX_LINE_LENGTH_PROPERTY_OFF) {
            return false
        }

        // Find the start of the current line
        var currentNode: ASTNode? = colonNode
        var lineStartOffset = 0
        while (currentNode != null) {
            val prevNode = currentNode.prevLeaf()
            if (prevNode == null || (prevNode.elementType == WHITE_SPACE && prevNode.text.contains('\n'))) {
                lineStartOffset = currentNode.startOffset
                break
            }
            currentNode = prevNode
        }

        // Find the end of the return type
        var returnTypeEndNode: ASTNode? = colonNode
        var afterColon = false
        while (returnTypeEndNode != null) {
            if (returnTypeEndNode == colonNode) {
                afterColon = true
            } else if (afterColon && returnTypeEndNode.elementType == WHITE_SPACE && returnTypeEndNode.text.contains('\n')) {
                // Return type ends at the newline
                break
            } else if (afterColon && returnTypeEndNode.nextLeaf() == null) {
                // End of file
                break
            } else if (afterColon && returnTypeEndNode.nextLeaf()?.text == "{") {
                // Return type ends before opening brace
                break
            }
            returnTypeEndNode = returnTypeEndNode.nextLeaf()
        }

        val returnTypeEndOffset = returnTypeEndNode?.endOffset ?: colonNode.endOffset

        // Calculate the column positions
        val lineStartColumn = getColumn(lineStartOffset, colonNode)
        val returnTypeEndColumn = getColumn(returnTypeEndOffset, colonNode)
        
        // If we're replacing a newline with a single space, we need to calculate the new line length
        val currentLength = if (currentWhiteSpace?.text?.contains('\n') == true) {
            // The return type is on a new line, so we need to calculate what the length would be
            // if everything was on the same line
            lineStartColumn + (returnTypeEndColumn - getColumn(colonNode.startOffset + 1, colonNode))
        } else {
            returnTypeEndColumn - lineStartColumn
        }

        return currentLength > maxLineLength
    }

    private fun getColumn(offset: Int, node: ASTNode): Int {
        val text = node.psi.containingFile.text
        var column = 0
        for (i in 0 until offset) {
            if (i >= text.length) break
            if (text[i] == '\n') {
                column = 0
            } else {
                column++
            }
        }
        return column
    }
}

public val FUNCTION_RETURN_TYPE_SPACING_RULE_ID: RuleId = FunctionReturnTypeSpacingRule().ruleId
