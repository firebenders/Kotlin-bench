/**
 * Disallows the usage of the ktlint-disable and ktlint-enable directives in comments. Ktlint suppression should be handled using @Suppress or @SuppressWarnings annotations.
 *
 * This rule cannot be disabled or suppressed via directives in comments.
 */
public class KtlintSuppressionRule :
    StandardRule("ktlint-suppression"),
    Rule.Experimental,
    Rule.OfficialCodeStyle {
    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        when (node.elementType) {
            EOL_COMMENT -> {
                visitEolComment(node, autoCorrect, emit)
            }
            BLOCK_COMMENT -> {
                visitBlockComment(node, autoCorrect, emit)
            }
        }
    }

    // Disable the option to disable this rule by restricting it from being suppressed
    override fun shouldContinueTraversalOfAST(): Boolean = true

    private fun visitEolComment(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val text = node.text.removePrefix("//").trim()
        if (text.startsWith(KTLINT_DISABLE) || text.startsWith(KTLINT_ENABLE)) {
            val args = text.split(" ").drop(1).filter { it.isNotBlank() }
            val ruleIds = args.map { normalizeRuleId(it) }
            
            emit(
                node.startOffset,
                "Directive '${text.split(" ").first()}' in comment is deprecated. Replace with @Suppress annotation",
                true
            )
            
            if (autoCorrect) {
                val targetNode = findTargetNodeForSuppression(node)
                val suppressAnnotation = createSuppressAnnotation(ruleIds)
                addSuppressAnnotation(targetNode, suppressAnnotation)
                removeCommentWithCleanup(node)
            }
        }
    }

    private fun visitBlockComment(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val text = node.text.removePrefix("/*").removeSuffix("*/").trim()
        
        if (text.startsWith(KTLINT_DISABLE)) {
            val args = text.split(" ").drop(1).filter { it.isNotBlank() }
            val ruleIds = args.map { normalizeRuleId(it) }
            
            emit(
                node.startOffset,
                "Directive 'ktlint-disable' in comment is deprecated. Replace with @Suppress annotation",
                false
            )
        } else if (text.startsWith(KTLINT_ENABLE)) {
            emit(
                node.startOffset,
                "Directive 'ktlint-enable' in comment is deprecated. Suppression should only use @Suppress annotation",
                false
            )
        }
    }

    private fun normalizeRuleId(ruleId: String): String {
        // Convert underscore format to colon format
        val normalizedId = if (ruleId.contains("_")) {
            val parts = ruleId.split("_", limit = 2)
            if (parts.size == 2) {
                "${parts[0]}:${parts[1]}"
            } else {
                ruleId
            }
        } else {
            ruleId
        }
        
        // Ensure ktlint prefix
        return if (normalizedId == "" || normalizedId == "ktlint") {
            "ktlint"
        } else if (!normalizedId.startsWith("ktlint:")) {
            "ktlint:$normalizedId"
        } else {
            normalizedId
        }
    }

    private fun findTargetNodeForSuppression(commentNode: ASTNode): ASTNode {
        // For EOL comments, find the element on the same line that should be annotated
        val prevCodeNode = commentNode.prevCodeSibling()
        if (prevCodeNode != null && !hasNewlineBetween(prevCodeNode, commentNode)) {
            return when (prevCodeNode.elementType) {
                IMPORT_LIST -> prevCodeNode.treeParent
                else -> prevCodeNode
            }
        }
        
        // If no element on same line, find the next code element
        val nextCodeNode = commentNode.nextCodeSibling()
        return nextCodeNode ?: commentNode.treeParent
    }

    private fun hasNewlineBetween(node1: ASTNode, node2: ASTNode): Boolean {
        var current = node1.nextSibling()
        while (current != null && current != node2) {
            if (current.isWhiteSpaceWithNewline()) {
                return true
            }
            current = current.nextSibling()
        }
        return false
    }

    private fun createSuppressAnnotation(ruleIds: List<String>): String {
        return when {
            ruleIds.isEmpty() || ruleIds.any { it == "ktlint" } -> "@Suppress(\"ktlint\")"
            ruleIds.size == 1 -> "@Suppress(\"${ruleIds[0]}\")"
            else -> "@Suppress(${ruleIds.joinToString(", ") { "\"$it\"" }})"
        }
    }

    private fun addSuppressAnnotation(targetNode: ASTNode, annotation: String) {
        when (targetNode.elementType) {
            FILE -> addFileAnnotation(targetNode, annotation)
            FUN, PROPERTY, CLASS -> addDeclarationAnnotation(targetNode, annotation)
            else -> {
                // For other elements, try to add to parent declaration
                val parent = targetNode.parent { it.elementType in listOf(FUN, PROPERTY, CLASS, FILE) }
                if (parent != null) {
                    addSuppressAnnotation(parent, annotation)
                }
            }
        }
    }

    private fun addFileAnnotation(fileNode: ASTNode, annotation: String) {
        val annotationNode = createAnnotationNode("@file:Suppress(${extractSuppressionArgs(annotation)})")
        
        val fileAnnotationList = fileNode.findChildByType(FILE_ANNOTATION_LIST)
        if (fileAnnotationList != null) {
            // Merge with existing @file:Suppress if present
            val existingSuppress = fileAnnotationList.children()
                .filterIsInstance<KtAnnotationEntry>()
                .find { it.shortName?.asString() == "Suppress" }
            
            if (existingSuppress != null) {
                mergeSuppressions(existingSuppress, extractSuppressionArgs(annotation))
            } else {
                // Add new annotation to existing list
                val newAnnotation = createAnnotationNode(annotation.replace("@Suppress", "@file:Suppress"))
                fileAnnotationList.addChild(newAnnotation, null)
                fileAnnotationList.addChild(PsiWhiteSpaceImpl("\n"), null)
            }
        } else {
            // Create new file annotation list
            val newFileAnnotationList = createFileAnnotationList("@file:Suppress(${extractSuppressionArgs(annotation)})")
            
            // Insert after package directive or at start of file
            val packageDirective = fileNode.findChildByType(PACKAGE_DIRECTIVE)
            if (packageDirective != null) {
                fileNode.addChild(PsiWhiteSpaceImpl("\n\n"), packageDirective.nextSibling())
                fileNode.addChild(newFileAnnotationList, packageDirective.nextSibling())
            } else {
                fileNode.addChild(newFileAnnotationList, fileNode.firstChildNode)
                fileNode.addChild(PsiWhiteSpaceImpl("\n\n"), newFileAnnotationList.nextSibling())
            }
        }
    }

    private fun addDeclarationAnnotation(targetNode: ASTNode, annotation: String) {
        val modifierList = targetNode.findChildByType(MODIFIER_LIST)
        val annotationNode = createAnnotationNode(annotation)
        
        if (modifierList != null) {
            // Check for existing @Suppress annotation
            val existingSuppress = modifierList.children()
                .filterIsInstance<KtAnnotationEntry>()
                .find { it.shortName?.asString() == "Suppress" }
            
            if (existingSuppress != null) {
                mergeSuppressions(existingSuppress, extractSuppressionArgs(annotation))
            } else {
                // Add annotation to modifier list
                modifierList.addChild(annotationNode, modifierList.firstChildNode)
                modifierList.addChild(PsiWhiteSpaceImpl(" "), annotationNode.nextSibling())
            }
        } else {
            // Create new modifier list with annotation
            val newModifierList = createModifierListWithAnnotation(annotation)
            
            // Insert before the declaration keyword
            val keyword = when (targetNode.elementType) {
                FUN -> targetNode.findChildByType(ElementType.FUN_KEYWORD)
                PROPERTY -> targetNode.findChildByType(ElementType.VAL_KEYWORD) ?: targetNode.findChildByType(ElementType.VAR_KEYWORD)
                CLASS -> targetNode.findChildByType(ElementType.CLASS_KEYWORD)
                else -> null
            }
            
            if (keyword != null) {
                targetNode.addChild(newModifierList, keyword)
                targetNode.addChild(PsiWhiteSpaceImpl(" "), keyword)
            }
        }
    }

    private fun removeCommentWithCleanup(commentNode: ASTNode) {
        val prevNode = commentNode.prevSibling()
        val nextNode = commentNode.nextSibling()
        
        // Remove extra whitespace
        if (prevNode?.isWhiteSpace() == true && nextNode?.isWhiteSpace() == true) {
            if (prevNode.text.contains('\n') || nextNode.text.contains('\n')) {
                // Keep one newline
                prevNode.treeParent.removeChild(nextNode)
            } else {
                // Keep one space
                (nextNode as? LeafPsiElement)?.rawReplaceWithText(" ")
            }
        }
        
        commentNode.treeParent.removeChild(commentNode)
    }

    private fun extractSuppressionArgs(annotation: String): String {
        return annotation
            .substringAfter("@Suppress(")
            .substringAfter("@file:Suppress(")
            .substringBefore(")")
    }

    private fun mergeSuppressions(existingAnnotation: KtAnnotationEntry, newArgs: String) {
        val existingArgs = existingAnnotation.valueArguments
            .mapNotNull { it.getArgumentExpression()?.text?.removeSurrounding("\"") }
            .toMutableSet()
        
        val argsToAdd = newArgs.split(",")
            .map { it.trim().removeSurrounding("\"") }
            .filter { it.isNotBlank() && it !in existingArgs }
        
        if (argsToAdd.isNotEmpty()) {
            // This is a simplified merge - in practice, you'd need to properly modify the PSI tree
            // For the POC, we'll just indicate what should be done
            val allArgs = (existingArgs + argsToAdd).joinToString(", ") { "\"$it\"" }
            // Would need to update the annotation's value argument list here
        }
    }

    private fun createAnnotationNode(annotation: String): ASTNode {
        // This is a simplified implementation - in practice, you'd need to create proper PSI elements
        // For the POC, we're just showing the structure
        return LeafPsiElement(ElementType.ANNOTATION_ENTRY, annotation)
    }

    private fun createFileAnnotationList(annotation: String): ASTNode {
        // Simplified implementation
        return LeafPsiElement(FILE_ANNOTATION_LIST, annotation)
    }

    private fun createModifierListWithAnnotation(annotation: String): ASTNode {
        // Simplified implementation
        return LeafPsiElement(MODIFIER_LIST, annotation)
    }

    companion object {
        private const val KTLINT_DISABLE = "ktlint-disable"
        private const val KTLINT_ENABLE = "ktlint-enable"
    }
}

public val KTLINT_SUPPRESSION_RULE_ID: RuleId = KtlintSuppressionRule().ruleId
