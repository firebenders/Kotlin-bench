package com.fsck.k9

import app.k9mail.legacy.account.Account
import app.k9mail.legacy.account.Account.FolderMode
import com.fsck.k9.preferences.Storage
import com.fsck.k9.preferences.StorageEditor
import java.util.ArrayList
import java.util.Calendar
import java.util.UUID

class AccountPreferenceSerializer {
    fun save(editor: StorageEditor, storage: Storage, account: Account) {
        editor.putString("$accountUuid.description", account.description)
        editor.putString("$accountUuid.email", account.email)
        editor.putBoolean("$accountUuid.isDefaultAccount", account.isDefaultAccount)
        editor.putString("$accountUuid.name", account.name)
        editor.putString("$accountUuid.signatureBeforeQuotedText", account.signatureBeforeQuotedText.toString())
        editor.putString("$accountUuid.expungePolicy", account.expungePolicy.toString())
        editor.putString("$accountUuid.autoExpandFolderName", account.autoExpandFolder)
        editor.putInt("$accountUuid.maxPushFolders", account.maxPushFolders)
        editor.putString("$accountUuid.searchableFolders", account.searchableFolders.name)
        editor.putInt("$accountUuid.chipColor", account.chipColor)
        editor.putBoolean("$accountUuid.goToUnreadMessageSearch", account.isGoToUnreadMessageSearch)
        editor.putBoolean("$accountUuid.notifyNewMail", account.isNotifyNewMail)
        editor.putString("$accountUuid.folderNotifyNewMailMode", account.folderNotifyNewMailMode.name)
        editor.putBoolean("$accountUuid.notifySelfNewMail", account.isNotifySelfNewMail)
        editor.putBoolean("$accountUuid.notifyContactsMailOnly", account.isNotifyContactsMailOnly)
        editor.putBoolean("$accountUuid.ignoreChatMessages", account.isIgnoreChatMessages)
        editor.putBoolean("$accountUuid.notifySync", account.isNotifySync)
        editor.putString("$accountUuid.deletePolicy", account.deletePolicy.toString())
        editor.putString("$accountUuid.messageFormat", account.messageFormat.name)
        editor.putString("$accountUuid.messageFormatAuto", account.isMessageFormatAuto.toString())
        editor.putString("$accountUuid.messageReadReceipt", account.isMessageReadReceipt.toString())
        editor.putString("$accountUuid.quoteStyle", account.quoteStyle.name)
        editor.putString("$accountUuid.quotePrefix", account.quotePrefix)
        editor.putBoolean("$accountUuid.defaultQuotedTextShown", account.isDefaultQuotedTextShown)
        editor.putBoolean("$accountUuid.replyAfterQuote", account.isReplyAfterQuote)
        editor.putBoolean("$accountUuid.stripSignature", account.isStripSignature)
        editor.putLong("$accountUuid.syncRemoteDeletions", if (account.isSyncRemoteDeletions) 1 else 0)
        editor.putString("$accountUuid.cryptoApp", account.openPgpProvider)
        editor.putLong("$accountUuid.cryptoKey", account.openPgpKey)
        editor.putBoolean("$accountUuid.allowRemoteSearch", account.isAllowRemoteSearch)
        editor.putBoolean("$accountUuid.remoteSearchFullText", account.isRemoteSearchFullText)
        editor.putInt("$accountUuid.remoteSearchNumResults", account.remoteSearchNumResults)
        editor.putBoolean("$accountUuid.uploadSentMessages", account.isUploadSentMessages)
        editor.putString("$accountUuid.folderDisplayMode", account.folderDisplayMode.name)
        editor.putString("$accountUuid.folderSyncMode", account.folderSyncMode.name)
        editor.putString("$accountUuid.folderPushMode", account.folderPushMode.name)
        editor.putString("$accountUuid.folderTargetMode", account.folderTargetMode.name)
        editor.putBoolean("$accountUuid.signatureUse", account.signatureUse)
        editor.putString("$accountUuid.signature", account.signature)
        editor.putString("$accountUuid.loadMoreMessages", account.loadMoreMessages.name)
        editor.putBoolean("$accountUuid.alwaysBcc", account.isAlwaysBcc)
        editor.putString("$accountUuid.alwaysBccAddress", account.alwaysBccAddress)
        editor.putBoolean("$accountUuid.autocryptMutualMode", account.autocryptMutualMode)
        
        // Most importantly, save folder assignments
        editor.putString("$accountUuid.inboxFolderName", account.inboxFolder)
        editor.putString("$accountUuid.sentFolderName", account.sentFolder)
        editor.putString("$accountUuid.draftsFolderName", account.draftsFolder)
        editor.putString("$accountUuid.trashFolderName", account.trashFolder)
        editor.putString("$accountUuid.archiveFolderName", account.archiveFolder)
        editor.putString("$accountUuid.spamFolderName", account.spamFolder)
        
        // Save special folder selection modes  
        editor.putString("$accountUuid.sentFolderMode", account.sentFolderMode.name)
        editor.putString("$accountUuid.draftsFolderMode", account.draftsFolderMode.name)
        editor.putString("$accountUuid.trashFolderMode", account.trashFolderMode.name)
        editor.putString("$accountUuid.archiveFolderMode", account.archiveFolderMode.name)
        editor.putString("$accountUuid.spamFolderMode", account.spamFolderMode.name)

        saveIdentities(editor, account)
        saveServerSettings(editor, account)
    }

    fun loadAccount(account: Account, storage: Storage) {
        val accountUuid = account.uuid
        
        account.description = storage.getString("$accountUuid.description", null)
        account.email = storage.getString("$accountUuid.email", account.email)
        account.isDefaultAccount = storage.getBoolean("$accountUuid.isDefaultAccount", false)
        account.name = storage.getString("$accountUuid.name", null)
        account.signatureBeforeQuotedText = storage.getBoolean("$accountUuid.signatureBeforeQuotedText", false)
        account.expungePolicy = storage.getString("$accountUuid.expungePolicy", Account.Expunge.EXPUNGE_IMMEDIATELY.toString())
        account.autoExpandFolder = storage.getString("$accountUuid.autoExpandFolderName", null)
        account.maxPushFolders = storage.getInt("$accountUuid.maxPushFolders", 10)
        account.chipColor = storage.getInt("$accountUuid.chipColor", 0)
        account.isGoToUnreadMessageSearch = storage.getBoolean("$accountUuid.goToUnreadMessageSearch", false)
        account.isNotifyNewMail = storage.getBoolean("$accountUuid.notifyNewMail", false)
        account.folderNotifyNewMailMode = FolderMode.valueOf(
            storage.getString("$accountUuid.folderNotifyNewMailMode", FolderMode.ALL.name)
        )
        account.isNotifySelfNewMail = storage.getBoolean("$accountUuid.notifySelfNewMail", true)
        account.isNotifyContactsMailOnly = storage.getBoolean("$accountUuid.notifyContactsMailOnly", false)
        account.isIgnoreChatMessages = storage.getBoolean("$accountUuid.ignoreChatMessages", false)
        account.isNotifySync = storage.getBoolean("$accountUuid.notifySync", true)
        account.deletePolicy = Account.DeletePolicy.valueOf(
            storage.getString("$accountUuid.deletePolicy", Account.DeletePolicy.NEVER.name)
        )
        
        // Load folder assignments
        account.inboxFolder = storage.getString("$accountUuid.inboxFolderName", "INBOX")
        account.sentFolder = storage.getString("$accountUuid.sentFolderName", null)
        account.draftsFolder = storage.getString("$accountUuid.draftsFolderName", null)
        account.trashFolder = storage.getString("$accountUuid.trashFolderName", null)
        account.archiveFolder = storage.getString("$accountUuid.archiveFolderName", null)
        account.spamFolder = storage.getString("$accountUuid.spamFolderName", null)
        
        // Load special folder selection modes
        account.sentFolderMode = loadFolderMode(storage, "$accountUuid.sentFolderMode")
        account.draftsFolderMode = loadFolderMode(storage, "$accountUuid.draftsFolderMode")  
        account.trashFolderMode = loadFolderMode(storage, "$accountUuid.trashFolderMode")
        account.archiveFolderMode = loadFolderMode(storage, "$accountUuid.archiveFolderMode")
        account.spamFolderMode = loadFolderMode(storage, "$accountUuid.spamFolderMode")
        
        loadServerSettings(account, storage)
        loadIdentities(account, storage)
    }
    
    private fun loadFolderMode(storage: Storage, key: String): FolderMode {
        val modeString = storage.getString(key, null)
        return if (modeString != null) {
            try {
                FolderMode.valueOf(modeString)
            } catch (e: IllegalArgumentException) {
                FolderMode.AUTOMATIC
            }
        } else {
            FolderMode.AUTOMATIC
        }
    }

