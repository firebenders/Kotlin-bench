        account.description = null
        account.signatureUse = true
        account.signature = null
        account.signatureBeforeQuotedText = false
        account.isNotifyNewMail = true
        account.folderNotifyNewMailMode = FolderMode.ALL
        account.isNotifySelfNewMail = true
