class SettingsImporter {
    /**
     * Class to list the contents of an import file/stream.
     */
    data class ImportContents(
        val globalSettings: Boolean,
        val accounts: List<AccountDescription>
    )

    data class AccountDescription(
        val name: String,
        val uuid: String
    )

    data class ImportResults(
        val globalSettings: Boolean,
        val importedAccounts: List<ImportedAccount>
    )

    data class ImportedAccount(
        val uuid: String,
        val importedName: String,
        val incomingServer: ImportedServer,
        val outgoingServers: List<ImportedServer>
    )

    data class ImportedServer(
        val name: String,
        val type: String
    )

    data class Imported(
        val globalSettings: Boolean,
        val accounts: Map<String, Account>
    )

    companion object {
        private const val SETTINGS_VERSION = 1
        private const val FILE_FORMAT_VERSION = 1
        private const val VERSION_ATTRIBUTE = "version"
        private const val FORMAT_ATTRIBUTE = "format"
        
        /**
         * Import settings from a K-9 Mail settings file.
         */
        @JvmStatic
        fun importSettings(
            context: Context,
            inputStream: InputStream,
            globalSettings: Boolean,
            accountUuids: List<String>,
            overwrite: Boolean
        ): ImportResults {
            val preferences = Preferences.getPreferences()
            val editor = preferences.createStorageEditor()
            val contentVersion = 1 // Default version

            val imported = parseSettings(inputStream, globalSettings, accountUuids, overwrite, preferences)

            if (globalSettings && imported.globalSettings) {
                importGlobalSettings(editor, preferences.storage, contentVersion, imported.globalSettings)
            }

            val importedAccounts = mutableListOf<ImportedAccount>()
            for ((uuid, account) in imported.accounts) {
                // This is where we need to ensure folder assignments are preserved
                importAccount(context, editor, preferences, account, overwrite)
                
                val incomingServer = ImportedServer(
                    account.incomingServerSettings.host ?: "",
                    account.incomingServerSettings.type
                )
                val outgoingServer = ImportedServer(
                    account.outgoingServerSettings.host ?: "",
                    account.outgoingServerSettings.type
                )
                
                importedAccounts.add(
                    ImportedAccount(
                        uuid = uuid,
                        importedName = account.name ?: "",
                        incomingServer = incomingServer,
                        outgoingServers = listOf(outgoingServer)
                    )
                )
            }

            if (!editor.commit()) {
                throw SettingsImportException("Failed to save imported settings")
            }

            preferences.loadAccounts()

            return ImportResults(
                globalSettings = globalSettings && imported.globalSettings,
                importedAccounts = importedAccounts
            )
        }

        private fun importAccount(
            context: Context,
            editor: StorageEditor,
            preferences: Preferences,
            account: Account,
            overwrite: Boolean
        ) {
            val accountPreferenceSerializer = AccountPreferenceSerializer()
            
            // Save all account settings
            accountPreferenceSerializer.save(editor, preferences.storage, account)
            
            // Make sure to trigger folder list refresh to apply imported folder assignments
            try {
                val localStore = LocalStore.getInstance(account, context)
                localStore.compact()
            } catch (e: Exception) {
                Timber.w(e, "Failed to compact local store after import")
            }
        }

        private fun parseSettings(
            inputStream: InputStream,
            globalSettings: Boolean,
            accountUuids: List<String>,
            overwrite: Boolean,
            preferences: Preferences
        ): Imported {
            val accounts = mutableMapOf<String, Account>()
            var parsedGlobalSettings = false

            try {
                val factory = XmlPullParserFactory.newInstance()
                val xpp = factory.newPullParser()
                xpp.setInput(inputStream, "UTF-8")

                var eventType = xpp.eventType
                while (eventType != XmlPullParser.END_DOCUMENT) {
                    if (eventType == XmlPullParser.START_TAG) {
                        when (xpp.name) {
                            "k9settings" -> {
                                // Verify version
                            }
                            "global" -> {
                                if (globalSettings) {
                                    parseGlobalSettings(xpp)
                                    parsedGlobalSettings = true
                                }
                            }
                            "account" -> {
                                val accountUuid = xpp.getAttributeValue(null, "uuid")
                                if (accountUuid != null && (accountUuids.isEmpty() || accountUuid in accountUuids)) {
                                    val account = parseAccount(xpp, accountUuid, preferences, overwrite)
                                    accounts[accountUuid] = account
                                }
                            }
                        }
                    }
                    eventType = xpp.next()
                }
            } catch (e: Exception) {
                throw SettingsImportException("Failed to parse settings XML", e)
            }

            return Imported(parsedGlobalSettings, accounts)
        }

        private fun parseAccount(
            xpp: XmlPullParser,
            uuid: String,
            preferences: Preferences,
            overwrite: Boolean
        ): Account {
            val account = if (overwrite) {
                preferences.getAccount(uuid) ?: preferences.newAccount(uuid)
            } else {
                preferences.newAccount(uuid)
            }

            var eventType = xpp.next()
            while (!(eventType == XmlPullParser.END_TAG && xpp.name == "account")) {
                if (eventType == XmlPullParser.START_TAG) {
                    when (xpp.name) {
                        "name" -> account.name = getText(xpp)
                        "email" -> account.email = getText(xpp)
                        "description" -> account.description = getText(xpp)
                        "incoming-server" -> parseServerSettings(xpp, account, true)
                        "outgoing-server" -> parseServerSettings(xpp, account, false)
                        "folders" -> parseFolders(xpp, account)
                        "identities" -> parseIdentities(xpp, account)
                        // Add more account settings as needed
                    }
                }
                eventType = xpp.next()
            }

            return account
        }

        private fun parseFolders(xpp: XmlPullParser, account: Account) {
            var eventType = xpp.next()
            while (!(eventType == XmlPullParser.END_TAG && xpp.name == "folders")) {
                if (eventType == XmlPullParser.START_TAG) {
                    when (xpp.name) {
                        "inbox" -> account.inboxFolder = getText(xpp)
                        "drafts" -> account.draftsFolder = getText(xpp)
                        "sent" -> account.sentFolder = getText(xpp) 
                        "trash" -> account.trashFolder = getText(xpp)
                        "spam" -> account.spamFolder = getText(xpp)
                        "archive" -> account.archiveFolder = getText(xpp)
                        "auto-expand" -> account.autoExpandFolder = getText(xpp)
                        "folder" -> parseFolderSettings(xpp, account)
                    }
                }
                eventType = xpp.next()
            }
        }

        private fun parseFolderSettings(xpp: XmlPullParser, account: Account) {
            val folderName = xpp.getAttributeValue(null, "name") ?: return
            
            var eventType = xpp.next()
            while (!(eventType == XmlPullParser.END_TAG && xpp.name == "folder")) {
                if (eventType == XmlPullParser.START_TAG) {
                    when (xpp.name) {
                        "class" -> {
                            val folderClass = getText(xpp)
                            // Store folder class settings
                            when (folderClass) {
                                "FIRST_CLASS" -> account.setFolderDisplayMode(FolderClass.FIRST_CLASS)
                                "SECOND_CLASS" -> account.setFolderDisplayMode(FolderClass.SECOND_CLASS) 
                                "NO_CLASS" -> account.setFolderDisplayMode(FolderClass.NO_CLASS)
                            }
                        }
                        "sync" -> {
                            val syncEnabled = getText(xpp).toBoolean()
                            // Store sync settings for folder
                        }
                        "push" -> {
                            val pushEnabled = getText(xpp).toBoolean()
                            // Store push settings for folder
                        }
                    }
                }
                eventType = xpp.next()
            }
        }

        private fun parseServerSettings(xpp: XmlPullParser, account: Account, incoming: Boolean) {
            // Parse server settings
            var host: String? = null
            var port: Int? = null
            var connectionSecurity: String? = null
            var authenticationType: String? = null
            var username: String? = null
            var password: String? = null
            var clientCertificateAlias: String? = null
            
            var eventType = xpp.next()
            val endTag = if (incoming) "incoming-server" else "outgoing-server"
            
            while (!(eventType == XmlPullParser.END_TAG && xpp.name == endTag)) {
                if (eventType == XmlPullParser.START_TAG) {
                    when (xpp.name) {
                        "host" -> host = getText(xpp)
                        "port" -> port = getText(xpp).toIntOrNull()
                        "connection-security" -> connectionSecurity = getText(xpp)
                        "authentication-type" -> authenticationType = getText(xpp) 
                        "username" -> username = getText(xpp)
                        "password" -> password = getText(xpp)
                        "client-certificate-alias" -> clientCertificateAlias = getText(xpp)
                    }
                }
                eventType = xpp.next()
            }
            
            // Apply server settings to account
            if (incoming) {
                // Set incoming server settings
                val serverSettings = ServerSettings(
                    type = "imap",
                    host = host,
                    port = port ?: 993,
                    connectionSecurity = connectionSecurity ?: "SSL_TLS_REQUIRED",
                    authenticationType = authenticationType ?: "PLAIN",
                    username = username,
                    password = password,
                    clientCertificateAlias = clientCertificateAlias
                )
                account.incomingServerSettings = serverSettings
            } else {
                // Set outgoing server settings  
                val serverSettings = ServerSettings(
                    type = "smtp",
                    host = host,
                    port = port ?: 587,
                    connectionSecurity = connectionSecurity ?: "STARTTLS_REQUIRED",
                    authenticationType = authenticationType ?: "PLAIN",
                    username = username,
                    password = password,
                    clientCertificateAlias = clientCertificateAlias
                )
                account.outgoingServerSettings = serverSettings
            }
        }

        private fun parseIdentities(xpp: XmlPullParser, account: Account) {
            // Parse identities
            var eventType = xpp.next()
            while (!(eventType == XmlPullParser.END_TAG && xpp.name == "identities")) {
                if (eventType == XmlPullParser.START_TAG && xpp.name == "identity") {
                    parseIdentity(xpp, account)
                }
                eventType = xpp.next()
            }
        }

        private fun parseIdentity(xpp: XmlPullParser, account: Account) {
            // Implementation for parsing identity
        }

        private fun parseGlobalSettings(xpp: XmlPullParser) {
            // Parse global settings
        }

        private fun importGlobalSettings(
            editor: StorageEditor,
            storage: Storage,
            contentVersion: Int,
            settings: Any
        ) {
            // Import global settings
        }

        private fun getText(xpp: XmlPullParser): String {
            var result = ""
            if (xpp.next() == XmlPullParser.TEXT) {
                result = xpp.text
                xpp.next()
            }
            return result
        }
    }

    class SettingsImportException : Exception {
        constructor(message: String) : super(message)
        constructor(message: String, cause: Throwable) : super(message, cause)
    }
}
