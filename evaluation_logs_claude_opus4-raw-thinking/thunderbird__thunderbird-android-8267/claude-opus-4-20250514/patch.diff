    }

    fun delete(editor: StorageEditor, storage: Storage, account: Account) {
        val accountUuid = account.uuid
        
        // Find all keys that belong to this account
        val keysToDelete = storage.all.keys.filter { it.startsWith("$accountUuid.") }
        
        for (key in keysToDelete) {
            editor.remove(key)
        }
        
        // Also remove the account from the account list
        removeAccountFromAccountList(editor, storage, accountUuid)
    }

    fun move(editor: StorageEditor, account: Account, storage: Storage, newPosition: Int) {
        val accountUuid = account.uuid
        val accountUuids = storage.getString("accountUuids", "")
            ?.split(",")
            ?.filter { it.isNotEmpty() }
            ?.toMutableList() ?: mutableListOf()
        
        if (accountUuid !in accountUuids) return
        
        accountUuids.remove(accountUuid)
        accountUuids.add(newPosition.coerceIn(0, accountUuids.size), accountUuid)
        
        editor.putString("accountUuids", accountUuids.joinToString(","))
    }

    private fun saveIdentities(editor: StorageEditor, account: Account) {
        val accountUuid = account.uuid
        deleteIdentities(editor, accountUuid)
        
        var identityCount = 0
        for (identity in account.identities) {
            editor.putString("$accountUuid.identity.$identityCount.description", identity.description)
            editor.putString("$accountUuid.identity.$identityCount.name", identity.name)
            editor.putString("$accountUuid.identity.$identityCount.email", identity.email)
            editor.putBoolean("$accountUuid.identity.$identityCount.signatureUse", identity.signatureUse)
            editor.putString("$accountUuid.identity.$identityCount.signature", identity.signature)
            editor.putString("$accountUuid.identity.$identityCount.replyTo", identity.replyTo)
            identityCount++
        }
        editor.putInt("$accountUuid.identityCount", identityCount)
    }

    private fun deleteIdentities(editor: StorageEditor, accountUuid: String) {
        var identityIndex = 0
        var identityKey = "$accountUuid.identity.$identityIndex"
        while (editor.getString("$identityKey.description", null) != null) {
            editor.remove("$identityKey.description")
            editor.remove("$identityKey.name")
            editor.remove("$identityKey.email")
            editor.remove("$identityKey.signatureUse")
            editor.remove("$identityKey.signature")
            editor.remove("$identityKey.replyTo")
            identityIndex++
            identityKey = "$accountUuid.identity.$identityIndex"
        }
        editor.remove("$accountUuid.identityCount")
    }

    private fun loadIdentities(account: Account, storage: Storage) {
        val accountUuid = account.uuid
        val identities = ArrayList<Identity>()
        val identityCount = storage.getInt("$accountUuid.identityCount", 0)
        
        for (i in 0 until identityCount) {
            val identity = Identity().apply {
                description = storage.getString("$accountUuid.identity.$i.description", null)
                name = storage.getString("$accountUuid.identity.$i.name", null)
                email = storage.getString("$accountUuid.identity.$i.email", null)
                signatureUse = storage.getBoolean("$accountUuid.identity.$i.signatureUse", true)
                signature = storage.getString("$accountUuid.identity.$i.signature", null)
                replyTo = storage.getString("$accountUuid.identity.$i.replyTo", null)
            }
            identities.add(identity)
        }
        
        if (identities.isEmpty()) {
            val identity = Identity().apply {
                description = account.email
                email = account.email
            }
            identities.add(identity)
        }
        
        account.identities = identities
    }

    private fun saveServerSettings(editor: StorageEditor, account: Account) {
        val accountUuid = account.uuid
        
        // Save incoming server settings
        val incoming = account.incomingServerSettings
        editor.putString("$accountUuid.storeUri", ServerSettings.encode(incoming))
        editor.putString("$accountUuid.transportUri", ServerSettings.encode(account.outgoingServerSettings))
    }

    private fun loadServerSettings(account: Account, storage: Storage) {
        val accountUuid = account.uuid
        
        val storeUri = storage.getString("$accountUuid.storeUri", null)
        if (storeUri != null) {
            account.incomingServerSettings = ServerSettings.decode(storeUri)
        }
        
        val transportUri = storage.getString("$accountUuid.transportUri", null)
        if (transportUri != null) {
            account.outgoingServerSettings = ServerSettings.decode(transportUri)
        }
    }

    private fun removeAccountFromAccountList(editor: StorageEditor, storage: Storage, accountUuid: String) {
        val accountUuids = storage.getString("accountUuids", "")
            ?.split(",")
            ?.filter { it.isNotEmpty() && it != accountUuid }
            ?.joinToString(",") ?: ""
        
        editor.putString("accountUuids", accountUuids)
    }
}
