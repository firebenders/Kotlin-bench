        account.isSubscribedFoldersOnly = false
        account.maximumPolledMessageAge = 10
        account.maximumAutoDownloadMessageSize = 32768
        account.messageFormat = Account.MessageFormat.HTML
        account.isMessageFormatAuto = true
        account.isMessageReadReceipt = false
        account.quoteStyle = Account.QuoteStyle.PREFIX
        account.quotePrefix = Account.DEFAULT_QUOTE_PREFIX
        account.isDefaultQuotedTextShown = Account.DEFAULT_QUOTED_TEXT_SHOWN
        account.isReplyAfterQuote = Account.DEFAULT_REPLY_AFTER_QUOTE
        account.isStripSignature = Account.DEFAULT_STRIP_SIGNATURE
        account.isSyncRemoteDeletions = true
        account.openPgpProvider = ""
        account.openPgpKey = Account.NO_OPENPGP_KEY
        account.isAllowRemoteSearch = true
        account.isRemoteSearchFullText = false
        account.remoteSearchNumResults = Account.DEFAULT_REMOTE_SEARCH_NUM_RESULTS
        account.isUploadSentMessages = true
        account.isAlwaysBcc = false
        account.alwaysBccAddress = ""
        account.autocryptMutualMode = false
        account.isMarkMessageAsReadOnView = true
        account.isMarkMessageAsReadOnDelete = true
        account.isAlwaysShowCcBcc = false
        
        // Default folder modes to automatic
        account.sentFolderMode = FolderMode.AUTOMATIC
        account.draftsFolderMode = FolderMode.AUTOMATIC
        account.trashFolderMode = FolderMode.AUTOMATIC
        account.archiveFolderMode = FolderMode.AUTOMATIC
        account.spamFolderMode = FolderMode.AUTOMATIC
        
        account.searchableFolders = Account.Searchable.ALL
