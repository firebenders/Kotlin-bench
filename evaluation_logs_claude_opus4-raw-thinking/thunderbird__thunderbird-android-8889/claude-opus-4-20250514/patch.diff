import androidx.activity.ComponentActivity
import androidx.activity.compose.LocalActivity
import androidx.activity.compose.setContent
import androidx.compose.runtime.Composable
import androidx.compose.runtime.CompositionContext

// Re-export LocalActivity from androidx.activity.compose
@Deprecated(
    message = "Use LocalActivity from androidx.activity.compose directly",
    replaceWith = ReplaceWith("LocalActivity", "androidx.activity.compose.LocalActivity")
)
val LocalActivity = LocalActivity

fun ComponentActivity.setActivityContent(
    parent: CompositionContext? = null,
    content: @Composable () -> Unit,
) {
    setContent(parent, content)
}
