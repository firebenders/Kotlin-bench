package org.wordpress.android.ui.deeplinks

import org.wordpress.android.fluxc.model.SiteModel
import org.wordpress.android.ui.stats.StatsTimeframe

// This is a partial file showing the new NavigateAction types that need to be added
// to the existing DeepLinkNavigator file

sealed class DeepLinkNavigator {
    sealed class NavigateAction {
        // Existing actions...
        object OpenStats : NavigateAction()
        data class OpenStatsForSite(val site: SiteModel) : NavigateAction()
        data class OpenStatsForTimeframe(val statsTimeframe: StatsTimeframe) : NavigateAction()
        data class OpenStatsForSiteAndTimeframe(
            val site: SiteModel,
            val statsTimeframe: StatsTimeframe
        ) : NavigateAction()
        object OpenJetpackStaticPosterView : NavigateAction()
        
        // New actions for Traffic and Subscribers tabs
        object OpenStatsTrafficTab : NavigateAction()
        data class OpenStatsTrafficTabForSite(val site: SiteModel) : NavigateAction()
        data class OpenStatsTrafficTabWithGranularity(val granularity: StatsTimeframe) : NavigateAction()
        data class OpenStatsTrafficTabForSiteWithGranularity(
            val site: SiteModel,
            val granularity: StatsTimeframe
        ) : NavigateAction()
        
        object OpenStatsSubscribersTab : NavigateAction()
        data class OpenStatsSubscribersTabForSite(val site: SiteModel) : NavigateAction()
    }
}
