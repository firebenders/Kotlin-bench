        suggestion = "Use setTime() or setDateTime() to set the time fields"
    )
    val second = UnsignedFieldSpec(
        PropertyAccessor(TimeFieldContainer::second),
        minValue = 0,
        maxValue = 59,
        defaultValue = 0,
        userFriendlyName = "second",
        suggestion = "Use setTime() or setDateTime() to set the time fields"
    )
    val fractionOfSecond = GenericFieldSpec(
        PropertyAccessor(TimeFieldContainer::fractionOfSecond),
        defaultValue = DecimalFraction(0, 9),
