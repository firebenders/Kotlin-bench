internal interface FormatDirective<in Target> {
    fun buildFormatToken(scope: FormattingContext): FormatToken<Target>

    /**
     * A representation of how this directive would look in a Kotlin DSL.
     */
    val builderRepresentation: String
}

internal interface FormattingContext {
    fun withFieldParsed(field: AssignableField<*, *>): FormattingContext
}

internal abstract class FieldFormatDirective<in Target, Type>(
    protected val fieldSpec: FieldSpec<Target, Type>,
) : FormatDirective<Target> {

    protected fun getField(container: Target): Type =
        fieldSpec.accessor.getterNotNull(container, fieldSpec.userFriendlyName, fieldSpec.suggestion)
}

internal abstract class UnsignedIntFieldFormatDirective<in Target>(
    fieldSpec: UnsignedFieldSpec<Target>,
    private val minDigits: Int,
    private val maxDigits: Int? = null,
    private val spacePadding: Int = 0,
) : FieldFormatDirective<Target, Int>(fieldSpec) {

    init {
        require(minDigits >= 1) { "The minimum number of digits must be at least 1" }
        if (maxDigits != null) {
            require(maxDigits >= minDigits) { "The maximum number of digits must be at least the minimum" }
        }
        require(spacePadding >= 0) { "Space padding must be non-negative" }
    }

    override fun buildFormatToken(scope: FormattingContext): FormatToken<Target> {
        val fieldSpec = this.fieldSpec as UnsignedFieldSpec<Target>
        return UnsignedIntFieldToken(
            fieldSpec.accessor,
            maxDigits ?: fieldSpec.maxDigits,
            minDigits,
            spacePadding
        )
    }
}

internal abstract class SignedIntFieldFormatDirective<in Target>(
    fieldSpec: FieldSpec<Target, Int>,
    private val minDigits: Int,
    private val maxDigits: Int? = null,
    private val spacePadding: Int = 0,
    private val outputPlusOnExceededWidth: Int? = null,
) : FieldFormatDirective<Target, Int>(fieldSpec) {

    init {
        require(minDigits >= 1) { "The minimum number of digits must be at least 1" }
        if (maxDigits != null) {
            require(maxDigits >= minDigits) { "The maximum number of digits must be at least the minimum" }
        }
        require(spacePadding >= 0) { "Space padding must be non-negative" }
        if (outputPlusOnExceededWidth != null) {
            require(outputPlusOnExceededWidth >= 1) { "The width to start outputting the plus sign at must be at least 1" }
        }
    }

    override fun buildFormatToken(scope: FormattingContext): FormatToken<Target> = SignedIntFieldToken(
        fieldSpec.accessor,
        maxDigits,
        minDigits,
        spacePadding,
        outputPlusOnExceededWidth
    )
}

internal class ReducedIntFieldDirective<in Target>(
    fieldSpec: FieldSpec<Target, Int>,
    private val digits: Int,
    private val base: Int,
) : FieldFormatDirective<Target, Int>(fieldSpec) {

    init {
        require(digits >= 1) { "The number of digits must be at least 1" }
    }

    override fun buildFormatToken(scope: FormattingContext): FormatToken<Target> = ReducedIntFieldToken(
        fieldSpec.accessor,
        digits,
        base
    )
}

internal abstract class StringFieldFormatDirective<in Target>(
    fieldSpec: FieldSpec<Target, String>,
    private val knownStrings: Set<String>,
) : FieldFormatDirective<Target, String>(fieldSpec) {

    init {
        require(knownStrings.isNotEmpty()) { "The set of known strings must not be empty" }
    }

    override fun buildFormatToken(scope: FormattingContext): FormatToken<Target> = StringFieldToken(
        fieldSpec.accessor,
        knownStrings
    )
}

internal abstract class NamedUnsignedIntFieldFormatDirective<in Target>(
    fieldSpec: UnsignedFieldSpec<Target>,
    private val names: List<String>,
    humanName: String,
) : FieldFormatDirective<Target, Int>(fieldSpec) {

    init {
        require(names.isNotEmpty()) { "The list of names must not be empty" }
        names.indices.forEach { ix ->
            for (ix2 in 0 until ix) {
                require(names[ix] != names[ix2]) {
                    "Names for the $humanName must be unique, but '${names[ix]}' was repeated"
                }
            }
        }
    }

    override fun buildFormatToken(scope: FormattingContext): FormatToken<Target> = NamedUnsignedIntFieldToken(
        fieldSpec.accessor,
        names
    )
}

internal abstract class NamedEnumIntFieldFormatDirective<in Target, Enum>(
    fieldSpec: FieldSpec<Target, Enum>,
    private val nameMapping: Map<Enum, String>,
    humanName: String,
) : FieldFormatDirective<Target, Enum>(fieldSpec) {

    init {
        require(nameMapping.isNotEmpty()) { "The name mapping must not be empty" }
        nameMapping.values.toSet().let { names ->
            require(names.size == nameMapping.size) {
                "Names for the $humanName must be unique, but duplicates were found"
            }
        }
    }

    override fun buildFormatToken(scope: FormattingContext): FormatToken<Target> = NamedEnumFieldToken(
        fieldSpec.accessor,
        nameMapping
    )
}

internal abstract class DecimalFractionFieldFormatDirective<in Target>(
    fieldSpec: FieldSpec<Target, DecimalFraction>,
    private val minDigits: Int,
    private val maxDigits: Int,
    private val zerosToAdd: List<Int>,
) : FieldFormatDirective<Target, DecimalFraction>(fieldSpec) {

    init {
        require(minDigits >= 0) { "The minimum number of digits must be non-negative" }
        require(maxDigits >= minDigits) { "The maximum number of digits must be at least the minimum" }
        require(maxDigits <= 9) { "The maximum number of digits must be at most 9" }
    }

    override fun buildFormatToken(scope: FormattingContext): FormatToken<Target> = DecimalFractionFieldToken(
        fieldSpec.accessor,
        minDigits,
        maxDigits,
        zerosToAdd
    )
}
