package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.ElementType.BLOCK
import com.pinterest.ktlint.rule.engine.core.api.ElementType.ELSE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.ELSE_KEYWORD
import com.pinterest.ktlint.rule.engine.core.api.ElementType.IF
import com.pinterest.ktlint.rule.engine.core.api.ElementType.LBRACE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.RBRACE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.THEN
import com.pinterest.ktlint.rule.engine.core.api.ElementType.WHITE_SPACE
import com.pinterest.ktlint.rule.engine.core.api.Rule
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.isWhiteSpace
import com.pinterest.ktlint.rule.engine.core.api.nextSibling
import com.pinterest.ktlint.rule.engine.core.api.upsertWhitespaceAfterMe
import com.pinterest.ktlint.rule.engine.core.api.upsertWhitespaceBeforeMe
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.com.intellij.psi.impl.source.tree.LeafPsiElement

/**
 * Ensures that multiline if-else statements are formatted consistently.
 */
public class MultiLineIfElseRule : StandardRule("multiline-if-else") {

    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        if (node.elementType == IF) {
            visitIfStatement(node, autoCorrect, emit)
        }
    }

    private fun visitIfStatement(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val thenNode = node.findChildByType(THEN)
        val elseNode = node.findChildByType(ELSE)

        if (thenNode != null && elseNode != null) {
            checkMultiLineIf(thenNode, elseNode, autoCorrect, emit)
        }
    }

    private fun checkMultiLineIf(
        thenNode: ASTNode,
        elseNode: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        // Check if THEN branch is multiline
        val thenFirstChild = thenNode.firstChildNode
        if (thenFirstChild?.elementType == BLOCK) {
            val thenBlock = thenFirstChild
            // Check if this is a multiline block
            if (containsNewline(thenBlock)) {
                checkElsePlacement(thenBlock, elseNode, autoCorrect, emit)
            }
        }
    }

    private fun containsNewline(node: ASTNode): Boolean {
        var current: ASTNode? = node.firstChildNode
        while (current != null) {
            if (current.elementType == WHITE_SPACE && current.text.contains('\n')) {
                return true
            }
            if (containsNewline(current)) {
                return true
            }
            current = current.treeNext
        }
        return false
    }

    private fun checkElsePlacement(
        thenBlock: ASTNode,
        elseNode: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val rbrace = thenBlock.findChildByType(RBRACE)
        if (rbrace != null) {
            val nextSibling = rbrace.nextSibling { !it.isWhiteSpace() }
            if (nextSibling?.elementType == ELSE_KEYWORD) {
                // Check if else is on the same line as closing brace
                val whitespace = rbrace.nextSibling { it.isWhiteSpace() }
                if (whitespace != null && whitespace.text.contains('\n')) {
                    emit(
                        nextSibling.startOffset,
                        "Else should be on the same line as the closing brace of the if",
                        true,
                    )
                    if (autoCorrect) {
                        whitespace.upsertWhitespaceAfterMe(" ")
                    }
                }
            }
        }
    }
}

public val MULTILINE_IF_ELSE_RULE_ID: RuleId = MultiLineIfElseRule().ruleId
