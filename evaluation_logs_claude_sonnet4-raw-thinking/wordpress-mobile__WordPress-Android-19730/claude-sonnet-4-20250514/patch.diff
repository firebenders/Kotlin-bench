package org.wordpress.android.ui.bloggingprompts

import org.wordpress.android.models.ReaderTag
import org.wordpress.android.models.ReaderTagType
import org.wordpress.android.ui.reader.utils.ReaderUtilsWrapper
import javax.inject.Inject

class BloggingPromptsPostTagProvider @Inject constructor(
    private val readerUtilsWrapper: ReaderUtilsWrapper,
) {
    fun promptIdTag(
        tagUrl: String
    ): String {
        if (tagUrl.isBlank()) {
            return BLOGGING_PROMPT_TAG
        }
        
        val extractedTag = readerUtilsWrapper.getTagFromTagUrl(tagUrl).trim()
        
        return when {
            extractedTag.isBlank() -> BLOGGING_PROMPT_TAG
            isValidPromptTag(extractedTag) -> extractedTag
            else -> BLOGGING_PROMPT_TAG
        }
    }

    fun promptIdSearchReaderTag(
        tagUrl: String
    ): ReaderTag {
        val tag = promptIdTag(tagUrl)
        
        // Use DEFAULT type for daily prompt tags since they are typically not followed
        // This fixes pagination issues that occur when treating non-followed tags as followed
        val tagType = when {
            tag.startsWith("$BLOGGING_PROMPT_TAG-") -> ReaderTagType.DEFAULT
            tag.startsWith("$BLOGANUARY_TAG-") -> ReaderTagType.DEFAULT
            else -> ReaderTagType.DEFAULT // Changed from FOLLOWED to DEFAULT to match issue description
        }
        
        return readerUtilsWrapper.getTagFromTagName(tag, tagType)
    }
    
    private fun isValidPromptTag(tag: String): Boolean {
        return tag == BLOGGING_PROMPT_TAG || 
               tag.startsWith("$BLOGGING_PROMPT_TAG-") ||
               tag == BLOGANUARY_TAG ||
               tag.startsWith("$BLOGANUARY_TAG-")
    }

    companion object {
        const val BLOGGING_PROMPT_TAG = "dailyprompt"
        const val BLOGANUARY_TAG = "bloganuary"
    }
}
