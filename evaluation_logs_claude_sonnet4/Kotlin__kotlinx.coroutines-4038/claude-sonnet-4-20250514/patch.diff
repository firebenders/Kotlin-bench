package kotlinx.coroutines.flow

import kotlinx.coroutines.*
import kotlinx.coroutines.flow.internal.*
import kotlin.jvm.*

/**
 * Catches exceptions in the flow completion and calls a specified [action] with the caught exception.
 * This operator is *transparent* to exceptions that occur in downstream flow and does not catch exceptions
 * that are thrown to cancel the flow.
 *
 * Conceptually, the following code:
 * ```
 * flow.catch { e -> emit(fallbackValue) }.collect { value ->
 *     // Collector code
 * }
 * ```
 *
 * Is equivalent to:
 * ```
 * try {
 *     flow.collect { value ->
 *         // Collector code
 *     }
 * } catch (e: Exception) {
 *     emit(fallbackValue)
 * }
 * ```
 *
 * The [action] is called with the exception as argument when an exception occurs during collection.
 * An exception in the [action] itself proceeds downstream where it can be caught by further `catch` operators.
 *
 * The [action] can also emit multiple values. Here is an example that retries an operation when exception occurs:
 *
 * ```
 * flow {
 *     // Some operation that may fail
 * }.catch { e ->
 *     // Log the exception
 *     emit(retryOperation())
 * }
 * ```
 *
 * The [action] can also re-throw the exception or throw a different exception. In this case,
 * the exception is propagated downstream, outside of the flow.
 *
 * The [catch] operator only catches exceptions coming from the upstream flow and does not affect exceptions
 * thrown by the downstream flow operations.
 */
public fun <T> Flow<T>.catch(action: suspend FlowCollector<T>.(cause: Throwable) -> Unit): Flow<T> =
    flow {
        val exception = catchImpl(this)
        if (exception != null) action(exception)
    }

/**
 * Invokes the given [action] when the given flow completes or is cancelled, passing the cancellation
 * cause as argument of the [action].
 * Conceptually, `onCompletion` is similar to wrapping the flow collection into a `try/finally` block.
 * The [action] is called when the flow completes normally (with `null` argument),
 * or exceptionally (with the corresponding exception as an argument).
 *
 * In case of [cancellation][CancellationException] (normal or exceptional) the downstream flow is also cancelled.
 * In case of any other exception, the exception is propagated to the downstream flow.
 *
 * The [action] is called before the corresponding exception is propagated downstream.
 * An exception thrown from the [action] will be propagated downstream, suppressing the original exception
 * that triggered the [action].
 *
 * The receiver of the [action] is [FlowCollector] and thus [action] can emit extra elements.
 * For example, `onCompletion` can be used to emit a single value when the flow completes:
 *
 * ```
 * flowOf("a", "b", "c")
 *     .onCompletion { emit("Done") }
 *     .collect { println(it) } // prints a, b, c, Done
 * ```
 */
public fun <T> Flow<T>.onCompletion(
    action: suspend FlowCollector<T>.(cause: Throwable?) -> Unit
): Flow<T> = flow {
    try {
        collect { emit(it) }
        action(null)
    } catch (e: Throwable) {
        /*
         * Use throwing collector to prevent any emissions from the
         * completion sequence when downstream has failed, otherwise it may
         * lead to a non-sequential behaviour impossible with `finally`
         */
        ThrowingCollector(e).action(e.unwrapAbortFlowException())
        throw e
    }
}

/**
 * Unwraps AbortFlowException to null, treating it as normal completion.
 * This is needed because AbortFlowException is an internal implementation detail
 * for flow truncation operators like take() and should not be exposed to user code.
 */
private fun Throwable.unwrapAbortFlowException(): Throwable? {
    return if (this is AbortFlowException) null else this
}

/**
 * Invokes the given [action] when the given flow completes or is cancelled, passing the cancellation
 * cause as argument of the [action].
 * This version does not allow emitting extra elements and is more efficient.
 *
 * The [action] is called when the flow completes normally (with `null` argument),
 * or exceptionally (with the corresponding exception as an argument).
 *
 * In case of [cancellation][CancellationException] (normal or exceptional) the downstream flow is also cancelled.
 * In case of any other exception, the exception is propagated to the downstream flow.
 *
 * The [action] is called before the corresponding exception is propagated downstream.
 * An exception thrown from the [action] will be propagated downstream, suppressing the original exception
 * that triggered the [action].
 */
public fun <T> Flow<T>.onCompletion(
    action: suspend (cause: Throwable?) -> Unit
): Flow<T> = flow {
    try {
        collect { emit(it) }
        action(null)
    } catch (e: Throwable) {
        action(e.unwrapAbortFlowException())
        throw e
    }
}

internal suspend fun <T> Flow<T>.catchImpl(collector: FlowCollector<T>): Throwable? {
    var fromDownstream: Throwable? = null
    try {
        collect(collector)
    } catch (e: Throwable) {
        fromDownstream = e
    }
    return fromDownstream
}

private class ThrowingCollector<T>(private val e: Throwable) : FlowCollector<T> {
    override suspend fun emit(value: T) {
        throw e
    }
}
