 * 
 * // Region-based - UTC+1 in winter, UTC+2 in summer
 * val berlinZone = TimeZone.of("Europe/Berlin")
 * 
 * val winterInstant = Instant.parse("2023-01-15T12:00:00Z")
 * val summerInstant = Instant.parse("2023-07-15T12:00:00Z")
 * 
 * // Fixed zone: always adds 1 hour
 * println(winterInstant.toLocalDateTime(fixedZone)) // 2023-01-15T13:00:00
 * println(summerInstant.toLocalDateTime(fixedZone)) // 2023-07-15T13:00:00
 * 
 * // Berlin zone: adds 1 hour in winter, 2 hours in summer
 * println(winterInstant.toLocalDateTime(berlinZone)) // 2023-01-15T13:00:00
 * println(summerInstant.toLocalDateTime(berlinZone)) // 2023-07-15T14:00:00
 * ```
 *
