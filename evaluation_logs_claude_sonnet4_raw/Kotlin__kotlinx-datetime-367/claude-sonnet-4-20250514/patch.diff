 * val apiTimestamp = "2023-07-15T14:30:00+05:30"
 * val instant = Instant.parse(apiTimestamp)
 * val offset = UtcOffset(hours = 5, minutes = 30)
 * val localTime = instant.toLocalDateTime(FixedOffsetTimeZone(offset))
 * 
 * // Database storage with known offset
 * data class LogEntry(
 *     val message: String,
 *     val timestamp: Instant,
 *     val recordedOffset: UtcOffset
 * ) {
 *     fun getLocalTime() = timestamp.toLocalDateTime(FixedOffsetTimeZone(recordedOffset))
 * }
 * ```
