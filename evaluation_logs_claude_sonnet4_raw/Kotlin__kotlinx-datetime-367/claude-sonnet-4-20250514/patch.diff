package kotlinx.datetime

import kotlin.time.*

/**
 * A source of [Instant] values representing moments in time.
 *
 * A [Clock] provides access to the current instant according to some time source. The primary purpose
 * of this abstraction is to allow alternate clocks to be plugged in as and when required. Applications
 * use an object to obtain the current time rather than a static method. This can simplify testing.
 *
 * ## How to acquire a Clock
 *
 * The most common way to obtain a [Clock] is to use the system clock:
 * ```kotlin
 * val clock = Clock.System
 * val now = clock.now()
 * ```
 *
 * For testing purposes, you can create custom implementations or use mock clocks that return
 * predetermined values.
 *
 * ## Usage contexts
 *
 * Use [Clock] when you need:
 * - The current time in a testable way (dependency injection)
 * - To abstract time sources for different environments
 * - Consistent time readings across an application
 *
 * ## System-specific behavior
 *
 * [Clock.System] uses the platform's system clock:
 * - **JVM**: Uses `System.currentTimeMillis()` and `System.nanoTime()`
 * - **Native**: Uses platform-specific system time functions
 * - **JS**: Uses `Date.now()` and high-resolution timing when available
 *
 * The precision and accuracy depend on the underlying platform capabilities.
 *
 * ## Basic usage example
 *
 * ```kotlin
 * val clock = Clock.System
 * val timestamp = clock.now()
 * println("Current time: $timestamp")
 *
 * // For testing, inject the clock
 * class EventLogger(private val clock: Clock) {
 *     fun logEvent(message: String) {
 *         val timestamp = clock.now()
 *         println("[$timestamp] $message")
 *     }
 * }
 * ```
 *
 * @see Instant for representing specific moments in time
 * @see TimeZone for converting between instants and local date-time
 */
public interface Clock {
    /**
     * Returns the [Instant] corresponding to the current time, according to this clock.
     *
     * The returned instant represents the current moment on the UTC-SLS time scale.
     * Successive calls to this method may return the same instant if the clock's
     * resolution is coarser than the call frequency.
     *
     * @return the current instant according to this clock
     */
    public fun now(): Instant

    /**
     * The [Clock] instance that queries the operating system as its source of knowledge of time.
     *
     * This clock provides access to the current instant using the system's best available
     * clock. The precision and behavior are platform-dependent:
     *
     * - **JVM**: Typically provides millisecond precision, with nanosecond precision available
     *   on some systems
     * - **Native**: Platform-dependent precision, usually microsecond or nanosecond
     * - **JS**: Millisecond precision, with higher precision available via Performance API
     *
     * ## Usage example
     *
     * ```kotlin
     * val now = Clock.System.now()
     * val todayInBerlin = Clock.System.todayIn(TimeZone.of("Europe/Berlin"))
     * ```
     */
    public object System : Clock {
        override fun now(): Instant = @Suppress("DEPRECATION_ERROR") Instant.now()
    }

    public companion object {

    }
}

/**
 * Returns the current date at the given [time zone][timeZone], according to [this Clock][this].
 *
 * This is equivalent to calling `clock.now().toLocalDateTime(timeZone).date`, but may be
 * more efficient on some platforms.
 *
 * ## Usage example
 *
 * ```kotlin
 * val berlinTimeZone = TimeZone.of("Europe/Berlin")
 * val todayInBerlin = Clock.System.todayIn(berlinTimeZone)
 * println("Today in Berlin: $todayInBerlin")
 * ```
 *
 * @param timeZone the time zone in which to determine the current date
 * @return the current date in the specified time zone
 * @see Clock.now
 * @see Instant.toLocalDateTime
 */
public fun Clock.todayIn(timeZone: TimeZone): LocalDate =
    now().toLocalDateTime(timeZone).date

/**
 * Returns a [TimeSource] that uses this [Clock] to mark a time instant and to find the amount of time elapsed since that mark.
 *
 * This allows using a [Clock] with Kotlin's time measurement APIs from `kotlin.time`.
 * The returned [TimeSource] will use this clock's [now] method to obtain time marks.
 *
 * ## Usage example
 *
 * ```kotlin
 * val timeSource = Clock.System.asTimeSource()
 * val mark = timeSource.markNow()
 * // ... do some work ...
 * val elapsed = mark.elapsedNow()
 * println("Operation took: $elapsed")
 * ```
 *
 * @return a [TimeSource] backed by this clock
 */
@ExperimentalTime
public fun Clock.asTimeSource(): TimeSource.WithComparableMarks = object : TimeSource.WithComparableMarks {
    override fun markNow(): ComparableTimeMark = InstantTimeMark(now(), this@asTimeSource)
}

@ExperimentalTime
private class InstantTimeMark(private val instant: Instant, private val clock: Clock) : ComparableTimeMark {
    override fun elapsedNow(): Duration = saturatingDiff(clock.now(), instant)

    override fun plus(duration: Duration): ComparableTimeMark = InstantTimeMark(instant.saturatingAdd(duration), clock)
    override fun minus(duration: Duration): ComparableTimeMark = InstantTimeMark(instant.saturatingAdd(-duration), clock)

    override fun minus(other: ComparableTimeMark): Duration {
        if (other !is InstantTimeMark || other.clock != this.clock) {
            throw IllegalArgumentException("Subtracting or comparing time marks from different time sources is not possible: $this and $other")
        }
        return saturatingDiff(this.instant, other.instant)
    }

    override fun equals(other: Any?): Boolean {
        return other is InstantTimeMark && this.clock == other.clock && this.instant == other.instant
    }

    override fun hashCode(): Int = instant.hashCode()

    override fun toString(): String = "InstantTimeMark($instant, $clock)"

    private fun Instant.isSaturated() = this == Instant.MAX || this == Instant.MIN
    private fun Instant.saturatingAdd(duration: Duration): Instant {
        if (isSaturated()) {
            if (duration.isInfinite() && duration.isPositive() != this.isDistantFuture) {
                throw IllegalArgumentException("Summing infinities of different signs")
            }
            return this
        }
        return this + duration
    }
    private fun saturatingDiff(instant1: Instant, instant2: Instant): Duration = when {
        instant1 == instant2 ->
            Duration.ZERO
        instant1.isSaturated() || instant2.isSaturated() ->
            (instant1 - instant2) * Double.POSITIVE_INFINITY
        else ->
            instant1 - instant2
    }
}

@Deprecated("Use Clock.todayIn instead", ReplaceWith("this.todayIn(timeZone)"), DeprecationLevel.WARNING)
public fun Clock.todayAt(timeZone: TimeZone): LocalDate = todayIn(timeZone)
