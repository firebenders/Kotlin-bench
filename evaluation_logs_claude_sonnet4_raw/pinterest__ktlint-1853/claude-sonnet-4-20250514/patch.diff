package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.ElementType.WHITE_SPACE
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.nextLeaf
import com.pinterest.ktlint.rule.engine.core.api.prevLeaf
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.com.intellij.psi.PsiComment
import org.jetbrains.kotlin.com.intellij.psi.PsiWhiteSpace
import org.jetbrains.kotlin.com.intellij.psi.impl.source.tree.LeafPsiElement
import org.jetbrains.kotlin.lexer.KtTokens

public class NoConsecutiveBlankLinesRule : StandardRule("no-consecutive-blank-lines") {
    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        if (node.elementType == WHITE_SPACE && node.text.contains("\n")) {
            val split = node.text.split("\n")
            if (split.size > 3) {
                // Check if this whitespace is between two KDoc comments
                val prevLeaf = node.prevLeaf()
                val nextLeaf = node.nextLeaf()
                
                // If we're between two KDoc comments, don't treat this as consecutive blank lines
                if (isKDocComment(prevLeaf) && isKDocComment(nextLeaf)) {
                    return
                }
                
                // Also check if we're at the end of a KDoc and beginning of another KDoc
                // by looking at the structure more carefully
                if (isEndOfKDocComment(prevLeaf) && isStartOfKDocComment(nextLeaf)) {
                    return
                }
                
                emit(node.startOffset + split[0].length + 1, "Needless blank line(s)", true)
                if (autoCorrect) {
                    val text =
                        split
                            .first() + "\n\n" + split.last()
                    (node as LeafPsiElement).rawReplaceWithText(text)
                }
            }
        }
    }
    
    private fun isKDocComment(node: ASTNode?): Boolean {
        return node?.elementType == KtTokens.DOC_COMMENT
    }
    
    private fun isEndOfKDocComment(node: ASTNode?): Boolean {
        return node?.elementType == KtTokens.DOC_COMMENT && node.text.endsWith("*/")
    }
    
    private fun isStartOfKDocComment(node: ASTNode?): Boolean {
        return node?.elementType == KtTokens.DOC_COMMENT && node.text.startsWith("/**")
    }
}

public val NO_CONSECUTIVE_BLANK_LINES_RULE_ID: RuleId = NoConsecutiveBlankLinesRule().ruleId
