package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.ElementType.BLOCK_COMMENT
import com.pinterest.ktlint.rule.engine.core.api.ElementType.EOL_COMMENT
import com.pinterest.ktlint.rule.engine.core.api.Rule
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.isWhiteSpaceWithNewline
import com.pinterest.ktlint.rule.engine.core.api.nextLeaf
import com.pinterest.ktlint.rule.engine.core.api.prevLeaf
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.com.intellij.psi.impl.source.tree.LeafPsiElement

/**
 * Detects usage of deprecated ktlint-enable/ktlint-disable directives and suggests migration to @Suppress annotations.
 * This rule cannot be suppressed to ensure migration guidance is always provided.
 */
public class NoKtlintDirectiveRule :
    StandardRule(
        id = "no-ktlint-directive",
        usesEditorConfigProperties = emptySet(),
    ),
    Rule.Experimental,
    Rule.OfficialCodeStyle {

    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        when (node.elementType) {
            EOL_COMMENT -> checkEolComment(node, autoCorrect, emit)
            BLOCK_COMMENT -> checkBlockComment(node, autoCorrect, emit)
        }
    }

    private fun checkEolComment(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val commentText = node.text.removePrefix("//").trim()
        val parts = commentText.split(" ")
        
        if (parts.isNotEmpty() && (parts[0] == "ktlint-disable" || parts[0] == "ktlint-enable")) {
            val directive = parts[0]
            val rules = parts.drop(1).filter { it.isNotBlank() }
            
            val suppressAnnotation = if (rules.isEmpty()) {
                "@Suppress(\"ktlint\")"
            } else {
                val ruleList = rules.joinToString("\", \"") { rule ->
                    if (rule.contains(":")) rule else "ktlint:standard:$rule"
                }
                "@Suppress(\"$ruleList\")"
            }
            
            emit(
                node.startOffset,
                "Deprecated ktlint directive '$directive' should be replaced with $suppressAnnotation",
                true
            )
            
            if (autoCorrect) {
                replaceEolDirectiveWithSuppressAnnotation(node, suppressAnnotation)
            }
        }
    }

    private fun checkBlockComment(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val commentText = node.text.removePrefix("/*").removeSuffix("*/").trim()
        val parts = commentText.split(" ")
        
        if (parts.isNotEmpty() && (parts[0] == "ktlint-disable" || parts[0] == "ktlint-enable")) {
            val directive = parts[0]
            val rules = parts.drop(1).filter { it.isNotBlank() }
            
            val suppressAnnotation = if (rules.isEmpty()) {
                "@Suppress(\"ktlint\")"
            } else {
                val ruleList = rules.joinToString("\", \"") { rule ->
                    if (rule.contains(":")) rule else "ktlint:standard:$rule"
                }
                "@Suppress(\"$ruleList\")"
            }
            
            emit(
                node.startOffset,
                "Deprecated ktlint directive '$directive' should be replaced with $suppressAnnotation",
                true
            )
            
            if (autoCorrect) {
                replaceBlockDirectiveWithSuppressAnnotation(node, suppressAnnotation)
            }
        }
    }

    private fun replaceEolDirectiveWithSuppressAnnotation(
        node: ASTNode,
        suppressAnnotation: String,
    ) {
        // Find the start of the line to place the annotation
        val lineStart = findLineStart(node)
        val indentation = extractIndentation(lineStart, node)
        
        // Create the annotation with proper indentation
        val annotationText = "$indentation$suppressAnnotation\n"
        
        // Insert the annotation at the beginning of the line
        val annotationNode = LeafPsiElement(EOL_COMMENT, "// $annotationText")
        lineStart.treeParent.addChild(annotationNode, lineStart)
        
        // Remove the original directive comment
        node.treeParent.removeChild(node)
    }

    private fun replaceBlockDirectiveWithSuppressAnnotation(
        node: ASTNode,
        suppressAnnotation: String,
    ) {
        // For block comments, we'll replace them with EOL comments containing the annotation suggestion
        val replacement = "// TODO: Replace with $suppressAnnotation"
        val newComment = LeafPsiElement(EOL_COMMENT, replacement)
        
        node.treeParent.addChild(newComment, node)
        node.treeParent.removeChild(node)
    }

    private fun findLineStart(node: ASTNode): ASTNode {
        var current = node
        while (true) {
            val prev = current.prevLeaf()
            if (prev == null || prev.isWhiteSpaceWithNewline()) {
                break
            }
            current = prev
        }
        return current
    }

    private fun extractIndentation(lineStart: ASTNode, target: ASTNode): String {
        val sb = StringBuilder()
        var current = lineStart
        while (current != target && current.nextLeaf() != null) {
            if (current.text.all { it == ' ' || it == '\t' }) {
                sb.append(current.text)
            } else {
                break
            }
            current = current.nextLeaf()!!
        }
        return sb.toString()
    }
}

public val NO_KTLINT_DIRECTIVE_RULE_ID: RuleId = NoKtlintDirectiveRule().ruleId
