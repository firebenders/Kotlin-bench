        editor.putString("$accountUuid.sentFolderSelection", account.sentFolderSelection.name)
        editor.putString("$accountUuid.trashFolderSelection", account.trashFolderSelection.name)
        editor.putString("$accountUuid.archiveFolderSelection", account.archiveFolderSelection.name)
        editor.putString("$accountUuid.spamFolderSelection", account.spamFolderSelection.name)

        // Save folder assignments
        saveFolderAssignments(editor, account)
    }

    private fun saveFolderAssignments(editor: StorageEditor, account: Account) {
        val accountUuid = account.uuid
        
        // Save folder assignments
        account.folderAssignments?.forEach { (folderName, assignment) ->
            editor.putString("$accountUuid.folderAssignment.$folderName", assignment)
        }
    }

    fun move(editor: StorageEditor, account: Account, storage: Storage, newPosition: Int) {
        val accountUuids = storage.getString("accountUuids", "")?.split(",")?.toMutableList() ?: mutableListOf()
        
        accountUuids.remove(account.uuid)
        accountUuids.add(newPosition, account.uuid)
        
        editor.putString("accountUuids", accountUuids.joinToString(","))
    }

    fun delete(editor: StorageEditor, storage: Storage, account: Account) {
        val accountUuid = account.uuid
        
        // Remove account from account list
        val accountUuids = storage.getString("accountUuids", "")?.split(",")?.toMutableList() ?: mutableListOf()
        accountUuids.remove(accountUuid)
        editor.putString("accountUuids", accountUuids.joinToString(","))
        
        // Remove all account-specific preferences
        val allKeys = storage.getAll().keys
        val accountKeys = allKeys.filter { it.startsWith("$accountUuid.") }
        
        for (key in accountKeys) {
            editor.remove(key)
        }
    }
