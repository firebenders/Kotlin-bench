@Suppress("TooManyFunctions", "LargeClass")
class Account(val uuid: String, private val isSensitiveDebugLoggingEnabled: () -> Boolean) {
    var storeUri: String? = null
    var transportUri: String? = null
    var description: String? = null
    var alwaysBcc: String? = null
    var automaticCheckIntervalMinutes = -1
    var idleRefreshMinutes = 24
    var isPushPollOnConnect = true
    var displayCount = DEFAULT_DISPLAY_COUNT
    var defaultQuotedTextShown = DEFAULT_QUOTED_TEXT_SHOWN
    var showPicturesEnum = ShowPictures.NEVER
    var isNotifyNewMail = true
    var folderNotifyNewMailMode = FolderMode.ALL
    var isNotifySelfNewMail = true
    var isNotifyContactsMailOnly = false
    var inboxFolderName: String? = null
    var draftsFolderName: String? = null
    var sentFolderName: String? = null
    var trashFolderName: String? = null
    var archiveFolderName: String? = null
    var spamFolderName: String? = null
    var outboxFolderName: String? = null
    var autoExpandFolderName: String? = null
    var accountNumber = UNASSIGNED_ACCOUNT_NUMBER
    var chipColor = 0
    var sortTypeEnum = SortType.SORT_DATE
    var isSortAscending = false
    var folderDisplayMode = FolderMode.NOT_SECOND_CLASS
    var folderSyncMode = FolderMode.FIRST_CLASS
    var folderPushMode = FolderMode.FIRST_CLASS
    var folderTargetMode = FolderMode.NOT_SECOND_CLASS
    var searchableFolders = Searchable.ALL
    var isSignatureBeforeQuotedText = false
    var expungePolicy = Expunge.EXPUNGE_IMMEDIATELY
    var syncRemoteDeletions = true
    var maxPushFolders = 10
    var isGoToUnreadMessageSearch = false
    var isSubscribedFoldersOnly = false
    var maximumPolledMessageAge = -1
    var maximumAutoDownloadMessageSize = 32768
    var messageFormat = MessageFormat.TEXT
    var isMessageFormatAuto = false
    var isMessageReadReceipt = false
    var quoteStyle = QuoteStyle.PREFIX
    var quotePrefix = ">"
    var isDefaultQuotedTextShown = false
    var isReplyAfterQuote = false
    var isStripSignature = true
    var useCompression = true
    var localStorageProviderId: String? = null

    // Special folder selections
    var inboxFolderSelection = SpecialFolderSelection.AUTOMATIC
    var draftsFolderSelection = SpecialFolderSelection.AUTOMATIC
    var sentFolderSelection = SpecialFolderSelection.AUTOMATIC
    var trashFolderSelection = SpecialFolderSelection.AUTOMATIC
    var archiveFolderSelection = SpecialFolderSelection.AUTOMATIC
    var spamFolderSelection = SpecialFolderSelection.AUTOMATIC

    // Folder assignments map - stores folder name to assignment type mapping
    var folderAssignments: MutableMap<String, String>? = null

    // Change tracking
    var isChangedVisibleLimits = false
        private set

    fun resetChangeMarkers() {
        isChangedVisibleLimits = false
    }

    val isFinishedSetup: Boolean
        get() = storeUri != null

    fun setDisplayCount(displayCount: Int) {
        if (this.displayCount != displayCount) {
            this.displayCount = displayCount
            isChangedVisibleLimits = true
        }
    }

    enum class FolderMode {
        NONE, ALL, FIRST_CLASS, FIRST_AND_SECOND_CLASS, NOT_SECOND_CLASS
    }

    enum class SortType {
        SORT_DATE, SORT_ARRIVAL, SORT_SUBJECT, SORT_SENDER, SORT_UNREAD, SORT_FLAGGED, SORT_ATTACHMENT
    }

    enum class Expunge {
        EXPUNGE_IMMEDIATELY, EXPUNGE_MANUALLY, EXPUNGE_ON_POLL
    }

    enum class Searchable {
        ALL, DISPLAYABLE, NONE
    }

    enum class QuoteStyle {
        PREFIX, HEADER
    }

    enum class MessageFormat {
        TEXT, HTML, AUTO
    }

    enum class ShowPictures {
        NEVER, ALWAYS, ONLY_FROM_CONTACTS
    }

    enum class SpecialFolderSelection {
        AUTOMATIC, MANUAL
    }

    enum class DeletePolicy {
        NEVER, SEVEN_DAYS, ON_DELETE, MARK_AS_READ
    }

    companion object {
        const val UNASSIGNED_ACCOUNT_NUMBER = -1
        const val DEFAULT_DISPLAY_COUNT = 25
        const val DEFAULT_QUOTED_TEXT_SHOWN = true

        @JvmStatic
        fun generateColorChip(): Int {
            // Generate a random color for the account chip
            val random = Random.Default
            val hue = random.nextFloat() * 360f
            val saturation = 0.7f + random.nextFloat() * 0.3f
            val lightness = 0.4f + random.nextFloat() * 0.2f
            
            return android.graphics.Color.HSVToColor(floatArrayOf(hue, saturation, lightness))
        }
    }
}
