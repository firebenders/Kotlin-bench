    private fun loadFolderAssignments(account: Account, storage: Storage) {
        val accountUuid = account.uuid
        
        // Load folder assignments for each special folder type
        val folderAssignments = mutableMapOf<String, String>()
        
        // Check for explicit folder assignments stored during export
        val assignmentKeys = storage.getAll().keys.filter { 
            it.startsWith("$accountUuid.folderAssignment.") 
        }
        
        for (key in assignmentKeys) {
            val folderName = key.removePrefix("$accountUuid.folderAssignment.")
            val assignment = storage.getString(key, null)
            if (assignment != null) {
                folderAssignments[folderName] = assignment
            }
        }
        
        // Apply folder assignments to account
        account.folderAssignments = folderAssignments
    }

    fun loadDefaults(account: Account) {
        account.displayCount = K9.DEFAULT_VISIBLE_LIMIT
        account.accountNumber = Account.UNASSIGNED_ACCOUNT_NUMBER
        account.chipColor = Account.generateColorChip()
        account.inboxFolderSelection = SpecialFolderSelection.AUTOMATIC
        account.draftsFolderSelection = SpecialFolderSelection.AUTOMATIC
        account.sentFolderSelection = SpecialFolderSelection.AUTOMATIC
        account.trashFolderSelection = SpecialFolderSelection.AUTOMATIC
        account.archiveFolderSelection = SpecialFolderSelection.AUTOMATIC
        account.spamFolderSelection = SpecialFolderSelection.AUTOMATIC
    }

