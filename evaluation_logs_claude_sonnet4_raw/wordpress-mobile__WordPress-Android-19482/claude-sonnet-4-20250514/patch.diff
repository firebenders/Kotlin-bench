    ),
    BUTTON_DELETE(
        6,
        R.string.button_delete,
        R.drawable.gb_ic_trash,
        MaterialR.attr.colorOnSurface
    ),
    BUTTON_PUBLISH(
        7,
        R.string.button_publish,
        R.drawable.gb_ic_globe,
        MaterialR.attr.colorOnSurface
    ),
    BUTTON_SYNC(
        8,
        R.string.button_sync,
        R.drawable.gb_ic_update,
        MaterialR.attr.colorOnSurface
    ),
    BUTTON_MORE(
        9,
        R.string.button_more,
