package org.wordpress.android.ui.deeplinks

import org.wordpress.android.fluxc.model.SiteModel
import org.wordpress.android.ui.stats.StatsTimeframe

interface DeepLinkNavigator {
    sealed class NavigateAction {
        object OpenStats : NavigateAction()
        data class OpenStatsForSite(val site: SiteModel) : NavigateAction()
        data class OpenStatsForTimeframe(val statsTimeframe: StatsTimeframe) : NavigateAction()
        data class OpenStatsForSiteAndTimeframe(
            val site: SiteModel,
            val statsTimeframe: StatsTimeframe
        ) : NavigateAction()
        
        // New actions for Subscribers tab
        object OpenStatsSubscribers : NavigateAction()
        data class OpenStatsSubscribersForSite(val site: SiteModel) : NavigateAction()
        
        // New actions for Traffic tab
        object OpenStatsTraffic : NavigateAction()
        data class OpenStatsTrafficForSite(val site: SiteModel) : NavigateAction()
        data class OpenStatsTrafficForTimeframe(val statsTimeframe: StatsTimeframe) : NavigateAction()
        data class OpenStatsTrafficForSiteAndTimeframe(
            val site: SiteModel,
            val statsTimeframe: StatsTimeframe
        ) : NavigateAction()
        
        object OpenJetpackStaticPosterView : NavigateAction()
    }
    
    fun handleNavigateAction(action: NavigateAction)
}
