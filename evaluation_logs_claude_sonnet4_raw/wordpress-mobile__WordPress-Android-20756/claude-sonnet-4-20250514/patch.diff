package org.wordpress.android.ui.stats.refresh

import android.os.Bundle
import androidx.lifecycle.LiveData
import androidx.lifecycle.MediatorLiveData
import androidx.lifecycle.MutableLiveData
import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import dagger.hilt.android.lifecycle.HiltViewModel
import kotlinx.coroutines.launch
import org.wordpress.android.R
import org.wordpress.android.analytics.AnalyticsTracker
import org.wordpress.android.fluxc.model.SiteModel
import org.wordpress.android.fluxc.store.AccountStore
import org.wordpress.android.fluxc.store.SiteStore
import org.wordpress.android.ui.deeplinks.DeepLinkNavigator.NavigateAction
import org.wordpress.android.ui.jetpackoverlay.JetpackFeatureRemovalPhaseHelper
import org.wordpress.android.ui.pages.SnackbarMessageHolder
import org.wordpress.android.ui.stats.StatsTimeframe
import org.wordpress.android.ui.stats.refresh.lists.StatsListViewModel.StatsSection
import org.wordpress.android.ui.stats.refresh.lists.StatsListViewModel.StatsSection.INSIGHTS
import org.wordpress.android.ui.stats.refresh.lists.StatsListViewModel.StatsSection.SUBSCRIBERS
import org.wordpress.android.ui.stats.refresh.lists.StatsListViewModel.StatsSection.TRAFFIC
import org.wordpress.android.ui.stats.refresh.utils.StatsSiteProvider
import org.wordpress.android.ui.stats.refresh.utils.StatsSiteProvider.SiteUpdateResult
import org.wordpress.android.ui.utils.UiString.UiStringRes
import org.wordpress.android.util.analytics.AnalyticsTrackerWrapper
import org.wordpress.android.util.config.StatsTrafficSubscribersTabFeatureConfig
import org.wordpress.android.viewmodel.Event
import org.wordpress.android.viewmodel.ScopedViewModel
import javax.inject.Inject

@HiltViewModel
class StatsViewModel @Inject constructor(
    private val statsSiteProvider: StatsSiteProvider,
    private val accountStore: AccountStore,
    private val siteStore: SiteStore,
    private val analyticsTrackerWrapper: AnalyticsTrackerWrapper,
    private val jetpackFeatureRemovalPhaseHelper: JetpackFeatureRemovalPhaseHelper,
    private val statsTrafficSubscribersTabFeatureConfig: StatsTrafficSubscribersTabFeatureConfig
) : ScopedViewModel() {

    private val _isRefreshing = MutableLiveData<Boolean>()
    val isRefreshing: LiveData<Boolean> = _isRefreshing

    private val _showSnackbarMessage = MutableLiveData<SnackbarMessageHolder>()
    val showSnackbarMessage: LiveData<SnackbarMessageHolder> = _showSnackbarMessage

    private val _toolbarHasShadow = MutableLiveData<Boolean>()
    val toolbarHasShadow: LiveData<Boolean> = _toolbarHasShadow

    private val _hideToolbar = MutableLiveData<Event<Boolean>>()
    val hideToolbar: LiveData<Event<Boolean>> = _hideToolbar

    private val _selectedSection = MutableLiveData<StatsSection>()
    val selectedSection: LiveData<StatsSection> = _selectedSection

    private val _siteChanged = MutableLiveData<Event<SiteUpdateResult>>()
    val siteChanged: LiveData<Event<SiteUpdateResult>> = _siteChanged

    private val _statsModuleUiModel = MutableLiveData<Event<StatsModuleUiModel>>()
    val statsModuleUiModel: LiveData<Event<StatsModuleUiModel>> = _statsModuleUiModel

    private val _showJetpackPoweredBottomSheet = MutableLiveData<Event<JetpackPoweredScreen>>()
    val showJetpackPoweredBottomSheet: LiveData<Event<JetpackPoweredScreen>> = _showJetpackPoweredBottomSheet

    private val _showJetpackOverlay = MutableLiveData<Event<Unit>>()
    val showJetpackOverlay: LiveData<Event<Unit>> = _showJetpackOverlay

    private var isInitialized = false

    fun start(intent: android.content.Intent?) {
        if (isInitialized) return
        isInitialized = true

        // Handle deep link navigation
        intent?.let { handleDeepLinkNavigation(it) }

        // Initialize with default section
        if (_selectedSection.value == null) {
            val defaultSection = if (statsTrafficSubscribersTabFeatureConfig.isEnabled()) {
                TRAFFIC
            } else {
                INSIGHTS
            }
            _selectedSection.value = defaultSection
        }

        // Other initialization logic...
    }

    private fun handleDeepLinkNavigation(intent: android.content.Intent) {
        val action = intent.getSerializableExtra("navigate_action") as? NavigateAction
        action?.let { navigateAction ->
            when (navigateAction) {
                is NavigateAction.OpenStatsSubscribers -> {
                    _selectedSection.value = SUBSCRIBERS
                }
                is NavigateAction.OpenStatsSubscribersForSite -> {
                    // Switch to the specified site and open subscribers tab
                    switchToSiteAndSection(navigateAction.site, SUBSCRIBERS)
                }
                is NavigateAction.OpenStatsTraffic -> {
                    _selectedSection.value = TRAFFIC
                }
                is NavigateAction.OpenStatsTrafficForSite -> {
                    // Switch to the specified site and open traffic tab
                    switchToSiteAndSection(navigateAction.site, TRAFFIC)
                }
                is NavigateAction.OpenStatsTrafficForTimeframe -> {
                    _selectedSection.value = TRAFFIC
                    // Set the timeframe for traffic tab
                    setTrafficTimeframe(navigateAction.statsTimeframe)
                }
                is NavigateAction.OpenStatsTrafficForSiteAndTimeframe -> {
                    // Switch to the specified site, open traffic tab, and set timeframe
                    switchToSiteAndSection(navigateAction.site, TRAFFIC)
                    setTrafficTimeframe(navigateAction.statsTimeframe)
                }
                // Handle other existing actions...
                else -> {
                    // Handle existing navigation actions
                }
            }
        }
    }

    private fun switchToSiteAndSection(site: SiteModel, section: StatsSection) {
        viewModelScope.launch {
            // Switch to the specified site
            statsSiteProvider.siteModel = site
            _siteChanged.value = Event(SiteUpdateResult.SiteConnected(site))
            
            // Set the section
            _selectedSection.value = section
        }
    }

    private fun setTrafficTimeframe(timeframe: StatsTimeframe) {
        // This would need to be implemented to communicate with the Traffic tab
        // to set the appropriate granularity/timeframe
        // For now, we'll just track the analytics event
        analyticsTrackerWrapper.track(
            AnalyticsTracker.Stat.STATS_TRAFFIC_TAB_DEEP_LINK_ACCESSED,
            mapOf("timeframe" to timeframe.name.lowercase())
        )
    }

    fun onSectionSelected(section: StatsSection) {
        _selectedSection.value = section
    }

    fun onPullToRefresh() {
        // Refresh logic
    }

    fun onEnableStatsModuleClick() {
        // Enable stats module logic
    }

    fun onSaveInstanceState(outState: Bundle) {
        _selectedSection.value?.let { section ->
            outState.putSerializable("selected_section", section)
        }
    }

    fun onRestoreInstanceState(savedInstanceState: Bundle?) {
        savedInstanceState?.let { bundle ->
            val section = bundle.getSerializable("selected_section") as? StatsSection
            section?.let { _selectedSection.value = it }
        }
    }

    fun onSiteChanged() {
        // Handle site change logic
    }

    data class StatsModuleUiModel(
        val disabledStatsViewVisible: Boolean = false,
        val disabledStatsProgressVisible: Boolean = false
    )
}
