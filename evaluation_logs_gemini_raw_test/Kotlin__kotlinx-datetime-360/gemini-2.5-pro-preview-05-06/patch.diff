package kotlinx.datetime.internal.format.parser

/**
 * Exception thrown when parsing fails.
 * @property errorIndex The 0-based index in the input string where the error occurred.
 * @property reasonProvider A lambda that provides the specific reason for the parsing failure.
 */
internal class ParseException(
    val errorIndex: Int,
    private val reasonProvider: () -> String
) : Exception() {
    // The message format now includes the 0-indexed position.
    override val message: String get() = "Position $errorIndex: ${reasonProvider()}"
}
