package kotlinx.datetime

import kotlin.time.*

/**
 * A source of [Instant] values.
 *
 * `Clock` is primarily used to obtain the current [Instant]. This is useful for timestamping events,
 * measuring durations, or simply getting the current time.
 *
 * ## Obtaining a Clock
 * The most common way to get a `Clock` is to use the system clock:
 * ```kotlin
 * val systemClock = Clock.System
 * val currentMoment = systemClock.now()
 * println("Current moment: $currentMoment")
 * ```
 * For testing purposes, you might inject a custom `Clock` implementation to control time precisely.
 * For example, a `FixedClock` that always returns the same instant:
 * ```kotlin
 * class FixedClock(private val instant: Instant) : Clock {
 *     override fun now(): Instant = instant
 * }
 *
 * val fixedInstant = Instant.parse("2023-01-01T12:00:00Z")
 * val testClock = FixedClock(fixedInstant)
 * println(testClock.now()) // Always prints 2023-01-01T12:00:00Z
 * ```
 *
 * ## Usage
 * `Clock` can be injected as a dependency to make code more testable:
 * ```kotlin
 * interface EventRecorder {
 *     fun recordEvent(message: String)
 * }
 *
 * class TimestampedEventRecorder(private val clock: Clock) : EventRecorder {
 *     override fun recordEvent(message: String) {
 *         val timestamp = clock.now()
 *         // In a real application, this might write to a log file or database
 *         println("[$timestamp] $message")
 *     }
 * }
 *
 * // In production code:
 * val productionRecorder = TimestampedEventRecorder(Clock.System)
 * productionRecorder.recordEvent("User logged in")
 *
 * // In test code:
 * val testInstant = Instant.parse("2023-10-27T10:00:00Z")
 * val fixedTestClock = FixedClock(testInstant)
 * val testRecorder = TimestampedEventRecorder(fixedTestClock)
 * testRecorder.recordEvent("Test event") // Will be timestamped with testInstant
 * ```
 *
 * The instants provided by a `Clock` are on the UTC-SLS time scale, consistent with [Instant].
 *
 * @see Clock.System The default system clock.
 * @see Instant Represents a moment in time.
 */
public interface Clock {
    /**
     * Returns the [Instant] corresponding to the current time, according to this clock.
     *
     * For [Clock.System], this typically represents the current system time.
     * For custom implementations, it returns the instant defined by that implementation.
     */
    public fun now(): Instant

    /**
     * The [Clock] instance that queries the operating system as its source of knowledge of time.
     *
     * This clock provides [Instant] values based on the current system time, typically expressed in UTC.
     * It is the standard clock to use for most application needs.
     *
     * Note that system time can be adjusted by the user or by network time protocols, which can lead to
     * discontinuities or backward jumps in time.
     *
     * ## Usage Example
     * ```kotlin
     * val currentMoment = Clock.System.now()
     * println("The current moment is: $currentMoment")
     *
     * val today = Clock.System.todayIn(TimeZone.currentSystemDefault())
     * println("Today's date in system default timezone: $today")
     * ```
     */
    public object System : Clock {
        /**
         * Returns the current [Instant] according to the system clock.
         */
        override fun now(): Instant = @Suppress("DEPRECATION_ERROR") Instant.now()
    }

    public companion object {
        // Placeholder for potential future static methods or properties related to Clock.
    }
}

/**
 * Returns the current date in the specified [timeZone], according to this `Clock`.
 *
 * This is a convenience function equivalent to `now().toLocalDateTime(timeZone).date`.
 *
 * ## Example
 * ```kotlin
 * val clock = Clock.System
 * val todayInBerlin = clock.todayIn(TimeZone.of("Europe/Berlin"))
 * println("Today in Berlin: $todayInBerlin") // e.g., 2023-10-27
 *
 * val todayInUtc = clock.todayIn(TimeZone.UTC)
 * println("Today in UTC: $todayInUtc") // e.g., 2023-10-27
 * ```
 * @param timeZone The time zone in which to determine the current date.
 * @return The [LocalDate] representing the current date in the given [timeZone].
 */
public fun Clock.todayIn(timeZone: TimeZone): LocalDate =
    now().toLocalDateTime(timeZone).date

/**
 * Returns a [TimeSource] that uses this `Clock` to mark a time instant and to find the amount of time elapsed since that mark.
 *
 * This is useful for measuring execution time or other durations based on this clock's notion of "now".
 * The returned [TimeSource] provides [ComparableTimeMark] instances, allowing marks from the same source to be compared.
 *
 * ## Example
 * ```kotlin
 * val clock = Clock.System
 * val timeSource = clock.asTimeSource()
 *
 * val mark1 = timeSource.markNow()
 * // Simulate some work
 * // For demonstration, using a simple loop; in real code, this would be actual processing.
 * for (i in 1..1_000_000) { /* do nothing */ }
 * val elapsedDuration = mark1.elapsedNow()
 * println("Work took $elapsedDuration") // e.g., PT0.005S or similar
 *
 * val mark2 = timeSource.markNow()
 * // ... more work ...
 * val durationBetweenMarks = mark2 - mark1 // if mark2 is later, duration is positive
 * println("Duration between mark1 and mark2: $durationBetweenMarks")
 * ```
 *
 * @return A [TimeSource.WithComparableMarks] tied to this [Clock].
 * @see kotlin.time.TimeSource
 * @see kotlin.time.ComparableTimeMark
 */
@ExperimentalTime
public fun Clock.asTimeSource(): TimeSource.WithComparableMarks = object : TimeSource.WithComparableMarks {
    override fun markNow(): ComparableTimeMark = InstantTimeMark(now(), this@asTimeSource)
}

@ExperimentalTime
private class InstantTimeMark(private val instant: Instant, private val clock: Clock) : ComparableTimeMark {
    override fun elapsedNow(): Duration = saturatingDiff(clock.now(), instant)

    override fun plus(duration: Duration): ComparableTimeMark = InstantTimeMark(instant.saturatingAdd(duration), clock)
    override fun minus(duration: Duration): ComparableTimeMark = InstantTimeMark(instant.saturatingAdd(-duration), clock)

    override fun minus(other: ComparableTimeMark): Duration {
        if (other !is InstantTimeMark || other.clock != this.clock) {
            throw IllegalArgumentException("Subtracting or comparing time marks from different time sources is not possible: $this and $other")
        }
        return saturatingDiff(this.instant, other.instant)
    }

    override fun equals(other: Any?): Boolean {
        return other is InstantTimeMark && this.clock == other.clock && this.instant == other.instant
    }

    override fun hashCode(): Int = instant.hashCode()

    override fun toString(): String = "InstantTimeMark($instant, $clock)"

    private fun Instant.isSaturated() = this == Instant.MAX || this == Instant.MIN
    private fun Instant.saturatingAdd(duration: Duration): Instant {
        if (isSaturated()) {
            if (duration.isInfinite() && duration.isPositive() != this.isDistantFuture) {
                throw IllegalArgumentException("Summing infinities of different signs")
            }
            return this
        }
        return this + duration
    }
    private fun saturatingDiff(instant1: Instant, instant2: Instant): Duration = when {
        instant1 == instant2 ->
            Duration.ZERO
        instant1.isSaturated() || instant2.isSaturated() ->
            (instant1 - instant2) * Double.POSITIVE_INFINITY
        else ->
            instant1 - instant2
    }
}

@Deprecated("Use Clock.todayIn instead", ReplaceWith("this.todayIn(timeZone)"), DeprecationLevel.WARNING)
public fun Clock.todayAt(timeZone: TimeZone): LocalDate = todayIn(timeZone)

