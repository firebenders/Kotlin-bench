package kotlinx.datetime.internal.format

import kotlinx.datetime.AmPmMarker
import kotlinx.datetime.internal.DecimalFraction
import kotlinx.datetime.internal.appendPadded
import kotlinx.datetime.internal.format.parser.FieldFormatDirective

/**
 * Base class for all field-specific format directives.
 * A [FieldFormatDirective] is responsible for formatting and parsing a single field of a date/time object.
 */
internal abstract class AbstractFieldFormatDirective<in T, F> : FieldFormatDirective<T, F> {
    /**
     * A string representation of the directive, used for error messages and debugging.
     * Typically, this is the Kotlin DSL function that creates this directive.
     * Example: "year()", "monthNumber(Padding.SPACE)".
     */
    abstract val builderRepresentation: String // Already expected by concrete directives

    /**
     * The name of the directive to be used in error messages.
     * Concrete directives will implement this, usually by returning [builderRepresentation].
     */
    protected abstract val directiveName: String
}

/**
 * Base class for directives that format and parse integer numbers.
 */
internal abstract class NumberFormatDirective<in T>(
    final override val field: FieldSpec<T, Int>,
    private val minDigits: Int,
    private val maxDigits: Int?,
    private val spacePadding: Int,
    private val outputPlusOnExceededWidth: Int?,
) : AbstractFieldFormatDirective<T, Int>() {

    init {
        require(minDigits > 0) { "Minimum digits must be positive, but was $minDigits" }
        maxDigits?.let { require(it >= minDigits) { "Maximum digits $it must be greater than or equal to minimum digits $minDigits" } }
        require(spacePadding >= 0) { "Space padding must be non-negative, but was $spacePadding" }
        outputPlusOnExceededWidth?.let { require(it > 0) { "Output plus on exceeded width must be positive, but was $it" } }
    }

    override fun format(value: T, output: Appendable) {
        val intValue = field.accessor.getterNotNull(value, "it is required by directive '$directiveName'")
        val isNegative = field.sign?.isNegative?.getter(value) == true && intValue != 0
        val absValue = if (isNegative && intValue == Int.MIN_VALUE) Int.MAX_VALUE.toLong() + 1 else kotlin.math.abs(intValue.toLong())
        output.appendPadded(
            absValue,
            minDigits,
            maxDigits,
            spacePadding,
            isNegative,
            outputPlusOnExceededWidth != null && absValue.toString().length > outputPlusOnExceededWidth
        )
    }
}

/**
 * Base class for directives that format and parse signed integer numbers.
 */
internal abstract class SignedIntFieldFormatDirective<in T>(
    field: FieldSpec<T, Int>,
    minDigits: Int,
    maxDigits: Int?,
    spacePadding: Int,
    outputPlusOnExceededWidth: Int?,
) : NumberFormatDirective<T>(field, minDigits, maxDigits, spacePadding, outputPlusOnExceededWidth)

/**
 * Base class for directives that format and parse unsigned integer numbers.
 */
internal abstract class UnsignedIntFieldFormatDirective<in T>(
    field: UnsignedFieldSpec<T, Int>,
    minDigits: Int,
    spacePadding: Int,
) : NumberFormatDirective<T>(field, minDigits, field.maxDigits, spacePadding, null)

/**
 * Base class for directives that format and parse an integer field with a reduced number of digits,
 * by using a base value. For example, '23' for a year, with a base of 2000, means 2023.
 */
internal abstract class ReducedIntFieldDirective<in T>(
    final override val field: FieldSpec<T, Int>,
    val digits: Int,
    val base: Int,
) : AbstractFieldFormatDirective<T, Int>() {
    override fun format(value: T, output: Appendable) {
        val intValue = field.accessor.getterNotNull(value, "it is required by directive '$directiveName'")
        val reducedValue = (intValue % 100).let { if (it < 0) it + 100 else it } // always positive
        output.appendPadded(reducedValue.toLong(), digits)
    }
}

/**
 * Base class for directives that format and parse an unsigned integer field by mapping its values to a list of names.
 * For example, month numbers (1-12) to month names ("January", "February", ...).
 */
internal abstract class NamedUnsignedIntFieldFormatDirective<in T>(
    final override val field: UnsignedFieldSpec<T, Int>,
    private val names: List<String>,
    private val fieldDescription: String,
) : AbstractFieldFormatDirective<T, Int>() {
    override fun format(value: T, output: Appendable) {
        val intValue = field.accessor.getterNotNull(value, "it is required by directive '$directiveName'")
        if (intValue < field.minValue || intValue > field.maxValue) {
            throw IllegalStateException(
                "Value $intValue for $fieldDescription is out of range ${field.minValue}..${field.maxValue} " +
                    "for directive '$directiveName'"
            )
        }
        output.append(names[intValue - field.minValue])
    }
}

/**
 * Base class for directives that format and parse an enum field by mapping its values to a map of strings.
 */
internal abstract class NamedEnumIntFieldFormatDirective<in T, E : Enum<E>>(
    final override val field: FieldSpec<T, E>,
    private val names: Map<E, String>,
    private val fieldDescription: String,
) : AbstractFieldFormatDirective<T, E>() {
    override fun format(value: T, output: Appendable) {
        val enumValue = field.accessor.getterNotNull(value, "it is required by directive '$directiveName'")
        output.append(
            names[enumValue]
                ?: throw IllegalStateException(
                    "Value $enumValue for $fieldDescription is not recognized by directive '$directiveName'"
                )
        )
    }
}

/**
 * Base class for directives that format and parse a string field.
 */
internal abstract class StringFieldFormatDirective<in T>(
    final override val field: FieldSpec<T, String>,
    private val acceptedValues: Set<String>,
) : AbstractFieldFormatDirective<T, String>() {
    override fun format(value: T, output: Appendable) {
        val stringValue = field.accessor.getterNotNull(value, "it is required by directive '$directiveName'")
        if (acceptedValues.isNotEmpty() && stringValue !in acceptedValues) {
            // TODO: list a few accepted values?
            throw IllegalStateException(
                "Value '$stringValue' for field '${field.name}' is not in the list of accepted values " +
                    "for directive '$directiveName'"
            )
        }
        output.append(stringValue)
    }
}

/**
 * Base class for directives that format and parse the fractional part of a second.
 */
internal abstract class DecimalFractionFieldFormatDirective<in T>(
    final override val field: FieldSpec<T, DecimalFraction>,
    private val minDigits: Int?,
    private val maxDigits: Int?,
    private val zerosToAdd: List<Int> = List(9) { 0 }
) : AbstractFieldFormatDirective<T, DecimalFraction>() {

    init {
        minDigits?.let { require(it in 1..9) }
        maxDigits?.let { require(it in 1..9) }
        minDigits?.let { mDigits -> maxDigits?.let { require(mDigits <= it) } }
    }

    override fun format(value: T, output: Appendable) {
        val decimalFraction = field.accessor.getterNotNull(value, "it is required by directive '$directiveName'")
        val min = minDigits ?: 1
        val max = maxDigits ?: 9
        val numDigits = decimalFraction.fractionalPartLength
        if (numDigits == 0 && min == 0) return // valid case: 0 digits asked, 0 digits present
        if (numDigits < min && decimalFraction.fractionalPart == 0) {
            // Special case: the fraction is zero, but we need to print at least `min` digits.
            // Example: .format { secondFraction(3) } on `LocalTime(1, 2, 3, 0)` should print `.000`.
            repeat(min) { output.append('0') }
            return
        }
        // TODO: a more efficient way to do this?
        val str = decimalFraction.fractionalPartWithNDigits(max)
        if (str.length < min) {
            output.append(str)
            repeat(min - str.length) { output.append('0') }
        } else {
            output.append(str)
        }
    }
}

