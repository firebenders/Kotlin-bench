package com.ichi2.anki.preferences

import androidx.preference.PreferenceCategory
import com.ichi2.anki.R
import com.ichi2.anki.cardviewer.CommandCategory
import com.ichi2.anki.cardviewer.ViewerCommand
import com.ichi2.anki.reviewer.MappableBinding.Companion.toPreferenceString
import com.ichi2.preferences.ControlPreference

class ControlsSettingsFragment : SettingsFragment() {
    override val preferenceResource: Int
        get() = R.xml.preferences_controls
    override val analyticsScreenNameConstant: String
        get() = "prefs.controls"

    override fun initSubscreen() {
        addCommandPreferencesByCategories()
    }

    /**
     * Adds all [ControlPreference] elements to the screen, grouped by [CommandCategory].
     */
    private fun addCommandPreferencesByCategories() {
        val screen = preferenceScreen ?: return

        // Ensure commands are sorted by their ordinal within each category for consistent display
        val commandsByCategories = ViewerCommand.values().groupBy { it.category }
            .mapValues { entry -> entry.value.sortedBy { it.ordinal } }

        for (categoryEnum in CommandCategory.values()) {
            val commandsInCategory = commandsByCategories[categoryEnum]
            if (commandsInCategory.isNullOrEmpty()) {
                continue
            }

            val preferenceCategory = PreferenceCategory(requireContext()).apply {
                title = getString(categoryEnum.titleResId)
                // Optional: assign a key for testing or other purposes
                // key = "controls_category_${categoryEnum.name}"
            }
            screen.addPreference(preferenceCategory)

            for (command in commandsInCategory) {
                val preference = ControlPreference(preferenceCategory.context).apply {
                    setTitle(command.resourceId)
                    key = command.preferenceKey
                    setDefaultValue(command.defaultValue.toPreferenceString())
                }
                preferenceCategory.addPreference(preference)
            }
        }
    }
}
