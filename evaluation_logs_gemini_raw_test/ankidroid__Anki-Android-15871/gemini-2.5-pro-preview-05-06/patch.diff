<svg version="1.1" width="162px" height="120" xmlns="http://www.w3.org/2000/svg" id="keyboard" class="keyboard">

<style>
  /* Default style for path elements */
  path {
    stroke: #2c2c2c;
    /* Paths will get their fill color from the --key-color CSS custom property.
       This property will be set on an ancestor, typically the <use> element
       itself (via JavaScript) or its parent <g> (for initial color). */
    fill: var(--key-color);
  }

  /* These classes are applied to <g> elements wrapping <use> elements. */
  /* They define the initial --key-color for the keys within them. */
  .white_key {
    --key-color: white;
  }

  .black_key {
    --key-color: #2c2c2c;
  }
</style>

<symbol id="white_key_path" width="23" height="120" >
  <!-- fill="inherit" is removed. The fill is now controlled by 'fill: var(--key-color)' from the <style> block. -->
  <path d="M0 0 h23 v115 q0 5 -5 5 h-13 q-5 0 -5 -5 v-115" />
</symbol>
<symbol id="black_key_path" width="13" height="80">
