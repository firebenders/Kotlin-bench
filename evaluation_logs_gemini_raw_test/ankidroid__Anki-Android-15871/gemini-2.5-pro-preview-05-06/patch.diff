[start of HTML Template]
```html
<div class="vexbox">
  <h3> Key? </h3>
	<object id="keyboard_obj" type="image/svg+xml" data="_keyboard.svg" onload="changeRectColor()">
  </object>
</div>

<h2 class="answer" id="answer_key" >
{{English}}
</h2>

<script>
function changeRectColor() {
  var img_obj = document.getElementById("keyboard_obj");
  // It's good practice to ensure contentDocument is available,
  // though 'onload' should typically guarantee this.
  if (img_obj.contentDocument) {
    var notes = img_obj.contentDocument.querySelectorAll(".note_{{English}}");
    notes.forEach( (note) => {
      // Instead of setting note.style.fill,
      // set the --key-color CSS custom property on the <use> element.
      // The <path> inside the symbol (referenced by <use>) will use this
      // variable for its fill color due to 'fill: var(--key-color)' in its style.
      note.style.setProperty("--key-color", "#98ff98");
    } );
  } else {
    // Log an error if the SVG's contentDocument isn't accessible.
    console.error("SVG contentDocument not available for styling.");
  }
}
</script>
