package com.ichi2.anki.previewer

import android.content.Context
import android.content.Intent
import android.os.Bundle
import android.view.KeyEvent
import androidx.activity.OnBackPressedCallback
import androidx.fragment.app.Fragment
import com.ichi2.anki.SingleFragmentActivity
import kotlin.reflect.KClass
import kotlin.reflect.jvm.jvmName

class PreviewerActivity : SingleFragmentActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        // If SingleFragmentActivity's onCreate returned early (e.g. showedActivityFailedScreen),
        // this code won't run, which is fine.
        // Add a callback for handling the Android system back button.
        onBackPressedDispatcher.addCallback(
            this,
            object : OnBackPressedCallback(true) { // true = enabled
                override fun handleOnBackPressed() {
                    // This callback will be invoked when the back button is pressed.
                    finish() // Close the PreviewerActivity.
                }
            }
        )
    }

    /**
     * Intercepts the back key press to ensure the PreviewerActivity closes.
     * This is necessary to override potential misbehavior in a fragment that might
     * consume the back key event via [DispatchKeyEventListener] without closing.
     */
    override fun dispatchKeyEvent(event: KeyEvent): Boolean {
        if (event.keyCode == KeyEvent.KEYCODE_BACK) {
            if (event.action == KeyEvent.ACTION_UP) {
                // On ACTION_UP, trigger the onBackPressedDispatcher.
                // This will invoke the OnBackPressedCallback registered in onCreate.
                if (!isFinishing && !event.isCanceled) {
                    onBackPressedDispatcher.onBackPressed()
                }
            }
            // Return true to indicate that the back key event (both DOWN and UP)
            // has been handled by this Activity. This prevents further propagation,
            // notably to SingleFragmentActivity's logic that might delegate to the fragment.
            return true
        }
        // For all other key events, defer to the default behavior.
        return super.dispatchKeyEvent(event)
    }

    companion object {
        fun getIntent(context: Context, fragmentClass: KClass<out Fragment>, arguments: Bundle? = null): Intent {
            return Intent(context, PreviewerActivity::class.java).apply {
                putExtra(FRAGMENT_NAME_EXTRA, fragmentClass.jvmName)
                putExtra(FRAGMENT_ARGS_EXTRA, arguments)
            }
        }
    }
}
