package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.logger.api.initKtLintKLogger
import com.pinterest.ktlint.rule.engine.core.api.ElementType
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.SinceKtlint
import com.pinterest.ktlint.rule.engine.core.api.SinceKtlint.Status.STABLE
import com.pinterest.ktlint.rule.engine.core.api.children
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.EditorConfig
import com.pinterest.ktlint.rule.engine.core.api.isWhiteSpace
import com.pinterest.ktlint.rule.engine.core.api.isWhiteSpaceWithNewline
import com.pinterest.ktlint.rule.engine.core.api.prevLeaf
import com.pinterest.ktlint.ruleset.standard.StandardRule
import mu.KotlinLogging
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.com.intellij.psi.PsiComment
import org.jetbrains.kotlin.com.intellij.psi.PsiWhiteSpace
import org.jetbrains.kotlin.psi.KtAnnotatedExpression
import org.jetbrains.kotlin.psi.KtAnnotationEntry
import org.jetbrains.kotlin.psi.KtDeclaration
import org.jetbrains.kotlin.psi.KtExpression
import org.jetbrains.kotlin.psi.KtFile
import org.jetbrains.kotlin.psi.KtModifierListOwner
import org.jetbrains.kotlin.psi.KtPsiFactory
import org.jetbrains.kotlin.psi.psiUtil.endOffset
import org.jetbrains.kotlin.psi.psiUtil.startOffset

private val LOGGER = KotlinLogging.logger {}.initKtLintKLogger()

@SinceKtlint("1.0", STABLE)
public class NoKtlintDirectiveRule : StandardRule("no-ktlint-directive") {
    private companion object {
        const val KTLINT_DISABLE = "ktlint-disable"
        const val KTLINT_ENABLE = "ktlint-enable"
        val KTLINT_DIRECTIVE_REGEX = Regex("\\s*ktlint-(disable|enable)\\s*(.*)")
    }

    private lateinit var ktPsiFactory: KtPsiFactory
    private val blockDirectives = mutableListOf<BlockDirective>()

    override fun beforeFirstNode(editorConfig: EditorConfig) {
        ktPsiFactory = KtPsiFactory(project = editorConfig.project)
        blockDirectives.clear()
    }

    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        if (node.elementType == ElementType.EOL_COMMENT) {
            handleEolComment(node, autoCorrect, emit)
        } else if (node.elementType == ElementType.BLOCK_COMMENT) {
            handleBlockComment(node, autoCorrect, emit)
        }
    }

    override fun afterLastNode() {
        // Process any remaining open block directives as if they extend to the end of the file
        blockDirectives.forEach { directive ->
            // This case should ideally not happen if directives are well-formed,
            // but we process them to ensure all collected directives are handled.
            // We can't autocorrect here as the scope is not clearly defined by an enable directive.
            // Emitting an error for the disable directive itself.
            // TODO: emit(directive.node.startOffset, "Unmatched '$KTLINT_DISABLE' directive.", false)
        }
        blockDirectives.clear()
    }

    private fun handleEolComment(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val commentText = node.text.removePrefix("//").trim()
        if (commentText.startsWith(KTLINT_DISABLE)) {
            emit(node.startOffset, "ktlint-disable directive is deprecated. Replace with @Suppress annotation.", true)
            if (autoCorrect) {
                val ruleIds = parseRuleIds(commentText.substringAfter(KTLINT_DISABLE).trim())
                val targetNode = findTargetNodeForEolComment(node)
                if (targetNode != null) {
                    addSuppressAnnotation(targetNode, ruleIds)
                    node.treeParent.removeChild(node)
                } else {
                    LOGGER.warn { "Could not find target node for EOL comment at ${node.startOffset}" }
                }
            }
        } else if (commentText.startsWith(KTLINT_ENABLE)) {
            // ktlint-enable in EOL comments doesn't have a defined behavior to migrate.
            // Report and remove if autocorrecting.
            emit(node.startOffset, "ktlint-enable directive in EOL comment is not supported by @Suppress. Please remove.", true)
            if (autoCorrect) {
                node.treeParent.removeChild(node)
            }
        }
    }

    private fun handleBlockComment(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val commentText = node.text.removePrefix("/*").removeSuffix("*/").trim()
        val matchResult = KTLINT_DIRECTIVE_REGEX.matchEntire(commentText) ?: return

        val directiveType = matchResult.groupValues[1]
        val ruleIdsString = matchResult.groupValues[2]
        val ruleIds = parseRuleIds(ruleIdsString)

        if (directiveType == "disable") {
            emit(node.startOffset, "ktlint-disable directive is deprecated. Replace with @Suppress annotation.", true)
            blockDirectives.add(BlockDirective(node, ruleIds, node.startOffset))
        } else if (directiveType == "enable") {
            emit(node.startOffset, "ktlint-enable directive is deprecated. Replace with @Suppress annotation.", true)
            val matchingDisable = blockDirectives.findLast { it.ruleIds == ruleIds }
            if (matchingDisable != null) {
                if (autoCorrect) {
                    val affectedNodes = findNodesBetween(matchingDisable.node, node)
                    affectedNodes.forEach { affectedNode ->
                        addSuppressAnnotation(affectedNode, ruleIds)
                    }
                    // Remove both directive comments
                    matchingDisable.node.treeParent.removeChild(matchingDisable.node)
                    node.treeParent.removeChild(node)
                }
                blockDirectives.remove(matchingDisable)
            } else {
                // No matching disable, this enable is orphaned. Report and remove if autocorrecting.
                // TODO: emit(node.startOffset, "Unmatched '$KTLINT_ENABLE' directive for rule(s): ${ruleIds.joinToString()}.", !autoCorrect)
                if (autoCorrect) {
                    node.treeParent.removeChild(node)
                }
            }
        }
    }

    private fun parseRuleIds(ruleIdsString: String): Set<RuleId> {
        if (ruleIdsString.isBlank()) {
            return emptySet() // Represents "all rules"
        }
        return ruleIdsString.split(Regex("\\s+"))
            .mapNotNull { rawRuleId ->
                try {
                    RuleId.prefixWithStandardRuleSetIdWhenMissing(rawRuleId)
                        .let { RuleId(it) }
                } catch (e: IllegalArgumentException) {
                    LOGGER.warn { "Invalid rule ID '$rawRuleId' in ktlint-disable directive. " + e.message }
                    null
                }
            }.toSet()
    }

    private fun findTargetNodeForEolComment(commentNode: ASTNode): ASTNode? {
        // Check if comment is on the same line as code or on its own line
        val prevLeaf = commentNode.prevLeaf()
        if (prevLeaf != null && !prevLeaf.isWhiteSpaceWithNewline()) {
            // Comment is on the same line as code. Target the statement on this line.
            var currentNode: ASTNode? = commentNode
            while (currentNode != null) {
                if (currentNode.psi is KtDeclaration || currentNode.psi is KtExpression) {
                    // Find the outermost expression or declaration on this line
                    var parent = currentNode.treeParent
                    while (parent != null && parent.psi is KtExpression && parent.startOffset == currentNode.startOffset) {
                        currentNode = parent
                        parent = parent.treeParent
                    }
                    return currentNode
                }
                if (currentNode.prevLeaf()?.isWhiteSpaceWithNewline() == true || currentNode.prevLeaf() == null) {
                    break // Reached start of line or file
                }
                currentNode = currentNode.prevLeaf()
            }
            return null
        } else {
            // Comment is on its own line. Target the next non-comment, non-whitespace statement.
            var nextNode = commentNode.treeNext
            while (nextNode != null && (nextNode.psi is PsiComment || nextNode.psi is PsiWhiteSpace)) {
                nextNode = nextNode.treeNext
            }
            return nextNode
        }
    }

    private fun findNodesBetween(startComment: ASTNode, endComment: ASTNode): List<ASTNode> {
        val nodes = mutableListOf<ASTNode>()
        var currentNode = startComment.treeNext
        while (currentNode != null && currentNode != endComment) {
            if (currentNode.psi !is PsiWhiteSpace && currentNode.psi !is PsiComment) {
                // Consider only non-whitespace and non-comment nodes as targets for @Suppress
                // And only top-level statements/declarations in the block
                if (currentNode.treeParent?.psi is KtFile || // Top-level in file
                    currentNode.treeParent?.elementType == ElementType.BLOCK || // Inside a block
                    currentNode.treeParent?.elementType == ElementType.CLASS_BODY // Inside a class body
                ) {
                    if (currentNode.psi is KtDeclaration || currentNode.psi is KtExpression) {
                        nodes.add(currentNode)
                    }
                }
            }
            currentNode = currentNode.treeNext
        }
        return nodes
    }

    private fun addSuppressAnnotation(targetNode: ASTNode, ruleIds: Set<RuleId>) {
        val suppressKtlintRuleIds =
            if (ruleIds.isEmpty()) {
                listOf("\"ktlint\"")
            } else {
                ruleIds.map { "\"ktlint:${it.value}\"" }
            }
        val annotationString = "@Suppress(${suppressKtlintRuleIds.joinToString(", ")})"

        try {
            val annotationEntry = ktPsiFactory.createAnnotationEntry(annotationString)
            val targetPsi = targetNode.psi

            when (targetPsi) {
                is KtModifierListOwner -> {
                    targetPsi.addAnnotationEntry(annotationEntry).node
                    ensureNewlineBeforeNode(targetPsi.node)
                }
                is KtAnnotatedExpression -> {
                    // For expressions like `(@Foo bar)`, add to its annotation list
                    targetPsi.addAnnotationEntry(annotationEntry).node
                    ensureNewlineBeforeNode(targetPsi.node)
                }
                is KtExpression, is KtFile -> { // KtFile for @file:Suppress
                    // Add annotation on its own line before the target node
                    val parent = targetNode.treeParent
                    val anchor = targetNode
                    parent.addChild(annotationEntry.node, anchor)
                    parent.addChild(ktPsiFactory.createWhiteSpace("\n").node, anchor)
                }
                else -> {
                    // Fallback: add before the node. This might not always be syntactically ideal.
                    val parent = targetNode.treeParent
                    val anchor = targetNode
                    if (parent != null) {
                        parent.addChild(annotationEntry.node, anchor)
                        parent.addChild(ktPsiFactory.createWhiteSpace("\n").node, anchor)
                    } else {
                        LOGGER.warn { "Cannot add annotation, target node has no parent: ${targetNode.text}" }
                    }
                }
            }
        } catch (e: Exception) {
            LOGGER.error(e) { "Failed to create or add annotation: $annotationString for node ${targetNode.text}" }
        }
    }

    private fun ensureNewlineBeforeNode(node: ASTNode) {
        val prev = node.prevLeaf()
        if (prev != null && prev.isWhiteSpace() && prev.textContains('\n')) {
            // Already has a newline
        } else if (prev != null && prev.isWhiteSpace()) {
            // Has whitespace but no newline, replace it
            val newPrev = ktPsiFactory.createWhiteSpace("\n${prev.text}")
            prev.treeParent.replaceChild(prev, newPrev.node)
        } else {
            // No whitespace or no newline, add one
            node.treeParent.addChild(ktPsiFactory.createWhiteSpace("\n").node, node)
        }
    }

    private data class BlockDirective(
        val node: ASTNode,
        val ruleIds: Set<RuleId>,
        val startOffset: Int,
        // endOffset and affectedNodes can be added if a more sophisticated analysis is needed
    )
}
