package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.ElementType.BLOCK
import com.pinterest.ktlint.rule.engine.core.api.ElementType.ELSE_KEYWORD
import com.pinterest.ktlint.rule.engine.core.api.ElementType.IF
import com.pinterest.ktlint.rule.engine.core.api.ElementType.LBRACE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.RBRACE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.RPAR
import com.pinterest.ktlint.rule.engine.core.api.ElementType.THEN
import com.pinterest.ktlint.rule.engine.core.api.IndentConfig
import com.pinterest.ktlint.rule.engine.core.api.Rule
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.EditorConfig
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.INDENT_SIZE_PROPERTY
import com.pinterest.ktlint.rule.engine.core.api.editorconfig.INDENT_STYLE_PROPERTY
import com.pinterest.ktlint.rule.engine.core.api.firstChildLeafOrSelf
import com.pinterest.ktlint.rule.engine.core.api.indent
import com.pinterest.ktlint.rule.engine.core.api.isCodeLeaf
import com.pinterest.ktlint.rule.engine.core.api.isWhiteSpace
import com.pinterest.ktlint.rule.engine.core.api.isWhiteSpaceWithNewline
import com.pinterest.ktlint.rule.engine.core.api.lastChildLeafOrSelf
import com.pinterest.ktlint.rule.engine.core.api.prevLeaf
import com.pinterest.ktlint.rule.engine.core.api.upsertWhitespaceAfterMe
import com.pinterest.ktlint.rule.engine.core.api.upsertWhitespaceBeforeMe
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode
import org.jetbrains.kotlin.com.intellij.psi.impl.source.tree.LeafPsiElement
import org.jetbrains.kotlin.com.intellij.psi.impl.source.tree.PsiWhiteSpaceImpl

/**
 * Rule to enforce Kotlin [coding conventions](https://kotlinlang.org/docs/coding-conventions.html#if-statement)
 * for if/else statements.
 *
 * The rule is simplified to make it compatible with IntelliJ IDEA default formatter.
 *
 * Rule does not conflict with [IfElseBracingRule] and [IfElseWrappingRule] as it only changes the indent of the
 * `else`-keyword.
 */
public class MultiLineIfElseRule :
    StandardRule(
        id = "multiline-if-else",
        usesEditorConfigProperties =
            setOf(
                INDENT_SIZE_PROPERTY,
                INDENT_STYLE_PROPERTY,
            ),
    ) {
    private var indentConfig = IndentConfig.DEFAULT_INDENT_CONFIG

    override fun beforeFirstNode(editorConfig: EditorConfig) {
        indentConfig =
            IndentConfig(
                indentStyle = editorConfig[INDENT_STYLE_PROPERTY],
                tabWidth = editorConfig[INDENT_SIZE_PROPERTY],
            )
    }

    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        if (node.elementType == IF) {
            visitIfStatement(node, autoCorrect, emit)
        }
    }

    private fun visitIfStatement(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val thenNode = node.findChildByType(THEN)
        val elseKeywordNode = node.findChildByType(ELSE_KEYWORD)
        val elseNode = node.findChildByType(com.pinterest.ktlint.rule.engine.core.api.ElementType.ELSE)

        // Skip when 'then' or 'else' is missing
        if (thenNode == null || elseKeywordNode == null || elseNode == null) {
            return
        }

        // Check if the IF condition is multiline
        val rparBeforeCondition = node.findChildByType(RPAR)
        val conditionIsMultiline = rparBeforeCondition?.prevLeaf { it.isCodeLeaf() }?.textContains('\n') == true

        // Check if the THEN branch is a multiline block
        // This is the location of the fix for the NullPointerException
        val thenActualNode = thenNode.firstChildNode
        val thenIsMultilineBlock =
            thenActualNode != null && // Ensure thenActualNode is not null (empty THEN block)
                thenActualNode.elementType == BLOCK &&
                thenActualNode.textContains('\n')

        // Check if the THEN branch is not a block but still contains a newline
        val thenIsNonBlockAndContainsNewline =
            (thenActualNode == null || thenActualNode.elementType != BLOCK) && // thenActualNode can be null for empty THEN
                thenNode.textContains('\n')

        val elseIsIf = elseNode.firstChildNode?.elementType == IF

        if (conditionIsMultiline || thenIsMultilineBlock || thenIsNonBlockAndContainsNewline) {
            // The 'else' keyword should be on a new line, correctly indented.
            // Exception: if 'else' is followed by 'if' (else-if) and the 'then' branch was a block,
            // 'else' can be on the same line as the closing brace of 'then'.
            val prevLeaf = elseKeywordNode.prevLeaf()
            if (thenActualNode?.elementType == BLOCK && elseIsIf) {
                // Case: if (...) { ... } else if (...)
                if (prevLeaf !is PsiWhiteSpaceImpl || prevLeaf.text != " ") {
                    emit(elseKeywordNode.startOffset, "Expected a single space before 'else if'", true)
                    if (autoCorrect) {
                        elseKeywordNode.upsertWhitespaceBeforeMe(" ")
                    }
                }
            } else {
                // Case: if condition is multiline, or then is multiline block, or then is multiline non-block
                if (prevLeaf?.isWhiteSpaceWithNewline() == false) {
                    emit(elseKeywordNode.startOffset, "Expected a newline before 'else'", true)
                    if (autoCorrect) {
                        elseKeywordNode.upsertWhitespaceBeforeMe(node.indent())
                    }
                }
            }
        } else {
            // Single-line 'if' condition and single-line 'then' branch.
            // 'else' should be on the same line as 'then' (or '}' if 'then' was a block).
            val prevLeaf = elseKeywordNode.prevLeaf()
            if (prevLeaf?.isWhiteSpaceWithNewline() == true) {
                emit(elseKeywordNode.startOffset, "Unexpected newline before 'else'", true)
                if (autoCorrect) {
                    // Simplification: ensure single space. More complex logic might be needed for perfect formatting.
                    prevLeaf.treeParent.removeChild(prevLeaf)
                    elseKeywordNode.upsertWhitespaceBeforeMe(" ")
                }
            } else if (prevLeaf is PsiWhiteSpaceImpl && prevLeaf.text != " ") {
                // Ensure a single space if it's not a newline but multiple spaces
                emit(elseKeywordNode.startOffset, "Expected a single space before 'else'", true)
                if (autoCorrect) {
                    (prevLeaf as LeafPsiElement).rawReplaceWithText(" ")
                }
            } else if (prevLeaf?.isWhiteSpace() == false && prevLeaf.elementType != RBRACE && prevLeaf.elementType != LBRACE) {
                // No whitespace at all, and not preceded by a brace (e.g. if (c) foo else bar)
                emit(elseKeywordNode.startOffset, "Expected a single space before 'else'", true)
                if (autoCorrect) {
                    elseKeywordNode.upsertWhitespaceBeforeMe(" ")
                }
            }

            // If 'else' is not an 'if' and its body is a block, ensure opening brace is spaced correctly.
            if (!elseIsIf && elseNode.firstChildNode?.elementType == BLOCK) {
                val elseLbrace = elseNode.firstChildNode?.findChildByType(LBRACE)
                if (elseLbrace != null && (elseLbrace.prevLeaf()?.isWhiteSpace() == false || elseLbrace.prevLeaf()?.text != " ")) {
                    emit(elseLbrace.startOffset, "Expected a single space before '{' of 'else' block", true)
                    if (autoCorrect) {
                        elseLbrace.upsertWhitespaceBeforeMe(" ")
                    }
                }
            }
        }

        // Ensure no newline between 'else' and its body if the body is not an 'if' statement
        if (!elseIsIf) {
            val elseBody = elseNode.firstChildNode ?: return // elseNode might be empty or contain only comments
            if (elseKeywordNode.lastChildLeafOrSelf().nextSibling.isWhiteSpaceWithNewline() &&
                elseBody.firstChildLeafOrSelf()?.elementType != LBRACE
            ) {
                emit(
                    elseBody.startOffset,
                    "Unexpected newline after 'else' keyword",
                    true,
                )
                if (autoCorrect) {
                    (elseKeywordNode.lastChildLeafOrSelf().nextSibling as LeafPsiElement).rawReplaceWithText(" ")
                }
            }
        }
    }
}

public val MULTI_LINE_IF_ELSE_RULE_ID: RuleId = MultiLineIfElseRule().ruleId
