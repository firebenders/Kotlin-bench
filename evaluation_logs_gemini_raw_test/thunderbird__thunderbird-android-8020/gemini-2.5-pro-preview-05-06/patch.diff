package com.fsck.k9.view

import com.fsck.k9.mail.Address
import org.apache.james.mime4j.util.CharsetUtil

/**
 * Used to parse name & email address pairs entered by the user.
 *
 * TODO: Build a custom implementation that can deal with typical inputs from users who are not familiar with the
 *  RFC 5322 address-list syntax. See (ignored) tests in `UserInputEmailAddressParserTest`.
 *  The changes below make the parser stricter for invalid inputs, as per the issue.
 */
internal class UserInputEmailAddressParser {

    @Throws(NonAsciiEmailAddressException::class, InvalidEmailSyntaxException::class)
    fun parse(input: String): List<Address> {
        if (input.isBlank()) {
            return emptyList()
        }

        val lenientlyParsedAddresses: Array<Address> = try {
            Address.parseUnencoded(input)
        } catch (e: Exception) {
            // Catch exceptions from lenient parsing (e.g., MimeException for unbalanced quotes)
            throw InvalidEmailSyntaxException("Error parsing address list: \"$input\"", e)
        }

        if (lenientlyParsedAddresses.isEmpty() && input.isNotBlank()) {
            // If input was provided but nothing could be parsed by the lenient parser.
            throw InvalidEmailSyntaxException("Invalid address format: \"$input\"")
        }

        return lenientlyParsedAddresses.map { lenientAddress ->
            // displayAddress includes personal part if present, used for error messages and strict parsing.
            val displayAddress = lenientAddress.toEncodedString()
            // rawAddressPart is just the "local@domain" string, used for specific content checks.
            val rawAddressPart = lenientAddress.address

            // 1. Check for incompleteness (missing local part or domain)
            if (lenientAddress.localPart.isNullOrBlank() || lenientAddress.hostname.isNullOrBlank()) {
                throw InvalidEmailSyntaxException("Incomplete address: \"$displayAddress\"")
            }
            // At this point, localPart and hostname are guaranteed to be non-blank.
            // So, rawAddressPart (local@domain) should also be non-null.

            // 2. Check for invalid characters in domain (e.g., '/')
            // lenientAddress.hostname is non-null here due to the check above.
            if (lenientAddress.hostname!!.contains('/')) {
                throw InvalidEmailSyntaxException(
                    "Invalid character '/' in domain part of address: \"$displayAddress\""
                )
            }

            // 3. Check for non-ASCII characters in the address (local@domain part)
            // rawAddressPart is guaranteed non-null here because localPart and hostname are non-null and non-blank.
            if (!CharsetUtil.isASCII(rawAddressPart!!)) {
                throw NonAsciiEmailAddressException("Non-ASCII character in address: \"$rawAddressPart\"")
            }

            // 4. Attempt to parse with the strict parser.
            // Input to strict parser is displayAddress, which includes the personal part,
            // consistent with original logic: Address.parse(address.toEncodedString())
            val strictlyParsedAddresses: Array<Address> = try {
                Address.parse(displayAddress)
            } catch (e: Exception) {
                // If Address.parse (strict) throws an exception (e.g., MimeException from mime4j).
                throw InvalidEmailSyntaxException("Invalid address syntax (strict parser error): \"$displayAddress\"", e)
            }

            if (strictlyParsedAddresses.isEmpty()) {
                // Strict parser returned no addresses, meaning it considered the input invalid.
                throw InvalidEmailSyntaxException("Invalid address format (rejected by strict parser): \"$displayAddress\"")
            }

            val strictlyParsedAddress = strictlyParsedAddresses.first()

            // 5. Final checks on the strictly parsed address (mostly for sanity, strict parser should ensure this).
            if (strictlyParsedAddress.localPart.isNullOrBlank() || strictlyParsedAddress.hostname.isNullOrBlank()) {
                throw InvalidEmailSyntaxException("Incomplete address after strict parsing: \"$displayAddress\"")
            }

            // It's highly unlikely the strict parser would produce a domain with '/', but check just in case.
            // strictlyParsedAddress.hostname is non-null here due to the check above.
            if (strictlyParsedAddress.hostname!!.contains('/')) {
                 throw InvalidEmailSyntaxException(
                    "Invalid character '/' in domain part of address (after strict parsing): \"$displayAddress\""
                )
            }

            strictlyParsedAddress
        }
    }
}

internal class NonAsciiEmailAddressException(message: String) : Exception(message)

internal class InvalidEmailSyntaxException(message: String, cause: Throwable? = null) : Exception(message, cause)
