    }

    fun buildChange(
        previousValue: Long?,
        value: Long,
        positive: Boolean,
        isFormattedNumber: Boolean
    ): String? {
        return previousValue?.let {
            val difference = value - previousValue
            // mapLongToString returns a string representation of the difference.
            // e.g., "2" for difference=2, "-2" for difference=-2, "0" for difference=0.
            val formattedDifference = mapLongToString(difference, isFormattedNumber)

            // Handle cases where previousValue is 0 (which would lead to infinite percentage)
            if (previousValue == 0L) {
                if (value == 0L) {
                    // Previous: 0, Current: 0. Difference is 0.
                    // Fall through to normal handling which should result in something like "+0 (0%)"
                    // as `positive` will be true and `percentageString` will be "0".
                } else {
                    // Previous: 0, Current: non-zero. This is the "infinite" percentage case.
                    // Expected: Show only the increase/decrease amount, e.g., "+2" or "-2".
                    if (difference > 0L) {
                        // formattedDifference is "X" (e.g. "2" for a difference of 2). Prepend "+" to get "+X".
                        return "+$formattedDifference"
                    } else { // difference < 0L
                        // formattedDifference is already "-X" (e.g. "-2" for a difference of -2).
                        return formattedDifference
                    }
                }
            }

            // Normal percentage calculation for non-infinite cases (previousValue != 0L)
            // or for 0-to-0 change (which is handled by previousValue == value).
            val percentageString = when {
                previousValue == value -> "0" // No change (e.g., X to X, or 0 to 0)
                // previousValue == 0L and value != 0L is handled by the `if (previousValue == 0L)` block above.
                // So, if we reach here, previousValue is guaranteed not to be 0 (unless value is also 0,
                // in which case the `previousValue == value` condition is met).
                else -> { // This implies previousValue != 0L
                    val percentageValue = difference.toFloat() / previousValue
                    percentFormatter.format(value = percentageValue, rounding = HALF_UP)
                }
            }

            // Use existing string resources for formatting the output.
            // `positive` flag determines if it's an increase/same (use R.string.stats_traffic_increase)
            // or a decrease (use R.string.stats_traffic_change).
            // R.string.stats_traffic_increase likely prepends a "+" to formattedDifference if it's not already signed.
            // R.string.stats_traffic_change uses formattedDifference as is (which includes "-" if negative).
            if (positive) {
                resourceProvider.getString(R.string.stats_traffic_increase, formattedDifference, percentageString)
            } else {
                resourceProvider.getString(R.string.stats_traffic_change, formattedDifference, percentageString)
            }
        }
    }

    private fun mapLongToString(value: Long, isFormattedNumber: Boolean): String {
        return when (isFormattedNumber) {
            true -> toFormattedString(value)
            false -> value.toString()
        }
    }
}

fun getBarWidth(views: Int, maxViews: Int) = getBarWidth(views.toDouble(), maxViews.toDouble())

fun getBarWidth(views: Long, maxViews: Long) = getBarWidth(views.toDouble(), maxViews.toDouble())

private fun getBarWidth(
    views: Double,
    maxViews: Double
): Int? {
    return if (maxViews > 0) {
        ((views / maxViews) * 100).toInt()
    } else {
        null
    }
}
