    fun getLineChartEntryContentDescriptions(
        @StringRes entryType: Int,
        entries: List<Line>
    ): List<String> {
        val contentDescriptions = mutableListOf<String>()
        entries.forEach { bar ->
            val contentDescription = resourceProvider.getString(
