package org.wordpress.android.ui.deeplinks.handlers

import org.wordpress.android.fluxc.model.SiteModel
import org.wordpress.android.ui.deeplinks.DeepLinkNavigator.NavigateAction
import org.wordpress.android.ui.deeplinks.DeepLinkNavigator.NavigateAction.OpenStats
import org.wordpress.android.ui.deeplinks.DeepLinkNavigator.NavigateAction.OpenStatsForSite
import org.wordpress.android.ui.deeplinks.DeepLinkNavigator.NavigateAction.OpenStatsForSiteAndTimeframe
import org.wordpress.android.ui.deeplinks.DeepLinkNavigator.NavigateAction.OpenStatsForTimeframe
import org.wordpress.android.ui.deeplinks.DeepLinkNavigator.NavigateAction.OpenJetpackStaticPosterView
// Assuming OpenStats, OpenStatsForSite, OpenStatsForSiteAndTimeframe, OpenStatsForTimeframe
// are updated to accept an optional StatsSection parameter.
// If not, new specific actions like OpenStatsTrafficTab(site, timeframe) and OpenStatsSubscribersTab(site)
// would be defined in DeepLinkNavigator.NavigateAction and used here.
import org.wordpress.android.ui.deeplinks.DeepLinkUriUtils
import org.wordpress.android.ui.deeplinks.DeepLinkingIntentReceiverViewModel.Companion.APPLINK_SCHEME
import org.wordpress.android.ui.deeplinks.DeepLinkingIntentReceiverViewModel.Companion.HOST_WORDPRESS_COM
import org.wordpress.android.ui.deeplinks.DeepLinkingIntentReceiverViewModel.Companion.SITE_DOMAIN
import org.wordpress.android.ui.jetpackoverlay.JetpackFeatureRemovalPhaseHelper
import org.wordpress.android.ui.stats.StatsTimeframe
import org.wordpress.android.ui.stats.refresh.lists.StatsListViewModel.StatsSection
import org.wordpress.android.util.UriWrapper
import javax.inject.Inject

class StatsLinkHandler
@Inject constructor(
    private val deepLinkUriUtils: DeepLinkUriUtils,
    private val jetpackFeatureRemovalPhaseHelper: JetpackFeatureRemovalPhaseHelper
) : DeepLinkHandler {
    /**
     * Builds navigate action from URL like:
     * https://wordpress.com/stats/$timeframe/$site
     * https://wordpress.com/stats/traffic/$timeframe/$site
     * https://wordpress.com/stats/subscribers/$site
     * where timeframe and site are optional
     * or
     * wordpress://stats
     * wordpress://stats/traffic
     * wordpress://stats/subscribers
     */
    override fun buildNavigateAction(uri: UriWrapper): NavigateAction {
        if (jetpackFeatureRemovalPhaseHelper.shouldShowStaticPage()) {
            return OpenJetpackStaticPosterView
        }

        var site: SiteModel? = null
        var timeframe: StatsTimeframe? = null
        var section: StatsSection? = null

        val allSegments = uri.pathSegments
        var currentIndex = 0

        // Determine the starting index of parameters after the "stats" segment
        if (allSegments.isNotEmpty()) {
            if (allSegments[0] == STATS_PATH) {
                // Handles https://wordpress.com/stats/... or wordpress://stats/stats/...
                currentIndex = 1
            } else if (uri.host == STATS_PATH) {
                // Handles wordpress://stats/traffic (where "traffic" is the first segment)
                currentIndex = 0
            }
            // If host is wordpress.com but first segment isn't "stats", it's not a valid stats link
            // and should have been filtered by shouldHandleUrl.
        }

        val firstParam = allSegments.getOrNull(currentIndex)
        val secondParam = allSegments.getOrNull(currentIndex + 1)
        val thirdParam = allSegments.getOrNull(currentIndex + 2)

        when (firstParam) {
            TRAFFIC_PATH_SEGMENT -> {
                section = StatsSection.TRAFFIC
                // URI: stats/traffic/{timeframe?}/{site?}
                // secondParam can be timeframe or site. thirdParam can only be site.
                if (thirdParam != null) { // stats/traffic/timeframe/site
                    timeframe = secondParam?.toStatsTimeframe()
                    site = thirdParam.toSite()
                } else if (secondParam != null) { // stats/traffic/site or stats/traffic/timeframe
                    site = secondParam.toSite()
                    if (site == null) {
                        timeframe = secondParam.toStatsTimeframe()
                    }
                }
            }
            SUBSCRIBERS_PATH_SEGMENT -> {
                section = StatsSection.SUBSCRIBERS
                // URI: stats/subscribers/{site?}
                // secondParam can be site.
                site = secondParam?.toSite()
            }
            else -> {
                // General stats link (not specific to traffic/subscribers tabs directly in URL)
                // URI: stats/{timeframe?}/{site?}
                // firstParam can be timeframe or site. secondParam can only be site.
                if (secondParam != null) { // stats/timeframe/site or stats/site/junk
                    timeframe = firstParam?.toStatsTimeframe()
                    site = secondParam.toSite()
                    // If firstParam was not a timeframe, it might be a site, and secondParam is junk
                    if (timeframe == null && site == null) { // try parsing firstParam as site
                        site = firstParam?.toSite()
                    } else if (timeframe == null) { // firstParam was not a timeframe, so it must be a site.
                        site = firstParam?.toSite()
                        // timeframe remains null, site is from firstParam, secondParam is ignored or junk
                    }
                } else if (firstParam != null) { // stats/timeframe or stats/site
                    timeframe = firstParam.toStatsTimeframe()
                    if (timeframe == null) {
                        site = firstParam.toSite()
                    }
                }
            }
        }

        // Construct NavigateAction, assuming actions can take an optional StatsSection
        return when {
            site != null && timeframe != null -> OpenStatsForSiteAndTimeframe(site, timeframe, section)
            site != null -> OpenStatsForSite(site, section)
            timeframe != null -> OpenStatsForTimeframe(timeframe, section)
            section != null -> OpenStats(section) // For paths like /stats/traffic or /stats/subscribers
            else -> OpenStats() // Default /stats
        }
    }

    /**
     * Returns true if the URI should be handled by StatsLinkHandler.
     * The handled links are `https://wordpress.com/stats/...` and `wordpress://stats/...`
     */
    override fun shouldHandleUrl(uri: UriWrapper): Boolean {
        return (uri.host == HOST_WORDPRESS_COM && uri.pathSegments.firstOrNull() == STATS_PATH) ||
            uri.host == STATS_PATH
    }

    override fun stripUrl(uri: UriWrapper): String {
        val builder = StringBuilder()
        val isWordPressScheme = uri.host == STATS_PATH
        if (isWordPressScheme) {
            builder.append(APPLINK_SCHEME) // "wordpress://"
        } else {
            builder.append("$HOST_WORDPRESS_COM/")
        }
        builder.append(STATS_PATH) // "stats"

        val allSegments = uri.pathSegments
        var currentIndex = 0
        if (allSegments.isNotEmpty()) {
            if (allSegments[0] == STATS_PATH) {
                currentIndex = 1
            } else if (uri.host == STATS_PATH) {
                currentIndex = 0
            }
        }

        val params = allSegments.drop(currentIndex)

        if (params.isNotEmpty()) {
            when (params[0]) {
                TRAFFIC_PATH_SEGMENT -> {
                    builder.append("/$TRAFFIC_PATH_SEGMENT")
                    if (params.size > 1) {
                        val potentialTimeframeSegment = params[1]
                        if (potentialTimeframeSegment.toStatsTimeframe() != null) {
                            builder.append("/$potentialTimeframeSegment") // Append timeframe string
                            if (params.size > 2 && params[2].toSite() != null) {
                                builder.append("/$SITE_DOMAIN")
                            }
                        } else if (potentialTimeframeSegment.toSite() != null) {
                            builder.append("/$SITE_DOMAIN")
                        }
                    }
                }
                SUBSCRIBERS_PATH_SEGMENT -> {
                    builder.append("/$SUBSCRIBERS_PATH_SEGMENT")
                    if (params.size > 1 && params[1].toSite() != null) {
                        builder.append("/$SITE_DOMAIN")
                    }
                }
                else -> { // General stats: timeframe or site
                    val potentialTimeframeSegment = params[0]
                    if (potentialTimeframeSegment.toStatsTimeframe() != null) {
                        builder.append("/$potentialTimeframeSegment") // Append timeframe string
                        if (params.size > 1 && params[1].toSite() != null) {
                            builder.append("/$SITE_DOMAIN")
                        }
                    } else if (potentialTimeframeSegment.toSite() != null) {
                        builder.append("/$SITE_DOMAIN")
                    }
                }
            }
        }
        return builder.toString()
    }

    /**
     * Converts HOST name of a site to SiteModel. It finds the Site in the current local sites and matches the name
     * to the host.
     */
    private fun String.toSite(): SiteModel? {
        return deepLinkUriUtils.hostToSite(this)
    }

    private fun String.toStatsTimeframe(): StatsTimeframe? {
        return when (this.lowercase()) { // Use lowercase for case-insensitivity
            "day" -> StatsTimeframe.DAY
            "week" -> StatsTimeframe.WEEK
            "month" -> StatsTimeframe.MONTH
            "year" -> StatsTimeframe.YEAR
            "insights" -> StatsTimeframe.INSIGHTS
            else -> null
        }
    }

    companion object {
        private const val STATS_PATH = "stats"
        private const val TRAFFIC_PATH_SEGMENT = "traffic"
        private const val SUBSCRIBERS_PATH_SEGMENT = "subscribers"
    }
}

