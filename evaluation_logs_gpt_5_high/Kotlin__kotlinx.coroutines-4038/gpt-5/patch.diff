package kotlinx.coroutines.flow

import kotlinx.coroutines.flow.internal.AbortFlowException
import kotlinx.coroutines.flow.internal.checkOwnership

/**
 * Returns the first element emitted by the flow and then cancels the collection to avoid
 * waiting for upstream completion. This guarantees that terminal operators like [first]
 * do not hang even when an intermediate operator (e.g. onCompletion) suspends on normal
 * completion of its upstream.
 *
 * Throws [NoSuchElementException] if the flow is empty.
 */
public suspend fun <T> Flow<T>.first(): T {
    var result: Any? = null
    var found = false
    // Collector that aborts the collection immediately after receiving the first value
    val collector = object : FlowCollector<T> {
        override suspend fun emit(value: T) {
            result = value
            found = true
            // Abort collection so that downstream does not wait for upstream's normal completion
            throw AbortFlowException(this)
        }
    }
    try {
        collect(collector)
    } catch (e: AbortFlowException) {
        // Swallow only if it was our own abort
        e.checkOwnership(collector)
    }
    if (!found) throw NoSuchElementException("Expected at least one element")
    @Suppress("UNCHECKED_CAST")
    return result as T
}
