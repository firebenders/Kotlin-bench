package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.ElementType.BLOCK_COMMENT
import com.pinterest.ktlint.rule.engine.core.api.ElementType.EOL_COMMENT
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode

/**
 * Flags usage of ktlint specific suppression directives in comments, like:
 *   // ktlint-disable [rules...]
 *   /* ktlint-disable [rules...] *&#47; ... /* ktlint-enable [rules...] *&#47;
 *
 * Support for these directives has been removed. Users should migrate to @Suppress annotations:
 *   @Suppress("ktlint") or @Suppress("ktlint:rule-set-id:rule-id")
 *
 * Note: This rule intentionally can not be suppressed by @Suppress. It is used to support migration away from
 * comment-based directives.
 */
public class ObsoleteKtlintDirectiveRule :
    StandardRule(
        id = "obsolete-ktlint-directive",
    ) {
    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        val isComment = node.elementType == EOL_COMMENT || node.elementType == BLOCK_COMMENT
        if (!isComment) {
            return
        }
        val text = node.text
        if (text.contains("ktlint-disable") || text.contains("ktlint-enable")) {
            emit(
                node.startOffset,
                "The 'ktlint-disable' / 'ktlint-enable' directives are no longer supported. Use @Suppress annotations instead.",
                false,
            )
        }
    }
}

public val OBSOLETE_KTLINT_DIRECTIVE_RULE_ID: RuleId = ObsoleteKtlintDirectiveRule().ruleId
