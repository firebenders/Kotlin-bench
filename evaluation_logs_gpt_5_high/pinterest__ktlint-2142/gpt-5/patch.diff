package com.pinterest.ktlint.ruleset.standard.rules

import com.pinterest.ktlint.rule.engine.core.api.ElementType.BLOCK
import com.pinterest.ktlint.rule.engine.core.api.ElementType.ELSE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.ELSE_KEYWORD
import com.pinterest.ktlint.rule.engine.core.api.ElementType.IF
import com.pinterest.ktlint.rule.engine.core.api.ElementType.RBRACE
import com.pinterest.ktlint.rule.engine.core.api.ElementType.THEN
import com.pinterest.ktlint.rule.engine.core.api.ElementType.WHITE_SPACE
import com.pinterest.ktlint.rule.engine.core.api.Rule
import com.pinterest.ktlint.rule.engine.core.api.RuleId
import com.pinterest.ktlint.rule.engine.core.api.upsertWhitespaceBeforeMe
import com.pinterest.ktlint.ruleset.standard.StandardRule
import org.jetbrains.kotlin.com.intellij.lang.ASTNode

/**
 * Ensures consistent formatting of multi-line if / else statements.
 *
 * Historically this rule crashed on malformed if-expressions where the THEN branch was missing (e.g. "else if (cond) else { }").
 * This implementation guards against such cases by null-checking branch nodes before dereferencing them.
 */
public class MultiLineIfElseRule : StandardRule(id = "multiline-if-else"), Rule.OfficialCodeStyle {

    override fun beforeVisitChildNodes(
        node: ASTNode,
        autoCorrect: Boolean,
        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
    ) {
        if (node.elementType != IF) {
            return
        }

        // If there is no else, nothing to do.
        val elseNode = node.findChildByType(ELSE) ?: return

        // Defensive: If THEN is missing (which can happen with malformed constructs),
        // bail out early to prevent NullPointerExceptions.
        val thenNode = node.findChildByType(THEN) ?: return
        val thenFirstChild = thenNode.firstChildNode ?: return

        // Only enforce placement when the THEN branch is a block ("{ ... }").
        if (thenFirstChild.elementType != BLOCK) {
            return
        }

        val rbrace = thenFirstChild.findChildByType(RBRACE) ?: return

        // If the whitespace between the closing brace '}' and the 'else' is a newline,
        // move 'else' to the same line by replacing the whitespace with a single space.
        val wsBetweenThenAndElse = elseNode.treePrev
        val hasNewlineBetweenThenAndElse =
            wsBetweenThenAndElse?.elementType == WHITE_SPACE && wsBetweenThenAndElse.textContains('\n')

        if (hasNewlineBetweenThenAndElse) {
            val elseKeyword = elseNode.findChildByType(ELSE_KEYWORD)
            val errorOffset =
                // Prefer to report at the 'else' keyword when available
                (elseKeyword ?: elseNode).startOffset

            emit(
                errorOffset,
                "The else keyword should be on the same line as the closing brace of the previous block",
                true,
            )
            if (autoCorrect) {
                // Replace whitespace before the entire ELSE node so that both "else" and "else if"
                // are moved to the same line as the preceding '}'.
                elseNode.upsertWhitespaceBeforeMe(" ")
            }
        }
    }
}

public val MULTILINE_IF_ELSE_RULE_ID: RuleId = MultiLineIfElseRule().ruleId
