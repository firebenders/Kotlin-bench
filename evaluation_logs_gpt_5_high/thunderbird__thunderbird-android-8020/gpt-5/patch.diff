package com.fsck.k9.view

import com.fsck.k9.mail.Address
import org.apache.james.mime4j.util.CharsetUtil

/**
 * Used to parse name & email address pairs entered by the user.
 *
 * TODO: Build a custom implementation that can deal with typical inputs from users who are not familiar with the
 *  RFC 5322 address-list syntax. See (ignored) tests in `UserInputEmailAddressParserTest`.
 */
internal class UserInputEmailAddressParser {

    @Throws(NonAsciiEmailAddressException::class)
    fun parse(input: String): List<Address> {
        return Address.parseUnencoded(input)
            .mapNotNull { address ->
                when {
                    // Treat addresses without a proper domain or with an RFC 5321-invalid domain as incomplete.
                    address.isIncompleteOrInvalidRfc5321() -> null
                    address.isNonAsciiAddress() -> throw NonAsciiEmailAddressException(address.address)
                    else -> Address.parse(address.toEncodedString()).firstOrNull()
                }
            }
    }

    /**
     * Consider an address incomplete if:
     * - the hostname extracted by the parser is missing, or
     * - the mailbox is not RFC 5321 compliant (e.g. domain contains a slash like "gmail.com/")
     */
    private fun Address.isIncompleteOrInvalidRfc5321(): Boolean {
        return hostname.isNullOrBlank() || !isRfc5321Compliant()
    }

    /**
     * Basic RFC 5321 mailbox validation focusing on the domain part to catch common user mistakes.
     *
     * - local-part validation is delegated to Address.parse* (we only ensure an '@' is present)
     * - domain can be a name (labels separated by dots) or a domain-literal ([...])
     * - disallows characters like '/' in the domain name (e.g., "user@gmail.com/" is invalid)
     */
    private fun Address.isRfc5321Compliant(): Boolean {
        val mailbox = address
        val atIndex = mailbox.lastIndexOf('@')
        if (atIndex <= 0 || atIndex == mailbox.length - 1) return false

        val domain = mailbox.substring(atIndex + 1).trim()
        if (domain.isEmpty()) return false

        // Accept domain-literal ([...]) per RFC 5321 without deep inspection.
        if (DOMAIN_LITERAL_REGEX.matches(domain)) {
            return true
        }

        // Otherwise require a valid domain name (no '/' or other illegal chars)
        return DOMAIN_NAME_REGEX.matches(domain)
    }

    private fun Address.isNonAsciiAddress() = !CharsetUtil.isASCII(address)
}

/**
 * Thrown when the user enters a non-ASCII email address.
 */
internal class NonAsciiEmailAddressException(message: String) : Exception(message)

/**
 * Regex for domain names:
 * - one or more labels separated by dots
 * - label: [a-z0-9] ( [a-z0-9-]{0,61} [a-z0-9] )?
 * - case-insensitive
 * - does not allow trailing dot or illegal characters like '/'
 */
private val DOMAIN_NAME_REGEX =
    Regex("(?i)^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)(?:\\.(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?))*$")

/**
 * Regex for a simple domain-literal:
 * - [ dtext ], where dtext is any visible ASCII except backslash and brackets
 * - This is a conservative check aimed at early user input validation, not a full RFC parser.
 */
private val DOMAIN_LITERAL_REGEX =
    Regex("^\\[[\\x21-\\x5A\\x5E-\\x7E]+\\]$")
