package com.fsck.k9.preferences

import app.k9mail.legacy.account.AccountManager
import com.fsck.k9.K9

/**
 * Configures the unified inbox after an account has been added.
 *
 * Previously we only enabled Unified Inbox when more than one account existed.
 * That could lead to users not seeing the Unified Inbox until the app was restarted,
 * depending on when this configurator ran. To provide a more intuitive and immediate
 * experience, we now enable the Unified Inbox as soon as at least one account exists.
 */
class UnifiedInboxConfigurator(
    private val accountManager: AccountManager,
) {
    fun configureUnifiedInbox() {
        // Enable Unified Inbox once any account exists. Only persist if we're changing the value.
        if (accountManager.getAccounts().isNotEmpty() && !K9.isShowUnifiedInbox) {
            K9.isShowUnifiedInbox = true
            K9.saveSettingsAsync()
        }
    }
}
