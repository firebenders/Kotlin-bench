+
+        /**
+         * Removes `FLIP_OR_ANSWER_RECOMMENDED` and `FLIP_OR_ANSWER_BETTER_THAN_RECOMMENDED`
+         * commands, migrating their user-assigned bindings to
+         * `FLIP_OR_ANSWER_EASE3` and `FLIP_OR_ANSWER_EASE4` respectively.
+         *
+         * These commands were redundant: "recommended" was always EASE_3,
+         * and "better than recommended" was always EASE_4.
+         */
+        internal class RemoveRecommendedButtons : PreferenceUpgrade(12) {
+            override fun upgrade(preferences: SharedPreferences) {
+                migrateBindings(
+                    preferences,
+                    "binding_FLIP_OR_ANSWER_RECOMMENDED",
+                    ViewerCommand.FLIP_OR_ANSWER_EASE3
+                )
+                migrateBindings(
+                    preferences,
+                    "binding_FLIP_OR_ANSWER_BETTER_THAN_RECOMMENDED",
+                    ViewerCommand.FLIP_OR_ANSWER_EASE4
+                )
+            }
+
+            private fun migrateBindings(
+                preferences: SharedPreferences,
+                oldKey: String,
+                targetCommand: ViewerCommand
+            ) {
+                if (!preferences.contains(oldKey)) return
+
+                val prefValue = preferences.getString(oldKey, null)
+                val oldBindings = MappableBinding.fromPreferenceString(prefValue)
+                for (binding in oldBindings) {
+                    targetCommand.addBindingAtEnd(preferences, binding)
+                }
+                preferences.edit { remove(oldKey) }
+            }
+        }
     }
 }
 
