+
+        /**
+         * Migrates user bindings from the removed `FLIP_OR_ANSWER_RECOMMENDED` and
+         * `FLIP_OR_ANSWER_BETTER_THAN_RECOMMENDED` commands to `FLIP_OR_ANSWER_EASE3`
+         * and `FLIP_OR_ANSWER_EASE4` respectively.
+         */
+        internal class UpgradeRecommendedCommandsToEaseCommands : PreferenceUpgrade(12) {
+            override fun upgrade(preferences: SharedPreferences) {
+                migrateBinding(preferences, "binding_FLIP_OR_ANSWER_RECOMMENDED", ViewerCommand.FLIP_OR_ANSWER_EASE3)
+                migrateBinding(preferences, "binding_FLIP_OR_ANSWER_BETTER_THAN_RECOMMENDED", ViewerCommand.FLIP_OR_ANSWER_EASE4)
+            }
+
+            private fun migrateBinding(preferences: SharedPreferences, oldKey: String, targetCommand: ViewerCommand) {
+                val oldValue = preferences.getString(oldKey, null) ?: return
+                val oldBindings = MappableBinding.fromPreferenceString(oldValue)
+                for (binding in oldBindings) {
+                    targetCommand.addBindingAtEnd(preferences, binding)
+                }
+                preferences.edit { remove(oldKey) }
+            }
+        }
     }
 }
 
