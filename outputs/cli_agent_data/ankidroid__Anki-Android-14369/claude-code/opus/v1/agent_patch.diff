+
+        /**
+         * Migrates bindings from the removed 'Answer recommended (green)' and
+         * 'Answer better than recommended' commands to 'Answer button 3' and
+         * 'Answer button 4' respectively.
+         */
+        internal class UpgradeRecommendedButtons : PreferenceUpgrade(12) {
+            override fun upgrade(preferences: SharedPreferences) {
+                migrateBindings(
+                    preferences,
+                    "binding_FLIP_OR_ANSWER_RECOMMENDED",
+                    ViewerCommand.FLIP_OR_ANSWER_EASE3
+                )
+                migrateBindings(
+                    preferences,
+                    "binding_FLIP_OR_ANSWER_BETTER_THAN_RECOMMENDED",
+                    ViewerCommand.FLIP_OR_ANSWER_EASE4
+                )
+            }
+
+            private fun migrateBindings(
+                preferences: SharedPreferences,
+                oldKey: String,
+                targetCommand: ViewerCommand
+            ) {
+                val oldValue = preferences.getString(oldKey, null) ?: return
+                val oldBindings = MappableBinding.fromPreferenceString(oldValue)
+                for (binding in oldBindings) {
+                    targetCommand.addBindingAtEnd(preferences, binding)
+                }
+                preferences.edit { remove(oldKey) }
+            }
+        }
     }
 }
 
