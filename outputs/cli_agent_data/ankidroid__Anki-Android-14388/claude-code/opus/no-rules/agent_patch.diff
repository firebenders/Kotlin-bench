+    /** Attaches all possible [ControlPreference] elements grouped by [CommandGroup] */
+    fun addAllControlPreferencesToCategory(screen: androidx.preference.PreferenceScreen) {
+        for (group in CommandGroup.values()) {
+            val commands = ViewerCommand.values().filter { it.group == group }
+            if (commands.isEmpty()) continue
+            val category = PreferenceCategory(screen.context).apply {
+                title = screen.context.getString(group.titleRes)
+            }
+            screen.addPreference(category)
+            for (command in commands) {
+                val preference = ControlPreference(screen.context).apply {
+                    setTitle(command.resourceId)
+                    key = command.preferenceKey
+                    setDefaultValue(command.defaultValue.toPreferenceString())
+                }
