 import com.ichi2.preferences.ControlPreference
@@ -28,8 +29,26 @@ class ControlsSettingsFragment : SettingsFragment() {
         get() = "prefs.controls"
 
     override fun initSubscreen() {
+        // Remove the placeholder category and add grouped categories dynamically
         val commandMappingCategory = requirePreference<PreferenceCategory>(R.string.controls_command_mapping_cat_key)
-        addAllControlPreferencesToCategory(commandMappingCategory)
+        preferenceScreen.removePreference(commandMappingCategory)
+
+        val commandsByCategory = ViewerCommand.values().groupBy { it.category }
+        for (category in CommandCategory.values()) {
+            val commands = commandsByCategory[category] ?: continue
+            val preferenceCategory = PreferenceCategory(preferenceScreen.context).apply {
+                setTitle(category.resourceId)
+            }
+            preferenceScreen.addPreference(preferenceCategory)
+            for (command in commands) {
+                val preference = ControlPreference(preferenceCategory.context).apply {
+                    setTitle(command.resourceId)
+                    key = command.preferenceKey
+                    setDefaultValue(command.defaultValue.toPreferenceString())
+                }
+                preferenceCategory.addPreference(preference)
+            }
+        }
     }
 
