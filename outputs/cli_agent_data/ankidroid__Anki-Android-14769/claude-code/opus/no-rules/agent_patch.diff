+    /**
+     * Converts a card ordinal (as returned by [Card.ord]) to a card index
+     * suitable for use with [getDummyCard].
+     *
+     * For standard note types, the ordinal is the same as the index.
+     * For cloze note types, the ordinal may differ from the index:
+     * e.g. `{{c1::A}} {{c3::B}}` has ordinals [0, 2] but indices [0, 1]
+     */
+    private fun indexFromOrdinal(col: Collection, ordinal: Int): Int {
+        if (mEditedNotetype == null || !mEditedNotetype!!.isCloze) {
+            return ordinal
+        }
+        // Build a note with the field values to determine cloze numbers
+        val fieldValues = getBundleEditFields(mNoteEditorBundle)
+        val n = col.newNote(mEditedNotetype!!)
+        for (i in fieldValues.indices) {
+            if (i < n.fields.size) {
+                n.setField(i, fieldValues[i])
+            }
+        }
+        val clozeNumbers = col.clozeNumbersInNote(n)
+        // ord is 0-based, cloze numbers are 1-based
+        val clozeNumber = ordinal + 1
+        val index = clozeNumbers.indexOf(clozeNumber)
+        return if (index >= 0) index else 0
+    }
+
