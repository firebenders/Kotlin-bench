+    /**
+     * Converts a card ordinal to an index into the list of available cards.
+     * For standard note types, ord == index.
+     * For cloze note types, the index is the position of (ord + 1) in the sorted cloze numbers.
+     * @param ordinal The `ord` of the card
+     * @return The index into the card list, or 0 if not found
+     */
+    private fun ordinalToIndex(col: Collection, ordinal: Int): Int {
+        if (mEditedNotetype?.isCloze == true) {
+            val note = col.newNote(mEditedNotetype!!)
+            // fill in the fields from the note editor bundle if available
+            val fieldValues = getBundleEditFields(mNoteEditorBundle)
+            for (i in 0 until minOf(fieldValues.size, note.fields.size)) {
+                note.setField(i, fieldValues[i])
+            }
+            val clozeNumbers = col.clozeNumbersInNote(note)
+            val index = clozeNumbers.indexOf(ordinal + 1)
+            return if (index >= 0) index else 0
+        }
+        return ordinal
+    }
+
