+    /**
+     * Converts an ordinal (`card.ord`) to a card index suitable for the previewer.
+     *
+     * For standard note types, the ordinal is the same as the card index.
+     * For cloze note types, the ordinal is `clozeNumber - 1`, and the card index is the
+     * position of that cloze number in the sorted list of cloze numbers in the note.
+     */
+    private fun getCardIndexFromOrdinal(col: Collection, ordinal: Int): Int {
+        val notetype = mEditedNotetype ?: return ordinal
+        if (!notetype.isCloze) return ordinal
+        val fieldValues = getBundleEditFields(mNoteEditorBundle)
+        val note = col.newNote(notetype)
+        for (i in fieldValues.indices) {
+            if (i < note.fields.size) {
+                note.setField(i, fieldValues[i])
+            }
+        }
+        val clozeNumbers = col.clozeNumbersInNote(note)
+        val clozeNumber = ordinal + 1
+        val index = clozeNumbers.indexOf(clozeNumber)
+        return if (index >= 0) index else 0
+    }
