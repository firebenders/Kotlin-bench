+    /**
+     * Executes a user-defined JavaScript action.
+     *
+     * This is similar to AnkiMobile's "User Action" feature. Card templates can define
+     * JavaScript variables named `userJs1` through `userJs9` which hold function references.
+     * When the corresponding user action is triggered (via gesture, gamepad, keyboard, etc.),
+     * the function assigned to that variable is called.
+     *
+     * Example in card template:
+     * ```
+     * var userJs1 = revealNext;
+     * ```
+     *
+     * @param actionNumber the user action number (1-9)
+     */
+    private fun executeUserAction(actionNumber: Int) {
+        loadUrlInViewer("javascript: if (typeof userJs$actionNumber !== 'undefined') { userJs$actionNumber(); }")
+    }
