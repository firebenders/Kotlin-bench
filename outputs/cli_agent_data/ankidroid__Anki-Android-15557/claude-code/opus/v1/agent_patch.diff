+    private fun trimJsString(jsResult: String): String {
+        // evaluateJavascript returns a JSON-encoded value (e.g. "\"hello\"" or "null")
+        if (jsResult == "null" || jsResult.isEmpty()) {
+            return ""
+        }
+        return try {
+            org.json.JSONTokener(jsResult).nextValue() as? String ?: ""
+        } catch (_: org.json.JSONException) {
+            ""
+        }
+    }
