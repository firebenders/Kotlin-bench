+        // If the URL has a fragment, it may be part of the filename (e.g. "image#1.png")
+        val fragment = url.fragment
+        if (fragment != null) {
+            val fileWithFragment = File(mediaDir, "$path#$fragment")
+            if (fileWithFragment.exists()) {
+                return fileWithFragment
+            }
+        }
