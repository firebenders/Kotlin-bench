+
+    private fun wouldExceedMaxLineLength(colonNode: ASTNode): Boolean {
+        if (maxLineLength == MAX_LINE_LENGTH_PROPERTY_OFF) {
+            return false
+        }
+        // Calculate the length of the line if the return type were placed on the same line as the colon.
+        // The colon column gives us the position of the colon in the current line.
+        // After the colon, we'd have ": " (space) and then the text up to the next newline on the following line.
+        val columnOfColon = colonNode.column
+        val lengthAfterColon = textLengthAfterColonOnNextLine(colonNode)
+        // Line length would be: (column of colon - 1) + 1 (colon) + 1 (space) + length of return type text
+        return (columnOfColon - 1 + 1 + 1 + lengthAfterColon) > maxLineLength
+    }
+
+    private fun textLengthAfterColonOnNextLine(colonNode: ASTNode): Int {
+        // Skip the whitespace after the colon (which contains the newline) and measure text until end or next newline
+        var length = 0
+        var leaf = colonNode.nextLeaf()
+        // Skip the whitespace node that contains the newline
+        if (leaf != null && leaf.elementType == WHITE_SPACE) {
+            leaf = leaf.nextLeaf()
+        }
+        while (leaf != null) {
+            if (leaf.textContains('\n')) {
+                // Only count text up to the newline
+                val textBeforeNewline = leaf.text.substringBefore('\n')
+                length += textBeforeNewline.length
+                break
+            }
+            length += leaf.textLength
+            leaf = leaf.nextLeaf()
+        }
+        return length
+    }
