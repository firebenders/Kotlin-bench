+    private fun lineLengthAfterCollapsingWhitespace(
+        colonNode: ASTNode,
+        whiteSpaceAfterColon: ASTNode,
+    ): Int {
+        // Length of the current line up to and including the colon + one space
+        var length = colonNode.column + 1 // column is 1-indexed and already includes position before colon, +1 for space after colon
+
+        // Add the length of the remaining text on the line after the whitespace
+        var leaf = whiteSpaceAfterColon.nextLeaf()
+        while (leaf != null) {
+            if (leaf.elementType == WHITE_SPACE && leaf.textContains('\n')) {
+                // Only count text before the newline
+                val textBeforeNewline = leaf.text.substringBefore('\n')
+                length += textBeforeNewline.length
+                break
+            }
+            length += leaf.textLength
+            leaf = leaf.nextLeaf()
+        }
+        return length
