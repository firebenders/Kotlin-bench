+    /**
+     * Check if this annotation entry is in the modifier list of a primary constructor.
+     */
+    private fun ASTNode.isConstructorAnnotation() =
+        treeParent?.elementType == MODIFIER_LIST &&
+            treeParent?.treeParent?.elementType == PRIMARY_CONSTRUCTOR
+
+    /**
+     * In ktlint_official code style, annotations before a class constructor should each be placed on a separate line.
+     *
+     * Disallow (ktlint_official):
+     *     data class Foo @Bar1 @Bar2("bar") constructor(val foobar: Int)
+     *
+     * Expected:
+     *     data class Foo
+     *         @Bar1
+     *         @Bar2("bar")
+     *         constructor(val foobar: Int)
+     */
+    private fun checkForAnnotationOnConstructorToBePlacedOnSeparateLine(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+        autoCorrect: Boolean,
+    ) {
+        val newlineWithIndent = getNewlineWithIndentForConstructorAnnotation(node)
+
+        if (node.isFirstAnnotationEntry() && !node.isPrecededByNewline()) {
+            emit(
+                node.startOffset,
+                "Annotation must be placed on a separate line when it is a constructor annotation",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .firstChildLeafOrSelf()
+                    .upsertWhitespaceBeforeMe(newlineWithIndent)
+            }
+        }
+
+        if (node.isFollowedByOtherAnnotationEntryOnTheSameLine()) {
+            emit(
+                node.startOffset,
+                "Annotation must be placed on a separate line when it is a constructor annotation",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .lastChildLeafOrSelf()
+                    .nextLeaf()
+                    ?.upsertWhitespaceBeforeMe(newlineWithIndent)
+            }
+        } else if (node.isOnSameLineAsAnnotatedConstruct()) {
+            emit(
+                node.startOffset,
+                "Annotation must be placed on a separate line when it is a constructor annotation",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .lastChildLeafOrSelf()
+                    .nextLeaf()
+                    ?.upsertWhitespaceBeforeMe(newlineWithIndent)
+            }
+        }
+    }
+
+    private fun ASTNode.isPrecededByNewline(): Boolean =
+        prevLeaf()?.isWhiteSpaceWithNewline() == true
+
+    private fun getNewlineWithIndentForConstructorAnnotation(node: ASTNode): String {
+        // Navigate from ANNOTATION_ENTRY -> MODIFIER_LIST -> PRIMARY_CONSTRUCTOR -> CLASS
+        val classNode = node.treeParent.treeParent.treeParent
+        val classIndent = classNode.indent(false)
+        return "\n$classIndent${indentConfig.indent}"
+    }
+
     private fun ASTNode.typeProjectionOrNull() =
         takeIf { elementType == ANNOTATION_ENTRY }
             ?.takeIf { it.treeParent.elementType == MODIFIER_LIST }
