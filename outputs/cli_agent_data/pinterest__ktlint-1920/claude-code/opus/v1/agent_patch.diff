+    private fun ASTNode.isAnnotationOnConstructor() =
+        treeParent.elementType == MODIFIER_LIST &&
+            treeParent.treeParent.elementType == PRIMARY_CONSTRUCTOR
+
+    private fun checkForAnnotationOnConstructorToBePlacedOnSeparateLine(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+        autoCorrect: Boolean,
+    ) {
+        val expectedIndent = getNewlineWithIndentForConstructorAnnotation(node)
+
+        if (node.isFirstAnnotationEntry() &&
+            !node.isPrecededByNewline()
+        ) {
+            // In ktlint_official code style, annotations before the constructor should be placed on a separate line:
+            //   data class Foo
+            //       @Bar1
+            //       constructor(...)
+            // Instead of:
+            //   data class Foo @Bar1 constructor(...)
+            emit(
+                node.startOffset,
+                "Annotation must be placed on a separate line when placed before the primary constructor",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .firstChildLeafOrSelf()
+                    .upsertWhitespaceBeforeMe(expectedIndent)
+            }
+        }
+
+        if (!node.isFirstAnnotationEntry() && node.isPrecededByOtherAnnotationEntryOnTheSameLine()) {
+            emit(
+                node.startOffset,
+                "Annotation must be placed on a separate line when placed before the primary constructor",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .firstChildLeafOrSelf()
+                    .upsertWhitespaceBeforeMe(expectedIndent)
+            }
+        }
+
+        if (node.isLastAnnotationEntry() && node.isOnSameLineAsAnnotatedConstruct()) {
+            emit(
+                node.startOffset,
+                "Annotation must be placed on a separate line when placed before the primary constructor",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .lastChildLeafOrSelf()
+                    .nextLeaf()
+                    ?.upsertWhitespaceBeforeMe(expectedIndent)
+            }
+        }
+    }
+
+    private fun getNewlineWithIndentForConstructorAnnotation(node: ASTNode): String {
+        // For annotations on a primary constructor, the indent should be based on the class indent + one indent level
+        // Given:  data class Foo @Bar1 constructor(...)
+        // The PRIMARY_CONSTRUCTOR's parent is the CLASS node
+        val classNode = node.treeParent.treeParent.treeParent // ANNOTATION_ENTRY -> MODIFIER_LIST -> PRIMARY_CONSTRUCTOR -> CLASS
+        val classIndent =
+            classNode
+                .treePrev
+                ?.text
+                .orEmpty()
+                .substringAfterLast('\n')
+        return "\n" + classIndent + indentConfig.indent
+    }
+
+    private fun ASTNode.isPrecededByNewline(): Boolean =
+        prevLeaf()?.isWhiteSpaceWithNewline() == true
+
     private fun ASTNode.typeProjectionOrNull() =
         takeIf { elementType == ANNOTATION_ENTRY }
             ?.takeIf { it.treeParent.elementType == MODIFIER_LIST }
