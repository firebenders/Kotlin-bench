+    private fun ASTNode.isRawStringLiteralFunctionBodyExpression(): Boolean {
+        if (prevLeaf()?.elementType == WHITE_SPACE && prevLeaf()?.text != " ") {
+            return false
+        }
+        val eq = prevCodeLeaf()?.takeIf { it.elementType == EQ } ?: return false
+        val funNode = eq.treeParent
+        if (funNode.elementType != FUN && funNode.elementType != PROPERTY) return false
+        // Only add extra indent when the declaration before '=' spans multiple lines. For single line declarations
+        // like 'fun foo() = """' or 'val foo = """' the closing quotes should be at the same indent as the
+        // declaration.
+        val firstLeaf = funNode.firstChildLeafOrSelf()
+        var leaf = eq.prevLeaf()
+        while (leaf != null && leaf != firstLeaf) {
+            if (leaf.isWhiteSpaceWithNewline()) return true
+            leaf = leaf.prevLeaf()
+        }
+        return false
+    }
 
     private fun ASTNode.isRawStringLiteralReturnInFunctionBodyBlock() = RETURN_KEYWORD == prevCodeLeaf()?.elementType
 
