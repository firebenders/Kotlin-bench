+    private fun ASTNode.isRawStringLiteralFunctionBodyExpression(): Boolean {
+        if (prevLeaf()?.elementType == WHITE_SPACE && prevLeaf()?.text != " ") return false
+        val eq = prevCodeLeaf()?.takeIf { it?.elementType == EQ } ?: return false
+        val funNode = eq.treeParent
+        if (funNode.elementType != FUN) return false
+        // Only match multi-line function declarations where there is a newline between the
+        // function keyword and the EQ sign. Single-line function declarations like
+        //   fun foo() = """
+        //       some text
+        //   """.trimIndent()
+        // should be handled the same way as property declarations.
+        var leaf = eq.prevLeaf()
+        val funKeyword = funNode.firstChildLeafOrSelf()
+        while (leaf != null && leaf != funKeyword) {
+            if (leaf.isWhiteSpaceWithNewline()) return true
+            leaf = leaf.prevLeaf()
+        }
+        return false
+    }
 
