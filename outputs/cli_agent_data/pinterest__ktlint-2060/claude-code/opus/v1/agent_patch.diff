     private fun ASTNode.exceedsMaxLineLength() = (column - 1 + textLength) > maxLineLength && !textContains('\n')
 
+    private fun ASTNode.functionTypeExceedsMaxLineLength(): Boolean {
+        require(elementType == VALUE_PARAMETER_LIST)
+        val functionType = treeParent?.takeIf { it.elementType == FUNCTION_TYPE } ?: return false
+        if (functionType.textContains('\n')) {
+            return false
+        }
+        val nullableType = functionType.treeParent?.takeIf { it.elementType == NULLABLE_TYPE }
+        return if (nullableType != null) {
+            // When the nullable type is going to be wrapped, the function type will be placed on a new line at the
+            // child indent of the nullable type. Calculate the expected line length after wrapping.
+            val childIndent = indentConfig.childIndentOf(nullableType)
+            val expectedIndentLength = childIndent.length - 1 // subtract the newline character
+            (expectedIndentLength + functionType.textLength) > maxLineLength
+        } else {
+            (functionType.column - 1 + functionType.textLength) > maxLineLength
+        }
+    }
+
     private fun errorMessage(node: ASTNode) =
