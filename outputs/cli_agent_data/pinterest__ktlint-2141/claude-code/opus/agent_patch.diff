+        val typeReference = findChildByType(TYPE_REFERENCE)?.text
+        if (typeReference != null) {
+            return MUTABLE_TYPES.any { typeReference.startsWith(it) }
+        }
+        val callExpression = findChildByType(CALL_EXPRESSION)
+        if (callExpression != null) {
+            val calleeText = callExpression.findChildByType(REFERENCE_EXPRESSION)?.text
