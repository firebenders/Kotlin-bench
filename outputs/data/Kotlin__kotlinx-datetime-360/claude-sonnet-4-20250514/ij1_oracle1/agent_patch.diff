--- a/core/common/test/format/LocalTimeFormatTest.kt
+++ b/core/common/test/format/LocalTimeFormatTest.kt
@@ -20,6 +20,18 @@ class LocalTimeFormatTest {
         val error = assertFailsWith<DateTimeFormatException> { format.parse("40:36") }
         assertContains(error.message!!, "40")
         assertFailsWith<DateTimeFormatException> { format.parse("XX:36") }
+        
+        // Test "one of" error message format (should be lowercase)
+        val amPmFormat = LocalTime.Format {
+            hour()
+            char(':')
+            minute()
+            char(' ')
+            amPmMarker("AM", "PM")
+        }
+        val amPmError = assertFailsWith<DateTimeFormatException> { amPmFormat.parse("15:30 XX") }
+        assertContains(amPmError.message!!, "one of") // Should be lowercase
+        assertContains(amPmError.message!!, "15:30 XX") // Should contain the input
     }
 
     @Test
