--- a/core/common/test/format/DateTimeComponentsFormatTest.kt
+++ b/core/common/test/format/DateTimeComponentsFormatTest.kt
@@ -53,16 +53,19 @@ class DateTimeComponentsFormatTest {
             DateTimeComponents().apply { hour = 23; hourOfAmPm = 11; minute = 15; amPm = AmPmMarker.AM },
             format.parse(time2)
         )
