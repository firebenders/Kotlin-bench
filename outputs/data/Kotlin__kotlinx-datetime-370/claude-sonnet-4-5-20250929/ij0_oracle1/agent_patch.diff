+++ b/verify-fix.kt
@@ -0,0 +1,47 @@
+import kotlinx.datetime.Instant
+import kotlinx.datetime.format.DateTimeFormatException
+
+fun main() {
+    println("Testing Instant.parse behavior after fix:")
+    println()
+    
+    // Test 1: Parsing with seconds should work
+    println("Test 1: Parsing with seconds (should work)")
+    try {
+        val instant = Instant.parse("2024-03-19T17:50:00Z")
+        println("✓ Successfully parsed: $instant")
+    } catch (e: DateTimeFormatException) {
+        println("✗ Failed: ${e.message}")
+    }
+    println()
+    
+    // Test 2: Parsing without seconds should fail (as per spec)
+    println("Test 2: Parsing without seconds (should fail)")
+    try {
+        val instant = Instant.parse("2024-03-19T17:50Z")
+        println("✗ Unexpectedly succeeded: $instant")
+    } catch (e: DateTimeFormatException) {
+        println("✓ Correctly failed with: ${e.message}")
+    }
+    println()
+    
+    // Test 3: Parsing with offset without minutes should work
+    println("Test 3: Parsing with offset without minutes (should work)")
+    try {
+        val instant = Instant.parse("2024-03-19T17:50:00+03")
+        println("✓ Successfully parsed: $instant")
+    } catch (e: DateTimeFormatException) {
+        println("✗ Failed: ${e.message}")
+    }
+    println()
+    
+    // Test 4: Parsing with full offset should work
+    println("Test 4: Parsing with full offset (should work)")
+    try {
+        val instant = Instant.parse("2024-03-19T17:50:00+03:30")
+        println("✓ Successfully parsed: $instant")
+    } catch (e: DateTimeFormatException) {
+        println("✗ Failed: ${e.message}")
+    }
+}
+
