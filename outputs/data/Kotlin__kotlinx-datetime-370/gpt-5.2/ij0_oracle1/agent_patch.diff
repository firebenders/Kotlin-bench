+/*
+ * Copyright 2019-2026 JetBrains s.r.o.
+ * Use of this source code is governed by the Apache 2.0 License that can be found in the LICENSE.txt file.
+ */
+
+package kotlinx.datetime.test
+
+import kotlinx.datetime.Instant
+import kotlin.test.Test
+import kotlin.test.assertEquals
+
+class InstantParseConsistencyTest {
+
+    @Test
+    fun missingSecondsAreRejected() {
+        assertInvalidFormat { Instant.parse("2024-03-19T17:50Z") }
+        assertInvalidFormat { Instant.parse("2024-03-19T17:50+01") }
+        assertInvalidFormat { Instant.parse("2024-03-19T17:50+01:00") }
+    }
+
+    @Test
+    fun offsetMinutesAreOptional() {
+        val parsed = Instant.parse("2024-03-19T17:50:00+01")
+        assertEquals(Instant.parse("2024-03-19T16:50:00Z"), parsed)
+    }
+}
+
