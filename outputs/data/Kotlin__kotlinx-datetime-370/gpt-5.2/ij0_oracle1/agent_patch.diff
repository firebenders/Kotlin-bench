-public fun String.toInstant(): Instant = Instant.parse(this)
+public fun String.toInstant(): Instant {
+    try {
+        return Instant.parse(this)
+    } catch (e: IllegalArgumentException) {
+        // Backward-compatibility: some older examples (and tests) used ISO-8601 instants without seconds,
+        // e.g. "2016-02-15T00:00Z".
+        val fixed = insertMissingSecondsInIsoInstant(this) ?: throw e
+        return Instant.parse(fixed)
+    }
+}
+
+private fun insertMissingSecondsInIsoInstant(input: String): String? {
+    val tIndex = input.indexOfAny(charArrayOf('T', 't'))
+    if (tIndex == -1) return null
+
+    // Offset starts right after the time part.
+    val offsetIndex = (tIndex + 1 until input.length).firstOrNull { i ->
+        when (input[i]) {
+            'Z', 'z', '+', '-' -> true
+            else -> false
+        }
+    } ?: return null
+
+    // Handle the legacy form with time "HH:MM" (seconds omitted).
+    val timePart = input.substring(tIndex + 1, offsetIndex)
+    if (timePart.length != 5 || timePart[2] != ':') return null
+    fun isDigitAt(ix: Int) = timePart[ix] in '0'..'9'
+    if (!isDigitAt(0) || !isDigitAt(1) || !isDigitAt(3) || !isDigitAt(4)) return null
+
+    return input.substring(0, offsetIndex) + ":00" + input.substring(offsetIndex)
+}
 
