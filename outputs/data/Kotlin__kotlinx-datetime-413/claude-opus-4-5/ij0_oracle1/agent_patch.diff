+
+package kotlinx.datetime.test.format
+
+import kotlinx.datetime.*
+import kotlinx.datetime.format.*
+import kotlin.test.*
+
+/**
+ * Tests to verify that parsing rejects non-ASCII digits.
+ * See issue: The parsing API accepts non-ASCII digits
+ */
+class NonAsciiDigitParsingTest {
+
+    @Test
+    fun testLocalDateRejectsNonAsciiDigits() {
+        // The string "2０2４٠٩０６" contains:
+        // "2" - ASCII digit 2
+        // "０" - Fullwidth digit 0 (U+FF10)
+        // "2" - ASCII digit 2
+        // "４" - Fullwidth digit 4 (U+FF14)
+        // "٠" - Arabic-Indic digit 0 (U+0660)
+        // "٩" - Arabic-Indic digit 9 (U+0669)
+        // "０" - Fullwidth digit 0 (U+FF10)
+        // "６" - Fullwidth digit 6 (U+FF16)
+        val stringWithNonAsciiDigits = "2\uFF102\uFF14\u0660\u0669\uFF10\uFF16"
+        
+        // This should fail to parse because it contains non-ASCII digits
+        assertFailsWith<IllegalArgumentException> {
+            LocalDate.parse(stringWithNonAsciiDigits, LocalDate.Formats.ISO_BASIC)
+        }
+    }
+
+    @Test
+    fun testLocalDateAcceptsAsciiDigits() {
+        // The correct ASCII string should still work
+        val validDate = LocalDate.parse("20240906", LocalDate.Formats.ISO_BASIC)
+        assertEquals(LocalDate(2024, 9, 6), validDate)
+    }
+
+    @Test
+    fun testLocalDateRejectsFullwidthDigits() {
+        // All fullwidth digits
+        // "２０２４０９０６" (U+FF12, U+FF10, U+FF12, U+FF14, U+FF10, U+FF19, U+FF10, U+FF16)
+        val fullwidthDigits = "\uFF12\uFF10\uFF12\uFF14\uFF10\uFF19\uFF10\uFF16"
+        
+        assertFailsWith<IllegalArgumentException> {
+            LocalDate.parse(fullwidthDigits, LocalDate.Formats.ISO_BASIC)
+        }
+    }
+
+    @Test
+    fun testLocalDateRejectsArabicIndicDigits() {
+        // Arabic-Indic digits ٢٠٢٤٠٩٠٦ (U+0662, U+0660, U+0662, U+0664, U+0660, U+0669, U+0660, U+0666)
+        val arabicIndicDigits = "\u0662\u0660\u0662\u0664\u0660\u0669\u0660\u0666"
+        
+        assertFailsWith<IllegalArgumentException> {
+            LocalDate.parse(arabicIndicDigits, LocalDate.Formats.ISO_BASIC)
+        }
+    }
+
+    @Test
+    fun testLocalDateIsoRejectsNonAsciiDigits() {
+        // "2024-09-06" with fullwidth digits for separators won't work since they're checked literally
+        // Let's test with a non-ASCII digit in the date portion
+        val stringWithNonAsciiYear = "\uFF12024-09-06" // First digit is fullwidth 2
+        
+        assertFailsWith<IllegalArgumentException> {
+            LocalDate.parse(stringWithNonAsciiYear, LocalDate.Formats.ISO)
+        }
+    }
+
+    @Test
+    fun testLocalTimeRejectsNonAsciiDigits() {
+        // "12:30:45" with fullwidth 1
+        val stringWithNonAsciiDigit = "\uFF112:30:45"
+        
+        assertFailsWith<IllegalArgumentException> {
+            LocalTime.parse(stringWithNonAsciiDigit, LocalTime.Formats.ISO)
+        }
+    }
+
+    @Test
+    fun testLocalDateTimeRejectsNonAsciiDigits() {
+        // "2024-09-06T12:30:45" with fullwidth digit in year
+        val stringWithNonAsciiDigit = "\uFF12024-09-06T12:30:45"
+        
+        assertFailsWith<IllegalArgumentException> {
+            LocalDateTime.parse(stringWithNonAsciiDigit, LocalDateTime.Formats.ISO)
+        }
+    }
+
+    @Test
+    fun testMixedAsciiAndNonAsciiDigits() {
+        // "2024" with one non-ASCII digit: "20２4"
+        val mixedDigits = "20\uFF124"
+        
+        // Should fail because it contains a non-ASCII digit
+        assertFailsWith<IllegalArgumentException> {
+            LocalDate.parse("$mixedDigits-09-06", LocalDate.Formats.ISO)
+        }
+    }
+}
+
