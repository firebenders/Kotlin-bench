diff --git a/core/common/test/LocalDateTest.kt b/core/common/test/LocalDateTest.kt
index a0f2a5e..bed02eb 100644
--- a/core/common/test/LocalDateTest.kt
+++ b/core/common/test/LocalDateTest.kt
@@ -64,6 +64,32 @@ class LocalDateTest {
         checkParsedComponents("-123456-01-01", -123456, 1, 1)
     }
 
+    @Test
+    fun parseExcessiveLeadingZeroes() {
+        // Test for the issue where excessive leading zeroes in ISO format caused parsing failures
+        // when delegating to platform parsers (Java/JSJoda) that don't support them
+        
+        // Both LocalDate.parse and LocalDate.Formats.ISO.parse should handle excessive leading zeroes
+        val dateStringWithExcessiveZeroes = "+00000000000002022-07-16"
+        val expectedDate = LocalDate(2022, 7, 16)
+        
+        val parsedDate1 = LocalDate.parse(dateStringWithExcessiveZeroes)
+        assertEquals(expectedDate, parsedDate1)
+        
+        val parsedDate2 = LocalDate.Formats.ISO.parse(dateStringWithExcessiveZeroes)
+        assertEquals(expectedDate, parsedDate2)
+        
+        // Test with negative years as well
+        val negativeYearString = "-00000000000001234-03-15"
+        val expectedNegativeDate = LocalDate(-1234, 3, 15)
+        
+        val parsedNegativeDate1 = LocalDate.parse(negativeYearString)
+        assertEquals(expectedNegativeDate, parsedNegativeDate1)
+        
+        val parsedNegativeDate2 = LocalDate.Formats.ISO.parse(negativeYearString)
+        assertEquals(expectedNegativeDate, parsedNegativeDate2)
+    }
