+    @Test
+    fun parseExcessiveLeadingZeroes() {
+        // Test for the issue where excessive leading zeroes in ISO format caused parsing failures
+        // when delegating to platform parsers (Java/JSJoda) that don't support them
+        
+        // Both LocalDateTime.parse and LocalDateTime.Formats.ISO.parse should handle excessive leading zeroes
+        val dateTimeStringWithExcessiveZeroes = "+00000000000002022-07-16T14:30:45.123456789"
+        val expectedDateTime = LocalDateTime(2022, 7, 16, 14, 30, 45, 123456789)
+        
+        val parsedDateTime1 = LocalDateTime.parse(dateTimeStringWithExcessiveZeroes)
+        assertEquals(expectedDateTime, parsedDateTime1)
+        
+        val parsedDateTime2 = LocalDateTime.Formats.ISO.parse(dateTimeStringWithExcessiveZeroes)
+        assertEquals(expectedDateTime, parsedDateTime2)
+        
+        // Test with negative years as well
+        val negativeYearString = "-00000000000001234-03-15T09:15:30"
+        val expectedNegativeDateTime = LocalDateTime(-1234, 3, 15, 9, 15, 30)
+        
+        val parsedNegativeDateTime1 = LocalDateTime.parse(negativeYearString)
+        assertEquals(expectedNegativeDateTime, parsedNegativeDateTime1)
+        
+        val parsedNegativeDateTime2 = LocalDateTime.Formats.ISO.parse(negativeYearString)
+        assertEquals(expectedNegativeDateTime, parsedNegativeDateTime2)
+    }
