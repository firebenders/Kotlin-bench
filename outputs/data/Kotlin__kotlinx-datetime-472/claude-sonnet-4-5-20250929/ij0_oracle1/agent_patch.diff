diff --git a/core/common/test/format/ErrorMessageTest.kt b/core/common/test/format/ErrorMessageTest.kt
new file mode 100644
--- /dev/null
+++ b/core/common/test/format/ErrorMessageTest.kt
@@ -0,0 +1,204 @@
+/*
