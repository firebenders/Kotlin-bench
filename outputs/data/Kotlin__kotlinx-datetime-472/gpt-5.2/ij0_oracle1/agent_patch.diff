diff --git a/core/common/src/internal/format/FieldSpec.kt b/core/common/src/internal/format/FieldSpec.kt
index cbb2d76..c4753b2 100644
--- a/core/common/src/internal/format/FieldSpec.kt
+++ b/core/common/src/internal/format/FieldSpec.kt
@@ -27,6 +27,28 @@ internal interface Accessor<in Object, Field>: AssignableField<Object, Field> {
         getter(container) ?: throw IllegalStateException("Field $name is not set")
 }
 
+/**
+ * An [Accessor] wrapper that overrides the exposed [name].
+ *
+ * This is useful when the underlying property name is an internal implementation detail (for example,
+ * `totalHoursAbs`), but end users see a different name in the formatting DSL (for example, `offsetHours`).
+ */
+internal class RenamedAccessor<Object, Field>(
+    private val delegate: Accessor<Object, Field>,
+    private val renamed: String,
+) : Accessor<Object, Field> {
+    override val name: String get() = renamed
+
+    override fun trySetWithoutReassigning(container: Object, newValue: Field): Field? =
+        delegate.trySetWithoutReassigning(container, newValue)
+
+    override fun getter(container: Object): Field? = delegate.getter(container)
+}
+
+internal fun <Object, Field> Accessor<Object, Field>.withName(name: String): Accessor<Object, Field> =
+    if (this.name == name) this else RenamedAccessor(this, name)
+
+
 /**
  * An implementation of [Accessor] for a mutable property of an object.
  */

