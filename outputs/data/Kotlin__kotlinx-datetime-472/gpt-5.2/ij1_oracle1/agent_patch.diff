     override fun getter(container: Object): Field? = property.get(container)
 }
 
+/**
+ * An [Accessor] wrapper that exposes a different [name] while delegating the actual access logic.
+ *
+ * This is useful when the underlying container stores the value in a field whose name is an internal detail,
+ * but we want user-facing error messages to mention the public API name.
+ */
+internal class RenamedAccessor<Object, Field>(
+    private val delegate: Accessor<Object, Field>,
+    override val name: String,
+) : Accessor<Object, Field> {
+    override fun trySetWithoutReassigning(container: Object, newValue: Field): Field? =
+        delegate.trySetWithoutReassigning(container, newValue)
+
+    override fun getter(container: Object): Field? = delegate.getter(container)
+}
