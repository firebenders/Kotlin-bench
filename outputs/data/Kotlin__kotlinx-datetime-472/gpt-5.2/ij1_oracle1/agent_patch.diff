+
+package kotlinx.datetime.test.format
+
+import kotlinx.datetime.format.DateTimeComponents
+import kotlinx.datetime.format.format
+import kotlin.test.Test
+import kotlin.test.assertEquals
+import kotlin.test.assertFailsWith
+import kotlin.test.assertTrue
+
+class FormattingMissingFieldMessageTest {
+
+    @Test
+    fun utcOffsetFieldNameIsPublicInErrorMessage() {
+        val format = DateTimeComponents.Format {
+            offsetHours()
+        }
+        val e = assertFailsWith<IllegalStateException> {
+            format.format {
+                // do not set any offset fields
+            }
+        }
+        assertEquals("Field offsetHours is not set", e.message)
+        assertTrue(e.message?.contains("totalHoursAbs") != true)
+    }
+}
