+
+package kotlinx.datetime.test.format
+
+import kotlinx.datetime.*
+import kotlinx.datetime.format.*
+import kotlin.test.*
+
+/**
+ * Test to verify that error messages use user-facing field names instead of internal property names.
+ * This test specifically addresses the issue where obscure error messages like
+ * "Field totalHoursAbs is not set" were shown instead of "Field offsetHours is not set".
+ */
+class ErrorMessageFixTest {
+
+    @Test
+    fun errorMessageForOffsetHoursUsesUserFacingName() {
+        // Create a minimal format that will trigger an error
+        val format = DateTimeComponents.Format {
+            offsetHours()
+        }
+
+        // Try to format without setting offset - should mention "offsetHours" not "totalHoursAbs"
+        val exception = assertFailsWith<IllegalStateException> {
+            format.format {
+                // Intentionally not setting offset to trigger the error
+            }
+        }
+
+        // The error message should mention the user-facing name "offsetHours"
+        val errorMessage = exception.message!!
+        assertTrue(errorMessage.contains("offsetHours"),
+            "Expected error message to contain 'offsetHours' but got: $errorMessage")
+        assertFalse(errorMessage.contains("totalHoursAbs"),
+            "Error message should not contain internal property name 'totalHoursAbs': $errorMessage")
+    }
+
+    @Test
+    fun errorMessageForOffsetMinutesOfHourUsesUserFacingName() {
+        val format = DateTimeComponents.Format {
+            offsetMinutesOfHour()
+        }
+
+        val exception = assertFailsWith<IllegalStateException> {
+            format.format {
+                // Not setting offset
+            }
+        }
+
+        val errorMessage = exception.message!!
+        assertTrue(errorMessage.contains("offsetMinutesOfHour"),
+            "Expected error message to contain 'offsetMinutesOfHour' but got: $errorMessage")
+        assertFalse(errorMessage.contains("minutesOfHour"),
+            "Error message should not contain internal property name 'minutesOfHour': $errorMessage")
+    }
+
+    @Test
+    fun errorMessageForOffsetSecondsOfMinuteUsesUserFacingName() {
+        val format = DateTimeComponents.Format {
+            offsetSecondsOfMinute()
+        }
+
+        val exception = assertFailsWith<IllegalStateException> {
+            format.format {
+                // Not setting offset
+            }
+        }
+
+        val errorMessage = exception.message!!
+        assertTrue(errorMessage.contains("offsetSecondsOfMinute"),
+            "Expected error message to contain 'offsetSecondsOfMinute' but got: $errorMessage")
+        assertFalse(errorMessage.contains("secondsOfMinute"),
+            "Error message should not contain internal property name 'secondsOfMinute': $errorMessage")
+    }
+
+    @Test
+    fun complexFormatWithAlternativeParsingShowsReadableError() {
+        // This is the format from the original issue report
+        val readableFormat = DateTimeComponents.Format {
+            year()
+            char('-')
+            monthNumber()
+            char('-')
+            dayOfMonth()
+            char(' ')
+            hour()
+            char(':')
+            minute()
+            char(':')
+            second()
+            alternativeParsing({
+                char(' ')
+            }) {
+                alternativeParsing({ timeZoneId() }, { offset(UtcOffset.Formats.ISO) }) {
+                    offsetHours()
+                    char(':')
+                    offsetMinutesOfHour()
+                    optional {
+                        char(':')
+                        offsetSecondsOfMinute()
+                    }
+                }
+            }
+        }
+
+        val zone = TimeZone.of("Europe/Berlin")
+        val instant = Instant.parse("2020-01-01T12:00:00Z")
+
+        // This should work properly when the offset is set on the second alternative
+        val result = readableFormat.format {
+            setDateTime(instant.toLocalDateTime(zone))
+            timeZoneId = zone.id
+            setOffset(zone.offsetAt(instant))
+        }
+
+        // Verify the result contains expected parts
+        assertTrue(result.length > 0, "Expected non-empty formatted string")
+        assertTrue(result.contains("2020"), "Expected year in formatted result")
+    }
+
+    @Test
+    fun errorInAlternativeParsingShowsUserFacingName() {
+        // Format that uses alternative parsing
+        val format = DateTimeComponents.Format {
+            alternativeParsing({ }) { char(' ') }
+        }
+
+        val exception = assertFailsWith<IllegalStateException> {
+            format.format {
+                // Not setting any fields
+            }
+        }
+
+        val errorMessage = exception.message!!
+        assertTrue(errorMessage.contains("is not set"), "Expected error message to mention missing field")
+        assertFalse(errorMessage.contains("totalHoursAbs"), 
+            "Error message should not contain internal property name 'totalHoursAbs'")
+    }
+}
