+
+package kotlinx.coroutines.future
+
+import kotlinx.coroutines.*
+import org.junit.Test
+import kotlin.test.*
+
+/**
+ * Tests that verify that `future` coroutine builder does NOT trigger global exception handler
+ * when the future is cancelled externally. This is consistent with FutureTask behavior and
+ * ensures that Future.cancel() does not cause app crashes.
+ *
+ * See: https://github.com/Kotlin/kotlinx.coroutines/issues/2456
+ */
+class FutureCancellationExceptionTest : TestBase() {
+
+    /**
+     * Tests the issue described in https://github.com/Kotlin/kotlinx.coroutines/issues/2456
+     *
+     * When a future is cancelled before the coroutine throws an exception,
+     * the exception should be silently dropped (NOT reported to global exception handler).
+     */
+    @Test
+    fun testFutureCancelledBeforeCoroutineThrows() = runTest {
+        expect(1)
+        // Use NonCancellable so exception doesn't propagate to parent
+        val future = future(NonCancellable + Dispatchers.Unconfined) {
+            try {
+                expect(2)
+                delay(Long.MAX_VALUE) // suspend here
+            } finally {
+                expect(3)
+                throw TestException("foo") // This exception should be dropped, not trigger global handler
+            }
+        }
+        // Cancel the future - this triggers the finally block
+        future.cancel(true)
+        expect(4)
+        assertTrue(future.isCancelled)
+        finish(5)
+    }
+
+    /**
+     * Tests that exceptions in finally blocks after external cancellation
+     * are silently dropped, not reported to global exception handler.
+     */
+    @Test
+    fun testExceptionInFinallyAfterExternalCancellation() = runTest {
+        expect(1)
+        val future = future(NonCancellable + Dispatchers.Unconfined) {
+            try {
+                delay(Long.MAX_VALUE)
+            } finally {
+                expect(2)
+                throw TestException() // this exception should be dropped, not go to global handler
+            }
+        }
+        future.cancel(true)
+        finish(3)
+    }
+
+    /**
+     * Tests that when future completes externally via complete() and then
+     * an exception occurs, it doesn't trigger global exception handler.
+     */
+    @Test
+    fun testExceptionAfterExternalComplete() = runTest {
+        expect(1)
+        val future = future(NonCancellable + Dispatchers.Unconfined) {
+            try {
+                delay(Long.MAX_VALUE)
+            } finally {
+                expect(2)
+                throw TestException() // this exception should be dropped
+            }
+        }
+        future.complete(Unit)
+        finish(3)
+    }
+
+    /**
+     * Stress test to verify that Future.cancel() does not report to
+     * CoroutineExceptionHandler, matching Guava's behavior.
+     */
+    @Test
+    fun testFutureDoesNotReportToCoroutineExceptionHandler() = runTest {
+        repeat(100) {
+            val future = future<Unit>(NonCancellable + Dispatchers.Default) {
+                throw TestException("can be lost")
+            }
+            // Cancel immediately, creating a race
+            future.cancel(true)
+            // Nothing should be reported to CoroutineExceptionHandler
+            // (otherwise would fail due to uncaught exception)
+        }
+    }
+}
+
