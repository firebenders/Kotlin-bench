@@ -594,4 +594,32 @@ class FutureTest : TestBase() {
             assertEquals(count, completed.get())
         }
     }
+
+    /**
+     * Test that future coroutine builder does not trigger global exception handler on cancellation.
+     * Regression test for the issue where future() may trigger global exception handler on cancellation.
+     */
+    @Test 
+    fun testFutureDoesNotTriggerGlobalExceptionHandlerOnCancellation() = runTest(
+        // This test should not trigger any unhandled exceptions
+        unhandled = emptyList()
+    ) {
+        expect(1)
+        // Create a future that will throw an exception
+        val future = GlobalScope.future {
+            expect(2)
+            error("foo")
+        }
+        yield() // Let the future coroutine start
+        
+        // Cancel the future - this should NOT trigger global exception handler
+        expect(3)
+        future.cancel(true)
+        yield() // Let cancellation propagate
+        
+        // Verify the future is cancelled
+        assertTrue(future.isCancelled)
+        assertFailsWith<CancellationException> { future.get() }
+        finish(4)
+    }
 }
