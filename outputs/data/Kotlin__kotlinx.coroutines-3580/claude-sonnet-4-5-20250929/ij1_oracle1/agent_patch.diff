+ */
+
+package kotlinx.coroutines.future
+
+import kotlinx.coroutines.*
+import org.junit.*
+import org.junit.Test
+import java.util.concurrent.*
+import java.util.concurrent.CancellationException as JavaCancellationException
+import kotlin.test.*
+
+class FutureCancellationExceptionTest : TestBase() {
+    
+    /**
+     * Test that future() does not trigger global exception handler when the future
+     * is cancelled externally and the coroutine throws an exception.
+     * See https://github.com/Kotlin/kotlinx.coroutines/issues/2712
+     */
+    @Test
+    fun testExternalCancellationDoesNotTriggerGlobalHandler() = runTest {
+        // This test reproduces the issue from #2712
+        val future = GlobalScope.future {
+            throw TestException("foo")
+        }
+        future.cancel(true) // Cancel externally
+        
+        // The future should be cancelled
+        try {
+            future.get()
+            fail("Expected CancellationException")
+        } catch (e: JavaCancellationException) {
+            // Expected - future was cancelled
+        }
+        
+        // Give time for coroutine to finish - should NOT trigger global handler
+        delay(200)
+    }
+    
+    /**
+     * Test that exceptions in future() are delivered via the CompletableFuture.
+     */
+    @Test
+    fun testExceptionDeliveredViaFuture() = runTest {
+        val future = GlobalScope.future<String> {
+            throw TestException("test")
+        }
+        
+        try {
+            future.get()
+            fail("Expected ExecutionException")
+        } catch (e: ExecutionException) {
+            assertTrue(e.cause is TestException)
+            assertEquals("test", e.cause?.message)
+        }
+    }
+    
+    /**
+     * Test that future() does not trigger global handler when future is already completed
+     * and coroutine encounters an exception.
+     */
+    @Test
+    fun testCompletedFutureDoesNotTriggerHandler() = runTest {
+        val latch = CountDownLatch(1)
+        val future = GlobalScope.future<String> {
+            latch.await() // Wait for external completion
+            throw TestException("This should not trigger global handler")
+        }
+        yield() // Let coroutine start
+        future.complete("external") // Complete externally
+        latch.countDown()
+        assertEquals("external", future.get())
+        delay(100) // Give time for coroutine to finish - should NOT trigger global handler
+    }
+    
+    /**
+     * Test that cancellation exception in future() cancels the CompletableFuture
+     * and does not trigger global handler.
+     */
+    @Test
+    fun testCancellationExceptionCancelsFuture() = runTest {
+        val future = GlobalScope.future {
+            throw kotlinx.coroutines.CancellationException("cancelled")
+        }
+        
+        try {
+            future.get()
+            fail("Expected CancellationException")
+        } catch (e: JavaCancellationException) {
+            // Future is cancelled when coroutine throws CancellationException
+        }
+    }
+}
+
