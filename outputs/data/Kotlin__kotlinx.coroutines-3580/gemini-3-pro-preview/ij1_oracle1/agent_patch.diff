+package kotlinx.coroutines.future
+
+import kotlinx.coroutines.*
+import org.junit.Test
+import java.util.concurrent.*
+import kotlin.test.*
+
+class FutureCrashTest : TestBase() {
+    
+    @Test
+    fun testCrashOnCancel() {
+        val future = GlobalScope.future {
+            error("foo")
+        }
+        future.cancel(true)
+        
+        // Wait for the coroutine to process the cancellation and exception
+        Thread.sleep(100)
+        
+        // If the bug exists, the exception "foo" will be delivered to the global exception handler.
+        // TestBase.onCompletion checks for uncaughtExceptions and fails if any are present.
+        // So this test will fail if the bug is present.
+    }
+}
