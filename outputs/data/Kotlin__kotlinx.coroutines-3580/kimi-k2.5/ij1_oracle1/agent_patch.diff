+
+package kotlinx.coroutines.future
+
+import kotlinx.coroutines.*
+import org.junit.Test
+import java.util.concurrent.*
+import kotlin.test.*
+
+/**
+ * Test for https://github.com/Kotlin/kotlinx.coroutines/issues/XXXX
+ * CoroutineScope.future() may trigger global exception handler on cancellation
+ */
+class FutureCancellationExceptionTest : TestBase() {
+
+    @Test
+    fun testFutureCancellationDoesNotTriggerGlobalExceptionHandler() = runTest {
+        // This test verifies that when a future is cancelled externally,
+        // the exception from the coroutine does not trigger the global exception handler
+        val future = GlobalScope.future {
+            error("foo")
+        }
+        
+        // Cancel the future externally - this should not trigger global exception handler
+        future.cancel(true)
+        
+        // Give some time for any potential exception to be reported
+        Thread.sleep(100)
+        
+        // The future should be cancelled
+        assertTrue(future.isCancelled)
+    }
+
+    @Test
+    fun testFutureCancellationWithDelay() = runTest {
+        val future = GlobalScope.future {
+            delay(Long.MAX_VALUE)
+            "OK"
+        }
+        
+        // Cancel the future externally
+        future.cancel(true)
+        
+        // The future should be cancelled
+        assertTrue(future.isCancelled)
+    }
+
+    @Test
+    fun testFutureExceptionIsStillDeliveredToFuture() = runTest {
+        val future = GlobalScope.future {
+            throw IllegalStateException("foo")
+        }
+        
+        // The exception should be delivered to the future, not to global exception handler
+        try {
+            future.get()
+            fail("Expected ExecutionException")
+        } catch (e: ExecutionException) {
+            assertTrue(e.cause is IllegalStateException)
+            assertEquals("foo", e.cause!!.message)
+        }
+    }
+}
