--- /dev/null
+++ b/kotlinx-coroutines-core/common/test/IsActiveTest.kt
@@ -0,0 +1,43 @@
+/*
+ * Copyright 2016-2022 JetBrains s.r.o. Use of this source code is governed by the Apache 2.0 license.
+ */
+
+package kotlinx.coroutines
+
+import kotlin.coroutines.*
+import kotlin.test.*
+
+class IsActiveTest : TestBase() {
+    @Test
+    fun testContextIsActiveWithoutJob() {
+        val context = EmptyCoroutineContext
+        // New behavior: returns true if no job is present
+        @Suppress("DEPRECATION")
+        assertTrue(context.isActive)
+    }
+
+    @Test
+    fun testScopeIsActiveWithoutJob() {
+        val scope = CoroutineScope(EmptyCoroutineContext)
+        // GlobalScope and scopes created without Job (though CoroutineScope(ctx) adds one if missing)
+        // Let's check GlobalScope
+        assertTrue(GlobalScope.isActive)
+        
+        val manualScope = object : CoroutineScope {
+            override val coroutineContext: CoroutineContext = EmptyCoroutineContext
+        }
+        assertTrue(manualScope.isActive)
+    }
+
+    @Test
+    fun testContextIsActiveWithJob() {
+        val job = Job()
+        val context = job
+        @Suppress("DEPRECATION")
+        assertTrue(context.isActive)
+        job.cancel()
+        @Suppress("DEPRECATION")
+        assertFalse(context.isActive)
+    }
+}
+
