+ */
+
+package kotlinx.coroutines
+
+import kotlin.coroutines.EmptyCoroutineContext
+import kotlin.coroutines.coroutineContext
+import kotlin.test.Test
+import kotlin.test.assertFalse
+import kotlin.test.assertTrue
+
+class CoroutineContextIsActiveTest : TestBase() {
+    @Test
+    fun `default to true when context lacks job`() {
+        assertTrue(EmptyCoroutineContext.isActive)
+    }
+
+    @Test
+    fun `jobless derived context stays active`() = runTest {
+        val joblessContext = coroutineContext.minusKey(Job)
+        assertTrue(joblessContext.isActive)
+    }
+
+    @Test
+    fun `reflects job state`() = runTest {
+        val job = Job()
+        val contextWithJob = job + EmptyCoroutineContext
+
+        assertTrue(contextWithJob.isActive)
+
+        job.cancel()
+        job.join()
+
+        assertFalse(contextWithJob.isActive)
+    }
+}
+
