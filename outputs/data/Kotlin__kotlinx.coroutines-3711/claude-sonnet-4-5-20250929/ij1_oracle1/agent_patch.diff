+ */
+
+package kotlinx.coroutines.flow
+
+import kotlinx.coroutines.*
+import kotlin.test.*
+
+/**
+ * Test that replicates the exact usage pattern from the reported issue.
+ * This test verifies that SharedFlow.toList(destination) properly passes
+ * the destination parameter through to the underlying Flow.toList() method.
+ */
+class SharedFlowToListIssueTest : TestBase() {
+    
+    @Test
+    fun testIssueScenario() = runTest {
+        val sharedFlow = MutableSharedFlow<Int>()
+        val acc = mutableListOf<Int>()
+        
+        // Launch with Undispatched to start immediately
+        val job = launch(start = CoroutineStart.UNDISPATCHED) {
+            @Suppress("DEPRECATION")
+            sharedFlow.toList(acc)
+        }
+        
+        // Emit values
+        sharedFlow.emit(1)
+        sharedFlow.emit(2)
+        sharedFlow.emit(3)
+        
+        // Give time for collection
+        yield()
+        
+        // Later... cancel the job
+        job.cancel()
+        
+        // Assert the destination list was properly populated
+        assertContentEquals(
+            expected = listOf(1, 2, 3),
+            actual = acc
+        )
+    }
+    
+    @Test
+    fun testMultipleCollectorsShareDestinations() = runTest {
+        val sharedFlow = MutableSharedFlow<String>()
+        val acc1 = mutableListOf<String>()
+        val acc2 = mutableListOf<String>()
+        
+        // Start two collectors
+        val job1 = launch(start = CoroutineStart.UNDISPATCHED) {
+            @Suppress("DEPRECATION")
+            sharedFlow.toList(acc1)
+        }
+        
+        val job2 = launch(start = CoroutineStart.UNDISPATCHED) {
+            @Suppress("DEPRECATION")
+            sharedFlow.toList(acc2)
+        }
+        
+        // Emit values
+        sharedFlow.emit("hello")
+        sharedFlow.emit("world")
+        
+        yield()
+        
+        // Cancel both jobs
+        job1.cancel()
+        job2.cancel()
+        
+        // Both collectors should have received all emitted values
+        assertContentEquals(listOf("hello", "world"), acc1)
+        assertContentEquals(listOf("hello", "world"), acc2)
+    }
+    
+    @Test
+    fun testReplayCache() = runTest {
+        val sharedFlow = MutableSharedFlow<Int>(replay = 2)
+        
+        // Emit some values before starting collection
+        sharedFlow.emit(10)
+        sharedFlow.emit(20)
+        
+        val acc = mutableListOf<Int>()
+        
+        val job = launch(start = CoroutineStart.UNDISPATCHED) {
+            @Suppress("DEPRECATION")
+            sharedFlow.toList(acc)
+        }
+        
+        // Wait for replay to be delivered
+        yield()
+        
+        // Emit more values
+        sharedFlow.emit(30)
+        sharedFlow.emit(40)
+        
+        yield()
+        
+        job.cancel()
+        
+        // Should have replay cache values plus new emissions
+        assertContentEquals(listOf(10, 20, 30, 40), acc)
+    }
+}
+

