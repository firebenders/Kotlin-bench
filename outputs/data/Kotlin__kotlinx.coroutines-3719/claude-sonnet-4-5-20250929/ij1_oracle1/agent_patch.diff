+ */
+
+package kotlinx.coroutines.flow
+
+import kotlinx.coroutines.*
+import kotlin.test.*
+
+/**
+ * This test reproduces the exact issue from the bug report:
+ * In 1.7.0-Beta, SharedFlow.toList(destination) was not properly passing 
+ * the destination parameter, causing the mutable list to remain empty.
+ */
+@Suppress("DEPRECATION")
+class SharedFlowToListBugTest : TestBase() {
+    
+    @Test
+    fun testBugReproduction() = runTest {
+        // This is the exact pattern from the issue report
+        val sharedFlow = MutableSharedFlow<Int>()
+        val acc = mutableListOf<Int>()
+        
+        val job = launch(start = CoroutineStart.UNDISPATCHED) {
+            sharedFlow.toList(acc)
+        }
+        
+        // Emit values
+        sharedFlow.emit(1)
+        sharedFlow.emit(2)
+        sharedFlow.emit(3)
+        
+        // Allow emissions to be collected
+        yield()
+        
+        // Cancel the collector
+        job.cancel()
+        job.join()
+        
+        // With the bug, acc would be empty because destination wasn't passed
+        // With the fix, acc should contain [1, 2, 3]
+        assertContentEquals(
+            expected = listOf(1, 2, 3),
+            actual = acc
+        )
+    }
+}
+

