diff --git a/kotlinx-coroutines-core/jvm/test/exceptions/StackTraceRecoveryNestedExceptionTest.kt b/kotlinx-coroutines-core/jvm/test/exceptions/StackTraceRecoveryNestedExceptionTest.kt
