+private inline fun Array<Constructor<*>>.findCtorOrNull(
+    expectedParamCount: Int,
+    predicate: (Array<Class<*>>) -> Boolean
+): Ctor? {
+    for (constructor in this) {
+        val parameters = constructor.parameterTypes
+        if (parameters.size == expectedParamCount && predicate(parameters)) {
+            return createSafeConstructor(constructor)
+        }
+    }
+    return null
