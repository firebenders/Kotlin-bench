+/**
+ * Comparator that prioritizes constructors based on their suitability for copying exceptions.
+ * For constructors with the same parameter count, prefers Throwable parameter over String parameter.
+ */
+private val constructorComparator = Comparator<Constructor<*>> { a, b ->
+    val aParams = a.parameterTypes
+    val bParams = b.parameterTypes
+    
+    // If different parameter counts, this comparator doesn't apply (handled by primary sort)
+    if (aParams.size != bParams.size) return@Comparator 0
+    
+    // For 1-parameter constructors, prefer Throwable over String
+    if (aParams.size == 1) {
+        val aIsThrowable = aParams[0] == Throwable::class.java
+        val bIsThrowable = bParams[0] == Throwable::class.java
+        
+        when {
+            aIsThrowable && !bIsThrowable -> -1  // a is better
+            !aIsThrowable && bIsThrowable -> 1   // b is better
+            else -> 0  // both are Throwable or both are not
+        }
+    } else {
+        0  // For other parameter counts, no preference
+    }
+}
