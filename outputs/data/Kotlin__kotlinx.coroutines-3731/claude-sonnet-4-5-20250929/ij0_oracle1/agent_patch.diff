@@ -0,0 +1,105 @@
+/*
+ * Copyright 2016-2021 JetBrains s.r.o. Use of this source code is governed by the Apache 2.0 license.
+ */
+
+package kotlinx.coroutines.exceptions
+
+import kotlinx.coroutines.*
+import org.junit.Test
+import kotlin.test.*
+
+/**
+ * Comprehensive test to verify that constructor selection works correctly
+ * regardless of the order constructors are declared.
+ */
+class ConstructorPriorityTest : TestBase() {
+
+    @Test
+    fun testThrowableCausePriorityOverString() = runTest {
+        // Verify that constructor(Throwable) is preferred over constructor(String)
+        val result = runCatching {
+            coroutineScope<Unit> {
+                val cause = IllegalStateException("original")
+                throw ExceptionWithMultipleConstructors(cause)
+            }
+        }
+        val ex = result.exceptionOrNull() ?: error("Expected to fail")
+        assertTrue(ex is ExceptionWithMultipleConstructors)
+        assertTrue(ex.cause is IllegalStateException)
+        assertEquals("original", (ex.cause as IllegalStateException).message)
+    }
+
+    @Test
+    fun testStringConstructorStillWorks() = runTest {
+        // Verify that constructor(String) still works when that's what's used
+        val result = runCatching {
+            coroutineScope<Unit> {
+                throw ExceptionWithMultipleConstructors("test message")
+            }
+        }
+        val ex = result.exceptionOrNull() ?: error("Expected to fail")
+        assertTrue(ex is ExceptionWithMultipleConstructors)
+        assertEquals("test message", ex.message)
+    }
+
+    @Test
+    fun testNoArgConstructorWorks() = runTest {
+        val result = runCatching {
+            coroutineScope<Unit> {
+                throw ExceptionWithMultipleConstructors()
+            }
+        }
+        val ex = result.exceptionOrNull() ?: error("Expected to fail")
+        assertTrue(ex is ExceptionWithMultipleConstructors)
+    }
+
+    @Test
+    fun testTwoArgConstructorPreferred() = runTest {
+        // When available, constructor(String, Throwable) should be preferred
+        // When copying, the 2-arg constructor will be used
+        val result = runCatching {
+            coroutineScope<Unit> {
+                val cause = IllegalStateException("cause")
+                throw ExceptionWithAllConstructors("message", cause)
+            }
+        }
+        val ex = result.exceptionOrNull() ?: error("Expected to fail")
+        assertTrue(ex is ExceptionWithAllConstructors)
+        // The message and cause structure should be preserved (though possibly copied)
+        assertNotNull(ex.message)
+        assertNotNull(ex.cause)
+    }
+
+    @Test
+    fun testDeepNestingPreserved() = runTest {
+        // Verify that legitimate deep nesting is preserved
+        val result = runCatching {
+            coroutineScope<Unit> {
+                val deepCause = RuntimeException("deep")
+                val middleCause = IllegalStateException(deepCause)
+                throw ExceptionWithMultipleConstructors(middleCause)
+            }
+        }
+        val ex = result.exceptionOrNull() ?: error("Expected to fail")
+        assertTrue(ex is ExceptionWithMultipleConstructors)
+        assertTrue(ex.cause is IllegalStateException)
+        assertTrue(ex.cause?.cause is RuntimeException)
+        assertEquals("deep", (ex.cause?.cause as RuntimeException).message)
+    }
+
+    // Constructor order: String first, then Throwable, then no-arg
+    class ExceptionWithMultipleConstructors : RuntimeException {
+        constructor(message: String) : super(message)
+        constructor(cause: Throwable) : super(cause)
+        constructor() : super()
+    }
+
+    // Exception with all constructor types
+    class ExceptionWithAllConstructors : RuntimeException {
+        constructor(message: String, cause: Throwable) : super(message, cause)
+        constructor(message: String) : super(message)
+        constructor(cause: Throwable) : super(cause)
+        constructor() : super()
+    }
+}
+

