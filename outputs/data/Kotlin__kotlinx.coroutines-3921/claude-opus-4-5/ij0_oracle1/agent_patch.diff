@@ -156,6 +156,18 @@ internal val CoroutineContext.delay: Delay get() = get(ContinuationInterceptor)
 /**
  * Convert this duration to its millisecond value.
  * Positive durations are coerced at least `1`.
+ * Durations with sub-millisecond components are rounded up to the next millisecond.
