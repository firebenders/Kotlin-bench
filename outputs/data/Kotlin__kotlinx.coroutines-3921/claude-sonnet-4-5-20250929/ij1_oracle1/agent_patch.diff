@@ -156,6 +156,15 @@ internal val CoroutineContext.delay: Delay get() = get(ContinuationInterceptor)
 /**
  * Convert this duration to its millisecond value.
  * Positive durations are coerced at least `1`.
+ * Sub-millisecond components are rounded up to ensure the delay is at least as long as requested.
  */
-internal fun Duration.toDelayMillis(): Long =
-    if (this > Duration.ZERO) inWholeMilliseconds.coerceAtLeast(1) else 0
+internal fun Duration.toDelayMillis(): Long = if (this > Duration.ZERO) {
+    val millis = inWholeMilliseconds
+    // Handle Long.MAX_VALUE (infinite duration) specially to avoid overflow
+    if (millis >= Long.MAX_VALUE / 1_000_000) {
+        millis
+    } else {
+        // Round up if there are sub-millisecond components to ensure delay is not shorter than requested
+        if (millis * 1_000_000 < inWholeNanoseconds) millis + 1 else millis.coerceAtLeast(1)
+    }
+} else 0
