@@ -155,7 +155,16 @@ internal val CoroutineContext.delay: Delay get() = get(ContinuationInterceptor)
 
 /**
  * Convert this duration to its millisecond value.
- * Positive durations are coerced at least `1`.
+ * Positive durations are rounded up and coerced to at least `1` millisecond of delay.
  */
-internal fun Duration.toDelayMillis(): Long =
-    if (this > Duration.ZERO) inWholeMilliseconds.coerceAtLeast(1) else 0
+internal fun Duration.toDelayMillis(): Long {
+    if (this <= Duration.ZERO) return 0
+    if (this == Duration.INFINITE) return Long.MAX_VALUE
+
+    val millis = inWholeMilliseconds
+    if (millis == Long.MAX_VALUE) return Long.MAX_VALUE
+
+    val millisDuration = millis.toDuration(DurationUnit.MILLISECONDS)
+    val rounded = if (this > millisDuration) millis + 1 else millis
+    return rounded.coerceAtLeast(1)
+}
