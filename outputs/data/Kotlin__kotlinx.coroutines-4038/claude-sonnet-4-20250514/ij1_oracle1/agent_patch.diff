+    fun testOnCompletionWithTakeAndFirst() = runTest {
+        // Regression test for exception propagation from downstream operators like first()
+        var cause: Throwable? = null
+        
+        val result = flowOf(1, 2, 3)
+            .take(2) 
+            .onCompletion { 
+                cause = it
+                // Should be called with exception from first() not null
