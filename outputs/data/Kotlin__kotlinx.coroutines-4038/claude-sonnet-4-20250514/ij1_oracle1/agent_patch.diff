+    }
 }
diff --git a/kotlinx-coroutines-core/common/test/flow/operators/TakeTest.kt b/kotlinx-coroutines-core/common/test/flow/operators/TakeTest.kt
index 3ecc2f4ad..47baf4ac0 100644
--- a/kotlinx-coroutines-core/common/test/flow/operators/TakeTest.kt
+++ b/kotlinx-coroutines-core/common/test/flow/operators/TakeTest.kt
@@ -141,4 +141,81 @@ class TakeTest : TestBase() {
         }
         assertEquals(listOf(1, 1, 1), outer.take(3).toList())
     }
+
+    @Test
+    fun testTakeWithOnCompletionAndFirst() = runTest {
+        // Regression test for issue where take + onCompletion + first would hang
+        // instead of returning the first value properly
+        val result = flowOf(1)
+            .take(1)
+            .onCompletion { cause ->
+                // This should be called with AbortFlowException from first()
+                assertNotNull(cause) { "Expected exception from first(), but got null" }
+            }
+            .first()
+        
+        assertEquals(1, result)
+    }
+    
+    @Test 
+    fun testTakeWithOnCompletionAwaitCancellationAndFirst() = runTest {
+        // Test the specific scenario from the bug report
+        var completionCalled = false
+        
+        val result = withTimeoutOrNull(1000) { // Should not hang
+            flowOf(1)
+                .take(1)
+                .onCompletion { cause ->
+                    completionCalled = true
+                    if (cause == null) {
+                        awaitCancellation() // This should not execute since first() throws
+                    }
+                }
+                .first()
+        }
+        
+        assertEquals(1, result)
+        assertTrue(completionCalled, "onCompletion should be called")
+    }
+    
+    @Test
+    fun testOriginalBugReportScenarios() = runTest {
+        // Test the exact scenarios from the bug report to ensure they all work
+
+        // Scenario 1: The original hanging case - should now work
+        val result1 = withTimeoutOrNull(1000) {
+            flowOf(1)
+                .take(1)
+                .onCompletion { if (it == null) awaitCancellation() }
+                .first()
+        }
+        assertEquals(1, result1, "Original hanging case should now return 1")
+
+        // Scenario 2: With onEach (was working before) - should still work
+        val result2 = withTimeoutOrNull(1000) {
+            flowOf(1)
+                .take(1)
+                .onEach { } // no-op operator
+                .onCompletion { if (it == null) awaitCancellation() }
+                .first()
+        }
+        assertEquals(1, result2, "Case with onEach should still work")
+
+        // Scenario 3: Without take() (was working before) - should still work  
+        val result3 = withTimeoutOrNull(1000) {
+            flowOf(1)
+                .onCompletion { if (it == null) awaitCancellation() }
+                .first()
+        }
+        assertEquals(1, result3, "Case without take should still work")
+        
+        // Scenario 4: The additional case with take(100) mentioned in comments
+        val result4 = withTimeoutOrNull(1000) {
+            flowOf(1, 2, 3)
+                .take(100) // This was also hanging 
+                .onCompletion { if (it == null) awaitCancellation() }
+                .first()
+        }
+        assertEquals(1, result4, "Case with take(100) should now work")
+    }
 }
