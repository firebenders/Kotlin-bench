diff --git a/kotlinx-coroutines-core/common/test/flow/operators/TakeAndFirstHangTest.kt b/kotlinx-coroutines-core/common/test/flow/operators/TakeAndFirstHangTest.kt
new file mode 100644
--- /dev/null
+++ b/kotlinx-coroutines-core/common/test/flow/operators/TakeAndFirstHangTest.kt
@@ -0,0 +1,43 @@
+package kotlinx.coroutines.flow.operators
+
+import kotlinx.coroutines.ExperimentalCoroutinesApi
+import kotlinx.coroutines.awaitCancellation
+import kotlinx.coroutines.flow.*
+import kotlinx.coroutines.test.runTest
+import kotlin.test.Test
+import kotlin.test.assertEquals
+import kotlin.test.assertFailsWith
+import kotlin.time.ExperimentalTime
+
+@OptIn(ExperimentalCoroutinesApi::class)
+class TakeAndFirstHangTest {
+    @Test
+    fun testTakeFirstOnCompletionNoHang() = runTest {
+        val result = flowOf(1)
+            .take(1)
+            .onCompletion { if (it == null) awaitCancellation() }
+            .first()
+        assertEquals(1, result)
+    }
+
+    @Test
+    fun testTakeLargeFirstOnCompletionNoHang() = runTest {
+        val result = flowOf(1, 2, 3)
+            .take(100)
+            .onCompletion { if (it == null) awaitCancellation() }
+            .first()
+        assertEquals(1, result)
+    }
+
+    @Test
+    fun testOnCompletionWithAbortException() = runTest {
+        val e = assertFailsWith<NoSuchElementException> {
+            emptyFlow<Int>()
+                .take(1)
+                .onCompletion { if (it == null) awaitCancellation() }
+                .first()
+        }
+        assertEquals("Expected at least one element", e.message)
+    }
+}
+
