@@ -0,0 +1,34 @@
+package kotlinx.coroutines.flow
+
+import kotlinx.coroutines.TestBase
+import kotlinx.coroutines.awaitCancellation
+import kotlinx.coroutines.testing.runTest
+import kotlin.test.Test
+import kotlin.test.assertEquals
+import kotlin.test.assertNotNull
+
+class TakeOnCompletionFirstTest : TestBase() {
+    @Test
+    fun testFirstDoesNotHangWhenOnCompletionAwaitsCancellation() = runTest {
+        val result = flowOf(1)
+            .take(1)
+            .onCompletion { if (it == null) awaitCancellation() }
+            .first()
+
+        assertEquals(1, result)
+    }
+
+    @Test
+    fun testOnCompletionReceivesDownstreamCancellation() = runTest {
+        var completionCause: Throwable? = null
+
+        val result = flowOf(1)
+            .take(1)
+            .onCompletion { completionCause = it }
+            .first()
+
+        assertEquals(1, result)
+        assertNotNull(completionCause)
+    }
+}
+
