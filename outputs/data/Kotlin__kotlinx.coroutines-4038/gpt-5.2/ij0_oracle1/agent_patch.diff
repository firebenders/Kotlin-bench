@@ -0,0 +1,31 @@
+package kotlinx.coroutines.flow
+
+import kotlinx.coroutines.*
+import kotlinx.coroutines.testing.*
+import kotlin.test.*
+
+class FirstTakeOnCompletionTest : TestBase() {
+
+    @Test
+    fun testTakeOnCompletionFirstDoesNotHang() = runTest {
+        val result = withTimeout(1_000) {
+            flowOf(1)
+                .take(1)
+                .onCompletion { if (it == null) awaitCancellation() }
+                .first()
+        }
+        assertEquals(1, result)
+    }
+
+    @Test
+    fun testTakeLargerThanUpstreamOnCompletionFirstDoesNotHang() = runTest {
+        val result = withTimeout(1_000) {
+            flowOf(1, 2, 3)
+                .take(100)
+                .onCompletion { if (it == null) awaitCancellation() }
+                .first()
+        }
+        assertEquals(1, result)
+    }
+}
+
