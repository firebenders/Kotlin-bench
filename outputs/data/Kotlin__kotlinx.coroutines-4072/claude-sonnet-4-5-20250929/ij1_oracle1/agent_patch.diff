+package kotlinx.coroutines.flow.operators
+
+import kotlinx.coroutines.testing.*
+import kotlinx.coroutines.*
+import kotlinx.coroutines.channels.*
+import kotlinx.coroutines.flow.*
+import kotlin.test.*
+import kotlin.time.Duration.Companion.milliseconds
+import kotlin.time.Duration.Companion.seconds
+
+class CallbackFlowTimeoutTest : TestBase() {
+    /**
+     * Tests that when callbackFlow is closed with an exception and chained directly with timeout,
+     * the exception is properly propagated to the downstream collector.
+     * 
+     * This is a regression test for the issue where .onClosed handler in timeout()
+     * was not accepting the exception parameter.
+     */
+    @Test
+    fun testCallbackFlowCloseExceptionWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            close(IllegalStateException("Test Exception"))
+        }.timeout(5.seconds)
+        
+        var caughtException: Exception? = null
+        try {
+            flow.collect()
+        } catch (e: Exception) {
+            caughtException = e
+        }
+        
+        assertNotNull(caughtException, "Exception should have been caught")
+        assertTrue(caughtException is IllegalStateException, "Should be IllegalStateException but got ${caughtException::class}")
+        assertEquals("Test Exception", caughtException.message)
+    }
+    
+    /**
+     * Tests that when callbackFlow is closed normally (without exception) and chained with timeout,
+     * the flow completes successfully without throwing.
+     */
+    @Test
+    fun testCallbackFlowCloseNormallyWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            close()
+        }.timeout(5.seconds)
+        
+        // Should complete without throwing
+        flow.collect()
+        finish(1)
+    }
+    
+    /**
+     * Tests that with an intermediate operator between callbackFlow and timeout,
+     * the exception is properly propagated (this was already working before the fix).
+     */
+    @Test
+    fun testCallbackFlowCloseExceptionWithIntermediateOperator() = runTest {
+        val flow = callbackFlow<Int> {
+            close(IllegalStateException("Test Exception"))
+        }.catch { throw it }.timeout(5.seconds)
+        
+        var caughtException: Exception? = null
+        try {
+            flow.collect()
+        } catch (e: Exception) {
+            caughtException = e
+        }
+        
+        assertNotNull(caughtException, "Exception should have been caught")
+        assertTrue(caughtException is IllegalStateException)
+        assertEquals("Test Exception", caughtException.message)
+    }
+    
+    /**
+     * Tests that timeout still works correctly and throws TimeoutCancellationException
+     * when a timeout actually occurs.
+     */
+    @Test
+    fun testCallbackFlowActualTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            // Never emit or close - should timeout
+            awaitClose()
+        }.timeout(100.milliseconds)
+        
+        assertFailsWith<TimeoutCancellationException> {
+            flow.collect()
+        }
+    }
+    
+    /**
+     * Tests that emissions work correctly before the exception is thrown.
+     */
+    @Test
+    fun testCallbackFlowEmitThenCloseWithException() = runTest {
+        val flow = callbackFlow<Int> {
+            send(1)
+            send(2)
+            close(IllegalStateException("Test Exception"))
+        }.timeout(5.seconds)
+        
+        val collected = mutableListOf<Int>()
+        var caughtException: Exception? = null
+        try {
+            flow.collect { collected.add(it) }
+        } catch (e: Exception) {
+            caughtException = e
+        }
+        
+        assertEquals(listOf(1, 2), collected, "Should have collected emitted values")
+        assertNotNull(caughtException, "Exception should have been caught")
+        assertTrue(caughtException is IllegalStateException)
+        assertEquals("Test Exception", caughtException.message)
+    }
+}
+
