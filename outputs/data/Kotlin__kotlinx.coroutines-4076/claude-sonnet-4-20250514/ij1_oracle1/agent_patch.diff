diff --git a/kotlinx-coroutines-core/common/test/flow/operators/TimeoutTest.kt b/kotlinx-coroutines-core/common/test/flow/operators/TimeoutTest.kt
index a2ca101ef..3c62356a3 100644
--- a/kotlinx-coroutines-core/common/test/flow/operators/TimeoutTest.kt
+++ b/kotlinx-coroutines-core/common/test/flow/operators/TimeoutTest.kt
@@ -245,4 +245,80 @@ class TimeoutTest : TestBase() {
             finish(2)
         })
     }
+
+    @Test
+    fun testCallbackFlowCloseWithExceptionPropagation() = runTest {
+        // Test for the bug where callbackFlow + timeout doesn't propagate close exceptions
+        val testException = IllegalStateException("Test Exception")
+        val flow = callbackFlow<Int> {
+            close(testException)
+        }.timeout(5.seconds)
+
+        // The exception from close() should be propagated through timeout
+        val thrownException = assertFailsWith<IllegalStateException> {
+            flow.collect()
+        }
+        assertEquals("Test Exception", thrownException.message)
+    }
+
+    @Test
+    fun testCallbackFlowNormalCloseWithTimeout() = runTest {
+        // Test that normal close (without exception) works correctly with timeout
+        val flow = callbackFlow<Int> {
+            emit(1)
+            close()  // Normal close
+        }.timeout(5.seconds)
+
+        val result = flow.toList()
+        assertEquals(listOf(1), result)
+    }
+
+    @Test
+    fun testCallbackFlowExceptionWithIntermediateOperator() = runTest {
+        // Verify that the fix works the same as adding an intermediate operator
+        val testException = IllegalStateException("Test Exception")
+        
+        // This should work the same as the direct callbackFlow + timeout
+        val flowWithCatch = callbackFlow<Int> {
+            close(testException)
+        }.catch { throw it }.timeout(5.seconds)
+
+        val flowDirect = callbackFlow<Int> {
+            close(testException)  
+        }.timeout(5.seconds)
+
+        // Both should throw the same exception
+        val exception1 = assertFailsWith<IllegalStateException> {
+            flowWithCatch.collect()
+        }
+        val exception2 = assertFailsWith<IllegalStateException> {
+            flowDirect.collect()
+        }
+        
+        assertEquals(exception1.message, exception2.message)
+    }
+
+    @Test
+    fun testOriginalIssueReproducer() = runTest {
+        // Direct test reproducing the exact issue from the bug report
+        val flow = callbackFlow<Int> {
+            close(IllegalStateException("Test Exception"))
+        }.timeout(5.seconds)
+        
+        var exceptionCaught = false
+        var caughtException: Exception? = null
+        
+        try {
+            flow.collect()
+        } catch (e: Exception) {
+            exceptionCaught = true
+            caughtException = e
+        }
+        
+        // Before the fix, no exception would be caught
+        // After the fix, we should catch the IllegalStateException
+        assertTrue(exceptionCaught, "Exception should have been caught")
+        assertTrue(caughtException is IllegalStateException, "Should catch IllegalStateException")
+        assertEquals("Test Exception", caughtException?.message)
+    }
 }
