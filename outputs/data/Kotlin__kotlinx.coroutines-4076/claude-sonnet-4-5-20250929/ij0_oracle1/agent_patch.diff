@@ -0,0 +1,72 @@
+package kotlinx.coroutines.flow.operators
+
+import kotlinx.coroutines.testing.*
+import kotlinx.coroutines.*
+import kotlinx.coroutines.flow.*
+import kotlin.test.*
+import kotlin.time.Duration.Companion.seconds
+
+class TimeoutCallbackFlowTest : TestBase() {
+    @Test
+    fun testCallbackFlowCloseExceptionWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            close(IllegalStateException("Test Exception"))
+        }.timeout(5.seconds)
+        
+        try {
+            flow.collect()
+            expectUnreached()
+        } catch (e: Exception) {
+            assertTrue(e is IllegalStateException)
+            assertEquals("Test Exception", e.message)
+        }
+        finish(1)
+    }
+    
+    @Test
+    fun testCallbackFlowCloseExceptionWithTimeoutAndIntermediateOperator() = runTest {
+        val flow = callbackFlow<Int> {
+            close(IllegalStateException("Test Exception"))
+        }.catch { throw it }.timeout(5.seconds)
+        
+        try {
+            flow.collect()
+            expectUnreached()
+        } catch (e: Exception) {
+            assertTrue(e is IllegalStateException)
+            assertEquals("Test Exception", e.message)
+        }
+        finish(1)
+    }
+    
+    @Test
+    fun testCallbackFlowCloseNormallyWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            close()
+        }.timeout(5.seconds)
+        
+        assertEquals(emptyList(), flow.toList())
+        finish(1)
+    }
+    
+    @Test
+    fun testCallbackFlowWithEmissionAndCloseExceptionWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            send(1)
+            send(2)
+            close(IllegalStateException("Test Exception"))
+        }.timeout(5.seconds)
+        
+        val result = mutableListOf<Int>()
+        try {
+            flow.collect { result.add(it) }
+            expectUnreached()
+        } catch (e: Exception) {
+            assertTrue(e is IllegalStateException)
+            assertEquals("Test Exception", e.message)
+            assertEquals(listOf(1, 2), result)
+        }
+        finish(1)
+    }
+}
+
