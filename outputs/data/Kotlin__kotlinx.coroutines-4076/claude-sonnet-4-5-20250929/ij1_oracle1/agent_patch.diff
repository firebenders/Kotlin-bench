+package kotlinx.coroutines.flow.operators
+
+import kotlinx.coroutines.*
+import kotlinx.coroutines.flow.*
+import kotlinx.coroutines.testing.*
+import kotlin.test.*
+import kotlin.time.Duration.Companion.seconds
+
+/**
+ * Test for callbackFlow and timeout interaction.
+ * This test verifies that when callbackFlow is closed with an exception
+ * and combined with timeout, the exception is properly propagated.
+ */
+class CallbackFlowTimeoutTest : TestBase() {
+    
+    @Test
+    fun testCallbackFlowCloseExceptionWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            close(IllegalStateException("Test Exception"))
+        }.timeout(5.seconds)
+        
+        try {
+            flow.collect()
+            expectUnreached()
+        } catch (e: IllegalStateException) {
+            assertEquals("Test Exception", e.message)
+            finish(1)
+        }
+    }
+    
+    @Test
+    fun testCallbackFlowCloseExceptionWithTimeoutAndIntermediateOperator() = runTest {
+        // This should work even without the fix (adding catch as intermediate operator)
+        val flow = callbackFlow<Int> {
+            close(IllegalStateException("Test Exception"))
+        }.catch { throw it }.timeout(5.seconds)
+        
+        try {
+            flow.collect()
+            expectUnreached()
+        } catch (e: IllegalStateException) {
+            assertEquals("Test Exception", e.message)
+            finish(1)
+        }
+    }
+    
+    @Test
+    fun testCallbackFlowNormalCloseWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            send(1)
+            send(2)
+            close()
+        }.timeout(5.seconds)
+        
+        val result = flow.toList()
+        assertEquals(listOf(1, 2), result)
+        finish(1)
+    }
+    
+    @Test
+    fun testCallbackFlowCancellationExceptionWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            close(CancellationException("Cancelled"))
+        }.timeout(5.seconds)
+        
+        try {
+            flow.collect()
+            expectUnreached()
+        } catch (e: CancellationException) {
+            assertEquals("Cancelled", e.message)
+            finish(1)
+        }
+    }
+    
+    @Test
+    fun testCallbackFlowMultipleEmitsBeforeExceptionWithTimeout() = runTest {
+        val flow = callbackFlow<Int> {
+            send(1)
+            send(2)
+            send(3)
+            close(IllegalStateException("After emissions"))
+        }.timeout(5.seconds)
+        
+        val result = mutableListOf<Int>()
+        try {
+            flow.collect { result.add(it) }
+            expectUnreached()
+        } catch (e: IllegalStateException) {
+            assertEquals("After emissions", e.message)
+            assertEquals(listOf(1, 2, 3), result)
+            finish(1)
+        }
+    }
+}
+
