new file mode 100644
--- /dev/null
+++ b/test_yield_fix.kt
@@ -0,0 +1,32 @@
+import kotlinx.coroutines.*
+
+fun main() = runBlocking {
+    println("Testing yield with delayed task issue...")
+    
+    var result = ""
+    
+    // Launch with UNDISPATCHED so it starts immediately
+    launch(start = CoroutineStart.UNDISPATCHED) {
+        delay(1) // Very short delay - should already be expired after 100ms sleep
+        result += "first"
+        println("Delayed task executed")
+    }
+    
+    // Sleep to ensure the delay time has passed
+    Thread.sleep(100)
+    println("After sleep - delay should be expired")
+    
+    // At this point, the launched coroutine should be ready to resume
+    // yield() should yield to it, not resume immediately  
+    println("About to yield...")
+    yield()
+    result += "second"
+    println("After yield")
+    
+    // Give time for any remaining work
+    delay(10)
+    
+    println("Final result: '$result'")
+    println("Expected: 'firstsecond'")
+    println("Test ${if (result == "firstsecond") "PASSED" else "FAILED"}")
+}
