@@ -0,0 +1,33 @@
+package kotlinx.coroutines
+
+import kotlinx.coroutines.testing.*
+import org.junit.Test
+import kotlin.test.*
+
+class YieldEventLoopTest : TestBase() {
+    @Test
+    fun testYieldToDelayedTask() = runBlocking {
+        var firstRan = false
+        launch {
+            delay(1)
+            firstRan = true
+        }
+        yield() // let launch run and reach delay
+        Thread.sleep(100) // wait for delay to expire
+        yield() // this yield should now yield to the expired delayed task
+        assertTrue(firstRan, "Yield should have resumed the delayed coroutine")
+    }
+
+    @Test
+    fun testYieldToDelayedTaskUndispatched() = runBlocking {
+        var firstRan = false
+        launch(start = CoroutineStart.UNDISPATCHED) {
+            delay(1)
+            firstRan = true
+        }
+        Thread.sleep(100) // wait for delay to expire
+        yield()
+        assertTrue(firstRan, "Yield should have resumed the delayed coroutine")
+    }
+}
+
