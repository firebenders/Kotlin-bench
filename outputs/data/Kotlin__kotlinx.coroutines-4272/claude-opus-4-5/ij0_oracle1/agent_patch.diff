+package kotlinx.coroutines.flow
+
+import kotlinx.coroutines.*
+import kotlinx.coroutines.testing.*
+import org.junit.Test
+import kotlin.coroutines.*
+import kotlin.test.*
+
+class FlowOnDispatcherExceptionTest : TestBase() {
+
+    /**
+     * Tests that flowOn with a throwing dispatcher properly propagates the exception
+     * instead of hanging. This is a regression test for
+     * https://github.com/JetBrains/compose-multiplatform/issues/4835
+     */
+    @Test
+    fun testFlowOnWithThrowingDispatcher() = runTest {
+        val exception = assertFailsWith<IllegalStateException> {
+            flowOf(1, 2, 3)
+                .flowOn(ThrowingDispatcher)
+                .collect {
+                    expectUnreached()
+                }
+        }
+        assertEquals("Dispatcher throws", exception.message)
+    }
+
+    /**
+     * Tests that flowOn with buffer and a throwing dispatcher properly propagates the exception.
+     */
+    @Test
+    fun testFlowOnBufferedWithThrowingDispatcher() = runTest {
+        val exception = assertFailsWith<IllegalStateException> {
+            flowOf(1, 2, 3)
+                .buffer()
+                .flowOn(ThrowingDispatcher)
+                .collect {
+                    expectUnreached()
+                }
+        }
+        assertEquals("Dispatcher throws", exception.message)
+    }
+
+    /**
+     * Tests channelFlow with a throwing dispatcher.
+     */
+    @Test
+    fun testChannelFlowWithThrowingDispatcher() = runTest {
+        val exception = assertFailsWith<IllegalStateException> {
+            channelFlow {
+                send(1)
+            }
+                .flowOn(ThrowingDispatcher)
+                .collect {
+                    expectUnreached()
+                }
+        }
+        assertEquals("Dispatcher throws", exception.message)
+    }
+
+    /**
+     * A dispatcher that always throws when dispatch is called.
+     * This simulates the case when Dispatchers.Main.immediate is used
+     * but Main dispatcher is not available in the classpath.
+     */
+    private object ThrowingDispatcher : CoroutineDispatcher() {
+        override fun dispatch(context: CoroutineContext, block: Runnable) {
+            throw IllegalStateException("Dispatcher throws")
+        }
+    }
+}
