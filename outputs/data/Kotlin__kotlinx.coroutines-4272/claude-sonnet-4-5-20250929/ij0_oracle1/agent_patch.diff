@@ -0,0 +1,31 @@
+import kotlinx.coroutines.*
+import kotlinx.coroutines.flow.*
+import kotlin.coroutines.*
+
+class FailingDispatcher : CoroutineDispatcher() {
+    override fun dispatch(context: CoroutineContext, block: Runnable) {
+        throw IllegalStateException("Dispatcher not available")
+    }
+
+    override fun isDispatchNeeded(context: CoroutineContext): Boolean {
+        throw IllegalStateException("Dispatcher not available")
+    }
+}
+
+fun main() = runBlocking {
+    println("Testing flowOn with failing dispatcher...")
+    
+    try {
+        flowOf(1, 2, 3)
+            .flowOn(FailingDispatcher())
+            .collect {
+                println("collect: $it")
+            }
+        println("ERROR: No exception was thrown!")
+    } catch (e: Exception) {
+        println("SUCCESS: Exception was caught: ${e.message}")
+    }
+    
+    println("Test completed.")
+}
+
