+/**
+ * Use this function to start coroutine in atomic mode, so that it starts in any case,
+ * but properly handles dispatcher failures by completing the coroutine with the exception.
+ */
+internal fun <R, T> (suspend (R) -> T).startCoroutineAtomic(
+    receiver: R, completion: Continuation<T>,
+) = runSafely(completion) {
+    startCoroutine(receiver, completion)
+}
