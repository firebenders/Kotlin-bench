+
+        internal class ReplaceRecommendedBindings : PreferenceUpgrade(12) {
+            override fun upgrade(preferences: SharedPreferences) {
+                moveBindings(preferences, OLD_RECOMMENDED_BINDING_KEY, ViewerCommand.FLIP_OR_ANSWER_EASE3)
+                moveBindings(preferences, OLD_BETTER_THAN_RECOMMENDED_KEY, ViewerCommand.FLIP_OR_ANSWER_EASE4)
+            }
+
+            private fun moveBindings(preferences: SharedPreferences, legacyKey: String, targetCommand: ViewerCommand) {
+                val legacyValue = preferences.getString(legacyKey, null)
+                if (legacyValue.isNullOrEmpty()) {
+                    preferences.edit { remove(legacyKey) }
+                    return
+                }
+                val legacyBindings = fromPreferenceString(legacyValue)
+                if (legacyBindings.isEmpty()) {
+                    preferences.edit { remove(legacyKey) }
+                    return
+                }
+                val targetBindings = fromPreference(preferences, targetCommand)
+                var changed = false
+                for (binding in legacyBindings) {
+                    if (!targetBindings.contains(binding)) {
+                        targetBindings.add(binding)
+                        changed = true
+                    }
+                }
+                preferences.edit {
+                    if (changed || preferences.contains(targetCommand.preferenceKey)) {
+                        putString(targetCommand.preferenceKey, targetBindings.toPreferenceString())
+                    }
+                    remove(legacyKey)
+                }
+            }
+
+            companion object {
+                private const val OLD_RECOMMENDED_BINDING_KEY = "binding_FLIP_OR_ANSWER_RECOMMENDED"
+                private const val OLD_BETTER_THAN_RECOMMENDED_KEY = "binding_FLIP_OR_ANSWER_BETTER_THAN_RECOMMENDED"
+            }
+        }
     }
 }
 
