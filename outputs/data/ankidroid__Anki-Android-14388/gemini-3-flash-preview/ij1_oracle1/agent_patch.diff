diff --git a/AnkiDroid/src/test/java/com/ichi2/anki/preferences/ControlsSettingsTest.kt b/AnkiDroid/src/test/java/com/ichi2/anki/preferences/ControlsSettingsTest.kt
new file mode 100644
--- /dev/null
+++ b/AnkiDroid/src/test/java/com/ichi2/anki/preferences/ControlsSettingsTest.kt
@@ -0,0 +1,52 @@
+package com.ichi2.anki.preferences
+
+import com.ichi2.anki.cardviewer.ViewerCommand
+import org.junit.Assert.assertTrue
+import org.junit.Test
+import java.io.File
+import kotlin.text.Regex
+
+class ControlsSettingsTest {
+    @Test
+    fun allCommandsPresentInXml() {
+        // We are running from the AnkiDroid module root
+        val xmlFile = File("src/main/res/xml/preferences_controls.xml")
+        assertTrue("XML file not found at ${xmlFile.absolutePath}", xmlFile.exists())
+        val content = xmlFile.readText()
+        for (command in ViewerCommand.values()) {
+            assertTrue("Command ${command.name} (key: ${command.preferenceKey}) missing from XML", 
+                content.contains("android:key=\"${command.preferenceKey}\""))
+        }
+    }
+
+    @Test
+    fun allCommandsInCorrectCategories() {
+        val xmlFile = File("src/main/res/xml/preferences_controls.xml")
+        assertTrue(xmlFile.exists())
+        val content = xmlFile.readText()
+
+        // Match PreferenceCategory blocks using (?s) for dot-all mode
+        val categoryRegex = Regex("(?s)<PreferenceCategory\\s+[^>]*android:key=\"([^\"]+)\"[^>]*>(.*?)</PreferenceCategory>")
+        val categoryMatches = categoryRegex.findAll(content).toList()
+
+        for (command in ViewerCommand.values()) {
+            val expectedCategoryKeyResName = when(command.category) {
+                ViewerCommand.Category.ANSWER_BUTTONS -> "controls_category_answer_buttons_key"
+                ViewerCommand.Category.FLAGS -> "controls_category_flags_key"
+                ViewerCommand.Category.WHITEBOARD -> "controls_category_whiteboard_key"
+                ViewerCommand.Category.CURRENT_CARD_NOTE -> "controls_category_current_card_note_key"
+                ViewerCommand.Category.NAVIGATION -> "controls_category_navigation_key"
+                ViewerCommand.Category.MISC -> "controls_category_misc_key"
+            }
+            val expectedCategoryKey = "@string/$expectedCategoryKeyResName"
+
+            val categoryMatch = categoryMatches.find { it.groupValues[1] == expectedCategoryKey }
+            assertTrue("Category $expectedCategoryKey not found in XML", categoryMatch != null)
+
+            val categoryContent = categoryMatch!!.groupValues[2]
