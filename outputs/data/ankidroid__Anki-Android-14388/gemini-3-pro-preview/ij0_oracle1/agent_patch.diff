-    /** Attaches all possible [ControlPreference] elements to a given [PreferenceCategory] */
-    fun addAllControlPreferencesToCategory(category: PreferenceCategory) {
+    /** Attaches all possible [ControlPreference] elements to the preference screen grouped by category */
+    fun addAllControlPreferencesToCategory() {
+        val orderedCategories = listOf(
+            R.string.controls_category_answer,
+            R.string.controls_category_flags,
+            R.string.controls_category_whiteboard,
+            R.string.controls_category_current_card,
+            R.string.controls_category_navigation,
+            R.string.controls_category_misc
+        )
+
+        val categoryMap = HashMap<Int, PreferenceCategory>()
+        val context = preferenceManager.context
+
+        for (resId in orderedCategories) {
+            val category = PreferenceCategory(context)
+            category.setTitle(resId)
+            preferenceScreen.addPreference(category)
+            categoryMap[resId] = category
+        }
+
         for (command in ViewerCommand.values()) {
-            val preference = ControlPreference(category.context).apply {
+            val preference = ControlPreference(context).apply {
                 setTitle(command.resourceId)
                 key = command.preferenceKey
                 setDefaultValue(command.defaultValue.toPreferenceString())
             }
-            category.addPreference(preference)
+
+            val categoryId = command.categoryResourceId ?: R.string.controls_category_misc
+            val category = categoryMap[categoryId]
+            if (category != null) {
+                category.addPreference(preference)
+            } else {
+                val newCategory = PreferenceCategory(context)
+                newCategory.setTitle(categoryId)
+                preferenceScreen.addPreference(newCategory)
+                categoryMap[categoryId] = newCategory
+                newCategory.addPreference(preference)
+            }
         }
     }
 }
