+package com.ichi2.anki.preferences
+
+import android.content.Context
+import androidx.preference.PreferenceManager
+import com.ichi2.anki.R
+import com.ichi2.anki.RobolectricTest
+import com.ichi2.anki.cardviewer.ViewerCommand
+import org.junit.Assert.assertNotNull
+import org.junit.Assert.assertTrue
+import org.junit.Test
+import org.junit.runner.RunWith
+import org.robolectric.RobolectricTestRunner
+
+@RunWith(RobolectricTestRunner::class)
+class ControlsSettingsFragmentTest : RobolectricTest() {
+
+    /**
+     * Test that all [ViewerCommand] values are assigned to a category.
+     * This ensures that no command is left without a category.
+     */
+    @Test
+    fun allCommandsHaveCategory() {
+        for (command in ViewerCommand.values()) {
+            assertNotNull("Command ${command.name} should have a category", command.category)
+        }
+    }
+
+    /**
+     * Test that all [ViewerCommand] values have a valid category resource ID.
+     */
+    @Test
+    fun allCommandCategoriesHaveValidResourceIds() {
+        val context = targetContext
+        for (category in ViewerCommand.CommandCategory.values()) {
+            val categoryName = context.getString(category.resourceId)
+            assertTrue("Category should have a non-empty name", categoryName.isNotEmpty())
+        }
+    }
+
+    /**
+     * Test that all commands can be grouped by category.
+     * Each category should have at least one command.
+     */
+    @Test
+    fun allCategoriesHaveAtLeastOneCommand() {
+        // Group commands by category
+        val commandsByCategory = ViewerCommand.values().groupBy { it.category }
+
+        // Check that each category has at least one command
+        for (category in ViewerCommand.CommandCategory.values()) {
+            val commands = commandsByCategory[category]
+            assertNotNull("Category ${category.name} should exist in map", commands)
+            assertTrue(
+                "Category ${category.name} should have at least one command",
+                commands!!.isNotEmpty()
+            )
+        }
+    }
+
+    /**
+     * Test that all commands have unique preference keys.
+     */
+    @Test
+    fun allCommandsHaveUniquePreferenceKeys() {
+        val keys = ViewerCommand.values().map { it.preferenceKey }
+        val uniqueKeys = keys.toSet()
+        assertTrue(
+            "All commands should have unique preference keys",
+            keys.size == uniqueKeys.size
+        )
+    }
+
+    /**
+     * Test that the fragment can be initialized and adds all control preferences.
+     */
+    @Test
+    fun fragmentCanBeInitialized() {
+        val fragment = ControlsSettingsFragment()
+        assertNotNull("Fragment should be created", fragment)
+    }
+}
+
