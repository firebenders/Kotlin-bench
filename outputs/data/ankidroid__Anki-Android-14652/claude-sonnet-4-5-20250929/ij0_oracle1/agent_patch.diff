+
+package com.ichi2.anki.cardviewer
+
+import com.ichi2.libanki.Sound
+import org.junit.Assert.assertFalse
+import org.junit.Assert.assertTrue
+import org.junit.Test
+
+/**
+ * Tests for the "Show play buttons on cards with audio" preference
+ */
+class ShowAudioPlayButtonsPreferenceTest {
+
+    @Test
+    fun `expandSounds with showPlayButtons true should include play button HTML`() {
+        val content = "Test [anki:play:q:0] content"
+        val result = Sound.expandSounds(content, showPlayButtons = true)
+        
+        // Should contain play button HTML elements
+        assertTrue("Result should contain play button HTML", result.contains("replay-button"))
+        assertTrue("Result should contain SVG element", result.contains("<svg"))
+    }
+
+    @Test
+    fun `expandSounds with showPlayButtons false should strip audio references`() {
+        val content = "Test [anki:play:q:0] content"
+        val result = Sound.expandSounds(content, showPlayButtons = false)
+        
+        // Should not contain audio references or play button HTML
+        assertFalse("Result should not contain audio references", result.contains("[anki:play"))
+        assertFalse("Result should not contain play button HTML", result.contains("replay-button"))
+        
+        // Should still contain the text content
+        assertTrue("Result should contain original text", result.contains("Test"))
+        assertTrue("Result should contain original text", result.contains("content"))
+    }
+
+    @Test
+    fun `expandSounds default behavior should show play buttons`() {
+        val content = "Test [anki:play:q:0] content"
+        val result = Sound.expandSounds(content)
+        
+        // Default behavior should show play buttons
+        assertTrue("Default behavior should include play button HTML", result.contains("replay-button"))
+    }
+
+    @Test
+    fun `expandSounds with no audio references should return unchanged content`() {
+        val content = "Test content without audio"
+        val resultWithButtons = Sound.expandSounds(content, showPlayButtons = true)
+        val resultWithoutButtons = Sound.expandSounds(content, showPlayButtons = false)
+        
+        // Content without audio references should be unchanged in both cases
+        assertTrue("Content should remain unchanged", resultWithButtons == content)
+        assertTrue("Content should remain unchanged", resultWithoutButtons == content)
+    }
+}
+

diff --git a/IMPLEMENTATION_SUMMARY.md b/IMPLEMENTATION_SUMMARY.md
new file mode 100644
--- /dev/null
+++ b/IMPLEMENTATION_SUMMARY.md
@@ -0,0 +1,92 @@
+# Implementation Summary: Show Play Buttons on Cards with Audio Preference
+
+## Overview
+This implementation adds a user preference to control whether audio play buttons are displayed on cards, matching the feature available in Anki Desktop.
+
+## Changes Made
+
+### 1. Preference Definition
+**File: `AnkiDroid/src/main/res/values/preferences.xml`**
+- Preference key already existed: `show_audio_play_buttons_key` → `showAudioPlayButtons`
+
+**File: `AnkiDroid/src/main/res/values/10-preferences.xml`**
+- Added strings:
+  - `show_audio_play_buttons`: "Show play buttons on cards with audio"
+  - `show_audio_play_buttons_summ`: "Display clickable play buttons for audio on cards"
+
+### 2. Preference UI
+**File: `AnkiDroid/src/main/res/xml/preferences_appearance.xml`**
+- Updated `SwitchPreferenceCompat` to use proper string resources
+- Set default value to `true` (matching Anki Desktop behavior)
+- Added title and summary attributes
+
+### 3. Core Implementation
+**File: `AnkiDroid/src/main/java/com/ichi2/anki/cardviewer/HtmlGenerator.kt`**
+- Added `showAudioPlayButtons: Boolean` parameter to constructor
+- Modified `createInstance()` to read the preference from SharedPreferences
+- Updated `expandSounds()` method to pass the preference value to `Sound.expandSounds()`
+
+**File: `AnkiDroid/src/main/java/com/ichi2/libanki/Sound.kt`**
+- Modified `expandSounds()` method signature to accept `showPlayButtons: Boolean` parameter (default = true)
+- Logic:
+  - When `showPlayButtons` is `true`: calls `addPlayIcons()` to insert play button HTML
+  - When `showPlayButtons` is `false`: calls `stripAvRefs()` to remove audio reference markers
+
+### 4. Analytics
+**File: `AnkiDroid/src/main/java/com/ichi2/anki/analytics/UsageAnalytics.kt`**
+- Added `showAudioPlayButtons` to the tracked preferences list for usage analytics
+
+### 5. Testing
+**File: `AnkiDroid/src/test/java/com/ichi2/anki/cardviewer/ShowAudioPlayButtonsPreferenceTest.kt`**
+- Created unit tests to verify:
+  - Play buttons are shown when preference is enabled
+  - Play buttons are hidden when preference is disabled
+  - Default behavior shows play buttons
+  - Content without audio references remains unchanged
+
+## How It Works
+
+1. **User Configuration**: User can toggle the preference in Settings → Appearance → Reviewer → "Show play buttons on cards with audio"
+
+2. **Preference Reading**: When `HtmlGenerator` is created, it reads the preference value from SharedPreferences
+
+3. **Content Processing**: When card content is processed:
+   - Audio references `[anki:play:q:0]` are found in the card HTML
+   - If preference is enabled: replaced with clickable play button HTML (SVG icons)
+   - If preference is disabled: removed completely (no visual indication)
+
+4. **Backward Compatibility**: Default value is `true`, maintaining existing behavior for users who don't change the setting
+
+## Testing Approach
+
+The implementation can be tested by:
+1. Opening AnkiDroid and navigating to Settings → Appearance
+2. Verifying the new preference appears under the Reviewer section
+3. Creating/viewing a card with audio
+4. Toggling the preference and observing whether play buttons appear/disappear
+5. Running the unit tests in `ShowAudioPlayButtonsPreferenceTest.kt`
+
+## Compatibility
+
+- **Anki Desktop**: Matches the `hide_audio_play_buttons` preference behavior (inverted logic)
+- **AnkiMobile**: Similar functionality expected
+- **Backward Compatible**: Existing cards and decks work without modification
+- **Default Behavior**: Play buttons shown by default (consistent with previous AnkiDroid behavior)
+
+## Files Modified
+
+1. `AnkiDroid/src/main/res/values/10-preferences.xml`
+2. `AnkiDroid/src/main/res/xml/preferences_appearance.xml`
+3. `AnkiDroid/src/main/java/com/ichi2/anki/cardviewer/HtmlGenerator.kt`
+4. `AnkiDroid/src/main/java/com/ichi2/libanki/Sound.kt`
+5. `AnkiDroid/src/main/java/com/ichi2/anki/analytics/UsageAnalytics.kt`
+
