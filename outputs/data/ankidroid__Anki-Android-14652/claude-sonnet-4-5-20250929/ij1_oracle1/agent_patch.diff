+
+package com.ichi2.anki.cardviewer
+
+import com.ichi2.libanki.Sound
+import org.junit.Test
+import kotlin.test.assertEquals
+import kotlin.test.assertTrue
+import kotlin.test.assertFalse
+
+class ShowAudioPlayButtonsTest {
+
+    @Test
+    fun testExpandSoundsWithPlayButtonsEnabled() {
+        val content = "Test [anki:play:q:0] content"
+        val result = Sound.expandSounds(content, showPlayButtons = true)
+        
+        // When play buttons are enabled, the content should contain the replay button HTML
+        assertTrue(result.contains("replay-button"), "Content should contain replay button when enabled")
+        assertTrue(result.contains("playsound:q:0"), "Content should contain playsound link when enabled")
+    }
+
+    @Test
+    fun testExpandSoundsWithPlayButtonsDisabled() {
+        val content = "Test [anki:play:q:0] content"
+        val result = Sound.expandSounds(content, showPlayButtons = false)
+        
+        // When play buttons are disabled, the anki:play references should be stripped
+        assertFalse(result.contains("[anki:play"), "Content should not contain anki:play references when disabled")
+        assertFalse(result.contains("replay-button"), "Content should not contain replay button when disabled")
+        assertEquals("Test  content", result, "Content should have anki:play references removed")
+    }
+
+    @Test
+    fun testExpandSoundsDefaultBehavior() {
+        val content = "Test [anki:play:q:0] content"
+        val result = Sound.expandSounds(content)
+        
+        // Default behavior should show play buttons (backwards compatible)
+        assertTrue(result.contains("replay-button"), "Default behavior should show play buttons")
+    }
+
+    @Test
+    fun testExpandSoundsWithMultipleAudioTags() {
+        val content = "Start [anki:play:q:0] middle [anki:play:a:1] end"
+        val result = Sound.expandSounds(content, showPlayButtons = false)
+        
+        // All audio references should be stripped
+        assertFalse(result.contains("[anki:play"), "All anki:play references should be removed")
+        assertEquals("Start  middle  end", result, "All anki:play references should be stripped")
+    }
+}
+

