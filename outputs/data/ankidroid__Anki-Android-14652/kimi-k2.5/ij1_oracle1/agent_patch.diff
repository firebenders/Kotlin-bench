+package com.ichi2.anki.cardviewer
+
+import android.content.res.Resources
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import com.ichi2.anki.reviewer.ReviewerCustomFonts
+import com.ichi2.libanki.Sound
+import org.junit.Test
+import org.junit.runner.RunWith
+import org.mockito.Mockito.mock
+import kotlin.test.assertEquals
+import kotlin.test.assertTrue
+import kotlin.test.assertFalse
+
+@RunWith(AndroidJUnit4::class)
+class HtmlGeneratorTest {
+
+    private val typeAnswer = mock(TypeAnswer::class.java)
+    private val cardAppearance = mock(CardAppearance::class.java)
+    private val cardTemplate = mock(CardTemplate::class.java)
+    private val resources = mock(Resources::class.java)
+
+    @Test
+    fun testExpandSoundsWithPlayButtonsEnabled() {
+        val htmlGenerator = HtmlGenerator(
+            typeAnswer,
+            cardAppearance,
+            cardTemplate,
+            resources,
+            showAudioPlayButtons = true
+        )
+
+        val contentWithSound = "[anki:play:q:0]"
+        val result = htmlGenerator.expandSounds(contentWithSound)
+
+        // When play buttons are enabled, the content should be transformed
