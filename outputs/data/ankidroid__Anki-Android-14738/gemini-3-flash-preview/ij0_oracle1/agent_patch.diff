diff --git a/AnkiDroid/src/main/java/com/ichi2/anki/Undo.kt b/AnkiDroid/src/main/java/com/ichi2/anki/Undo.kt
index 09159098ad..a3b6ac2c10 100644
--- a/AnkiDroid/src/main/java/com/ichi2/anki/Undo.kt
+++ b/AnkiDroid/src/main/java/com/ichi2/anki/Undo.kt
@@ -42,3 +42,22 @@ suspend fun FragmentActivity.undoAndShowSnackbar(duration: Int = Snackbar.LENGTH
         showSnackbar(message, duration)
     }
 }
+
+/** If there's an action that can be redone, redo it and show a snackbar */
+suspend fun FragmentActivity.redoAndShowSnackbar(duration: Int = Snackbar.LENGTH_SHORT) {
+    withProgress {
+        val changes = undoableOp {
+            if (!redoAvailable()) {
+                OpChangesAfterUndo.getDefaultInstance()
+            } else {
+                redo()
+            }
+        }
+        val message = if (changes.operation.isEmpty()) {
+            TR.actionsNothingToRedo()
+        } else {
+            TR.redoActionRedone(changes.operation)
+        }
+        showSnackbar(message, duration)
+    }
+}
