+    /**
+     * Converts the card's `ord` (ordinal) to the `cardIndex` used for preview navigation.
+     * For standard note types, ord equals cardIndex.
+     * For cloze note types, the index is determined by the position in clozeNumbersInNote.
+     * @param col The collection
+     * @param ordinal The card's ord value
+     * @return The card index for preview, or 0 if not found
+     */
+    private fun getCardIndexFromOrdinal(col: Collection, ordinal: Int): Int {
+        if (mEditedNotetype == null) {
+            return ordinal
+        }
+        return if (mEditedNotetype!!.isCloze) {
+            val note = col.newNote(mEditedNotetype!!)
+            val fieldValues = getBundleEditFields(mNoteEditorBundle)
+            for (i in fieldValues.indices) {
+                if (i < note.fields.size) {
+                    note.setField(i, fieldValues[i])
+                }
+            }
+            val clozeNumbers = col.clozeNumbersInNote(note)
+            // ordinal is 0-indexed, clozeNumbers are 1-indexed (c1 -> 1, c2 -> 2, etc.)
+            val index = clozeNumbers.indexOf(ordinal + 1)
+            if (index >= 0) index else 0
+        } else {
+            ordinal
+        }
+    }
