+/**
+ * Given a card 'ord', returns the card index
+ * This is the reverse of [cardIndexToOrd]
+ */
+private fun Note.ordToCardIndex(ord: Int): Int {
+    return when {
+        this.notetype.isCloze -> {
+            val clozeNumbers = col.clozeNumbersInNote(this)
+            // ord is 0-indexed, cloze numbers are 1-indexed
+            val index = clozeNumbers.indexOf(ord + 1)
+            // If not found (e.g., empty card), default to 0
+            if (index >= 0) index else 0
+        }
+        else -> ord
+    }
+}
