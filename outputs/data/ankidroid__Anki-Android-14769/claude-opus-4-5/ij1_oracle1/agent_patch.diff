+    /**
+     * Computes the initial card index from the ordinal value passed from the note editor.
+     * For cloze note types, ordinal (ord) is different from card index.
+     * For example, with `{{c1::A}} {{c3::B}}`, ord 2 (c3) corresponds to card index 1.
+     */
+    private fun getInitialCardIndexFromOrdinal(col: Collection): Int {
+        if (mEditedNotetype == null) {
+            return 0
+        }
+        val fieldValues = getBundleEditFields(mNoteEditorBundle)
+        if (fieldValues.isEmpty()) {
+            return 0
+        }
+        val n = col.newNote(mEditedNotetype!!)
+        var i = 0
+        while (i < fieldValues.size && i < n.fields.size) {
+            n.setField(i, fieldValues[i])
+            i++
+        }
+        return n.ordToCardIndex(mOrdinal)
+    }
