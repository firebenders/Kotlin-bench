+
+/**
+ * Converts an ordinal (ord) to a card index.
+ * For non-cloze note types, ordinal == index.
+ * For cloze note types, the index is the position of the ordinal in the cloze numbers list.
+ */
+private fun Note.ordinalToIndex(ordinal: Int): Int {
+    return when {
+        this.notetype.isCloze -> {
+            val clozeNumbers = col.clozeNumbersInNote(this)
+            // clozeNumbersInNote returns 1-based cloze numbers, ord is 0-based
+            val index = clozeNumbers.indexOf(ordinal + 1)
+            if (index >= 0) index else 0
+        }
+        else -> ordinal
+    }
+}
