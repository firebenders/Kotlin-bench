+    @Test 
+    fun `ordinal to index conversion for cloze cards works correctly`() {
+        // Test the basic functionality of ordinal to index conversion for cloze cards
+        val fields: MutableList<NoteService.NoteField?> = arrayListOf(
+            Field(0, "{{c1::First}} {{c3::Third}} {{c5::Fifth}}"),
+            Field(1, "Extra")
+        )
+
+        val clozeModel = getCurrentDatabaseModelCopy("Cloze")
+        val tempModelPath = CardTemplateNotetype.saveTempModel(targetContext, clozeModel)
+
+        // Test ordinal 0 (c1) - should be index 0
+        val intent1 = Intent(Intent.ACTION_VIEW).apply {
+            putExtra(CardTemplateNotetype.INTENT_MODEL_FILENAME, tempModelPath)
+            putExtra(
+                "noteEditorBundle",
+                bundleOf(
+                    "editFields" to getFieldsAsBundleForPreview(fields),
+                    "did" to 1L
+                )
+            )
+            putExtra("ordinal", 0)
+        }
+
+        val previewer1 = super.startActivityNormallyOpenCollectionWithIntent(TestCardTemplatePreviewer::class.java, intent1)
+        assertThat("Card index should be 0 for ordinal 0", previewer1.cardIndex, equalTo(0))
+
+        // Test ordinal 4 (c5) - should be index 2 
+        val intent2 = Intent(Intent.ACTION_VIEW).apply {
+            putExtra(CardTemplateNotetype.INTENT_MODEL_FILENAME, tempModelPath)
+            putExtra(
+                "noteEditorBundle",
+                bundleOf(
+                    "editFields" to getFieldsAsBundleForPreview(fields),
+                    "did" to 1L
+                )
+            )
+            putExtra("ordinal", 4)
+        }
+
+        val previewer2 = super.startActivityNormallyOpenCollectionWithIntent(TestCardTemplatePreviewer::class.java, intent2)
+        assertThat("Card index should be 2 for ordinal 4 (c5)", previewer2.cardIndex, equalTo(2))
+    }
 
