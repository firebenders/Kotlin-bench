+    private fun indexFromOrdinal(col: Collection, ordinal: Int, fieldValues: MutableList<String>): Int {
+        val notetype = mEditedNotetype ?: return 0
+        return if (notetype.isCloze) {
+            val note = col.newNote(notetype)
+            for (i in 0 until fieldValues.size.coerceAtMost(note.fields.size)) {
+                note.setField(i, fieldValues[i])
+            }
+            val clozeNumbers = col.clozeNumbersInNote(note)
+            val index = clozeNumbers.indexOf(ordinal + 1)
+            if (index != -1) index else 0
+        } else {
