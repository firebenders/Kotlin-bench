+    /**
+     * @return initial value for [cardIndex] when launched from the Note Editor.
+     *
+     * In this flow, the intent provides an "ordinal" which is [Card.ord] (not an index into the list of valid
+     * cards for a cloze note).
+     */
+    private fun getInitialCardIndexFromOrdinal(col: Collection): Int {
+        val notetype = mEditedNotetype ?: return 0
+        val ordinal = mOrdinal
+        if (ordinal < 0) {
+            return 0
+        }
+
+        // Build a note using the current editor fields, so cloze card indices match what will be rendered.
+        val fieldValues = getBundleEditFields(mNoteEditorBundle)
+        val n = col.newNote(notetype)
+        var i = 0
+        while (i < fieldValues.size && i < n.fields.size) {
+            n.setField(i, fieldValues[i])
+            i++
+        }
+
+        val count = n.numberOfCardsEphemeral()
+        cardCount = count
+        if (count <= 0) {
+            return 0
+        }
+
+        val requestedIndex = if (notetype.isCloze) {
+            // The backend may return either cloze numbers (1-based) or ordinals (0-based). Prefer an exact ordinal match,
+            // and fall back to treating the provided ordinal as 0-based.
+            val clozeOrdinalsOrNumbers = col.clozeNumbersInNote(n).sorted()
+            clozeOrdinalsOrNumbers.indexOf(ordinal).takeIf { it >= 0 }
+                ?: clozeOrdinalsOrNumbers.indexOf(ordinal + 1).takeIf { it >= 0 }
+                ?: 0
+        } else {
+            ordinal
+        }
+
+        return requestedIndex.coerceIn(0, count - 1)
+    }
+
     private fun setCurrentCardFromNoteEditorBundle(col: Collection): Card? {
