+    /**
+     * Converts an ordinal (ord) to a card index for the previewer.
+     * For standard note types, ordinal == index.
+     * For cloze note types, we need to find the index of the cloze number in the list.
+     * For example: {{c1::A}} {{c3::B}} has clozeNumbers [1, 3], so ord 2 (c3) is at index 1.
+     */
+    private fun indexFromOrdinal(col: Collection, ordinal: Int): Int {
+        return when (mEditedNotetype?.isCloze) {
+            true -> col.clozeNumbersInNote(col.newNote(mEditedNotetype!!)).indexOf(ordinal + 1)
+            else -> ordinal
+        }
+    }
+
