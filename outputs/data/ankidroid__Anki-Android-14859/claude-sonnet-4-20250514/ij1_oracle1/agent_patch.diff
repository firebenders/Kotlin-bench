@@ -755,6 +755,78 @@ class CardBrowserTest : RobolectricTest() {
         }
     }
 
+    @Test
+    fun sortOrderIsPreservedWhenSwitchingBetweenCardsAndNotes() {
+        // This test verifies the fix for: [BUG]: display order bug for notes
+        // GitHub issue: Notes mode should preserve separate sort order from cards mode
+        
+        val browser = browserWithMultipleNotes
+        
+        // Set initial sort order for cards mode
+        browser.changeCardOrder(SortType.EASE)
+        val initialCardsSort = browser.mOrder
+        val initialCardsAsc = browser.mOrderAsc
+        
+        // Switch to notes mode
+        browser.switchCardOrNote(NOTES)
+        
+        // Change sort order for notes mode
+        browser.changeCardOrder(SortType.CREATED_TIME)
+        val notesSort = browser.mOrder
+        val notesAsc = browser.mOrderAsc
+        
+        // Switch back to cards mode
+        browser.switchCardOrNote(CARDS)
+        
+        // Verify that cards mode preserved its original sort order
+        assertThat("Cards mode should preserve EASE sort", browser.mOrder, equalTo(initialCardsSort))
+        assertThat("Cards mode should preserve sort direction", browser.mOrderAsc, equalTo(initialCardsAsc))
+        
+        // Switch back to notes mode
+        browser.switchCardOrNote(NOTES)
+        
+        // Verify that notes mode preserved its sort order  
+        assertThat("Notes mode should preserve CREATED_TIME sort", browser.mOrder, equalTo(notesSort))
+        assertThat("Notes mode should preserve sort direction", browser.mOrderAsc, equalTo(notesAsc))
+        
+        // Verify config keys are mode-specific
+        val config = col.config
+        assertThat("Cards sort type should be saved", config.get<String>("sortType"), equalTo("cardEase"))
+        assertThat("Notes sort type should be saved", config.get<String>("sortTypeNotes"), equalTo("noteCrt"))
+    }
+
+    @Test  
+    fun notesModeDoesNotAlwaysDefaultToCreatedTime() {
+        // This test addresses the specific bug: "When you select 'notes', it automatically 
+        // sets the display order to 'by created time' oldest to newest"
+        
+        val browser = browserWithMultipleNotes
+        
+        // Start in cards mode with a non-created-time sort
+        browser.changeCardOrder(SortType.SORT_FIELD)
+        assertThat("Cards should be sorted by field", browser.mOrder, equalTo(SortType.SORT_FIELD))
+        
+        // Switch to notes mode - it should use the default SORT_FIELD, not CREATED_TIME
+        browser.switchCardOrNote(NOTES)
+        assertThat("Notes mode should not automatically default to CREATED_TIME", 
+                   browser.mOrder, not(equalTo(SortType.CREATED_TIME)))
+        assertThat("Notes mode should use reasonable default", 
+                   browser.mOrder, equalTo(SortType.SORT_FIELD))
+        
+        // Change to a different sort order in notes mode
+        browser.changeCardOrder(SortType.DUE_TIME) 
+        assertThat("Notes mode sort should change", browser.mOrder, equalTo(SortType.DUE_TIME))
+        
+        // Switch back to cards mode and then to notes again
+        browser.switchCardOrNote(CARDS)
+        browser.switchCardOrNote(NOTES)
+        
+        // Notes mode should remember DUE_TIME, not reset to CREATED_TIME
+        assertThat("Notes mode should remember DUE_TIME sort", browser.mOrder, equalTo(SortType.DUE_TIME))
+        assertThat("Notes mode should not reset to CREATED_TIME", 
+                   browser.mOrder, not(equalTo(SortType.CREATED_TIME)))
+    }
+
