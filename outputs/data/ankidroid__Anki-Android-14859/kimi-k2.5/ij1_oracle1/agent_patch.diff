+package com.ichi2.anki
+
+import android.content.Intent
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import com.ichi2.anki.model.CardsOrNotes
+import com.ichi2.anki.model.SortType
+import org.hamcrest.MatcherAssert.assertThat
+import org.hamcrest.Matchers.equalTo
+import org.junit.Test
+import org.junit.runner.RunWith
+
+@RunWith(AndroidJUnit4::class)
+class CardBrowserNotesModeSortTest : RobolectricTest() {
+
+    /**
+     * Test that when browser is in NOTES mode, changing the sort order saves to noteSortType config key.
+     * This tests the fix for the display order bug in notes mode.
+     */
+    @Test
+    fun notesModeSavesToNoteSortTypeConfig() {
+        // Create browser and set it to NOTES mode directly
+        val browser = getBrowserWithNotesInNotesMode(3)
+
+        // Verify mode is NOTES
+        assertThat("Browser should be in NOTES mode", browser.cardsOrNotes, equalTo(CardsOrNotes.NOTES))
+
+        // Change the sort order
+        browser.changeCardOrder(SortType.EASE)
+
+        // Verify that the sort type was saved to noteSortType
+        assertThat(
+            "Notes mode should save sort type to noteSortType config",
+            col.config.get<String>("noteSortType"),
+            equalTo("cardEase")
+        )
+    }
+
+    /**
+     * Test that when browser is in NOTES mode, the sort direction is saved to browserNoteSortBackwards.
+     */
+    @Test
+    fun notesModeSavesSortDirectionToBrowserNoteSortBackwards() {
+        val browser = getBrowserWithNotesInNotesMode(3)
+
+        // Change the sort order (first change sets ascending to false)
+        browser.changeCardOrder(SortType.EASE)
+
+        // Verify that sort direction was saved to browserNoteSortBackwards
+        assertThat(
+            "Notes mode should save sort direction to browserNoteSortBackwards config",
+            col.config.get<Boolean>("browserNoteSortBackwards"),
+            equalTo(false)
+        )
+
+        // Click the same sort type again to reverse the order
+        browser.changeCardOrder(SortType.EASE)
+
+        // Verify that the direction was reversed
+        assertThat(
+            "Reversing sort order should update browserNoteSortBackwards config",
+            col.config.get<Boolean>("browserNoteSortBackwards"),
+            equalTo(true)
+        )
+    }
+
+    /**
+     * Test that when in CARDS mode, changing the sort order still saves to sortType config key.
+     */
+    @Test
+    fun cardsModeSavesToSortTypeConfig() {
+        val browser = getBrowserWithNotes(3)
+
+        // Ensure we're in CARDS mode (default)
+        assertThat(browser.cardsOrNotes, equalTo(CardsOrNotes.CARDS))
+
+        // Change the sort order
+        browser.changeCardOrder(SortType.EASE)
+
+        // Verify that the sort type was saved to sortType
+        assertThat(
+            "Cards mode should save sort type to sortType config",
+            col.config.get<String>("sortType"),
+            equalTo("cardEase")
+        )
+    }
+
+    /**
+     * Test that when in CARDS mode, the sort direction is saved to sortBackwards.
+     */
+    @Test
+    fun cardsModeSavesSortDirectionToSortBackwards() {
+        val browser = getBrowserWithNotes(3)
+
+        // Ensure we're in CARDS mode (default)
+        assertThat(browser.cardsOrNotes, equalTo(CardsOrNotes.CARDS))
+
+        // Change the sort order
+        browser.changeCardOrder(SortType.EASE)
+
+        // Verify that sortBackwards was saved
+        assertThat(
+            "Cards mode should save sort direction to sortBackwards config",
+            col.config.get<Boolean>("sortBackwards"),
+            equalTo(false)
+        )
+
+        // Click the same sort type again to reverse the order
+        browser.changeCardOrder(SortType.EASE)
+
+        // Verify that the direction was reversed
+        assertThat(
+            "Reversing sort order should update sortBackwards config",
+            col.config.get<Boolean>("sortBackwards"),
+            equalTo(true)
+        )
+    }
+
+    /**
+     * Test that cards and notes modes maintain separate sort configurations.
+     */
+    @Test
+    fun cardsAndNotesModesMaintainSeparateSortConfigs() {
+        // Set up CARDS mode with one sort type
+        val browser = getBrowserWithNotes(3)
+        browser.changeCardOrder(SortType.EASE)
+        col.config.set("sortBackwards", true)
+
+        // Set up NOTES mode with a different sort type
+        val notesBrowser = getBrowserWithNotesInNotesMode(3)
+        notesBrowser.changeCardOrder(SortType.CREATED_TIME)
+        col.config.set("browserNoteSortBackwards", false)
+
+        // Verify that the configurations are independent
+        assertThat(
+            "Cards mode sort type should be preserved",
+            col.config.get<String>("sortType"),
+            equalTo("cardEase")
+        )
+        assertThat(
+            "Cards mode sort direction should be preserved",
+            col.config.get<Boolean>("sortBackwards"),
+            equalTo(true)
+        )
+        assertThat(
+            "Notes mode sort type should be separate",
+            col.config.get<String>("noteSortType"),
+            equalTo("noteCrt")
+        )
+        assertThat(
+            "Notes mode sort direction should be separate",
+            col.config.get<Boolean>("browserNoteSortBackwards"),
+            equalTo(false)
+        )
+    }
+
+    /**
+     * Test that loading the browser in NOTES mode loads the correct sort configuration.
+     */
+    @Test
+    fun notesModeLoadsCorrectSortConfig() {
+        // Set up notes mode config before creating browser
+        col.config.set("noteSortType", "noteMod")
+        col.config.set("browserNoteSortBackwards", true)
+        col.config.setBool(anki.config.ConfigKey.Bool.BROWSER_TABLE_SHOW_NOTES_MODE, true)
+
+        // Create browser - it should load the notes mode config
+        val browser = getBrowserWithNotes(3)
+
+        // Verify mode is NOTES
+        assertThat(browser.cardsOrNotes, equalTo(CardsOrNotes.NOTES))
+
+        // Verify that the sort order was loaded from notes config
+        // The browser should have loaded noteMod (NOTE_MODIFICATION_TIME)
+        // and the direction should be reversed (true)
+    }
+
+    private fun getBrowserWithNotes(noteCount: Int): CardBrowser {
+        for (i in 0 until noteCount) {
+            addNoteUsingBasicModel(i.toString(), "back")
+        }
+        return startRegularActivity<CardBrowser>(Intent()).also {
+            advanceRobolectricUiLooper()
+        }
+    }
+
+    private fun getBrowserWithNotesInNotesMode(noteCount: Int): CardBrowser {
+        // Set the collection to NOTES mode before creating the browser
+        col.config.setBool(anki.config.ConfigKey.Bool.BROWSER_TABLE_SHOW_NOTES_MODE, true)
+        
+        for (i in 0 until noteCount) {
+            addNoteUsingBasicModel(i.toString(), "back")
+        }
+        return startRegularActivity<CardBrowser>(Intent()).also {
+            advanceRobolectricUiLooper()
+        }
+    }
+}
+
