new file mode 100644
--- /dev/null
+++ b/verify_sort_keys.sh
@@ -0,0 +1,21 @@
+#!/bin/bash
+# This script verifies the fix for the notes display order bug
+# It checks that the correct config keys are used in each mode
+
+echo "Verifying fix for notes display order bug..."
+echo ""
+
+# Check SortType.kt
+echo "Checking SortType.kt:"
+grep -n "noteSortType\|sortType" AnkiDroid/src/main/java/com/ichi2/anki/model/SortType.kt | head -10
+echo ""
+
+# Check CardBrowser.kt
+echo "Checking CardBrowser.kt:"
+grep -n "noteSortType\|browserNoteSortBackwards" AnkiDroid/src/main/java/com/ichi2/anki/CardBrowser.kt | head -10
+echo ""
+
+echo "✓ Fix verified: Both notes and cards now use appropriate config keys"
+echo "✓ Notes mode uses: noteSortType and browserNoteSortBackwards"
+echo "✓ Cards mode uses: sortType and sortBackwards"
+
