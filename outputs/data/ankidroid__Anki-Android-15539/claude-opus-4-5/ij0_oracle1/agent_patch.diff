+/*
+ * User Actions - Allow card templates to define custom JavaScript actions
+ * that can be triggered by gestures, keyboard shortcuts, or gamepad buttons.
+ *
+ * To use, define a variable in your card template like:
+ *   var userJs1 = function() { revealNextCloze(); };
+ * or
+ *   var userJs1 = revealNextCloze;
+ *
+ * Then configure User Action 1 in AnkiDroid settings to trigger it.
+ * Supports userJs1 through userJs9.
+ */
+function userAction(actionNumber) {
+    var userFunc = window["userJs" + actionNumber];
+    if (typeof userFunc === "function") {
+        userFunc();
+    }
+}
