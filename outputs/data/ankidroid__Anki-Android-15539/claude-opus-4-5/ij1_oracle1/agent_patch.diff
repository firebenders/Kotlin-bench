--- a/AnkiDroid/src/main/assets/scripts/card.js
+++ b/AnkiDroid/src/main/assets/scripts/card.js
@@ -239,3 +239,28 @@ function showAllHints() {
         el.click();
     });
 }
+
+/**
+ * User Actions - allow card templates to define JavaScript functions that
+ * can be triggered via gestures, keyboard shortcuts, or gamepad buttons.
+ *
+ * Card templates can define functions like:
+ *   var userJs1 = function() { revealNextCloze(); };
+ *   var userJs2 = revealAllClozes;
+ *
+ * These can then be triggered using AnkiDroid's customizable controls.
+ * @param {number} actionNumber - The user action number (1-9)
+ */
+function userAction(actionNumber) {
+    var userJsName = "userJs" + actionNumber;
+    if (typeof window[userJsName] === "function") {
+        window[userJsName]();
+    } else if (typeof window[userJsName] !== "undefined") {
+        // Support for assigning a function reference directly, e.g., var userJs1 = revealNext;
+        try {
+            window[userJsName]();
+        } catch (e) {
+            console.log("userAction " + actionNumber + " is defined but not callable: " + e);
+        }
+    }
+}
