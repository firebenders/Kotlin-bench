--- a/AnkiDroid/src/main/assets/scripts/card.js
+++ b/AnkiDroid/src/main/assets/scripts/card.js
@@ -239,3 +239,22 @@ function showAllHints() {
         el.click();
     });
 }
+
+/**
+ * Executes a user action by calling the corresponding userJsN variable/function
+ * defined in the card template. This is similar to AnkiMobile's "User Action" feature.
+ *
+ * In the card template, users can define:
+ *   var userJs1 = revealNext;
+ * Then AnkiDroid can call userJs1() to trigger the action.
+ *
+ * @param {number} number - The user action number (1-9)
+ */
+function userAction(number) {
+    var userJs = eval("typeof userJs" + number + " !== 'undefined' ? userJs" + number + " : undefined");
+    if (userJs !== undefined) {
+        if (typeof userJs === "function") {
+            userJs();
+        }
+    }
+}
