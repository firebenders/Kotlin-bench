         el.click();
     });
 }
+
+function runUserAction(index) {
+    var action = window["userJs" + index];
+    if (!action) {
+        return;
+    }
+    try {
+        if (typeof action === "function") {
+            action();
+        } else if (typeof action === "string") {
+            // Allow templates to store JavaScript snippets as strings.
+            eval(action);
+        }
+    } catch (e) {
+        console.log(e);
+    }
+}
