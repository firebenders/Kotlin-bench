diff --git a/AnkiDroid/src/main/assets/scripts/card.js b/AnkiDroid/src/main/assets/scripts/card.js
index 1ea2b9cbd5..ebc1d43121 100644
--- a/AnkiDroid/src/main/assets/scripts/card.js
+++ b/AnkiDroid/src/main/assets/scripts/card.js
@@ -239,3 +239,37 @@ function showAllHints() {
         el.click();
     });
 }
+
+// User Actions (compatible with AnkiMobile's userJs1-8 feature)
+function _ankiRunUserAction(action) {
+    if (action == null) {
+        return;
+    }
+
+    try {
+        if (typeof action === "function") {
+            action();
+            return;
+        }
+
+        // Support a string of JavaScript code.
+        if (typeof action === "string") {
+            if (action.trim().length === 0) {
+                return;
+            }
+            // Indirect eval runs in global scope.
+            (0, eval)(action);
+        }
+    } catch (e) {
+        console.log(e);
+    }
+}
+
+function ankiUserAction(n) {
+    try {
+        var key = "userJs" + n;
+        _ankiRunUserAction(window[key]);
+    } catch (e) {
+        console.log(e);
+    }
+}
