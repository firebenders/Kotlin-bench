+    /**
+     * Executes a user-defined JavaScript action from the review screen.
+     * @param actionNumber The user action number (1-9)
+     */
+    protected open fun executeUserAction(actionNumber: Int) {
+        // Read the user action JavaScript from preferences
+        val preferences = sharedPrefs()
+        val userJsKey = when (actionNumber) {
+            1 -> getString(R.string.user_js_1_string)
+            2 -> getString(R.string.user_js_2_string)
+            3 -> getString(R.string.user_js_3_string)
+            4 -> getString(R.string.user_js_4_string)
+            5 -> getString(R.string.user_js_5_string)
+            6 -> getString(R.string.user_js_6_string)
+            7 -> getString(R.string.user_js_7_string)
+            8 -> getString(R.string.user_js_8_string)
+            9 -> getString(R.string.user_js_9_string)
+            else -> return
+        }
+        val userJs = preferences.getString(userJsKey, "") ?: ""
+
+        if (userJs.isNotEmpty()) {
+            // Execute the JavaScript in the WebView
+            executeUserJavascript(userJs)
+        }
+    }
+
+    private fun executeUserJavascript(jsCode: String) {
+        processCardAction { webView: WebView? ->
+            webView?.evaluateJavascript("(function() { $jsCode })();", null)
+        }
+    }
+
