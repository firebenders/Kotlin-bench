+<script>
+function revealNext() {
+    // Find the next hidden cloze and make it visible
+    var clozes = document.querySelectorAll('.cloze-fallback, .cloze');
+    for (var i = 0; i < clozes.length; i++) {
+        var cloze = clozes[i];
+        if (cloze.style.visibility === 'hidden' ||
+            cloze.style.display === 'none' ||
+            getComputedStyle(cloze).visibility === 'hidden') {
+            cloze.style.visibility = 'visible';
+            cloze.style.display = 'inline';
+            break;
+        }
+    }
+}
+
+function revealAll() {
+    // Make all clozes visible
+    var clozes = document.querySelectorAll('.cloze-fallback, .cloze');
+    for (var i = 0; i < clozes.length; i++) {
+        clozes[i].style.visibility = 'visible';
+        clozes[i].style.display = 'inline';
+    }
+}
+
+function showToast(message) {
+    console.log('Toast: ' + message);
+    alert(message);
+}
+</script>
+```
+
