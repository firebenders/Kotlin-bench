+            // When using input tag, capture the typed input from the WebView
+            // before generating the answer HTML
+            webView?.evaluateJavascript("_getTypedText()") { result ->
+                // Result is JSON-encoded, e.g., "\"hello\"" for "hello", or "\"\"" for empty
+                typeAnswer!!.input = result?.let {
+                    if (it.length >= 2 && it.startsWith("\"") && it.endsWith("\"")) {
+                        // Remove surrounding quotes and unescape
+                        it.substring(1, it.length - 1)
+                            .replace("\\\"", "\"")
+                            .replace("\\\\", "\\")
+                            .replace("\\n", "\n")
+                            .replace("\\r", "\r")
+                            .replace("\\t", "\t")
+                    } else {
+                        ""
+                    }
+                } ?: ""
+                onTypedInputCaptured()
+            }
+        } else {
+            onTypedInputCaptured()
