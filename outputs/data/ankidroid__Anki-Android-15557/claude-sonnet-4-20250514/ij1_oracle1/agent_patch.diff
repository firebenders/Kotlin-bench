diff --git a/AnkiDroid/src/main/java/com/ichi2/anki/AbstractFlashcardViewer.kt b/AnkiDroid/src/main/java/com/ichi2/anki/AbstractFlashcardViewer.kt
index 9f1599a7eb..9fc8cab98a 100644
--- a/AnkiDroid/src/main/java/com/ichi2/anki/AbstractFlashcardViewer.kt
+++ b/AnkiDroid/src/main/java/com/ichi2/anki/AbstractFlashcardViewer.kt
@@ -2342,7 +2342,32 @@ abstract class AbstractFlashcardViewer :
                 WebViewSignalParserUtils.SHOW_ANSWER -> {
                     // display answer when showAnswer() called from card.js
                     if (!Companion.displayAnswer) {
-                        displayCardAnswer()
+                        // Fix for issue: Answer comparison not shown when "Type answer into the card" is enabled
+                        // When using input tag for type answer, we need to capture the current input value 
+                        // from the WebView before displaying the answer, otherwise the comparison won't show
+                        // the user's typed input.
+                        if (typeAnswer?.useInputTag == true && typeAnswer?.validForEditText() == true) {
+                            view.evaluateJavascript(
+                                "var input = document.getElementById('typeans'); input ? input.value : '';"
+                            ) { result ->
+                                if (result != null && result != "null") {
+                                    // Remove quotes from the JSON string result
+                                    val cleanResult = result.trim('"')
+                                    // Decode any URL encoding that might be present
+                                    try {
+                                        val decodedInput = java.net.URLDecoder.decode(cleanResult, "UTF-8")
+                                        typeAnswer?.input = decodedInput
+                                    } catch (e: Exception) {
+                                        // If decoding fails, use the raw result
+                                        typeAnswer?.input = cleanResult
+                                    }
+                                }
+                                // Now display the answer with the captured input
+                                displayCardAnswer()
+                            }
+                        } else {
+                            displayCardAnswer()
+                        }
                     }
                     return true
                 }
