+package com.ichi2.anki
+
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import com.ichi2.anki.cardviewer.TypeAnswer
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertTrue
+import org.junit.Test
+import org.junit.runner.RunWith
+
+@RunWith(AndroidJUnit4::class)
+class AbstractFlashcardViewerTypeAnswerIntegrationTest : RobolectricTest() {
+
+    @Test
+    fun testTypeAnswerInputCaptureWithInputTagEnabled() {
+        // Test that verifies the fix for the issue where answer comparison
+        // is not shown when "Type answer into the card" is enabled
+        
+        // Create TypeAnswer instance with useInputTag = true (Type answer into card enabled)
+        val typeAnswer = TypeAnswer(
+            useInputTag = true,
+            doNotUseCodeFormatting = false,
+            autoFocus = false
+        )
+        
+        // Simulate user typing "hello" as their answer
+        typeAnswer.input = "hello"
+        
+        // The card answer template that contains [[type:field]]
+        val answerTemplate = """
+            <div>
+                Question: What is the greeting?
+                [[type:Answer]]
+                <hr id="answer">
+                The correct answer is: hello
+            </div>
+        """.trimIndent()
+        
+        // Filter the answer with the user's input
+        val filteredAnswer = typeAnswer.filterAnswer(answerTemplate, "hello", "hello")
+        
+        // Verify that the answer comparison is shown (not just the correct answer)
+        assertTrue("Answer should contain comparison HTML", filteredAnswer.contains("<code id=typeans>"))
+        assertTrue("Answer should show user's input was correct", filteredAnswer.contains("typeGood"))
+    }
+    
+    @Test
+    fun testTypeAnswerInputCaptureWithIncorrectAnswer() {
+        // Test with an incorrect answer
+        val typeAnswer = TypeAnswer(
+            useInputTag = true,
+            doNotUseCodeFormatting = false,
+            autoFocus = false
+        )
+        
+        // Simulate user typing "hi" when the correct answer is "hello"
+        typeAnswer.input = "hi"
+        
+        val answerTemplate = """
+            <div>
+                Question: What is the greeting?
+                [[type:Answer]]
+                <hr id="answer">
+                The correct answer is: hello
+            </div>
+        """.trimIndent()
+        
+        val filteredAnswer = typeAnswer.filterAnswer(answerTemplate, "hi", "hello")
+        
+        // Verify that the answer comparison shows both user input and correct answer
+        assertTrue("Answer should contain comparison HTML", filteredAnswer.contains("<code id=typeans>"))
+        assertTrue("Answer should show user's input was incorrect", filteredAnswer.contains("typeBad"))
+        assertTrue("Answer should show the correct answer", filteredAnswer.contains("typeMissed"))
+    }
+    
+    @Test
+    fun testTypeAnswerInputCaptureWithEmptyInput() {
+        // Test when user didn't type anything
+        val typeAnswer = TypeAnswer(
+            useInputTag = true,
+            doNotUseCodeFormatting = false,
+            autoFocus = false
+        )
+        
+        // Simulate empty user input
+        typeAnswer.input = ""
+        
+        val answerTemplate = """
+            <div>
+                Question: What is the greeting?
+                [[type:Answer]]
+                <hr id="answer">
+                The correct answer is: hello
+            </div>
+        """.trimIndent()
+        
+        val filteredAnswer = typeAnswer.filterAnswer(answerTemplate, "", "hello")
+        
+        // Verify that only the correct answer is shown when no input was provided
+        assertTrue("Answer should contain the correct answer", filteredAnswer.contains("hello"))
+        assertTrue("Answer should contain type answer HTML", filteredAnswer.contains("<code id=typeans>"))
+    }
+}
