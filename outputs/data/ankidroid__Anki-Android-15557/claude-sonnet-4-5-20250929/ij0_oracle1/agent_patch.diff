--- a/AnkiDroid/src/main/java/com/ichi2/anki/AbstractFlashcardViewer.kt
+++ b/AnkiDroid/src/main/java/com/ichi2/anki/AbstractFlashcardViewer.kt
@@ -1332,7 +1332,40 @@ abstract class AbstractFlashcardViewer :
         // Clean up the user answer and the correct answer
         if (!typeAnswer!!.useInputTag) {
             typeAnswer!!.input = answerField!!.text.toString()
+            continueDisplayAnswer()
+        } else {
+            // When using input tag, manually capture the input value
+            // This ensures the typed answer is captured even if the input field hasn't lost focus
+            processCardAction { cardWebView ->
+                if (cardWebView != null) {
+                    cardWebView.evaluateJavascript(
+                        "(function(){var input=document.getElementById('typeans');return input?input.value:'';})()"
+                    ) { result ->
+                        // Result is a JSON-encoded string, so parse it to get the actual value
+                        val value = if (result.isNullOrEmpty() || result == "null") {
+                            ""
+                        } else {
+                            try {
+                                // Use JSONTokener to properly parse the JSON-encoded string
+                                org.json.JSONTokener(result).nextValue().toString()
+                            } catch (e: Exception) {
+                                Timber.w(e, "Failed to parse evaluateJavascript result")
+                                ""
+                            }
+                        }
+                        typeAnswer!!.input = value
+                        continueDisplayAnswer()
+                    }
+                } else {
+                    // WebView is null, continue without input
+                    typeAnswer!!.input = ""
+                    continueDisplayAnswer()
+                }
+            }
         }
+    }
+
+    private fun continueDisplayAnswer() {
         isSelecting = false
         val answerContent = htmlGenerator!!.generateHtml(getColUnsafe, currentCard!!, SingleCardSide.BACK)
         automaticAnswer.onDisplayAnswer()
