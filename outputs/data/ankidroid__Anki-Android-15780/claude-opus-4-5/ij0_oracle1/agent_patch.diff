+package com.ichi2.libanki
+
+import org.junit.jupiter.api.Test
+import kotlin.test.assertContains
+import kotlin.test.assertEquals
+
+/**
+ * Tests for verifying that script tags are preserved in [parseSourcesToFileScheme].
+ * Related to: https://github.com/ankidroid/Anki-Android/issues/15860
+ */
+class TemplateManagerScriptPreservationTest {
+
+    @Test
+    fun `parseSourcesToFileScheme - script tags are preserved when substitution occurs`() {
+        val content = """
+            <script>
+            var test = "hello";
+            </script>
+            <img src="test.png">
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(content, "/media")
+
+        // Verify script tag is present (whitespace may be normalized)
+        assertContains(result, "<script>")
+        assertContains(result, """var test = "hello";""")
+        assertContains(result, "</script>")
+        assertContains(result, """src="file:///media/test.png"""")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - multiple script tags are preserved`() {
+        val content = """
+            <script>var a = 1;</script>
+            <img src="img1.png">
+            <script>var b = 2;</script>
+            <img src="img2.png">
+            <script>var c = 3;</script>
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(content, "/media")
+
+        assertContains(result, "<script>var a = 1;</script>")
+        assertContains(result, "<script>var b = 2;</script>")
+        assertContains(result, "<script>var c = 3;</script>")
+        assertContains(result, """src="file:///media/img1.png"""")
+        assertContains(result, """src="file:///media/img2.png"""")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - script with complex content is preserved`() {
+        val content = """
+            <script>
+            async function enhancedClozesMain() {
+                const clozeRegex = /{(?:){c(\d+)::([\W\w]*?)(?:::([\W\w]*?))?}}/g
+                var showHintsForPseudoClozes = true
+            }
+            </script>
+            <img src="paste-123.jpg" width="203">
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(content, "/media")
+
+        // Verify script content is preserved
+        assertContains(result, "async function enhancedClozesMain()")
+        assertContains(result, "const clozeRegex")
+        assertContains(result, "showHintsForPseudoClozes")
+        // Verify image src is modified
+        assertContains(result, """src="file:///media/paste-123.jpg"""")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - no changes when no media to replace - script preserved`() {
+        val content = """
+            <script>var test = 1;</script>
+            <p>Hello world</p>
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(content, "/media")
+
+        assertContains(result, "<script>var test = 1;</script>")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - SCRIPT uppercase tag is preserved`() {
+        val content = """
+            <SCRIPT>var test = 1;</SCRIPT>
+            <img src="test.png">
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(content, "/media")
+
+        assertContains(result, "<SCRIPT>var test = 1;</SCRIPT>")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - script with img-like content inside is preserved`() {
+        // This tests that script tags containing HTML-like strings are handled correctly
+        val content = """
+            <script>
+            var htmlString = '<img src="example.png">';
+            </script>
+            <img src="real.png">
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(content, "/media")
+
+        // The img inside the script string should NOT be modified
+        assertContains(result, """var htmlString = '<img src="example.png">';""")
+        // But the real img tag should be modified
+        assertContains(result, """src="file:///media/real.png"""")
+    }
+}
