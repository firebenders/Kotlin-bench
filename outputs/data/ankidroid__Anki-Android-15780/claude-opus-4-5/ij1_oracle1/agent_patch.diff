+package com.ichi2.libanki
+
+import org.junit.jupiter.api.Test
+import kotlin.test.assertContains
+import kotlin.test.assertEquals
+
+/**
+ * Tests for script tag preservation in [parseSourcesToFileScheme].
+ * 
+ * This addresses the issue where complex card templates with `<script>` tags
+ * were broken when `parseSourcesToFileScheme` made substitutions.
+ * 
+ * See: https://github.com/ankidroid/Anki-Android/issues/15631
+ */
+class TemplateManagerScriptPreservationTest {
+
+    @Test
+    fun `parseSourcesToFileScheme - script tags are preserved when substitution occurs`() {
+        val input = """
+            <script>
+            var showHintsForPseudoClozes = true
+            </script>
+            <img src="test.png">
+        """.trimIndent()
+        
+        val result = parseSourcesToFileScheme(input, "/storage/media")
+        
+        // The script tag and its contents should be preserved
+        assertContains(result, "<script>")
+        assertContains(result, "var showHintsForPseudoClozes = true")
+        assertContains(result, "</script>")
+        // The image src should be converted to file scheme
+        assertContains(result, "file:///storage/media/test.png")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - script tags at beginning are preserved`() {
+        val input = """
+            <script>
+            var scrollToClozeOnToggle = false
+            var animateScroll = true
+            </script>
+            <div id="card-body">
+            <img src="image.jpg">
+            </div>
+        """.trimIndent()
+        
+        val result = parseSourcesToFileScheme(input, "/storage/media")
+        
+        assertContains(result, "<script>")
+        assertContains(result, "var scrollToClozeOnToggle = false")
+        assertContains(result, "var animateScroll = true")
+        assertContains(result, "</script>")
+        assertContains(result, "file:///storage/media/image.jpg")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - multiple script tags are preserved`() {
+        val input = """
+            <script>var first = 1;</script>
+            <img src="a.png">
+            <script>var second = 2;</script>
+        """.trimIndent()
+        
+        val result = parseSourcesToFileScheme(input, "/storage/media")
+        
+        assertContains(result, "var first = 1;")
+        assertContains(result, "var second = 2;")
+        assertContains(result, "file:///storage/media/a.png")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - script with special characters in code`() {
+        // Scripts may contain < and > characters which should not confuse the parser
+        val input = """
+            <script>
+            if (x < 10 && y > 5) { console.log("ok"); }
+            </script>
+            <img src="test.png">
+        """.trimIndent()
+        
+        val result = parseSourcesToFileScheme(input, "/storage/media")
+        
+        assertContains(result, "<script>")
+        assertContains(result, "</script>")
+        assertContains(result, "file:///storage/media/test.png")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - complex Enhanced Cloze template preserved`() {
+        // Simplified version of the Enhanced Cloze template from the bug report
+        val input = """
+            <!-- VERSION 1.14 -->
+            <script>
+            var scrollToClozeOnToggle = false
+            var showHintsForPseudoClozes = true
+
+            async function enhancedClozesMain() {
+                await maybeInjectJquery()
+            }
+            </script>
+
+            <div id="card-body">
+            <img src="paste-0f5d2bfd.jpg" width="203">
+            </div>
+            
+            <script>
+            function toggleCloze(elem, displayOption) {
+                if (elem == null) return
+            }
+            </script>
+        """.trimIndent()
+        
+        val result = parseSourcesToFileScheme(input, "/storage/media")
+        
+        // All script content should be preserved
+        assertContains(result, "var scrollToClozeOnToggle = false")
+        assertContains(result, "var showHintsForPseudoClozes = true")
+        assertContains(result, "async function enhancedClozesMain()")
+        assertContains(result, "function toggleCloze(elem, displayOption)")
+        
+        // Image should be converted
+        assertContains(result, "file:///storage/media/paste-0f5d2bfd.jpg")
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - no changes returns original content`() {
+        // When no substitution is made, original content is returned as-is
+        val input = """
+            <script>var x = 1;</script>
+            <p>No images here</p>
+        """.trimIndent()
+        
+        val result = parseSourcesToFileScheme(input, "/storage/media")
+        
+        assertEquals(input, result)
+    }
+}
+
