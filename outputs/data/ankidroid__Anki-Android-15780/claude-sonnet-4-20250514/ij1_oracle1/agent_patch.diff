+    
+    @Test
+    fun `parseSourcesToFileScheme - simple script with image`() {
+        val input = """
+            <script>var test = true;</script>
+            <img src="test.jpg">
+        """.trimIndent()
+        val result = parseSourcesToFileScheme(input, "/media")
+        
+        // The script tag should be preserved
+        assert(result.contains("<script>var test = true;</script>")) { "Script tag was stripped: $result" }
+        
+        // The image source should be updated
+        assert(result.contains("file:///media/test.jpg")) { "Image source was not updated: $result" }
+    }
+    
+    @Test
+    fun `parseSourcesToFileScheme - no script tags, changes made`() {
+        val input = """<img src="test.jpg"><p>content</p>"""
+        val result = parseSourcesToFileScheme(input, "/media")
+        
+        // Should only return body content when no head content exists
+        assertEquals("""<img src="file:///media/test.jpg"><p>content</p>""", result)
+    }
+    
+    @Test
+    fun `parseSourcesToFileScheme - script tags, no changes made`() {
+        val input = """<script>var test = true;</script><p>content</p>"""
+        val result = parseSourcesToFileScheme(input, "/media")
+        
+        // Should return original content when no changes are made
+        assertEquals(input, result)
+    }
