@@ -373,7 +373,21 @@ fun parseSourcesToFileScheme(content: String, mediaDir: String): String {
             replaceWithFileScheme("object", "data")
 
     return if (hasMadeChanges) {
-        doc.body().html()
+        // If the original content doesn't have <html> tag,
+        // we shouldn't add <html>, <head>, and <body> wrappers.
+        // Combine head and body content without wrappers to preserve
+        // script tags and other head content.
+        if (content.contains("<html", ignoreCase = true)) {
+            doc.html()
+        } else {
+            val headHtml = doc.head().html()
+            val bodyHtml = doc.body().html()
+            if (headHtml.isEmpty()) {
+                bodyHtml
+            } else {
+                headHtml + bodyHtml
+            }
+        }
     } else {
         content
     }
