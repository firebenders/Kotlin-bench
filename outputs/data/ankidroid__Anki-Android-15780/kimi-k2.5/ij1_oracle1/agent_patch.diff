+package com.ichi2.libanki
+
+import org.intellij.lang.annotations.Language
+import org.junit.jupiter.api.Test
+import kotlin.test.assertEquals
+
+/**
+ * Test for issue: parseSourcesToFileScheme strips <script> tags if a substitution takes place
+ * https://github.com/ankidroid/Anki-Android/issues/15644
+ */
+class TemplateManagerScriptTest {
+
+    @Test
+    fun `parseSourcesToFileScheme - preserves script tags when making changes`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+
+        @Language("HTML")
+        val input = """
+            <script>
+            var showHintsForPseudoClozes = true
+            </script>
+            <div id="extra-section">
+            <div id="extra" class="content">
+            <img src="paste-0f5d2bfd133325a24eb52012f66c8887ef5d79b7.jpg" width="203">
+            </div>
+            </div>
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(input, mediaDir)
+
+        // The script tag should be preserved in the output
+        // and the img src should be converted to file scheme
+        assert(result.contains("var showHintsForPseudoClozes = true")) {
+            "Script content should be preserved. Result was:\n$result"
+        }
+        assert(result.contains("file:///$mediaDir/paste-0f5d2bfd133325a24eb52012f66c8887ef5d79b7.jpg")) {
+            "Image src should be converted to file scheme. Result was:\n$result"
+        }
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - preserves complex script tags`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+
+        @Language("HTML")
+        val input = """
+            <!-- VERSION 1.14 -->
+            <script>
+            var scrollToClozeOnToggle = false
+            var animateScroll = true
+            var showHintsForPseudoClozes = true
+            var underlineRevealedPseudoClozes = false
+            var underlineRevealedGenuineClozes = true
+            var revealPseudoClozesByDefault = false
+            var swapLeftAndRightBorderActions = false
+
+            // Shortcut options
+            var revealNextGenuineClozeShortcut = "W"
+            var revealAllGenuineClozesShortcut = "Shift+W"
+
+            var revealNextPseudoClozeShortcut = "Q"
+            var revealAllPseudoClozesShortcut = "Shift+Q"
+
+            // Touch open ("genuine" or "pseudo")
+            var leftTouchOpen = "genuine"
+            var rightTouchOpen = "genuine"
+            </script>
+
+            <div id="extra-section">
+            <div id="extra" class="content" style="display:none">
+            <img src="test.jpg" width="203">
+            </div>
+            </div>
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(input, mediaDir)
+
+        // The script tag content should be preserved
+        assert(result.contains("var showHintsForPseudoClozes = true")) {
+            "Script content should be preserved. Result was:\n$result"
+        }
+        assert(result.contains("var revealNextGenuineClozeShortcut = \"W\"")) {
+            "Script content should be preserved. Result was:\n$result"
+        }
+        assert(result.contains("file:///$mediaDir/test.jpg")) {
+            "Image src should be converted to file scheme. Result was:\n$result"
+        }
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - no changes returns original content`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+
+        @Language("HTML")
+        val input = """
+            <script>
+            var showHintsForPseudoClozes = true
+            </script>
+            <div>no images here</div>
+        """.trimIndent()
+
+        val result = parseSourcesToFileScheme(input, mediaDir)
+
+        // When no changes are made, the original content should be returned exactly
+        assertEquals(input, result)
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - preserves script tags with mixed content`() {
+        val mediaDir = "storage/emulated/0/15773/collection.media"
+
+        // This is based on the actual issue report from Enhanced Cloze 2.1
+        @Language("HTML")
+        val input = """
+            <!-- VERSION 1.14 -->
+            <script>
+            var scrollToClozeOnToggle = false
