+package com.ichi2.anki
+
+import com.ichi2.libanki.parseSourcesToFileScheme
+import org.junit.Assert.assertEquals
+import org.junit.Assert.assertTrue
+import org.junit.Test
+
+/**
+ * Test to verify that SVG files loaded via object tag can be accessed via JavaScript
+ * when using file:// protocol as the base URL.
+ * 
+ * This test verifies the fix for: [BUG]: SVG CSS update via JS incorrect rendering
+ * Issue: JavaScript cannot access contentDocument of SVG files loaded via <object> tag
+ * when the WebView uses http://127.0.0.1 as base URL due to CORS restrictions.
+ * 
+ * Solution: Use file:// protocol as base URL to avoid CORS issues.
+ */
+class SVGContentDocumentAccessTest {
+
+    /**
+     * Test that parseSourcesToFileScheme converts SVG object data attribute to file:// URL
+     */
+    @Test
+    fun `parseSourcesToFileScheme converts object data attribute to file URL`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        val html = """<object id="keyboard_obj" type="image/svg+xml" data="_keyboard.svg" onload="changeRectColor()"></object>"""
+        
+        val result = parseSourcesToFileScheme(html, mediaDir)
+        
+        assertTrue("Object data should be converted to file:// URL", 
+            result.contains("file:///$mediaDir/_keyboard.svg"))
+    }
+
+    /**
+     * Test that parseSourcesToFileScheme preserves URLs that already have a scheme
+     */
+    @Test
+    fun `parseSourcesToFileScheme preserves URLs with scheme`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        val html = """<object data="file:///path/to/file.svg"></object><object data="http://example.com/file.svg"></object>"""
+        
+        val result = parseSourcesToFileScheme(html, mediaDir)
+        
+        assertTrue("file:// URL should be preserved", 
+            result.contains("file:///path/to/file.svg"))
+        assertTrue("http:// URL should be preserved", 
+            result.contains("http://example.com/file.svg"))
+    }
+
+    /**
+     * Test the complete scenario from the bug report:
+     * - Card HTML with SVG object tag with relative path
+     * - parseSourcesToFileScheme converts relative path to file:// URL
+     * - JavaScript is preserved in the output
+     * 
+     * With file:// base URL, the page and SVG are on the same origin,
+     * so JavaScript can access contentDocument without CORS errors
+     */
+    @Test
+    fun `full scenario - card with SVG and JavaScript`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        // Simplified card HTML similar to the issue report
+        val cardHtml = """<div><object id="keyboard_obj" type="image/svg+xml" data="_keyboard.svg"></object></div><script>var img = document.getElementById("keyboard_obj"); var notes = img.contentDocument.querySelectorAll(".note_C");</script>"""
+        
+        val result = parseSourcesToFileScheme(cardHtml, mediaDir)
+        
+        // Verify that the SVG path is converted to file:// URL
+        assertTrue("SVG path should be converted to file:// URL", 
+            result.contains("file:///$mediaDir/_keyboard.svg"))
+        
+        // Verify that the JavaScript code is preserved
+        assertTrue("JavaScript should be preserved", 
+            result.contains("contentDocument.querySelectorAll"))
+    }
+}
+

