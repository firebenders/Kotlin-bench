+ * This program is free software; you can redistribute it and/or modify it under
+ * the terms of the GNU General Public License as published by the Free Software
+ * Foundation; either version 3 of the License, or (at your option) any later
+ * version.
+ */
+package com.ichi2.libanki
+
+import org.junit.jupiter.api.Test
+import kotlin.test.assertFalse
+import kotlin.test.assertTrue
+
+class TemplateManagerSvgObjectTest {
+
+    @Test
+    fun `parseSourcesToFileScheme - object svg is not rewritten to file scheme`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        val result = parseSourcesToFileScheme(
+            """<img src=magenta.png><object type="image/svg+xml" data="_keyboard.svg"></object>""",
+            mediaDir
+        )
+
+        assertTrue(result.contains("data=\"_keyboard.svg\""), result)
+        assertFalse(result.contains("file:///$mediaDir/_keyboard.svg"), result)
+}
+}
