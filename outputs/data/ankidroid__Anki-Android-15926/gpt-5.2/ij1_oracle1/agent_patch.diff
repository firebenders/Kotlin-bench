+    "cardLeft",
+    "cardODid",
+    "cardODue",
+    "cardQueue",
+    "cardLapses",
+    "cardDue",
+]);
+
+function coerceApiValue(endpoint, value) {
+    if (value === null || value === undefined) {
+        return value;
+    }
+
+    if (BOOLEAN_ENDPOINTS.has(endpoint)) {
+        if (typeof value === "boolean") {
+            return value;
+        }
+        if (typeof value === "string") {
+            return value.toLowerCase() === "true";
+        }
+        if (typeof value === "number") {
+            return value !== 0;
+        }
+        return Boolean(value);
+    }
+
+    if (NUMBER_ENDPOINTS.has(endpoint)) {
+        if (typeof value === "number") {
+            return value;
+        }
+        if (typeof value === "string") {
+            const n = Number(value);
+            return Number.isNaN(n) ? value : n;
+        }
+        return value;
+    }
+
+    return value;
+}
