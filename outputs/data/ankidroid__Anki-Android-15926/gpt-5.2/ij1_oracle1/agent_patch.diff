+const NUMBER_ENDPOINTS = new Set([
+    "newCardCount",
+    "lrnCardCount",
+    "revCardCount",
+    "eta",
+    "cardFlag",
+    "cardReps",
+    "cardInterval",
+    "cardFactor",
