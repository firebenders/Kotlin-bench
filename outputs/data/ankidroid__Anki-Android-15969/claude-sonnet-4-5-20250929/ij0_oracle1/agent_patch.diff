@@ -38,11 +38,21 @@ class ViewerResourceHandler(context: Context, private val authority: String) {
 
     fun shouldInterceptRequest(request: WebResourceRequest): WebResourceResponse? {
         val url = request.url
-        val path = url.path
+        val urlPath = url.path
 
-        if (request.method != "GET" || path == null || url.authority != authority) {
+        if (request.method != "GET" || urlPath == null || url.authority != authority) {
             return null
         }
+
+        // Handle legacy filenames with unencoded # characters
+        // When # is not encoded in HTML (e.g., <img src="file#name.jpg">),
+        // the URL parser treats everything after # as a fragment, not part of the path
+        val path = if (url.fragment != null) {
+            "$urlPath#${url.fragment}"
+        } else {
+            urlPath
+        }
+
         if (path == "/favicon.ico") {
             return WebResourceResponse(null, null, ByteArrayInputStream(ByteArray(0)))
         }
