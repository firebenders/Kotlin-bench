+package com.ichi2.libanki
+
+import org.intellij.lang.annotations.Language
+import org.junit.jupiter.api.Test
+import kotlin.test.assertEquals
+
+/**
+ * Test for handling images with '#' in filenames
+ * Regression test for: https://github.com/ankidroid/Anki-Android/issues/XXXXX
+ */
+@Suppress("HtmlUnknownTarget", "HtmlRequiredAltAttribute")
+class TemplateManagerHashtagTest {
+
+    @Test
+    fun `parseSourcesToFileScheme - img with hashtag in filename`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        // Test unencoded # (legacy format from Anki Desktop)
+        val result = parseSourcesToFileScheme("<img src=\"test#image.jpg\">", mediaDir)
+        assertEquals("""<img src="file:///$mediaDir/test%23image.jpg">""", result)
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - img with encoded hashtag in filename`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        // Test encoded %23 (proper encoding)
+        val result = parseSourcesToFileScheme("<img src=\"test%23image.jpg\">", mediaDir)
+        assertEquals("""<img src="file:///$mediaDir/test%23image.jpg">""", result)
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - audio with hashtag in filename`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        val result = parseSourcesToFileScheme("<audio src=\"sound#file.mp3\"></audio>", mediaDir)
+        assertEquals("""<audio src="file:///$mediaDir/sound%23file.mp3"></audio>""", result)
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - video with hashtag in filename`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        val result = parseSourcesToFileScheme("<video src=\"video#file.mp4\"></video>", mediaDir)
+        assertEquals("""<video src="file:///$mediaDir/video%23file.mp4"></video>""", result)
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - multiple hashtags in filename remain unchanged`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        // Multiple # characters create an invalid URI, so the source should remain unchanged
+        val content = "<img src=\"test#image#2.jpg\">"
+        val result = parseSourcesToFileScheme(content, mediaDir)
+        assertEquals(content, result)
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - hashtag with other special characters`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        @Language("HTML")
+        val content = "<img src=\"test#image@file.jpg\">"
+        val result = parseSourcesToFileScheme(content, mediaDir)
+        assertEquals("""<img src="file:///$mediaDir/test%23image@file.jpg">""", result)
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - source tag with hashtag`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        @Language("HTML")
+        val content = """<video controls><source src="video#file.mp4" type="video/mp4"></video>"""
+        @Language("HTML")
+        val expected = """<video controls><source src="file:///$mediaDir/video%23file.mp4" type="video/mp4"></video>"""
+        val result = parseSourcesToFileScheme(content, mediaDir)
+        assertEquals(expected, result)
+    }
+}
