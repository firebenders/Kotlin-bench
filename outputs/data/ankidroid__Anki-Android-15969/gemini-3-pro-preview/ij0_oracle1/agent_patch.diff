@@ -161,6 +161,17 @@ class TemplateManagerTest {
         assertEquals(expectedResult, result)
     }
 
+    @Test
+    fun `parseSourcesToFileScheme - source with hash should be parsed`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        val result = parseSourcesToFileScheme("<img src=\"foo#bar.png\">", mediaDir)
+
+        // 'foo#bar.png' -> 'foo%23bar.png'
+        val expected = """<img src="file:///$mediaDir/foo%23bar.png">"""
+
+        assertEquals(expected, result)
+    }
+
