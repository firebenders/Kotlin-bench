diff --git a/AnkiDroid/src/main/java/com/ichi2/libanki/TemplateManager.kt b/AnkiDroid/src/main/java/com/ichi2/libanki/TemplateManager.kt
index 01bb151f93..ed936950ed 100644
--- a/AnkiDroid/src/main/java/com/ichi2/libanki/TemplateManager.kt
+++ b/AnkiDroid/src/main/java/com/ichi2/libanki/TemplateManager.kt
@@ -357,13 +357,23 @@ fun parseSourcesToFileScheme(content: String, mediaDir: String): String {
             val attrValue = elem.attr(attr)
             if (attrValue.isEmpty()) continue
 
-            val attrUri = try {
+            var attrUri = try {
                 URI(attrValue)
             } catch (_: URISyntaxException) {
                 continue
             }
             if (attrUri.scheme != null) continue
 
+            if (attrValue.contains('#')) {
+                // # is a valid filename character in Anki, but URI treats it as a fragment
+                // We encode it so that it is treated as part of the path
+                try {
+                    attrUri = URI(attrValue.replace("#", "%23"))
+                } catch (_: URISyntaxException) {
+                    continue
+                }
+            }
+
             val path = Paths.get(mediaDir, attrUri.path).toString()
             val newUri = getFileUri(path)
 
