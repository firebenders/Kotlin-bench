+package com.ichi2.libanki
+
+import org.junit.jupiter.api.Test
+import kotlin.test.assertEquals
+
+@Suppress("HtmlUnknownTarget", "HtmlRequiredAltAttribute")
+class TemplateManagerHashFilenameTest {
+
+    @Test
+    fun `parseSourcesToFileScheme - unescaped hash in filename is treated as part of filename`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        val result = parseSourcesToFileScheme("""<img src="foo#bar.jpg">""", mediaDir)
+        assertEquals("""<img src="file:///$mediaDir/foo%23bar.jpg">""", result)
+    }
+
+    @Test
+    fun `parseSourcesToFileScheme - media fragment is not treated as part of filename`() {
+        val mediaDir = "storage/emulated/0/AnkiDroid/collection.media"
+        val result = parseSourcesToFileScheme("""<video src="clip.mp4#t=10"></video>""", mediaDir)
+        assertEquals("""<video src="file:///$mediaDir/clip.mp4"></video>""", result)
+    }
+}
