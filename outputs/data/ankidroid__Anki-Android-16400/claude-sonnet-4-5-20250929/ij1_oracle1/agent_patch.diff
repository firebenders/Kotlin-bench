+    protected open fun toggleAutoAdvance() {
+        // Check if auto advance is enabled in settings
+        if (!automaticAnswer.isEnabled()) {
+            // Auto advance is disabled in settings, so we can't toggle it
+            return
+        }
+        // Toggle the runtime state
+        val isCurrentlyDisabled = automaticAnswer.isDisabled
+        if (isCurrentlyDisabled) {
+            automaticAnswer.enable()
+            showSnackbar(getString(R.string.auto_advance_enabled_notification))
+        } else {
+            automaticAnswer.disable()
+            showSnackbar(getString(R.string.auto_advance_disabled_notification))
+        }
+        refreshActionBar()
+    }
+
     private fun abortAndSync() {
         closeReviewer(RESULT_ABORT_AND_SYNC)
     }
