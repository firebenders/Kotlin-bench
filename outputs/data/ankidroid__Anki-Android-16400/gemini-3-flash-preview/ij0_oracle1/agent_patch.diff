+    private fun toggleAutoAdvance() {
+        val preferences = sharedPrefs()
+        val isCurrentlyEnabled = automaticAnswer.isEnabled()
+        val newState = !isCurrentlyEnabled
+
+        // Disable the old instance to clear tasks
+        automaticAnswer.disable()
+
+        preferences.edit().putBoolean("timeoutAnswer", newState).apply()
+
+        // Update the automaticAnswer instance
+        automaticAnswer = AutomaticAnswer.createInstance(this, preferences, getColUnsafe)
+
+        if (newState) {
+            showSnackbar(getString(R.string.auto_advance_enabled), Snackbar.LENGTH_SHORT)
+            // If we just enabled it, we might want to start it for the current card
+            if (isDisplayingAnswer) {
+                automaticAnswer.scheduleAutomaticDisplayQuestion()
+            } else {
+                automaticAnswer.scheduleAutomaticDisplayAnswer()
+            }
+        } else {
+            showSnackbar(getString(R.string.auto_advance_disabled), Snackbar.LENGTH_SHORT)
+        }
+        refreshActionBar()
+    }
