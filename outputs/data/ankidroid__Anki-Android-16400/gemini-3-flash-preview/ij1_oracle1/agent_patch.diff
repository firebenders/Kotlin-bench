+    open fun toggleAutoAdvance() {
+        val prefs = AnkiDroidApp.getSharedPrefs(baseContext)
+        val newState = !automaticAnswer.isEnabled()
+        prefs.edit().putBoolean("timeoutAnswer", newState).apply()
+        automaticAnswer = AutomaticAnswer.createInstance(this, prefs, getColUnsafe)
+        if (newState) {
+            if (isDisplayingAnswer) {
+                automaticAnswer.scheduleAutomaticDisplayQuestion()
+            } else {
+                automaticAnswer.scheduleAutomaticDisplayAnswer()
+            }
+            showSnackbar(getString(R.string.enable_auto_advance), Snackbar.LENGTH_SHORT)
+        } else {
+            automaticAnswer.disable()
+            showSnackbar(getString(R.string.disable_auto_advance), Snackbar.LENGTH_SHORT)
+        }
+        invalidateOptionsMenu()
+    }
+
