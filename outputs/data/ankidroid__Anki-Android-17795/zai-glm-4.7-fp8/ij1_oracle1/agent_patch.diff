+            val basic = models.byName(BASIC_MODEL_NAME)
+            basic!!.put("did", didA)
+            val note = addBasicNote("foo", "bar")
+
+            val reviewer: Reviewer = startReviewer()
+            val jsapi = reviewer.jsApi
+
+            // Add some tags to the note
+            note.addTag("tag1")
+            note.addTag("tag2")
+            note.addTag("tag3")
+            col.updateNote(note)
+
+            waitForAsyncTasksToComplete()
+
+            // Get tags from the note
+            val tagsData = getDataFromRequest("getTagsFromNote", jsapi, """{"noteId":${note.id}}""")
+            val tagsResult = JSONObject(tagsData)
+            val tagsArray = tagsResult.getJSONArray(VALUE_KEY)
+
+            assertThat(tagsArray.length(), equalTo(3))
+            assertThat(tagsArray.getString(0), equalTo("tag1"))
+            assertThat(tagsArray.getString(1), equalTo("tag2"))
+            assertThat(tagsArray.getString(2), equalTo("tag3"))
+        }
+
+    @Test
+    fun ankiSetNoteTagsTest() =
+        runTest {
+            val models = col.notetypes
+            val didA = addDeck("Test", setAsSelected = true)
+            val basic = models.byName(BASIC_MODEL_NAME)
+            basic!!.put("did", didA)
+            val note = addBasicNote("foo", "bar")
+
+            val reviewer: Reviewer = startReviewer()
+            val jsapi = reviewer.jsApi
+
+            // Note initially has no tags
+            assertThat(note.tags.size, equalTo(0))
+
+            // Set tags to the note
+            val setTagsData = """{"noteId":${note.id},"tags":["newTag1","newTag2","newTag3"]}"""
+            assertThat(getDataFromRequest("setNoteTags", jsapi, setTagsData), equalTo(formatApiResult(true)))
+            waitForAsyncTasksToComplete()
+
+            // Refresh note from collection
+            val updatedNote = col.getNote(note.id)
+
+            // Verify tags were set
+            assertThat(updatedNote.tags.size, equalTo(3))
+            assertThat(updatedNote.tags.contains("newTag1"), equalTo(true))
+            assertThat(updatedNote.tags.contains("newTag2"), equalTo(true))
+            assertThat(updatedNote.tags.contains("newTag3"), equalTo(true))
+        }
+
+    @Test
+    fun ankiSetNoteTagsReplaceExistingTagsTest() =
+        runTest {
+            val models = col.notetypes
+            val didA = addDeck("Test", setAsSelected = true)
+            val basic = models.byName(BASIC_MODEL_NAME)
+            basic!!.put("did", didA)
+            val note = addBasicNote("foo", "bar")
+
+            val reviewer: Reviewer = startReviewer()
+            val jsapi = reviewer.jsApi
+
+            // Add initial tags
+            note.addTag("oldTag1")
+            note.addTag("oldTag2")
+            col.updateNote(note)
+
+            waitForAsyncTasksToComplete()
+
+            // Set new tags (should replace existing ones)
+            val setTagsData = """{"noteId":${note.id},"tags":["replacementTag1","replacementTag2"]}"""
+            assertThat(getDataFromRequest("setNoteTags", jsapi, setTagsData), equalTo(formatApiResult(true)))
+            waitForAsyncTasksToComplete()
+
+            // Refresh note from collection
+            val updatedNote = col.getNote(note.id)
+
+            // Verify old tags were replaced
+            assertThat(updatedNote.tags.size, equalTo(2))
+            assertThat(updatedNote.tags.contains("oldTag1"), equalTo(false))
+            assertThat(updatedNote.tags.contains("oldTag2"), equalTo(false))
+            assertThat(updatedNote.tags.contains("replacementTag1"), equalTo(true))
+            assertThat(updatedNote.tags.contains("replacementTag2"), equalTo(true))
+        }
+
+    @Test
+    fun ankiRemoveTagFromNoteTest() =
+        runTest {
+            val models = col.notetypes
+            val didA = addDeck("Test", setAsSelected = true)
+            val basic = models.byName(BASIC_MODEL_NAME)
+            basic!!.put("did", didA)
+            val note = addBasicNote("foo", "bar")
+
+            val reviewer: Reviewer = startReviewer()
+            val jsapi = reviewer.jsApi
+
+            // Add initial tags
+            note.addTag("tag1")
+            note.addTag("tag2")
+            note.addTag("tag3")
+            col.updateNote(note)
+
+            waitForAsyncTasksToComplete()
+
+            // Get current tags
+            val tagsData = getDataFromRequest("getTagsFromNote", jsapi, """{"noteId":${note.id}}""")
+            val tagsResult = JSONObject(tagsData)
+            val tagsArray = tagsResult.getJSONArray(VALUE_KEY)
+
+            // Build new tag list without "tag2" (simulating remove)
+            val updatedTags = mutableListOf<String>()
+            for (i in 0 until tagsArray.length()) {
+                val tag = tagsArray.getString(i)
+                if (tag != "tag2") {
+                    updatedTags.add(tag)
+                }
+            }
+
+            // Set updated tags (effectively removes "tag2")
+            val tagsJson =
+                updatedTags.joinToString(
+                    prefix = """{"noteId":${note.id},"tags":[""",
+                    separator = """",
+                    postfix = """]}""",
+                )
+            assertThat(getDataFromRequest("setNoteTags", jsapi, tagsJson), equalTo(formatApiResult(true)))
+            waitForAsyncTasksToComplete()
+
+            // Refresh note from collection
+            val updatedNote = col.getNote(note.id)
+
+            // Verify tag2 was removed while tag1 and tag3 remain
+            assertThat(updatedNote.tags.size, equalTo(2))
+            assertThat(updatedNote.tags.contains("tag1"), equalTo(true))
+            assertThat(updatedNote.tags.contains("tag2"), equalTo(false))
+            assertThat(updatedNote.tags.contains("tag3"), equalTo(true))
+        }
