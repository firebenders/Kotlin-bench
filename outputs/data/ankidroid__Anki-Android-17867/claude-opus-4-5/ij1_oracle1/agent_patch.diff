+package com.ichi2.anki
+
+import android.content.Intent
+import android.net.Uri
+import androidx.test.ext.junit.runners.AndroidJUnit4
+import com.ichi2.anki.IntentHandler.Companion.getLaunchType
+import com.ichi2.anki.IntentHandler.LaunchType
+import org.hamcrest.MatcherAssert.assertThat
+import org.hamcrest.Matchers.equalTo
+import org.junit.Test
+import org.junit.runner.RunWith
+
+/**
+ * Tests for the text/csv MIME type handling fix.
+ *
+ * This test verifies that CSV files with the standard "text/csv" MIME type
+ * are correctly recognized as TEXT_IMPORT, allowing users to import CSV files
+ * from external file managers.
+ *
+ * Related issue: Users couldn't see or open CSV files because "text/csv"
+ * MIME type was not being handled properly.
+ */
+@RunWith(AndroidJUnit4::class)
+class IntentHandlerCsvMimeTypeTest {
+    @Test
+    fun textCsvMimeTypeReturnsTextImport() {
+        // Test that text/csv MIME type is correctly handled as TEXT_IMPORT
+        val intent = Intent(Intent.ACTION_VIEW)
+        intent.setDataAndType(Uri.parse("content://valid"), "text/csv")
+        val actual = getLaunchType(intent)
+
+        assertThat(
+            "text/csv MIME type should be recognized as TEXT_IMPORT",
+            actual,
+            equalTo(LaunchType.TEXT_IMPORT),
+        )
+    }
+
+    @Test
+    fun textCsvMimeTypeWithActionSendReturnsTextImport() {
+        // Test that text/csv MIME type is correctly handled as TEXT_IMPORT for ACTION_SEND
+        val intent = Intent(Intent.ACTION_SEND)
+        intent.setDataAndType(Uri.parse("content://valid"), "text/csv")
+        val actual = getLaunchType(intent)
+
+        assertThat(
+            "text/csv MIME type with ACTION_SEND should be recognized as TEXT_IMPORT",
+            actual,
+            equalTo(LaunchType.TEXT_IMPORT),
+        )
+    }
+
+    @Test
+    fun allCsvMimeTypesAreHandled() {
+        // Comprehensive test for all CSV-related MIME types
+        val csvMimeTypes = listOf(
+            "text/csv",
+            "text/comma-separated-values",
+            "text/tab-separated-values",
+        )
+
+        for (mimeType in csvMimeTypes) {
+            val intent = Intent(Intent.ACTION_VIEW)
+            intent.setDataAndType(Uri.parse("content://valid"), mimeType)
+            val actual = getLaunchType(intent)
+
+            assertThat(
+                "MIME type '$mimeType' should be recognized as TEXT_IMPORT",
+                actual,
+                equalTo(LaunchType.TEXT_IMPORT),
+            )
+        }
+    }
+}
