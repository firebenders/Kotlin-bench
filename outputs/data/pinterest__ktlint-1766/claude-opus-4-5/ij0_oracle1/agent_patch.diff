--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRuleArraySyntaxTest.kt
@@ -0,0 +1,91 @@
+package com.pinterest.ktlint.ruleset.standard
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for array syntax annotations handling in [AnnotationRule].
+ * Issue #1765 - Array syntax annotations should be placed on separate lines.
+ */
+class AnnotationRuleArraySyntaxTest {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Given an array syntax annotation on same line as annotated construct then report violation`() {
+        val code =
+            """
+            @[JvmStatic Provides] fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an array syntax annotation on separate line from annotated construct then no violation`() {
+        val code =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an array syntax annotation without space before annotated construct then report violation`() {
+        val code =
+            """
+            @[JvmStatic Provides]fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an array syntax annotation on property on same line then report violation`() {
+        val code =
+            """
+            class Foo {
+                @[JvmField Volatile] var bar: String = ""
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Foo {
+                @[JvmField Volatile]
+                var bar: String = ""
+            }
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(2, 5, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an array syntax annotation on class on same line then report violation`() {
+        val code =
+            """
+            @[Deprecated("use Bar") Suppress("UNCHECKED_CAST")] class Foo
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[Deprecated("use Bar") Suppress("UNCHECKED_CAST")]
+            class Foo
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+}
+

