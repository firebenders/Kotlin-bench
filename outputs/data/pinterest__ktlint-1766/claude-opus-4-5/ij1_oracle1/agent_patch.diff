+package com.pinterest.ktlint.ruleset.standard
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for issue #1765 - array syntax annotations should be placed on separate lines.
+ */
+class AnnotationRuleArraySyntaxTest {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Given an annotation array on same line as annotated construct then report violation`() {
+        val code =
+            """
+            @[JvmStatic Provides] fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation array on separate line from annotated construct then no violation`() {
+        val code =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an annotation array on same line as class then report violation`() {
+        val code =
+            """
+            @[Foo Bar] class FooBar
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[Foo Bar]
+            class FooBar
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation array on same line as property then report violation`() {
+        val code =
+            """
+            class FooBar {
+                @[JvmField Volatile] var foo: String = ""
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class FooBar {
+                @[JvmField Volatile]
+                var foo: String = ""
+            }
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(2, 5, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation array without space before construct then report violation`() {
+        val code =
+            """
+            @[JvmStatic Provides]fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+}
+

