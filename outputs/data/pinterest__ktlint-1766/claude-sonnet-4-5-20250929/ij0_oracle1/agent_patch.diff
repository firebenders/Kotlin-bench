diff --git a/ktlint-ruleset-standard/src/main/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRule.kt b/ktlint-ruleset-standard/src/main/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRule.kt
index 7fdfdd88..21e01ca7 100644
--- a/ktlint-ruleset-standard/src/main/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRule.kt
+++ b/ktlint-ruleset-standard/src/main/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRule.kt
@@ -49,11 +49,45 @@ public class AnnotationRule : Rule("annotation") {
             FILE_ANNOTATION_LIST -> {
                 visitFileAnnotationList(node, emit, autoCorrect)
             }
+            ANNOTATION ->
+                visitAnnotation(node, emit, autoCorrect)
             ANNOTATION_ENTRY ->
                 visitAnnotationEntry(node, emit, autoCorrect)
         }
     }
 
+    private fun visitAnnotation(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+        autoCorrect: Boolean,
+    ) {
+        require(node.elementType == ANNOTATION)
+
+        // Array syntax annotations like @[...] should always be on a separate line
+        if (node.isOnSameLineAsAnnotatedConstruct()) {
+            emit(
+                node.startOffset,
+                "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .lastChildLeafOrSelf()
+                    .nextLeaf()
+                    .safeAs<LeafPsiElement>()
+                    ?.let {
+                        if (it.elementType == WHITE_SPACE) {
+                            it.replaceWithText(getNewlineWithIndent(node.treeParent))
+                        } else {
+                            it.rawInsertBeforeMe(
+                                PsiWhiteSpaceImpl(getNewlineWithIndent(node.treeParent)),
+                            )
+                        }
+                    }
+            }
+        }
+    }
+
     private fun visitAnnotationEntry(
         node: ASTNode,
         emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,

diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRuleArraySyntaxTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRuleArraySyntaxTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRuleArraySyntaxTest.kt
@@ -0,0 +1,104 @@
+package com.pinterest.ktlint.ruleset.standard
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class AnnotationRuleArraySyntaxTest {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Issue 1765 - Given an array syntax annotation on the same line as annotated construct then force onto separate line`() {
+        val code =
+            """
+            @[JvmStatic Provides] fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1765 - Given an array syntax annotation with single entry on the same line as annotated construct`() {
+        val code =
+            """
+            @[JvmStatic] fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1765 - Given an array syntax annotation on separate line from annotated construct then no violation`() {
+        val code =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1765 - Given an array syntax annotation on class on same line as annotated construct`() {
+        val code =
+            """
+            @[One Two Three] class FooBar
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[One Two Three]
+            class FooBar
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1765 - Given an array syntax annotation on property on same line as annotated construct`() {
+        val code =
+            """
+            @[One Two] val foo: String = "test"
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[One Two]
+            val foo: String = "test"
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1765 - Given an array syntax annotation followed by comment on separate line from annotated construct then no violation`() {
+        val code =
+            """
+            @[JvmStatic Provides] // comment
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1765 - Given an array syntax annotation with multiple entries on separate line`() {
+        val code =
+            """
+            @[Bar1 Bar2 Bar3 Bar4 Bar5]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
