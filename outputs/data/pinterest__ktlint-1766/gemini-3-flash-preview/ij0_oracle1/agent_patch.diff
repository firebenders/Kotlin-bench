diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRule1765Test.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRule1765Test.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRule1765Test.kt
@@ -0,0 +1,47 @@
+package com.pinterest.ktlint.ruleset.standard
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class AnnotationRule1765Test {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Issue 1765 - Given an annotation with multiple annotation entries then force it to be on a separate line`() {
+        val code =
+            """
+            @[JvmStatic Provides] fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation must be placed on separate line")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1765 - Given multiple array syntax annotations on same line`() {
+        val code =
+            """
+            @[Foo] @[Bar]
+            fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[Foo]
+            @[Bar]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 1, "Annotation must be placed on separate line"),
+                LintViolation(1, 8, "Annotation must be placed on separate line")
+            )
+            .isFormattedAs(formattedCode)
+    }
+}
+

