@@ -271,4 +273,30 @@ public class AnnotationRule : Rule("annotation") {
             newLineWithIndent
         }
     }
+
+    /**
+     * Forces array annotations (@[...]) onto separate lines before the annotated construct.
+     */
+    private fun checkArrayAnnotationOnSameLine(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+        autoCorrect: Boolean
+    ) {
+        if (node.elementType == ANNOTATION
+            && node.firstChildNode?.elementType?.toString() == "AT"
+            && node.lastChildNode?.elementType?.toString() == "RBRACKET"
+        ) {
+            val nextLeaf = node.lastChildLeafOrSelf().nextCodeLeaf()
+            if (nextLeaf != null && !node.lastChildLeafOrSelf().isWhiteSpaceWithNewline()) {
+                emit(
+                    node.startOffset,
+                    "Array annotation (@[…]) must be placed on a separate line prior to the annotated construct",
+                    true
+                )
+                if (autoCorrect) {
+                    node.lastChildLeafOrSelf().upsertWhitespaceBeforeMe(getNewlineWithIndent(node))
+                }
+            }
+        }
+    }
 }

diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/ArrayAnnotationRuleTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/ArrayAnnotationRuleTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/ArrayAnnotationRuleTest.kt
@@ -0,0 +1,34 @@
+package com.pinterest.ktlint.ruleset.standard
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class ArrayAnnotationRuleTest {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Given an array annotation and the annotated construct is on the same line, then violation is triggered`() {
+        val code = """
+            @[JvmStatic Provides] fun foo() = 42
+        """.trimIndent()
+        val formattedCode = """
+            @[JvmStatic Provides]
+            fun foo() = 42
+        """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Array annotation (@[…]) must be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an array annotation already on a separate line then no violation occurs`() {
+        val code = """
+            @[JvmStatic Provides]
+            fun foo() = 42
+        """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+}
+

