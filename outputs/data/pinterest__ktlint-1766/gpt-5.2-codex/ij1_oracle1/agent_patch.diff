diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRuleArrayAnnotationTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRuleArrayAnnotationTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRuleArrayAnnotationTest.kt
@@ -0,0 +1,35 @@
+package com.pinterest.ktlint.ruleset.standard
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class AnnotationRuleArrayAnnotationTest {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Given an annotation array on same line as annotated construct`() {
+        val code =
+            """
+            @[JvmStatic Provides] fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation must be placed on separate line")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation array on separate line before annotated construct`() {
+        val code =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

