diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/ArraySyntaxAnnotationRuleTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/ArraySyntaxAnnotationRuleTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/ArraySyntaxAnnotationRuleTest.kt
@@ -0,0 +1,54 @@
+package com.pinterest.ktlint.ruleset.standard
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class ArraySyntaxAnnotationRuleTest {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Given an array syntax annotation on the same line as the annotated construct then place it on a separate line`() {
+        val code =
+            """
+            @[JvmStatic Provides] fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Multiple annotations should not be placed on the same line as the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an array syntax annotation containing an annotation with parameter on the same line as the annotated construct then place it on a separate line without wrapping entries`() {
+        val code =
+            """
+            @[Foo("bar") Bar] fun foo() = 42
+            """.trimIndent()
+        val formattedCode =
+            """
+            @[Foo("bar") Bar]
+            fun foo() = 42
+            """.trimIndent()
+
+        annotationRuleAssertThat(code)
+            .hasLintViolation(1, 1, "Annotation with parameter(s) should be placed on a separate line prior to the annotated construct")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an array syntax annotation on its own line then do not report a violation`() {
+        val code =
+            """
+            @[JvmStatic Provides]
+            fun foo() = 42
+            """.trimIndent()
+
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

