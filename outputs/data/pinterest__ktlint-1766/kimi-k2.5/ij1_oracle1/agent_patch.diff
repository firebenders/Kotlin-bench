+++ b/ktlint-ruleset-standard/src/main/kotlin/com/pinterest/ktlint/ruleset/standard/AnnotationRule.kt
@@ -49,11 +49,36 @@ public class AnnotationRule : Rule("annotation") {
             FILE_ANNOTATION_LIST -> {
                 visitFileAnnotationList(node, emit, autoCorrect)
             }
+            ANNOTATION ->
+                visitAnnotation(node, emit, autoCorrect)
             ANNOTATION_ENTRY ->
                 visitAnnotationEntry(node, emit, autoCorrect)
         }
     }
 
+    private fun visitAnnotation(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+        autoCorrect: Boolean,
+    ) {
+        require(node.elementType == ANNOTATION)
+
+        // Array syntax annotations like @[JvmStatic Provides] should always be on separate lines
+        if (node.isOnSameLineAsAnnotatedConstruct()) {
+            emit(
+                node.startOffset,
+                "Annotation using array syntax (@[...]) should be placed on a separate line prior to the annotated construct",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .lastChildLeafOrSelf()
+                    .nextCodeLeaf()
+                    ?.upsertWhitespaceBeforeMe(getNewlineWithIndent(node))
+            }
+        }
+    }
+
