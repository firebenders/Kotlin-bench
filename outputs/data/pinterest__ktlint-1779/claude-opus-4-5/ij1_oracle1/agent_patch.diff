+
+    @Test
+    fun `Issue 1796 - Given a lambda in a raw string literal exceeding the max line length then do not wrap`() {
+        // Interpret "$." in code sample below as "$". It is used here as otherwise the indentation in the code sample
+        // is disapproved when running ktlint on the unit tests during the build process.
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER          $EOL_CHAR
+            val q = $MULTILINE_STRING_QUOTE
+                SELECT *
+                FROM table_name_that_is_long
+                $.{foo?.let { "bar" } ?: ""}
+            $MULTILINE_STRING_QUOTE
+            """.trimIndent()
+                .replacePlaceholderWithStringTemplate()
+        wrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasNoLintViolations()
+    }
 }
 
