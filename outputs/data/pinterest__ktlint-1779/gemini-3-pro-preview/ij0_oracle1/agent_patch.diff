diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/WrappingRuleRawStringTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/WrappingRuleRawStringTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/WrappingRuleRawStringTest.kt
@@ -0,0 +1,37 @@
+package com.pinterest.ktlint.ruleset.standard
+
+import com.pinterest.ktlint.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class WrappingRuleRawStringTest {
+    private val wrappingRuleAssertThat = assertThatRule { WrappingRule() }
+
+    @Test
+    fun `Given a raw string with a interpolated block that exceeds the max line length then do not wrap the block`() {
+        val code = """
+            package test
+
+            class QueryGenerator {
+                fun getQueryString(query: QueryRequest): String {
+                    val q = ""${'"'}
+                        SELECT *
+                        FROM table_name_long_enough_so_max_line_length_is_met_and_wrapping_rule_is_violated_and_generates_an_error
+                        WHERE 1 = 1
+                        ${'$'}{query.gameId?.let { "AND id = ?" } ?: ""}
+                    ""${'"'}
+                    return q
+                }
+            }
+
+            data class QueryRequest(
+                val gameId: String?,
+            )
+        """.trimIndent()
+        wrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 160)
+            .hasNoLintViolations()
+    }
+}
+

