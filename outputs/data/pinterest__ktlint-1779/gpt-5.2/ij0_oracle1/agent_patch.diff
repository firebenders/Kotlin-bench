+    private fun ASTNode.textOnSameLine(): String {
+        // Do not rely on whitespace tokens only, because e.g. in raw strings the newline is part of a string template
+        // entry instead of a whitespace token.
+        val root = rootNode()
+        val startLeaf = prevLeaf { it.textContains('\n') } ?: root.firstChildLeafOrSelf()
+        val endLeaf = nextLeaf { it.textContains('\n') }
+
+        val sb = StringBuilder()
+        sb.append(
+            if (startLeaf.textContains('\n')) {
+                startLeaf.text.substringAfterLast('\n')
+            } else {
+                startLeaf.text
+            },
+        )
+
+        var leaf = startLeaf.nextLeaf()
+        while (leaf != null && leaf != endLeaf) {
+            sb.append(leaf.text)
+            leaf = leaf.nextLeaf()
+        }
+        if (endLeaf != null) {
+            sb.append(endLeaf.text.substringBefore('\n'))
+        }
+        return sb.toString()
+    }
+
+    private fun ASTNode.rootNode(): ASTNode {
+        var node = this
+        while (node.treeParent != null) {
+            node = node.treeParent
+        }
+        return node
+    }
