+    /**
+     * Check if the node is part of a string template (e.g., blocks in ${let { ... }})
+     */
+    private fun ASTNode.isPartOfStringTemplate(): Boolean {
+        var currentNode: ASTNode? = this.treeParent
+        while (currentNode != null) {
+            if (currentNode.elementType == STRING_TEMPLATE) {
+                return true
+            }
+            currentNode = currentNode.treeParent
+        }
