@@ -0,0 +1,13 @@
+package com.pinterest.ktlint.ruleset.experimental.internal
+
+/**
+ * Transforms a string containing regular expression ranges like "A-Z", "a-z", and "\\d" to a RegEx which checks whether a
+ * unicode character has an uppercase versus a lowercase mapping to a letter, or is a decimal number. This function intents to keep the original
+ * expression more readable
+ */
+internal fun String.regExIgnoringDiacriticsAndStrokesOnLetters() =
+    replace("A-Z", "\\p{Lu}")
+        .replace("a-z", "\\p{Ll}")
+        .replace("\\\\d", "\\p{Nd}")
+        .toRegex()
+

diff --git a/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RegExIgnoringDiacriticsAndStrokesOnLettersTest.kt b/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RegExIgnoringDiacriticsAndStrokesOnLettersTest.kt
new file mode 100644
