@@ -0,0 +1,46 @@
+package com.pinterest.ktlint.ruleset.experimental.internal
+
+import org.assertj.core.api.Assertions.assertThat
+import org.junit.jupiter.api.Test
+import org.junit.jupiter.params.ParameterizedTest
+import org.junit.jupiter.params.provider.ValueSource
+
+class RegExIgnoringDiacriticsAndStrokesOnLettersTest {
+    @ParameterizedTest(name = "Original character: {0}")
+    @ValueSource(
+        strings = [
+            "脿谩芒盲忙茫氓膩",
+            "莽膰膷",
+            "猫茅锚毛膿臈臋",
+            "卯茂铆墨寞矛",
+            "艂",
+            "帽艅",
+            "么枚貌贸艙酶艒玫",
+            "脽艣拧",
+            "没眉霉煤奴",
+            "每",
+            "啪藕偶",
+            "脌脕脗脛脝脙脜膧",
+            "脟膯膶",
+            "脠脡脢脣膾臇臉",
+            "脦脧脥莫漠脤",
+            "艁",
+            "脩艃",
+            "脭脰脪脫艗脴艑脮",
+            "艢艩",
+            "脹脺脵脷弄",
+            "鸥",
+            "沤殴呕",
+        ],
+    )
+    fun `Given a letter with a diacritic then remove it`(original: String) {
+        assertThat(original.matches("[A-Za-z]*".regExIgnoringDiacriticsAndStrokesOnLetters())).isTrue
+    }
+
+    @Test
+    fun `Given digits and letters with diacritics then match pattern`() {
+        val testString = "脿谩芒盲123脝脙脜"
+        assertThat(testString.matches("[A-Za-z\\d]*".regExIgnoringDiacriticsAndStrokesOnLetters())).isTrue
+    }
+}
