+package com.pinterest.ktlint.ruleset.experimental
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class ClassNamingRuleNordicCharsTest {
+    private val classNamingRuleAssertThat = assertThatRule { ClassNamingRule() }
+
+    @Test
+    fun `Given a class name containing Nordic characters then do not return lint errors`() {
+        val code =
+            """
+            class Føø
+            """.trimIndent()
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a class name with various Nordic characters (Å, Ä, Ö, Æ, Ø) then do not return lint errors`() {
+        val code =
+            """
+            class TëstNørdiçChàrsÅÄÖÆØ
+            """.trimIndent()
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a class name starting with uppercase Nordic character then do not return lint errors`() {
+        val code =
+            """
+            class ØtestClass
+            """.trimIndent()
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an object name with Nordic characters then do not return lint errors`() {
+        val code =
+            """
+            object TëstØbjëct
+            """.trimIndent()
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a class name starting with lowercase then return lint error`() {
+        val code =
+            """
+            class føø
+            """.trimIndent()
+        classNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(1, 7, "Class or object name should start with an uppercase letter and use camel case")
+    }
+}
+

