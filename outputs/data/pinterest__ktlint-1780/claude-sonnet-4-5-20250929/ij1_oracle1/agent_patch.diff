+package com.pinterest.ktlint.ruleset.experimental
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+import org.junit.jupiter.params.ParameterizedTest
+import org.junit.jupiter.params.provider.ValueSource
+
+/**
+ * Tests for Nordic characters in class names
+ * Related to: https://github.com/pinterest/ktlint/issues/1761
+ */
+class ClassNamingRuleNordicCharsTest {
+    private val classNamingRuleAssertThat =
+        KtLintAssertThat.assertThatRule { ClassNamingRule() }
+
+    @ParameterizedTest(name = "Class with Nordic chars: {0}")
+    @ValueSource(
+        strings = [
+            "Føø",
+            "Bår",
+            "Tæst",
+            "Æøå",
+            "Höst",
+            "Grön",
+            "Blå",
+            "FøøBar",
+            "BårBaz",
+            "TæstClass",
+        ],
+    )
+    fun `Given a class name containing Nordic characters then do not emit`(className: String) {
+        val code =
+            """
+            class $className
+            """.trimIndent()
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @ParameterizedTest(name = "Object with Nordic chars: {0}")
+    @ValueSource(
+        strings = [
+            "Føø",
+            "Bår",
+            "Tæst",
+            "Æøå",
+            "Höst",
+            "Grön",
+            "Blå",
+        ],
+    )
+    fun `Given an object name containing Nordic characters then do not emit`(objectName: String) {
+        val code =
+            """
+            object $objectName
+            """.trimIndent()
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a class name with mixed ASCII and Nordic characters then do not emit`() {
+        val code =
+            """
+            class FøøBar123
+            """.trimIndent()
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a class name with numbers and Nordic characters then do not emit`() {
+        val code =
+            """
+            class Føø2Bar3
+            """.trimIndent()
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
