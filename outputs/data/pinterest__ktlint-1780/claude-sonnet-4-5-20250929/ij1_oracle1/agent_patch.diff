+
+/**
+ * Tests for Nordic characters in property names
+ * Related to: https://github.com/pinterest/ktlint/issues/1761
+ */
+class PropertyNamingRuleNordicCharsTest {
+    private val propertyNamingRuleAssertThat =
+        KtLintAssertThat.assertThatRule { PropertyNamingRule() }
+
+    @ParameterizedTest(name = "Property with Nordic chars: {0}")
+    @ValueSource(
+        strings = [
+            "føø",
+            "bår",
+            "tæst",
+            "æøå",
+            "höst",
+            "grön",
+            "blå",
+            "føøBar",
+            "bårBaz",
+            "tæstProperty",
+        ],
+    )
+    fun `Given a property name containing Nordic characters then do not emit`(propertyName: String) {
+        val code =
+            """
+            class Foo {
+                val $propertyName = 1
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a property name with mixed ASCII and Nordic characters then do not emit`() {
+        val code =
+            """
+            class Foo {
+                val føøBar123 = 1
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a property name with numbers and Nordic characters then do not emit`() {
+        val code =
+            """
+            class Foo {
+                val føø2Bar3 = 1
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a const property with Nordic characters in screaming snake case then do not emit`() {
+        val code =
+            """
+            const val FØØ_BÅR = 1
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a top level val with Nordic characters in screaming snake case then do not emit`() {
+        val code =
+            """
+            val FØØ_BÅR = 1
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an object val with Nordic characters in screaming snake case then do not emit`() {
+        val code =
+            """
+            object Foo {
+                val FØØ_BÅR = 1
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a backing property with Nordic characters then do not emit`() {
+        val code =
+            """
+            class Foo {
+                private val _føøBar = 1
+                val føøBar = _føøBar
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
