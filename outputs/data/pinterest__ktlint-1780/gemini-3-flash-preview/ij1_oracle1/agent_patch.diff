diff --git a/ktlint-ruleset-experimental/src/main/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RegExIgnoringDiacriticsAndStrokesOnLetters.kt b/ktlint-ruleset-experimental/src/main/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RegExIgnoringDiacriticsAndStrokesOnLetters.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-experimental/src/main/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RegExIgnoringDiacriticsAndStrokesOnLetters.kt
@@ -0,0 +1,12 @@
+package com.pinterest.ktlint.ruleset.experimental.internal
+
+/**
+ * Transforms a string containing regular expression ranges like "A-Z" and "a-z" to a RegEx which checks whether a
+ * unicode character has an uppercase versus a lowercase mapping to a letter. This function intents to keep the original
+ * expression more readable
+ */
+internal fun String.regExIgnoringDiacriticsAndStrokesOnLetters() =
+    replace("A-Z", "\\p{Lu}")
+        .replace("a-z", "\\p{Ll}")
+        .toRegex()
+

