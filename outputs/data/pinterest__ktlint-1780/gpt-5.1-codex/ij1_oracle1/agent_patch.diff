diff --git a/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/NordicNamingRulesTest.kt b/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/NordicNamingRulesTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/NordicNamingRulesTest.kt
@@ -0,0 +1,53 @@
+package com.pinterest.ktlint.ruleset.experimental
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class NordicNamingRulesTest {
+    private val classNamingRuleAssertThat = assertThatRule { ClassNamingRule() }
+    private val functionNamingRuleAssertThat = assertThatRule { FunctionNamingRule() }
+    private val propertyNamingRuleAssertThat = assertThatRule { PropertyNamingRule() }
+
+    @Test
+    fun `Given class and object names containing nordic characters then do not emit`() {
+        val code =
+            """
+            class Ångström
+
+            object Øresund
+            """.trimIndent()
+
+        classNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given function names containing nordic characters then do not emit`() {
+        val code =
+            """
+            fun grønn() = Unit
+
+            fun blåHimmel() {}
+            """.trimIndent()
+
+        functionNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given property names containing nordic characters then do not emit`() {
+        val code =
+            """
+            class Fôr {
+                val føø = 1
+                private val _bæver = 3
+                val bæver = _bæver
+
+                companion object {
+                    const val ØVRE_GRENSE = 2
+                }
+            }
+            """.trimIndent()
+
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

