--- /dev/null
+++ b/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/NamingRulesUnicodeCharactersTest.kt
@@ -0,0 +1,49 @@
+package com.pinterest.ktlint.ruleset.experimental
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+class NamingRulesUnicodeCharactersTest {
+    @Test
+    fun `Given a class name containing nordic characters then do not emit`() {
+        val code =
+            """
+            class Ångström
+            """.trimIndent()
+
+        KtLintAssertThat.assertThatRule { ClassNamingRule() }(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function name containing nordic characters then do not emit`() {
+        val code =
+            """
+            fun føø() = Unit
+            """.trimIndent()
+
+        KtLintAssertThat.assertThatRule { FunctionNamingRule() }(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a property name containing nordic characters then do not emit`() {
+        val code =
+            """
+            var føø = "foo"
+            """.trimIndent()
+
+        KtLintAssertThat.assertThatRule { PropertyNamingRule() }(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a top level val property in screaming snake case containing nordic characters then do not emit`() {
+        val code =
+            """
+            val FØØ_BAR = FooBar()
+
+            class FooBar
+            """.trimIndent()
+
+        KtLintAssertThat.assertThatRule { PropertyNamingRule() }(code).hasNoLintViolations()
+    }
+}
+

