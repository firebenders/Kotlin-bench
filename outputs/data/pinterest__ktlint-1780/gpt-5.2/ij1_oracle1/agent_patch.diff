+++ b/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/UnicodeNamingRulesTest.kt
@@ -0,0 +1,46 @@
+package com.pinterest.ktlint.ruleset.experimental
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+class UnicodeNamingRulesTest {
+    @Test
+    fun `Given a class name containing nordic characters then do not emit`() {
+        val code =
+            """
+            class ÆøÅ
+            """.trimIndent()
+
+        KtLintAssertThat
+            .assertThatRule { ClassNamingRule() }
+            .invoke(code)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function name containing nordic characters then do not emit`() {
+        val code =
+            """
+            fun føø() = Unit
+            """.trimIndent()
+
+        KtLintAssertThat
+            .assertThatRule { FunctionNamingRule() }
+            .invoke(code)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a property name containing nordic characters then do not emit`() {
+        val code =
+            """
+            var føø = "foo"
+            """.trimIndent()
+
+        KtLintAssertThat
+            .assertThatRule { PropertyNamingRule() }
+            .invoke(code)
+            .hasNoLintViolations()
+    }
+}
+

