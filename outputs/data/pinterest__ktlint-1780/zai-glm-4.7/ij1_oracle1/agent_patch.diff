diff --git a/ktlint-ruleset-experimental/src/main/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RegExIgnoringDiacriticsAndStrokesOnLetters.kt b/ktlint-ruleset-experimental/src/main/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RegExIgnoringDiacriticsAndStrokesOnLetters.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-experimental/src/main/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RegExIgnoringDiacriticsAndStrokesOnLetters.kt
@@ -0,0 +1,12 @@
+package com.pinterest.ktlint.ruleset.experimental.internal
+
+/**
+ * Transforms a string containing regular expression ranges like "A-Z" and "a-z" to a RegEx which checks whether a
+ * unicode character has an uppercase versus a lowercase mapping to a letter. This function intents to keep the original
+ * expression more readable
+ */
+internal fun String.regExIgnoringDiacriticsAndStrokesOnLetters() =
+    replace("A-Z", "\\p{Lu}")
+        .replace("a-z", "\\p{Ll}")
+        .toRegex()
+

diff --git a/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RemoveDiacriticsFromLettersTest.kt b/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RemoveDiacriticsFromLettersTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-experimental/src/test/kotlin/com/pinterest/ktlint/ruleset/experimental/internal/RemoveDiacriticsFromLettersTest.kt
@@ -0,0 +1,39 @@
+package com.pinterest.ktlint.ruleset.experimental.internal
+
+import org.assertj.core.api.Assertions.assertThat
+import org.junit.jupiter.params.ParameterizedTest
+import org.junit.jupiter.params.provider.ValueSource
+
+class RemoveDiacriticsFromLettersTest {
+    @ParameterizedTest(name = "Original character: {0}")
+    @ValueSource(
+        strings = [
+            "àáâäæãåā",
+            "çćč",
+            "èéêëēėę",
+            "îïíīįì",
+            "ł",
+            "ñń",
+            "ôöòóœøōõ",
+            "ßśš",
+            "ûüùúū",
+            "ÿ",
+            "žźż",
+            "ÀÁÂÄÆÃÅĀ",
+            "ÇĆČ",
+            "ÈÉÊËĒĖĘ",
+            "ÎÏÍĪĮÌ",
+            "Ł",
+            "ÑŃ",
+            "ÔÖÒÓŒØŌÕ",
+            "ŚŠ",
+            "ÛÜÙÚŪ",
+            "Ÿ",
+            "ŽŹŻ",
+        ],
+    )
+    fun `Given a letter with a diacritic then remove it`(original: String) {
+        assertThat(original.matches("[A-Za-z]*".regExIgnoringDiacriticsAndStrokesOnLetters())).isTrue
+    }
+}
+

