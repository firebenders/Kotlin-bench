+    @Test
+    fun `Issue 1786 - Given an enum class with member definition and missing trailing comma then it is added correctly`() {
+        // When the trailing comma is added, it should be inserted after the enum entry at the CLASS_BODY level,
+        // not inside the enum entry. If inserted incorrectly, the no-semi rule would incorrectly flag the semicolon.
+        val code =
+            """
+            enum class TestEnum() {
+                A,
+                B;
+
+                companion object {
+                    const val A_NUMBER = 1L
+                }
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            enum class TestEnum() {
+                A,
+                B,
+                ;
+
+                companion object {
+                    const val A_NUMBER = 1L
+                }
+            }
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasLintViolation(3, 6, "Missing trailing comma before \";\"")
+            .isFormattedAs(formattedCode)
+    }
