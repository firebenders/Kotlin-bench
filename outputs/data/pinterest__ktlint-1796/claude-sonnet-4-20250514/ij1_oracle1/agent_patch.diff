diff --git a/EnumTrailingCommaTest.kt b/EnumTrailingCommaTest.kt
new file mode 100644
--- /dev/null
+++ b/EnumTrailingCommaTest.kt
@@ -0,0 +1,50 @@
+import com.pinterest.ktlint.core.RuleProvider
+import com.pinterest.ktlint.ruleset.standard.TrailingCommaOnDeclarationSiteRule
+import com.pinterest.ktlint.ruleset.standard.WrappingRule
+import com.pinterest.ktlint.ruleset.standard.IndentationRule
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+class EnumTrailingCommaTest {
+
+    private val ruleAssertThat = KtLintAssertThat.assertThatRule(
+        provider = { TrailingCommaOnDeclarationSiteRule() },
+        additionalRuleProviders = setOf(
+            RuleProvider { WrappingRule() },
+            RuleProvider { IndentationRule() },
+        ),
+    )
+
+    @Test
+    fun testEnumWithSemicolonAndCompanionObject() {
+        val code = """
+            enum class TestEnum {
+                A,
+                B;
+
+                companion object {
+                    const val A_NUMBER = 1L
+                }
+            }
+        """.trimIndent()
+
+        val expected = """
+            enum class TestEnum {
+                A,
+                B,
+                ;
+
+                companion object {
+                    const val A_NUMBER = 1L
+                }
+            }
+        """.trimIndent()
+
+        ruleAssertThat(code)
+            .withEditorConfigOverride(
+                TrailingCommaOnDeclarationSiteRule.TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true
+            )
+            .isFormattedAs(expected)
+    }
+}
+

