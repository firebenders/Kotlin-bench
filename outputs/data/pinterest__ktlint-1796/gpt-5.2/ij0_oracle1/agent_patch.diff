diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/EnumTrailingCommaWithMemberDeclarationsFormattingTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/EnumTrailingCommaWithMemberDeclarationsFormattingTest.kt
new file mode 100644
