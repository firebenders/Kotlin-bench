+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/TrailingCommaOnDeclarationSiteRuleEmptyEnumTest.kt
@@ -0,0 +1,94 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.RuleProvider
+import com.pinterest.ktlint.ruleset.standard.rules.TrailingCommaOnDeclarationSiteRule.Companion.TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for empty enum class handling in TrailingCommaOnDeclarationSiteRule.
+ * Regression test for https://github.com/pinterest/ktlint/issues/1801
+ */
+class TrailingCommaOnDeclarationSiteRuleEmptyEnumTest {
+    private val trailingCommaOnDeclarationSiteRuleAssertThat =
+        KtLintAssertThat.assertThatRule(
+            provider = { TrailingCommaOnDeclarationSiteRule() },
+            additionalRuleProviders = setOf(
+                // WrappingRule must be loaded in order to run TrailingCommaOnDeclarationSiteRule
+                RuleProvider { WrappingRule() },
+            ),
+        )
+
+    @Test
+    fun `Issue 1801 - Given an empty enum class then no error should be raised`() {
+        val code =
+            """
+            enum class Empty
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1801 - Given an empty enum class with empty body then no error should be raised`() {
+        val code =
+            """
+            enum class Empty {}
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1801 - Given an empty enum class with empty body spanning multiple lines then no error should be raised`() {
+        val code =
+            """
+            enum class Empty {
+            }
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1801 - Given an empty enum class when trailing comma is not allowed then no error should be raised`() {
+        val code =
+            """
+            enum class Empty {}
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to false)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1801 - Given an empty enum class with only a semicolon then no error should be raised`() {
+        val code =
+            """
+            enum class Empty {
+                ;
+            }
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1801 - Given an empty enum class with only functions should not raise error`() {
+        val code =
+            """
+            enum class Empty {
+                ;
+                fun doSomething() = Unit
+            }
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+}
+

