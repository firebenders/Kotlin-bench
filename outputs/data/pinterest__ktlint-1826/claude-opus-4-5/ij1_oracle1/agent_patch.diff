+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.RuleProvider
+import com.pinterest.ktlint.ruleset.standard.rules.TrailingCommaOnDeclarationSiteRule.Companion.TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+/**
+ * Test for GitHub issue: ktlint raises error when there is an empty enum class.
+ * See: https://github.com/pinterest/ktlint/issues/1801
+ */
+class TrailingCommaOnDeclarationSiteRuleEmptyEnumTest {
+    private val trailingCommaOnDeclarationSiteRuleAssertThat =
+        KtLintAssertThat.assertThatRule(
+            provider = { TrailingCommaOnDeclarationSiteRule() },
+            additionalRuleProviders = setOf(
+                // WrappingRule must be loaded in order to run TrailingCommaOnDeclarationSiteRule
+                RuleProvider { WrappingRule() },
+                // Apply the IndentationRule always as additional rule, so that the formattedCode in the unit test looks
+                // correct.
+                RuleProvider { IndentationRule() },
+            ),
+        )
+
+    @Test
+    fun `Given an empty enum class with trailing comma allowed should not throw an exception`() {
+        val code =
+            """
+            enum class EmptyEnum {}
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an empty enum class with trailing comma not allowed should not throw an exception`() {
+        val code =
+            """
+            enum class EmptyEnum {}
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to false)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an empty enum class with body on multiple lines should not throw an exception`() {
+        val code =
+            """
+            enum class EmptyEnum {
+            }
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an empty enum class with a comment inside should not throw an exception`() {
+        val code =
+            """
+            enum class EmptyEnum {
+                // This enum is intentionally empty
+            }
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an empty enum class with a semicolon only should not throw an exception`() {
+        val code =
+            """
+            enum class EmptyEnum {
+                ;
+                fun doSomething() {}
+            }
+            """.trimIndent()
+        trailingCommaOnDeclarationSiteRuleAssertThat(code)
+            .withEditorConfigOverride(TRAILING_COMMA_ON_DECLARATION_SITE_PROPERTY to true)
+            .hasNoLintViolations()
+    }
+}
+

