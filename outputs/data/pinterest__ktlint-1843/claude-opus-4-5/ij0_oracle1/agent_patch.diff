+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class FunctionReturnTypeSpacingRuleMaxLineLengthTest {
+    private val functionReturnTypeSpacingRuleAssertThat = assertThatRule { FunctionReturnTypeSpacingRule() }
+
+    @Test
+    fun `Given a function signature with return type on a new line and merging would exceed max line length then do not report`() {
+        // Merged line would be:
+        // "fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction(): AndAlsoALongReturnType {"
+        // which is 126 characters > 120
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                AndAlsoALongReturnType {
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function signature with return type on a new line and merging would not exceed max line length then report`() {
+        val code =
+            """
+            fun foo():
+                String {
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(): String {
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasLintViolation(1, 10, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function signature with return type on a new line and max line length not set then report`() {
+        // "fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():" = 102 chars
+        // So colon is at column 102
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                AndAlsoALongReturnType {
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction(): AndAlsoALongReturnType {
+            }
+            """.trimIndent()
+        // When max line length is not set (off), the rule should still reformat
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .hasLintViolation(1, 102, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function signature with return type on a new line where merging would exactly hit max line length then report`() {
+        // When merged line length exactly equals max_line_length, it should still be allowed (not exceed)
+        // "fun someFunction(): Unit {" = 26 chars
+        val code =
+            """
+            fun someFunction():
+                Unit {
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun someFunction(): Unit {
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 26)
+            .hasLintViolation(1, 19, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function signature with return type on a new line where merging would exceed max line length by 1 then do not report`() {
+        // "fun someFunction(): Unit {" = 26 chars, with max_line_length = 25 it exceeds
+        val code =
+            """
+            fun someFunction():
+                Unit {
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 25)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function with expression body and return type on a new line and merging would exceed max line length then do not report`() {
+        // "fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction(): String = "result"" = 120 chars
+        // Using max_line_length of 119 to ensure it would exceed
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                String = "result"
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 119)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function with expression body and return type on a new line and merging would exactly match max line length then report`() {
+        // "fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction(): String = "result"" = 120 chars
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                String = "result"
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction(): String = "result"
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasLintViolation(1, 102, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+}
+

