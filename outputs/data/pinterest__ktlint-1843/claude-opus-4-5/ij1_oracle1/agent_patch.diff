+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class FunctionReturnTypeSpacingRuleMaxLineLengthTest {
+    private val functionReturnTypeSpacingRuleAssertThat = assertThatRule { FunctionReturnTypeSpacingRule() }
+
+    @Test
+    fun `Given a function signature with return type on separate line that would exceed max line length when merged, then do not reformat`() {
+        // Line would be 134 chars when merged which exceeds 120
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                AndAlsoALongReturnType = TODO()
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function signature with return type on separate line that would not exceed max line length when merged, then reformat`() {
+        val code =
+            """
+            fun foo():
+                String = "some-result"
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(): String = "some-result"
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasLintViolation(1, 10, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function signature with return type on separate line and max line length off, then reformat`() {
+        // The colon is at column 102 (line has 102 chars up to and including the colon)
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                AndAlsoALongReturnType = TODO()
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction(): AndAlsoALongReturnType = TODO()
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .hasLintViolation(1, 102, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function signature with return type on separate line that exactly exceeds max line length when merged, then do not reformat`() {
+        // veryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunctionName(): LongType = TODO()
+        // Line would be 121 chars when merged which exceeds 120
+        val code =
+            """
+            fun veryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunctionName():
+                LongType = TODO()
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function signature with return type on separate line that exactly fits max line length when merged, then reformat`() {
+        // veryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunctionNam(): LongType = TODO()
+        // Line would be exactly 120 chars when merged which equals max line length (allowed)
+        val code =
+            """
+            fun veryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunctionNam():
+                LongType = TODO()
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun veryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunctionNam(): LongType = TODO()
+            """.trimIndent()
+        // The colon is at column 102
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasLintViolation(1, 102, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an indented function signature with return type on separate line that would exceed max line length when merged, then do not reformat`() {
+        val code =
+            """
+            class SomeClass {
+                fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                    AndAlsoALongReturnType = TODO()
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function signature with block body and return type on separate line that would exceed max line length when merged, then do not reformat`() {
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                AndAlsoALongReturnType {
+                return TODO()
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasNoLintViolations()
+    }
+}
+

