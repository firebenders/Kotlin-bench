+    private fun wouldExceedMaxLineLength(colonNode: ASTNode): Boolean {
+        // Calculate the length of the line if the return type were moved to the same line as the colon.
+        // colonNode.column is the 1-based column of the colon character.
+        // After the colon, we'd have " " (single space), so the content starts at column + 1
+        val columnAfterColonAndSpace = colonNode.column + 1
+
+        // Find the text after the whitespace (i.e., the return type and everything following on that line)
+        val whiteSpaceAfterColon = colonNode.nextLeaf()?.takeIf { it.elementType == WHITE_SPACE }
+        val nextNonWhitespaceLeaf = whiteSpaceAfterColon?.nextLeaf() ?: return false
+
+        // Calculate the length of text from the return type to the next newline
+        var lengthOfRestOfLine = 0
+        var leaf: ASTNode? = nextNonWhitespaceLeaf
+        while (leaf != null) {
+            if (leaf.elementType == WHITE_SPACE && leaf.textContains('\n')) {
+                break
+            }
+            lengthOfRestOfLine += leaf.textLength
+            leaf = leaf.nextLeaf()
+        }
