@@ -56,14 +67,61 @@ public class FunctionReturnTypeSpacingRule :
             .nextLeaf()
             ?.takeIf { it.elementType == WHITE_SPACE }
             .let { whiteSpaceAfterColon ->
-                if (whiteSpaceAfterColon?.text != " ") {
-                    emit(node.startOffset, "Single space expected between colon and return type", true)
-                    if (autoCorrect) {
-                        node.upsertWhitespaceAfterMe(" ")
+                when {
+                    whiteSpaceAfterColon?.text == " " -> {
+                        // Already correctly formatted, nothing to do
+                    }
+                    whiteSpaceAfterColon?.text?.contains('\n') == true && wouldExceedMaxLineLength(node) -> {
+                        // There's a newline and putting it on the same line would exceed max line length,
+                        // so keep the newline but ensure it's properly formatted
+                        if (whiteSpaceAfterColon.text != "\n") {
+                            emit(node.startOffset, "Newline expected between colon and return type", true)
+                            if (autoCorrect) {
+                                node.upsertWhitespaceAfterMe("\n")
+                            }
+                        }
+                    }
+                    else -> {
+                        // For all other cases (no space, multiple spaces, newline but doesn't exceed max length),
+                        // use single space
+                        emit(node.startOffset, "Single space expected between colon and return type", true)
+                        if (autoCorrect) {
+                            node.upsertWhitespaceAfterMe(" ")
+                        }
                     }
                 }
             }
     }
+
+    private fun wouldExceedMaxLineLength(colonNode: ASTNode): Boolean {
+        require(colonNode.elementType == COLON)
+
+        // Find the function node (FUN) to calculate from its start
+        val functionNode = colonNode.treeParent
+        val returnTypeNode = colonNode.nextLeaf()?.nextLeaf() // Skip whitespace to get to return type
+
+        if (returnTypeNode == null) return false
+
+        // Calculate the hypothetical line length if we put everything on one line
+        // This is: function start column + entire function text length from start to end of return type
+        val functionStartColumn = functionNode.column - 1
+        val startOffset = functionNode.startOffset
+        val endOffset = returnTypeNode.startOffset + returnTypeNode.textLength
+        val totalTextLength = endOffset - startOffset
+
+        // We need to account for the ": " that would be inserted between colon and return type
+        // But we also need to subtract any existing whitespace that would be replaced
+        val existingWhitespaceAfterColon = colonNode.nextLeaf()
+        val whitespaceAdjustment = if (existingWhitespaceAfterColon?.elementType == WHITE_SPACE) {
+            2 - existingWhitespaceAfterColon.textLength // ": " (2 chars) minus existing whitespace
+        } else {
+            2 // Just add ": " (2 chars)
+        }
+
+        val totalLength = functionStartColumn + totalTextLength + whitespaceAdjustment
+
+        return totalLength > maxLineLength
+    }
 }
 
