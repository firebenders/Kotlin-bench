+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class FunctionReturnTypeSpacingRuleMaxLineLengthTest {
+    private val functionReturnTypeSpacingRuleAssertThat = assertThatRule { FunctionReturnTypeSpacingRule() }
+
+    @Test
+    fun `Given a function signature with a newline between colon and return type that would exceed max line length, keep the newline`() {
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                AndAlsoALongReturnType {
+
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function signature with a newline between colon and return type that would NOT exceed max line length, reformat to single line`() {
+        val code =
+            """
+            fun shortFunction():
+                String {
+
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun shortFunction(): String {
+
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasLintViolation(1, 20, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function signature with newline and max line length disabled, always reformat to single line`() {
+        val code =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction():
+                AndAlsoALongReturnType {
+
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun thisIsAVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryVeryLongFunction(): AndAlsoALongReturnType {
+
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to -1)
+            .hasLintViolation(1, 102, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function signature with a newline that is just under the max line length, reformat to single line`() {
+        val code =
+            """
+            fun thisIsAFunctionWithReasonableName():
+                ReasonableReturnType {
+
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun thisIsAFunctionWithReasonableName(): ReasonableReturnType {
+
+            }
+            """.trimIndent()
+        functionReturnTypeSpacingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 120)
+            .hasLintViolation(1, 40, "Single space expected between colon and return type")
+            .isFormattedAs(formattedCode)
+    }
+}
+

