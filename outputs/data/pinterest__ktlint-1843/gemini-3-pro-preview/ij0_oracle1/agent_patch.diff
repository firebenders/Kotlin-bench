+        val fileText = colonNode.psi.containingFile.text
+        val lastNewLineIndex = fileText.lastIndexOf('\n', colonNode.startOffset)
+        val lineStartOffset = if (lastNewLineIndex == -1) 0 else lastNewLineIndex + 1
