+    private fun wouldExceedMaxLineLength(
+        colonNode: ASTNode,
+        whiteSpaceAfterColon: ASTNode?,
+    ): Boolean {
+        if (maxLineLength == MAX_LINE_LENGTH_PROPERTY_OFF) {
+            return false
+        }
+
+        val isCurrentMultiline = (whiteSpaceAfterColon?.text ?: "").contains("\n")
+
+        return if (isCurrentMultiline) {
+            // Current format has newline after colon, converting to single line
+            // Calculate what the single line length would be
+            val singleLineLength = getFullFunctionSignatureLength(colonNode)
+
+            singleLineLength > maxLineLength
+        } else {
+            // Already on single line, no change
+            false
+        }
+    }
+
+    private fun getFullFunctionSignatureLength(colonNode: ASTNode): Int {
+        val rootNode = colonNode.treeParent?.treeParent ?: return 0
+        val nodeText = rootNode.text
+
+        val colonIndex = colonNode.startOffset - rootNode.startOffset
+        if (colonIndex < 0 || colonIndex >= nodeText.length) {
+            return 0
+        }
+
+        // Find the end of the return type
+        var returnTypeEndIndex = colonIndex
+        var currentIndex = colonIndex
+        while (currentIndex < nodeText.length) {
+            if (nodeText[currentIndex] == '\n') {
+                break
+            }
+            returnTypeEndIndex = currentIndex
+            currentIndex++
+        }
+
+        // Find the start of the function signature (start of line containing colon)
+        var startIndex = colonIndex
+        while (startIndex > 0 && nodeText[startIndex - 1] != '\n') {
+            startIndex--
+        }
+
+        // Calculate full signature length on a single line
+        val signatureText = nodeText.substring(startIndex, returnTypeEndIndex)
+        return signatureText.length
+    }
