--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/TypeArgumentAnnotationTest.kt
@@ -0,0 +1,38 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class TypeArgumentAnnotationTest {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Multiple annotations on a type argument should not be forced to separate lines`() {
+        val code =
+            """
+            data class FooRequestDto(
+                val data: List<@Valid @NotNull FooDto>,
+            )
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Multiple annotations on a type parameter should not be forced to separate lines`() {
+        val code =
+            """
+            class Foo<@Valid @NotNull T>
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Annotation with parameter on a type argument should not be forced to separate lines`() {
+        val code =
+            """
+            val list: List<@Suppress("SomeRule") FooDto>
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

