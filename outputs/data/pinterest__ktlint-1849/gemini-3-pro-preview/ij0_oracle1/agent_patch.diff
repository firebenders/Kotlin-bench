@@ -0,0 +1,35 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class AnnotationRuleIssue673Test {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Test
+    fun `Issue 673 - A type with multiple annotations inside a TypeArgumentList is not formatted correctly`() {
+        val code =
+            """
+            data class FooRequestDto(
+                val data: List<@Valid @NotNull FooDto>,
+            )
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 673 - A type with multiple annotations inside a TypeArgumentList can be on separate lines`() {
+        val code =
+            """
+            data class FooRequestDto(
+                val data: List<
+                    @Valid
+                    @NotNull
+                    FooDto
+                >,
+            )
+            """.trimIndent()
+        annotationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
