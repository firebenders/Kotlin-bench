+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+/**
+ * Test for issue #673 - Multiple annotations inside TypeArgumentList should not be wrapped incorrectly.
+ */
+class TypeArgumentListWrappingRuleTest {
+    private val wrappingRuleAssertThat = assertThatRule { WrappingRule() }
+
+    @Test
+    fun `Issue 673 - annotations inside TypeArgumentList should not be wrapped`() {
+        val code =
+            """
+            annotation class Valid
+            annotation class NotNull
+            data class FooDto(val value: String)
+
+            data class FooRequestDto(
+                val data: List<@Valid @NotNull FooDto>,
+            )
+            """.trimIndent()
+
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 673 - single annotation inside TypeArgumentList should not add comma`() {
+        val code =
+            """
+            annotation class Valid
+            data class FooDto(val value: String)
+
+            data class FooRequestDto(
+                val data: List<@Valid FooDto>,
+            )
+            """.trimIndent()
+
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+
