+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Nested
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for try/catch indentation and typealias indentation issues.
+ * See: https://github.com/pinterest/ktlint/issues/1935
+ */
+class IndentationRuleTryCatchTypealiasTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Nested
+    inner class `Given try-catch on separate lines` {
+        @Test
+        fun `Given a function expression with try-catch where catch is on a new line should not add extra indent`() {
+            // When try { is on the same line as =, and catch is on a new line after },
+            // the catch should be at the same level as the start of the line (column 0)
+            // This is the behavior from ktlint 0.47.1
+            val code =
+                """
+                fun test() = try {
+                    1
+                }
+                catch(_: Throwable) {
+                    2
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a function expression with try on new line and catch on same line as brace`() {
+            // When try is on a new line after =, the entire expression is indented
+            // catch on the same line as } doesn't need separate indentation
+            val code =
+                """
+                fun test() =
+                    try {
+                        1
+                    } catch(_: Throwable) {
+                        2
+                    }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasNoLintViolations()
+        }
+    }
+
+    @Nested
+    inner class `Given typealias with type on next line` {
+        @Test
+        fun `Given a typealias with type reference on the next line`() {
+            val code =
+                """
+                typealias Foo =
+                    HashMap<Bar, Baz?>
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a typealias with type reference on the next line and indent size 2`() {
+            val code =
+                """
+                typealias Foo =
+                  HashMap<Bar, Baz?>
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(com.pinterest.ktlint.rule.engine.core.api.editorconfig.INDENT_SIZE_PROPERTY to 2)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a typealias with missing indentation should be fixed`() {
+            val code =
+                """
+                typealias Foo =
+                HashMap<Bar, Baz?>
+                """.trimIndent()
+            val formattedCode =
+                """
+                typealias Foo =
+                    HashMap<Bar, Baz?>
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasLintViolation(2, 1, "Unexpected indentation (0) (should be 4)")
+                .isFormattedAs(formattedCode)
+        }
+    }
+}
