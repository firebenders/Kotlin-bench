+        //
+        // Create a single context for the entire TRY expression with childIndent = ""
+        // This ensures that newlines between blocks (try block -> catch, catch -> finally)
+        // don't add extra indentation.
+        startIndentContext(
+            fromAstNode = node,
+            toAstNode = node.lastChildLeafOrSelf(),
+            childIndent = "",
+        )
