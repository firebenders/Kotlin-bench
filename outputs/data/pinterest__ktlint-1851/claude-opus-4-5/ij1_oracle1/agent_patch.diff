+    @Nested
+    inner class `Issue try-catch and typealias` {
+        @Test
+        fun `Given a try-catch where catch is on a separate line`() {
+            val code =
+                """
+                fun test() = try {
+                    1
+                }
+                catch (_: Throwable) {
+                    2
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code).hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a try-catch-finally where catch and finally are on separate lines`() {
+            val code =
+                """
+                fun test() = try {
+                    1
+                }
+                catch (_: Throwable) {
+                    2
+                }
+                finally {
+                    3
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code).hasNoLintViolations()
+        }
+
