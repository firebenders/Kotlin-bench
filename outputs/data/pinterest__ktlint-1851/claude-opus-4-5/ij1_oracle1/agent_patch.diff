+    private fun visitTry(node: ASTNode) {
+        // Find the try block (BLOCK element) and create a context for content after it
+        // This ensures catch and finally blocks are not indented extra relative to try
+        node
+            .findChildByType(BLOCK)
+            ?.lastChildLeafOrSelf()
+            ?.nextLeaf()
+            ?.let { nodeAfterTryBlock ->
+                startIndentContext(
+                    fromAstNode = nodeAfterTryBlock,
+                    toAstNode = node.lastChildLeafOrSelf(),
+                    childIndent = "",
+                )
+            }
+    }
+
+    private fun visitTypealias(node: ASTNode) {
+        node
+            .findChildByType(EQ)
+            ?.let { eq ->
+                startIndentContext(
+                    fromAstNode = eq,
+                    toAstNode = node.lastChildLeafOrSelf(),
+                )
+            }
+    }
+
