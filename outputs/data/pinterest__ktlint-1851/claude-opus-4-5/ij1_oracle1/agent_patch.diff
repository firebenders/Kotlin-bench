+    private fun visitTry(node: ASTNode) {
+        // Capture the current indent before creating any contexts
+        // This ensures all parts of the try expression (try block, catch, finally) are at the same level
+        val nodeIndent = currentIndent()
+
+        // Inner indent contexts in reversed order
+        var nextToAstNode = node.lastChildLeafOrSelf()
+        node
+            .findChildByType(FINALLY)
+            ?.let { fromAstNode ->
+                nextToAstNode = startIndentContext(
+                    fromAstNode = fromAstNode,
+                    toAstNode = nextToAstNode,
+                    nodeIndent = nodeIndent,
+                    // childIndent = "" ensures finally block stays at the same indent level as try block
+                    // firstChildIndent = "" ensures 'finally' keyword itself is not extra indented
+                    // when on a new line after the preceding block's closing brace
+                    childIndent = "",
+                    firstChildIndent = "",
+                ).prevCodeLeaf()
+            }
+
+        node
+            .findChildByType(CATCH)
+            ?.let { fromAstNode ->
+                nextToAstNode = startIndentContext(
+                    fromAstNode = fromAstNode,
+                    toAstNode = nextToAstNode,
+                    nodeIndent = nodeIndent,
+                    // childIndent = "" ensures catch block stays at the same indent level as try block
+                    // firstChildIndent = "" ensures 'catch' keyword itself is not extra indented
+                    // when on a new line after try block's closing brace
+                    childIndent = "",
+                    firstChildIndent = "",
+                ).prevCodeLeaf()
+            }
+
+        node
+            .findChildByType(BLOCK)
+            ?.lastChildLeafOrSelf()
+            ?.nextLeaf()
+            ?.let { nodeAfterTryBlock ->
+                nextToAstNode = startIndentContext(
+                    fromAstNode = nodeAfterTryBlock,
+                    toAstNode = nextToAstNode,
+                    nodeIndent = nodeIndent,
+                    childIndent = "",
+                ).prevCodeLeaf()
+            }
+
+        startIndentContext(
+            fromAstNode = node,
+            toAstNode = nextToAstNode,
+            nodeIndent = nodeIndent,
+            childIndent = "",
+        )
+    }
+
+    private fun visitTypeAlias(node: ASTNode) {
+        node
+            .findChildByType(EQ)
+            ?.let { eq ->
+                startIndentContext(
+                    fromAstNode = eq,
+                    toAstNode = node.lastChildLeafOrSelf(),
+                )
+            }
+    }
