+            .toList()
+            .asReversed()
+            .forEach { catchNode ->
+                nextToAstNode = startIndentContext(
+                    fromAstNode = catchNode,
+                    toAstNode = nextToAstNode,
+                    firstChildIndent = "",
+                    lastChildIndent = "",
+                ).prevCodeLeaf()
+            }
+
+        // The TRY block itself - childIndent = "" ensures catch/finally keywords are at same
+        // level as try keyword when on separate lines
+        startIndentContext(
+            fromAstNode = node,
+            toAstNode = nextToAstNode,
+            childIndent = "",
+        )
+    }
