+    private fun visitTry(node: ASTNode) {
+        // Similar to if-else handling - handle the complex parts in reverse order
+        var nextToAstNode = node.lastChildLeafOrSelf()
+
+        // Handle finally block first (if present)
+        node
+            .findChildByType(FINALLY)
+            ?.let { finallyNode ->
+                nextToAstNode = startIndentContext(
+                    fromAstNode = finallyNode,
+                    toAstNode = nextToAstNode,
+                ).prevCodeLeaf()
+            }
+
+        // Handle catch blocks (there can be multiple, process in reverse order)
+        val catchNodes = node.children().filter { it.elementType == CATCH }.toList()
+        for (catchNode in catchNodes.reversed()) {
+            nextToAstNode = startIndentContext(
+                fromAstNode = catchNode,
+                toAstNode = nextToAstNode,
+            ).prevCodeLeaf()
+        }
+
+        // Handle the try block itself (main context)
+        startIndentContext(
+            fromAstNode = node,
+            toAstNode = nextToAstNode,
+        )
+    }
+
+    private fun visitTypeAlias(node: ASTNode) {
+        // Handle the type reference after the equals sign - similar to how properties are handled
+        node
+            .findChildByType(EQ)
+            ?.let { fromAstNode ->
+                startIndentContext(
+                    fromAstNode = fromAstNode,
+                    toAstNode = node.lastChildLeafOrSelf(),
+                )
+            }
+    }
