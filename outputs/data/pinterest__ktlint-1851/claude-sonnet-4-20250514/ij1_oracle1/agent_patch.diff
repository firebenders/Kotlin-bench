+    @Test
+    fun `Given a try-catch expression as function body with improper indentation`() {
+        val code =
+            """
+            fun test() = try {
+            1
+            }
+            catch(_: Throwable) {
+            2
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun test() = try {
+                1
+            }
+            catch(_: Throwable) {
+                2
+            }
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(2, 1, "Unexpected indentation (0) (should be 4)"),
+                LintViolation(5, 1, "Unexpected indentation (0) (should be 4)"),
+            ).isFormattedAs(formattedCode)
+    }
+
