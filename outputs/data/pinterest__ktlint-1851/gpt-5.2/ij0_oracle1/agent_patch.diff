+    private fun visitTry(node: ASTNode) {
+        // Inner indent contexts in reversed order
+        var nextToAstNode: ASTNode = node.lastChildLeafOrSelf()
+
+        // Ensure that catch/finally clauses align with the try expression. This prevents a false positive where a
+        // continuation indent (e.g. after '=') is applied to the catch/finally keyword.
+        node
+            .findChildByType(FINALLY)
+            ?.let { fromAstNode ->
+                nextToAstNode = startIndentContext(
+                    fromAstNode = fromAstNode,
+                    toAstNode = nextToAstNode,
+                    childIndent = "",
+                ).prevCodeLeaf()
+            }
+
+        // There can be multiple catch clauses. Start the indent context for the first catch clause; subsequent catch
+        // clauses are part of this same context.
+        node
+            .findChildByType(CATCH)
+            ?.let { fromAstNode ->
+                nextToAstNode = startIndentContext(
+                    fromAstNode = fromAstNode,
+                    toAstNode = nextToAstNode,
+                    childIndent = "",
+                ).prevCodeLeaf()
+            }
+
+        startIndentContext(
+            fromAstNode = node,
+            toAstNode = nextToAstNode,
+            childIndent = "",
+        )
+    }
+
+    private fun visitTypeAlias(node: ASTNode) {
+        // Inner indent contexts in reversed order
+        var nextToAstNode: ASTNode = node.lastChildLeafOrSelf()
+        node
+            .findChildByType(EQ)
+            ?.let { eq ->
+                nextToAstNode = startIndentContext(
+                    fromAstNode = eq,
+                    toAstNode = nextToAstNode,
+                ).prevCodeLeaf()
+            }
+
+        startIndentContext(
+            fromAstNode = node,
+            toAstNode = nextToAstNode,
+            childIndent = "",
+        )
+    }
