+    private fun visitTypeAlias(node: ASTNode) {
+        // Typealias with continuation on next line should be indented like other assignments
+        node.findChildByType(EQ)?.let { eq ->
+            startIndentContext(
+                fromAstNode = eq,
+                toAstNode = node.lastChildLeafOrSelf(),
+            )
+        }
+    }
