+                    LintViolation(3, 1, "Wildcard import"),
+                )
+        }
+
+        @Test
+        fun `All wildcard imports are detected when property is not explicitly set`() {
+            val code =
+                """
+                import a.b.*
+                import java.util.*
+                import kotlinx.android.synthetic.main.layout_name.*
+                import react.*
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasLintViolationsWithoutAutoCorrect(
+                    LintViolation(1, 1, "Wildcard import"),
+                    LintViolation(2, 1, "Wildcard import"),
+                    LintViolation(3, 1, "Wildcard import"),
+                    LintViolation(4, 1, "Wildcard import"),
+                )
+        }
+
+        @Test
+        fun `Wildcard imports can still be allowed when explicitly configured via editorconfig property`() {
+            val code =
+                """
+                import a.b.*
+                import java.util.*
+                import kotlinx.android.synthetic.main.layout_name.*
+                import react.*
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .withEditorConfigOverride(IJ_KOTLIN_PACKAGES_TO_USE_IMPORT_ON_DEMAND to "java.util.*,react.*")
+                .hasLintViolationsWithoutAutoCorrect(
