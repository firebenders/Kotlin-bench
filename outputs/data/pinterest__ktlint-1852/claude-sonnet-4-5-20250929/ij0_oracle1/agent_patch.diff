+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Nested
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests to verify that the default allowed wildcard imports are different based on code style.
+ */
+class NoWildcardImportsRuleCodeStyleTest {
+    private val noWildcardImportsRuleAssertThat = assertThatRule { NoWildcardImportsRule() }
+
+    @Nested
+    inner class `Given ktlint_official code style` {
+        @Test
+        fun `java util wildcard import triggers violation`() {
+            val code =
+                """
+                import java.util.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.ktlint_official)
+                .hasLintViolationWithoutAutoCorrect(1, 1, "Wildcard import")
+        }
+
+        @Test
+        fun `kotlinx android synthetic wildcard import triggers violation`() {
+            val code =
+                """
+                import kotlinx.android.synthetic.main.layout_name.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.ktlint_official)
+                .hasLintViolationWithoutAutoCorrect(1, 1, "Wildcard import")
+        }
+
+        @Test
+        fun `multiple default wildcard imports all trigger violations`() {
+            val code =
+                """
+                import java.util.*
+                import kotlinx.android.synthetic.main.*
+                import a.b.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.ktlint_official)
+                .hasLintViolationsWithoutAutoCorrect(
+                    LintViolation(1, 1, "Wildcard import"),
+                    LintViolation(2, 1, "Wildcard import"),
+                    LintViolation(3, 1, "Wildcard import"),
+                )
+        }
+    }
+
+    @Nested
+    inner class `Given intellij_idea code style` {
+        @Test
+        fun `java util wildcard import does not trigger violation`() {
+            val code =
+                """
+                import java.util.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.intellij_idea)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `kotlinx android synthetic wildcard import does not trigger violation`() {
+            val code =
+                """
+                import kotlinx.android.synthetic.main.layout_name.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.intellij_idea)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `other wildcard imports trigger violations`() {
+            val code =
+                """
+                import a.b.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.intellij_idea)
+                .hasLintViolationWithoutAutoCorrect(1, 1, "Wildcard import")
+        }
+    }
+
+    @Nested
+    inner class `Given android_studio code style` {
+        @Test
+        fun `java util wildcard import does not trigger violation`() {
+            val code =
+                """
+                import java.util.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.android_studio)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `kotlinx android synthetic wildcard import does not trigger violation`() {
+            val code =
+                """
+                import kotlinx.android.synthetic.main.layout_name.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.android_studio)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `other wildcard imports trigger violations`() {
+            val code =
+                """
+                import a.b.*
+
+                val a = 1
+                """.trimIndent()
+            noWildcardImportsRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.android_studio)
+                .hasLintViolationWithoutAutoCorrect(1, 1, "Wildcard import")
+        }
+    }
+}
+

