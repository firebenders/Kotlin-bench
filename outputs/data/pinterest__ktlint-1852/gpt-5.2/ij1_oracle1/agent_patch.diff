diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoWildcardImportsRuleKtlintOfficialCodeStyleTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoWildcardImportsRuleKtlintOfficialCodeStyleTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoWildcardImportsRuleKtlintOfficialCodeStyleTest.kt
@@ -0,0 +1,51 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.ktlint_official
+import com.pinterest.ktlint.ruleset.standard.rules.NoWildcardImportsRule.Companion.IJ_KOTLIN_PACKAGES_TO_USE_IMPORT_ON_DEMAND
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class NoWildcardImportsRuleKtlintOfficialCodeStyleTest {
+    private val noWildcardImportsRuleAssertThat = assertThatRule { NoWildcardImportsRule() }
+
+    @Test
+    fun `Given ktlint_official code style and property is not set then java util wildcard import is reported`() {
+        val code =
+            """
+            import java.util.*
+            """.trimIndent()
+
+        noWildcardImportsRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .hasLintViolationWithoutAutoCorrect(1, 1, "Wildcard import")
+    }
+
+    @Test
+    fun `Given ktlint_official code style and property allows java util wildcard import then it is not reported`() {
+        val code =
+            """
+            import java.util.*
+            """.trimIndent()
+
+        noWildcardImportsRuleAssertThat(code)
+            .withEditorConfigOverride(
+                CODE_STYLE_PROPERTY to ktlint_official,
+                IJ_KOTLIN_PACKAGES_TO_USE_IMPORT_ON_DEMAND to "java.util.*",
+            ).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given ktlint_official code style and property is not set then kotlinx android synthetic wildcard import is reported`() {
+        val code =
+            """
+            import kotlinx.android.synthetic.main.layout_name.*
+            """.trimIndent()
+
+        noWildcardImportsRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .hasLintViolationWithoutAutoCorrect(1, 1, "Wildcard import")
+    }
+}
+

