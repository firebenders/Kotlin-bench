--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingBetweenDeclarationsWithAnnotationsRuleConsecutiveKdocTest.kt
@@ -0,0 +1,130 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for the issue with consecutive KDocs incorrectly triggering the
+ * spacing-between-declarations-with-annotations rule.
+ *
+ * @see https://github.com/pinterest/ktlint/issues/1754
+ */
+class SpacingBetweenDeclarationsWithAnnotationsRuleConsecutiveKdocTest {
+    private val spacingBetweenDeclarationsWithAnnotationsRuleAssertThat =
+        assertThatRule { SpacingBetweenDeclarationsWithAnnotationsRule() }
+
+    @Test
+    fun `Given consecutive KDocs before an annotated declaration with blank line before first KDoc should not report violation`() {
+        val code =
+            """
+            public class JsonReader {
+                public var lenient: Boolean = false
+
+                /**
+                 * Hey
+                 */
+                /** Sup */
+                @get:JvmName("failOnUnknown")
+                public var failOnUnknown: Boolean = false
+            }
+            """.trimIndent()
+        // The rule should NOT report a violation because there IS a blank line after the previous declaration
+        // (even though there are consecutive KDocs, which is a separate issue)
+        spacingBetweenDeclarationsWithAnnotationsRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given consecutive KDocs before an annotated declaration without blank line should report violation`() {
+        val code =
+            """
+            public class JsonReader {
+                public var lenient: Boolean = false
+                /**
+                 * Hey
+                 */
+                /** Sup */
+                @get:JvmName("failOnUnknown")
+                public var failOnUnknown: Boolean = false
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            public class JsonReader {
+                public var lenient: Boolean = false
+
+                /**
+                 * Hey
+                 */
+                /** Sup */
+                @get:JvmName("failOnUnknown")
+                public var failOnUnknown: Boolean = false
+            }
+            """.trimIndent()
+        spacingBetweenDeclarationsWithAnnotationsRuleAssertThat(code)
+            .hasLintViolation(7, 5, "Declarations and declarations with annotations should have an empty space between.")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a KDoc before an annotated declaration with blank line should not report violation`() {
+        val code =
+            """
+            public class JsonReader {
+                public var lenient: Boolean = false
+
+                /**
+                 * Hey
+                 */
+                @get:JvmName("failOnUnknown")
+                public var failOnUnknown: Boolean = false
+            }
+            """.trimIndent()
+        spacingBetweenDeclarationsWithAnnotationsRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a block comment and KDoc before an annotated declaration with blank line should not report violation`() {
+        val code =
+            """
+            public class Test {
+                public var a: Boolean = false
+
+                /* Block comment */
+                /** KDoc */
+                @Suppress("UNUSED")
+                public var b: Boolean = false
+            }
+            """.trimIndent()
+        spacingBetweenDeclarationsWithAnnotationsRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given multiple multiline KDocs before an annotated declaration with blank line should not report violation`() {
+        val code =
+            """
+            public class JsonReader {
+                public var lenient: Boolean = false
+
+                /**
+                 * True to throw a [JsonDataException] on any attempt to call [skipValue].
+                 *
+                 * ## Getting
+                 * Returns true if this parser forbids skipping names and values.
+                 *
+                 * ## Setting
+                 * Configure whether this parser throws a [JsonDataException] when [skipValue] is
+                 * called. By default this parser permits values to be skipped.
+                 *
+                 * Forbid skipping to prevent unrecognized values from being silently ignored. This option is
+                 * useful in development and debugging because it means a typo like "locatiom" will be detected
+                 * early. It's potentially harmful in production because it complicates revising a JSON schema.
+                 */
+                /** Returns true if this parser forbids skipping names and values. */
+                @get:JvmName("failOnUnknown")
+                public var failOnUnknown: Boolean = false
+            }
+            """.trimIndent()
+        spacingBetweenDeclarationsWithAnnotationsRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

