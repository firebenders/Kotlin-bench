+    @Test
+    fun `Issue 1539 - Given a KDoc on line above annotated class member should do nothing`() {
+        val code =
+            """
+            class C {
+                fun foo() = 1
+
+                /** Some KDoc. */
+                @E
+                fun bar() = 2
+            }
+            """.trimIndent()
+        spacingBetweenDeclarationsWithAnnotationsRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1539 - Given consecutive KDocs (accidental double-KDoc) before an annotated class member should do nothing`() {
+        val code =
+            """
+            public class JsonReader {
+                public var lenient: Boolean = false
+
+                /**
+                 * Hey
+                 */
+                /** Sup */
+                @get:JvmName("failOnUnknown")
+                public var failOnUnknown: Boolean = false
+            }
+            """.trimIndent()
+        spacingBetweenDeclarationsWithAnnotationsRuleAssertThat(code).hasNoLintViolations()
+    }
+
