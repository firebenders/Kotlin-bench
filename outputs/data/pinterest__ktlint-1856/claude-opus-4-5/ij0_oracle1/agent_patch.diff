+private fun ASTNode?.shouldStartIndentContext(childElementType: IElementType): Boolean {
+    // For DOT_QUALIFIED_EXPRESSION and SAFE_ACCESS_EXPRESSION, treat them as the same type of chain.
+    // When they are nested within each other, only one indent context should be created for the entire chain.
+    // For USER_TYPE, keep the original behavior (only skip when parent is also USER_TYPE).
+    val parentElementType = this?.elementType
+    return when {
+        childElementType == USER_TYPE -> parentElementType != USER_TYPE
+        childElementType == DOT_QUALIFIED_EXPRESSION || childElementType == SAFE_ACCESS_EXPRESSION ->
+            parentElementType != DOT_QUALIFIED_EXPRESSION && parentElementType != SAFE_ACCESS_EXPRESSION
+        else -> parentElementType != childElementType
+    }
+}
