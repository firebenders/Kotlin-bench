+    /**
+     * Checks whether the current node is part of a chained expression (DOT_QUALIFIED_EXPRESSION,
+     * SAFE_ACCESS_EXPRESSION, or USER_TYPE). In a chain like `foo.bar()?.baz()`, the inner expressions should not
+     * create separate indent contexts as the entire chain is considered as one expression for indentation purposes.
+     */
+    private fun ASTNode.isPartOfChainedExpression(): Boolean {
+        val parentElementType = treeParent?.elementType
+        return parentElementType == DOT_QUALIFIED_EXPRESSION ||
+            parentElementType == SAFE_ACCESS_EXPRESSION ||
+            parentElementType == USER_TYPE
+    }
