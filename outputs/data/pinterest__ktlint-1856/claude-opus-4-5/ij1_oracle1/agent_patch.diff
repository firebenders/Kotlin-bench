@@ -0,0 +1,122 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests related to GitHub issue about false positive indent after updating from 0.47.1.
+ * The issue is that the following code should pass indent validation but fails.
+ */
+internal class IndentationRuleIssueTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Given an expression body function with runCatching and chained safe access lambda should not have indent issues`() {
+        val code =
+            """
+            private fun test(): Boolean? =
+                runCatching { true }
+                    .getOrNull()?.let { result ->
+                        !result
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Test case without expression body function - simple chained calls`() {
+        val code =
+            """
+            fun test() {
+                val x = runCatching { true }
+                    .getOrNull()?.let { result ->
+                        !result
+                    }
+            }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Test case without safe access - only dot qualified with let`() {
+        val code =
+            """
+            private fun test(): Boolean =
+                runCatching { true }
+                    .getOrThrow().let { result ->
+                        !result
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Test case - simplest version with expression body`() {
+        val code =
+            """
+            private fun test(): Boolean? =
+                foo()?.let { result ->
+                    !result
+                }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Test case - multiple chained safe access calls`() {
+        val code =
+            """
+            private fun test(): Boolean? =
+                runCatching { true }
+                    .getOrNull()
+                    ?.let { result -> !result }
+                    ?.let { result -> !result }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Test case - safe access in middle of chain with trailing lambda`() {
+        val code =
+            """
+            private fun test(): Boolean? =
+                foo()
+                    ?.bar()
+                    .baz { result ->
+                        !result
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Test case - alternating dot and safe access in chain`() {
+        val code =
+            """
+            private fun test(): Boolean? =
+                foo()
+                    .bar()
+                    ?.baz()
+                    .qux { result ->
+                        !result
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Test case - nested lambdas with safe access chain`() {
+        val code =
+            """
+            private fun test(): Boolean? =
+                runCatching { true }
+                    .getOrNull()?.let { result ->
+                        innerCall()?.let { inner ->
+                            !inner
+                        }
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
