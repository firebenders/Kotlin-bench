+    @Test
+    fun `Issue from GitHub - chained method calls with let should be correctly indented`() {
+        // This test represents the issue from GitHub where chained calls with mixed
+        // DOT_QUALIFIED_EXPRESSION and SAFE_ACCESS_EXPRESSION caused incorrect indentation errors
+        val code =
+            """
+            private fun test(): Boolean? =
+                runCatching { true }
+                    .getOrNull()?.let { result ->
+                        !result
+                    }
+            """.trimIndent()
+
+        // This should pass without lint violations after the fix
+        indentationRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given mixed dot qualified and safe access expressions in chain`() {
+        val code =
+            """
+            val result =
+                someObject
+                    .method1()
+                    ?.method2()
+                    .method3()?.let { value ->
+                        value.toString()
+                    }
+            """.trimIndent()
+
+        indentationRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
