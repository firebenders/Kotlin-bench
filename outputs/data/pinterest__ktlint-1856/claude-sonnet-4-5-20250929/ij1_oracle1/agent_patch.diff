@@ -0,0 +1,129 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Test for issue with chained method calls mixing DOT_QUALIFIED_EXPRESSION and SAFE_ACCESS_EXPRESSION
+ * This test verifies that lambda bodies in chained calls have correct indentation.
+ */
+internal class IndentationRuleChainedCallTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Given a function with runCatching chained with getOrNull and let with lambda`() {
+        val code =
+            """
+            private fun test(): Boolean? =
+                runCatching { true }
+                    .getOrNull()?.let { result ->
+                        !result
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function with chained calls mixing dot and safe access with lambda on multiple lines`() {
+        val code =
+            """
+            fun process(): String? =
+                someValue
+                    .transform()
+                    ?.let { value ->
+                        value.toString()
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a property with chained safe access and dot qualified expressions`() {
+        val code =
+            """
+            val result =
+                foo?.bar()
+                    .baz()
+                    ?.let { item ->
+                        item.process()
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given deeply nested chained calls with mixed safe access and dot notation`() {
+        val code =
+            """
+            val computed =
+                data?.field
+                    .method1()
+                    ?.method2()
+                    .method3()?.let { value ->
+                        value * 2
+                    }?.let { doubled ->
+                        doubled + 1
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a chained call starting with safe access followed by dot notation`() {
+        val code =
+            """
+            val result =
+                value?.method()
+                    .anotherMethod()
+                    .finalMethod { item ->
+                        item.process()
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a chained call starting with dot notation followed by safe access`() {
+        val code =
+            """
+            val result =
+                value.method()
+                    ?.anotherMethod()
+                    ?.finalMethod { item ->
+                        item.process()
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given multiple chained safe access calls with lambda expressions`() {
+        val code =
+            """
+            val result =
+                value
+                    ?.map { it * 2 }
+                    ?.filter { it > 10 }
+                    ?.firstOrNull { element ->
+                        element % 3 == 0
+                    }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a class member function with chained calls`() {
+        val code =
+            """
+            class Example {
+                private fun test(): Boolean? =
+                    runCatching { true }
+                        .getOrNull()?.let { result ->
+                            !result
+                        }
+            }
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

