+
+    @Test
+    fun `Given imports not matching first patterns in a layout with separators then do not insert blank lines before the first import`() {
+        // Issue: https://github.com/pinterest/ktlint/issues/1845
+        // Config: *, |, javax.**, java.**, |, kotlinx.**, kotlin.**
+        // The imports only match java.**, but since the pattern has | separators before java.**, it was incorrectly
+        // adding blank lines before the first import.
+        val code =
+            """
+            import java.nio.file.Files
+            import java.nio.file.Paths
+            import java.util.Objects
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given imports with extra blank lines before first import when pattern has unmatched leading groups then format correctly`() {
+        // Issue: https://github.com/pinterest/ktlint/issues/1845
+        // This tests that when the code has extra blank lines before imports (due to the bug), formatting removes them.
+        val code =
+            """
+            import java.nio.file.Files
+
+
+            import java.nio.file.Paths
+            import java.util.Objects
+            """.trimIndent()
+        val formattedCode =
+            """
+            import java.nio.file.Files
+            import java.nio.file.Paths
+            import java.util.Objects
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given imports from different groups with separators and first group empty then correctly separate groups`() {
+        // Issue: https://github.com/pinterest/ktlint/issues/1845
+        // Config: *, |, javax.**, java.**, |, kotlinx.**, kotlin.**
+        // The imports match java.** and kotlin.**, with a separator between them.
+        val code =
+            """
+            import java.nio.file.Files
+            import kotlin.io.path.Path
+            """.trimIndent()
+        val formattedCode =
+            """
+            import java.nio.file.Files
+
+            import kotlin.io.path.Path
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .isFormattedAs(formattedCode)
+    }
