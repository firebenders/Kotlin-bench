+package com.pinterest.ktlint.ruleset.standard.rules.importordering
+
+import com.pinterest.ktlint.ruleset.standard.rules.ImportOrderingRule
+import com.pinterest.ktlint.ruleset.standard.rules.ImportOrderingRule.Companion.IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for the issue where multiple blank line patterns in ij_kotlin_imports_layout
+ * cause extra blank lines to be inserted before the first import.
+ */
+class ImportOrderingRuleIssueTest {
+    private val importOrderingRuleAssertThat = assertThatRule { ImportOrderingRule() }
+
+    @Test
+    fun `Issue - Given imports layout with multiple blank line separators and file has only imports matching one pattern, do not add blank lines before first import`() {
+        val code =
+            """
+            import java.nio.file.Files
+            import java.nio.file.Paths
+            import java.util.Objects
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue - Given imports layout with blank line separators before matching pattern, format correctly without extra blank lines`() {
+        val code =
+            """
+            import java.nio.file.Files
+            import java.nio.file.Paths
+            import java.util.Objects
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue - Given imports from multiple groups with blank line separators between them, format correctly`() {
+        val code =
+            """
+            import java.nio.file.Files
+            import kotlin.concurrent.Thread
+            """.trimIndent()
+        val formattedCode =
+            """
+            import java.nio.file.Files
+
+            import kotlin.concurrent.Thread
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .hasLintViolation(1, 1, "Imports must be ordered according to the pattern specified in .editorconfig")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue - Given layout starting with blank line pattern and only matching later pattern, do not add blank lines before first import`() {
+        val code =
+            """
+            import kotlin.concurrent.Thread
+            import kotlin.io.Closeable
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "|, |, kotlin.**, *")
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue - Given imports matching first pattern after blank line separators, do not add blank lines before first import`() {
+        val code =
+            """
+            import android.app.Activity
+            import android.view.View
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, java.**, |, kotlin.**")
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue - Complex layout with multiple blank line separators and imports from various groups`() {
+        val code =
+            """
+            import android.app.Activity
+            import android.view.View
+
+            import javax.inject.Inject
+
+            import java.nio.file.Files
+            import java.util.Objects
+
+            import kotlin.concurrent.Thread
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "android.**, |, javax.**, |, java.**, |, kotlin.**, *")
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue - Given imports that need reordering with blank line separators, do not add blank lines before first import after reformatting`() {
+        val code =
+            """
+            import kotlin.concurrent.Thread
+            import java.nio.file.Files
+            """.trimIndent()
+        val formattedCode =
+            """
+            import java.nio.file.Files
+
+            import kotlin.concurrent.Thread
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, java.**, |, kotlin.**")
+            .hasLintViolation(1, 1, "Imports must be ordered according to the pattern specified in .editorconfig")
+            .isFormattedAs(formattedCode)
+    }
+}
