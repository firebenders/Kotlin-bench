diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/importordering/ImportOrderingRuleBlankLineBugTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/importordering/ImportOrderingRuleBlankLineBugTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/importordering/ImportOrderingRuleBlankLineBugTest.kt
@@ -0,0 +1,114 @@
+package com.pinterest.ktlint.ruleset.standard.rules.importordering
+
+import com.pinterest.ktlint.ruleset.standard.rules.ImportOrderingRule
+import com.pinterest.ktlint.ruleset.standard.rules.ImportOrderingRule.Companion.IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for issue where multiple blank line separators in ij_kotlin_imports_layout pattern
+ * were incorrectly causing extra blank lines to be added before the first import.
+ *
+ * See: https://github.com/pinterest/ktlint/issues/XXXX
+ */
+class ImportOrderingRuleBlankLineBugTest {
+    private val importOrderingRuleAssertThat = assertThatRule { ImportOrderingRule() }
+
+    @Test
+    fun `Given a layout with multiple blank line separators and imports matching only one group, no extra blank lines should be added before first import`() {
+        val code =
+            """
+            package test
+
+            import java.nio.file.Files
+            import java.nio.file.Paths
+            import java.util.Objects
+
+            object TestData {
+                fun loadString(dataset: String): String {
+                    val path = Paths.get(Objects.requireNonNull(TestData::class.java.getResource(dataset)).toURI())
+                    return String(Files.readAllBytes(path))
+                }
+            }
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given only java imports with pattern starting with wildcard and blank separators, should not add extra blank lines`() {
+        val code =
+            """
+            package test
+
+            import java.nio.file.Files
+            import java.util.Objects
+            import java.nio.file.Paths
+
+            object TestData
+            """.trimIndent()
+        val formattedCode =
+            """
+            package test
+
+            import java.nio.file.Files
+            import java.nio.file.Paths
+            import java.util.Objects
+
+            object TestData
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .hasLintViolation(3, 1, "Imports must be ordered according to the pattern specified in .editorconfig")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given imports from multiple groups with blank separators, should add blank lines between groups but not before first import`() {
+        val code =
+            """
+            package test
+
+            import kotlin.concurrent.Thread
+            import java.nio.file.Files
+            import javax.servlet.http.HttpServlet
+
+            object TestData
+            """.trimIndent()
+        val formattedCode =
+            """
+            package test
+
+            import javax.servlet.http.HttpServlet
+            import java.nio.file.Files
+
+            import kotlin.concurrent.Thread
+
+            object TestData
+            """.trimIndent()
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .hasLintViolation(3, 1, "Imports must be ordered according to the pattern specified in .editorconfig")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given correctly formatted imports, applying format multiple times should be stable`() {
+        val code =
+            """
+            package test
+
+            import java.nio.file.Files
+            import java.nio.file.Paths
+            import java.util.Objects
+
+            object TestData
+            """.trimIndent()
+        // First format pass - should have no violations
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*, |, javax.**, java.**, |, kotlinx.**, kotlin.**")
+            .hasNoLintViolations()
+    }
+}
+

