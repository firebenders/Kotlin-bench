diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/importordering/ImportOrderingRuleRegressionTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/importordering/ImportOrderingRuleRegressionTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/importordering/ImportOrderingRuleRegressionTest.kt
@@ -0,0 +1,37 @@
+package com.pinterest.ktlint.ruleset.standard.rules.importordering
+
+import com.pinterest.ktlint.ruleset.standard.rules.ImportOrderingRule
+import com.pinterest.ktlint.ruleset.standard.rules.ImportOrderingRule.Companion.IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class ImportOrderingRuleRegressionTest {
+    private val importOrderingRuleAssertThat = assertThatRule { ImportOrderingRule() }
+
+    @Test
+    fun `Given custom import layout with blank line entries before first matching group then do not insert blank lines before first import`() {
+        val code =
+            """
+            package test
+
+            import java.nio.file.Files
+            import java.nio.file.Paths
+            import java.util.Objects
+
+            object TestData {
+                fun loadString(dataset: String): String {
+                    val path = Paths.get(
+                        Objects.requireNonNull(TestData::class.java.getResource(dataset)).toURI(),
+                    )
+                    return String(Files.readAllBytes(path))
+                }
+            }
+            """.trimIndent()
+
+        importOrderingRuleAssertThat(code)
+            .withEditorConfigOverride(
+                IJ_KOTLIN_IMPORTS_LAYOUT_PROPERTY to "*,|,javax.**,java.**,|,kotlinx.**,kotlin.**",
+            ).hasNoLintViolations()
+    }
+}
+

