diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeOperatorRuleRangeUntilTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeOperatorRuleRangeUntilTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeOperatorRuleRangeUntilTest.kt
@@ -0,0 +1,112 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+/**
+ * Test for .< (range until) operator support in SpacingAroundRangeOperatorRule.
+ */
+class SpacingAroundRangeOperatorRuleRangeUntilTest {
+    private val spacingAroundRangeOperatorRuleAssertThat = assertThatRule { SpacingAroundRangeOperatorRule() }
+
+    @Test
+    fun `Given a range-until operator without spacing`() {
+        val code =
+            """
+            val foo1 = (1..<12).last
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a range-until operator with spacing after`() {
+        val code =
+            """
+            val foo2 = (1..< 12).last
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolation(1, 17, "Unexpected spacing after \"..<\"")
+    }
+
+    @Test
+    fun `Given a range-until operator with spacing around`() {
+        val code =
+            """
+            val foo3 = (1 ..< 12).last
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolation(1, 15, "Unexpected spacing around \"..<\"")
+    }
+
+    @Test
+    fun `Given a range-until operator with spacing before`() {
+        val code =
+            """
+            val foo4 = (1 ..<12).last
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolation(1, 14, "Unexpected spacing before \"..<\"")
+    }
+
+    @Test
+    fun `Given a range-until in when expression with inconsistent spacing`() {
+        val code =
+            """
+            fun foo(int: Int): String =
+                when (int) {
+                    in 10..<20 -> "A"
+                    in 20..< 30 -> "B"
+                    in 30 ..< 40 -> "C"
+                    in 40 ..<50 -> "D"
+                    else -> "unknown"
+                }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(int: Int): String =
+                when (int) {
+                    in 10..<20 -> "A"
+                    in 20..<30 -> "B"
+                    in 30..<40 -> "C"
+                    in 40..<50 -> "D"
+                    else -> "unknown"
+                }
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(4, 17, "Unexpected spacing after \"..<\""),
+                LintViolation(5, 15, "Unexpected spacing around \"..<\""),
+                LintViolation(6, 14, "Unexpected spacing before \"..<\""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a range-until in for loop`() {
+        val code =
+            """
+            fun foo() {
+                for (i in 1..<4) print(i)
+                for (i in 1..< 4) print(i)
+                for (i in 1 ..< 4) print(i)
+                for (i in 1 ..<4) print(i)
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo() {
+                for (i in 1..<4) print(i)
+                for (i in 1..<4) print(i)
+                for (i in 1..<4) print(i)
+                for (i in 1..<4) print(i)
+            }
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(3, 19, "Unexpected spacing after \"..<\""),
+                LintViolation(4, 17, "Unexpected spacing around \"..<\""),
+                LintViolation(5, 16, "Unexpected spacing before \"..<\""),
+            ).isFormattedAs(formattedCode)
+    }
+}
+

