diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeUntilOperatorRuleTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeUntilOperatorRuleTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeUntilOperatorRuleTest.kt
@@ -0,0 +1,118 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class SpacingAroundRangeUntilOperatorRuleTest {
+    private val spacingAroundRangeOperatorRuleAssertThat = assertThatRule { SpacingAroundRangeOperatorRule() }
+
+    @Test
+    fun `Given a range-until operator with various spacing`() {
+        val code =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo(int: Int): String =
+                when (int) {
+                    in 10..<20 -> "A"
+                    in 20..< 30 -> "B"
+                    in 30 ..< 40 -> "C"
+                    in 40 ..<50 -> "D"
+                    else -> "unknown"
+                }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo(int: Int): String =
+                when (int) {
+                    in 10..<20 -> "A"
+                    in 20..<30 -> "B"
+                    in 30..<40 -> "C"
+                    in 40..<50 -> "D"
+                    else -> "unknown"
+                }
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(5, 17, "Unexpected spacing after \"..<\""),
+                LintViolation(6, 15, "Unexpected spacing around \"..<\""),
+                LintViolation(7, 14, "Unexpected spacing before \"..<\""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a range-until operator in a for loop`() {
+        val code =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo() {
+                for (i in 1..<4) print(i)
+                for (i in 1..< 4) print(i)
+                for (i in 1 ..< 4) print(i)
+                for (i in 1 ..<4) print(i)
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo() {
+                for (i in 1..<4) print(i)
+                for (i in 1..<4) print(i)
+                for (i in 1..<4) print(i)
+                for (i in 1..<4) print(i)
+            }
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(4, 19, "Unexpected spacing after \"..<\""),
+                LintViolation(5, 17, "Unexpected spacing around \"..<\""),
+                LintViolation(6, 16, "Unexpected spacing before \"..<\""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a range-until operator without spacing`() {
+        val code =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo() {
+                val range1 = 1..<10
+                val range2 = 0..<100
+                for (i in 1..<5) print(i)
+            }
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given mixed range and range-until operators`() {
+        val code =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo() {
+                val range1 = 1..10
+                val range2 = 1 .. 10
+                val range3 = 1..<10
+                val range4 = 1 ..< 10
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo() {
+                val range1 = 1..10
+                val range2 = 1..10
+                val range3 = 1..<10
+                val range4 = 1..<10
+            }
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(4, 20, "Unexpected spacing around \"..\""),
+                LintViolation(6, 20, "Unexpected spacing around \"..<\""),
+            ).isFormattedAs(formattedCode)
+    }
+}
