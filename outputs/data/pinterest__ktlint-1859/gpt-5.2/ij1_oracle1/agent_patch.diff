diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeUntilOperatorRuleTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeUntilOperatorRuleTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundRangeUntilOperatorRuleTest.kt
@@ -0,0 +1,40 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class SpacingAroundRangeUntilOperatorRuleTest {
+    private val spacingAroundRangeOperatorRuleAssertThat = assertThatRule { SpacingAroundRangeOperatorRule() }
+
+    @Test
+    fun `Given a range until operator`() {
+        val code =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo() {
+                val a = 1..<2
+                val b = 1..< 2
+                val c = 1 ..< 2
+                val d = 1 ..<2
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @OptIn(ExperimentalStdlibApi::class)
+            fun foo() {
+                val a = 1..<2
+                val b = 1..<2
+                val c = 1..<2
+                val d = 1..<2
+            }
+            """.trimIndent()
+        spacingAroundRangeOperatorRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(4, 17, "Unexpected spacing after \"..<\""),
+                LintViolation(5, 15, "Unexpected spacing around \"..<\""),
+                LintViolation(6, 14, "Unexpected spacing before \"..<\""),
+            ).isFormattedAs(formattedCode)
+    }
+}
+

