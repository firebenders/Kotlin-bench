+    private fun ASTNode.isPartOfPrimaryConstructorAnnotations() =
+        takeIf { elementType == ANNOTATION_ENTRY }
+            ?.takeIf { it.treeParent.elementType == MODIFIER_LIST }
+            ?.treeParent
+            ?.takeIf { it.treeParent.elementType == PRIMARY_CONSTRUCTOR }
+            .let { it != null }
+
+    private fun checkForAnnotationOnPrimaryConstructorToBePlacedOnSeparateLine(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+        autoCorrect: Boolean,
+    ) {
+        require(node.elementType == ANNOTATION_ENTRY)
+        require(node.treeParent.elementType == MODIFIER_LIST)
+        require(node.treeParent.treeParent.elementType == PRIMARY_CONSTRUCTOR)
+
+        val modifierList = node.treeParent
+
+        // Check if this is the first annotation and needs a newline before it
+        if (node.isFirstAnnotationEntry()) {
+            val prevLeaf = modifierList.prevLeaf { !it.isWhiteSpace() }
+            if (prevLeaf != null && !modifierList.prevLeaf().isWhiteSpaceWithNewline()) {
+                emit(
+                    node.startOffset,
+                    "Annotation on primary constructor should be placed on a separate line",
+                    true,
+                )
+                if (autoCorrect) {
+                    node
+                        .firstChildLeafOrSelf()
+                        .upsertWhitespaceBeforeMe(getNewlineWithIndentForPrimaryConstructor(modifierList))
+                }
+            }
+        }
+
+        // Check if annotation should be on separate line from other annotations on the same line
+        if (node.isPrecededByOtherAnnotationEntryOnTheSameLine()) {
+            emit(
+                node.startOffset,
+                "Annotation on primary constructor should be placed on a separate line",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .firstChildLeafOrSelf()
+                    .upsertWhitespaceBeforeMe(getNewlineWithIndentForPrimaryConstructor(modifierList))
+            }
+        }
+
+        // Check if this is the last annotation and needs a newline after it (before the constructor keyword)
+        if (node.isLastAnnotationEntry()) {
+            val constructorKeyword = modifierList
+                .treeParent
+                .findChildByType(CONSTRUCTOR_KEYWORD)
+            if (constructorKeyword != null) {
+                val prevLeaf = constructorKeyword.prevLeaf()
+                if (prevLeaf == null || !prevLeaf.isWhiteSpaceWithNewline()) {
+                    emit(
+                        constructorKeyword.startOffset,
+                        "Expected newline before 'constructor'",
+                        true,
+                    )
+                    if (autoCorrect) {
+                        constructorKeyword.upsertWhitespaceBeforeMe(getNewlineWithIndentForPrimaryConstructor(modifierList))
+                    }
+                }
+            }
+        }
+    }
+
+    private fun getNewlineWithIndentForPrimaryConstructor(modifierList: ASTNode): String {
+        // For primary constructor annotations, we need to find the indent of the class declaration
+        // and add one level of indentation
+        val primaryConstructor = modifierList.treeParent
+        val classNode = primaryConstructor.treeParent
+        val nodeBeforeClass = classNode.treePrev
+        val indentWithoutNewline =
+            nodeBeforeClass
+                ?.text
+                .orEmpty()
+                .substringAfterLast('\n')
+        return "\n".plus(indentWithoutNewline).plus(indentConfig.indent)
+    }
