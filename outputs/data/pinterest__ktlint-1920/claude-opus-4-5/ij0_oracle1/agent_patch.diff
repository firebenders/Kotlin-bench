+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.ktlint_official
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Nested
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for annotation wrapping on primary constructor when using ktlint_official code style.
+ */
+class AnnotationRulePrimaryConstructorTest {
+    private val annotationRuleAssertThat = assertThatRule { AnnotationRule() }
+
+    @Nested
+    inner class `Given ktlint_official code style` {
+        @Test
+        fun `Given a single annotation without parameter on primary constructor`() {
+            val code =
+                """
+                data class Foo @Bar constructor(private val foobar: Int)
+                """.trimIndent()
+            val formattedCode =
+                """
+                data class Foo
+                    @Bar
+                    constructor(private val foobar: Int)
+                """.trimIndent()
+            annotationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasLintViolations(
+                    LintViolation(1, 16, "Annotation on primary constructor should be placed on a separate line"),
+                    LintViolation(1, 21, "Expected newline before 'constructor'"),
+                ).isFormattedAs(formattedCode)
+        }
+
+        @Test
+        fun `Given multiple annotations on primary constructor`() {
+            val code =
+                """
+                data class Foo @Bar1 @Bar2("bar") @Bar3 @Bar4 constructor(private val foobar: Int) {
+                    fun foo(): String = "foo"
+                }
+                """.trimIndent()
+            val formattedCode =
+                """
+                data class Foo
+                    @Bar1
+                    @Bar2("bar")
+                    @Bar3
+                    @Bar4
+                    constructor(private val foobar: Int) {
+                    fun foo(): String = "foo"
+                }
+                """.trimIndent()
+            @Suppress("ktlint:argument-list-wrapping", "ktlint:max-line-length")
+            annotationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasLintViolations(
+                    LintViolation(1, 16, "Annotation on primary constructor should be placed on a separate line"),
+                    LintViolation(1, 22, "Annotation on primary constructor should be placed on a separate line"),
+                    LintViolation(1, 35, "Annotation on primary constructor should be placed on a separate line"),
+                    LintViolation(1, 41, "Annotation on primary constructor should be placed on a separate line"),
+                    LintViolation(1, 47, "Expected newline before 'constructor'"),
+                ).isFormattedAs(formattedCode)
+        }
+
+        @Test
+        fun `Given annotations already on separate lines on primary constructor`() {
+            val code =
+                """
+                data class Foo
+                    @Bar1
+                    @Bar2("bar")
+                    constructor(private val foobar: Int)
+                """.trimIndent()
+            annotationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a class with visibility modifier and annotations on primary constructor`() {
+            val code =
+                """
+                class Foo @Inject internal constructor()
+                """.trimIndent()
+            val formattedCode =
+                """
+                class Foo
+                    @Inject internal
+                    constructor()
+                """.trimIndent()
+            annotationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasLintViolations(
+                    LintViolation(1, 11, "Annotation on primary constructor should be placed on a separate line"),
+                    LintViolation(1, 28, "Expected newline before 'constructor'"),
+                ).isFormattedAs(formattedCode)
+        }
+    }
+
+    @Nested
+    inner class `Given default code style` {
+        @Test
+        fun `Given a single annotation without parameter on primary constructor is allowed`() {
+            val code =
+                """
+                class Foo @Inject internal constructor()
+                """.trimIndent()
+            annotationRuleAssertThat(code)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given multiple annotations on primary constructor without parameters reports violation`() {
+            // Note: the default code style still reports violations for multiple annotations on same line as annotated construct
+            // This is the existing behavior and is not changed by this fix
+            // The formatted code includes a space before constructor because of spacing rules
+            val code =
+                """
+                class Foo @Bar1 @Bar2 constructor()
+                """.trimIndent()
+            val formattedCode =
+                """
+                class Foo @Bar1 @Bar2
+                 constructor()
+                """.trimIndent()
+            annotationRuleAssertThat(code)
+                .hasLintViolation(1, 23, "Multiple annotations should not be placed on the same line as the annotated construct")
+                .isFormattedAs(formattedCode)
+        }
+    }
+}
