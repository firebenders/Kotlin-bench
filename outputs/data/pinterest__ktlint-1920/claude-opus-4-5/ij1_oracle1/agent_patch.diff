+    private fun ASTNode.isPrimaryConstructorAnnotation() =
+        takeIf { elementType == ANNOTATION_ENTRY }
+            ?.takeIf { it.treeParent.elementType == MODIFIER_LIST }
+            ?.treeParent
+            ?.takeIf { it.treeParent.elementType == PRIMARY_CONSTRUCTOR }
+            .let { it != null }
+
+    private fun visitPrimaryConstructorAnnotation(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+        autoCorrect: Boolean,
+    ) {
+        val expectedIndent = getNewlineWithIndentForPrimaryConstructorAnnotation(node)
+        if (node.isFirstAnnotationEntry()) {
+            // Annotation before constructor should be on separate line from class identifier:
+            //    data class Foo @Bar1 constructor()
+            // should be formatted as:
+            //    data class Foo
+            //        @Bar1
+            //        constructor()
+            node
+                .firstChildLeafOrSelf()
+                .prevLeaf()
+                ?.takeIf { it.elementType == WHITE_SPACE && !it.textContains('\n') }
+                ?.let {
+                    emit(node.startOffset, "Expected newline before annotation", true)
+                    if (autoCorrect) {
+                        node.firstChildLeafOrSelf().upsertWhitespaceBeforeMe(expectedIndent)
+                    }
+                }
+        }
+        if (node.isFollowedByOtherAnnotationEntryOnTheSameLine()) {
+            // Each annotation should be on a separate line:
+            //    data class Foo @Bar1 @Bar2 constructor()
+            // should be formatted as:
+            //    data class Foo
+            //        @Bar1
+            //        @Bar2
+            //        constructor()
+            emit(node.startOffset, "Expected each annotation to be on a separate line", true)
+            if (autoCorrect) {
+                node.lastChildLeafOrSelf().nextLeaf()?.upsertWhitespaceBeforeMe(expectedIndent)
+            }
+        }
+        if (node.isLastAnnotationEntry()) {
+            // Last annotation should be on separate line from constructor keyword (or visibility modifier):
+            //    data class Foo @Bar1 constructor()
+            //    data class Foo @Bar1 internal constructor()
+            // should be formatted as:
+            //    data class Foo
+            //        @Bar1
+            //        constructor()
+            //    data class Foo
+            //        @Bar1
+            //        internal constructor()
+            node
+                .lastChildLeafOrSelf()
+                .nextLeaf()
+                ?.takeIf { it.elementType == WHITE_SPACE && !it.textContains('\n') }
+                ?.let { whiteSpaceAfterAnnotation ->
+                    val nextCodeLeaf = whiteSpaceAfterAnnotation.nextCodeLeaf()
+                    if (nextCodeLeaf != null) {
+                        emit(nextCodeLeaf.startOffset, "Expected newline", true)
+                        if (autoCorrect) {
+                            nextCodeLeaf.upsertWhitespaceBeforeMe(expectedIndent)
+                        }
+                    }
+                }
+        }
+    }
+
+    private fun getNewlineWithIndentForPrimaryConstructorAnnotation(node: ASTNode): String {
+        // For primary constructor annotations, the indent should be computed from the CLASS element
+        // node.treeParent = MODIFIER_LIST
+        // node.treeParent.treeParent = PRIMARY_CONSTRUCTOR
+        // node.treeParent.treeParent.treeParent = CLASS
+        val classNode =
+            node
+                .treeParent
+                .treeParent
+                .treeParent
+        val nodeBeforeClass = classNode.treePrev
+        // Make sure we only insert a single newline
+        val classIndent =
+            nodeBeforeClass
+                ?.text
+                .orEmpty()
+                .substringAfterLast('\n')
+        return "\n".plus(classIndent).plus(indentConfig.indent)
+    }
+
