+    private fun wrapPrimaryConstructorAnnotationEntry(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+        autoCorrect: Boolean,
+    ) {
+        if (node.isFirstAnnotationEntry() && node.isOnSameLineAsPreviousCodeLeaf()) {
+            emit(
+                node.startOffset,
+                "Annotation should be placed on a separate line before the primary constructor",
+                true,
+            )
+            if (autoCorrect) {
+                node.upsertWhitespaceBeforeMe(node.treeParent.indent())
+            }
+        }
+
+        if (node.isPrecededByOtherAnnotationEntryOnTheSameLine()) {
+            emit(
+                node.startOffset,
+                "Annotation should be placed on a separate line before the primary constructor",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .firstChildLeafOrSelf()
+                    .upsertWhitespaceBeforeMe(node.treeParent.indent())
+            }
+        }
+
+        if (node.isLastAnnotationEntry() && node.isOnSameLineAsAnnotatedConstruct()) {
+            emit(
+                node.startOffset,
+                "Annotation should be placed on a separate line before the primary constructor",
+                true,
+            )
+            if (autoCorrect) {
+                node
+                    .lastChildLeafOrSelf()
+                    .nextCodeLeaf()
+                    ?.upsertWhitespaceBeforeMe(node.treeParent.indent())
+            }
+        }
+    }
+
+    private fun ASTNode.isPrimaryConstructorAnnotationEntry() =
+        elementType == ANNOTATION_ENTRY &&
+            treeParent.elementType == MODIFIER_LIST &&
+            treeParent.treeParent.elementType == PRIMARY_CONSTRUCTOR
+
+    private fun ASTNode.isOnSameLineAsPreviousCodeLeaf(): Boolean {
+        val previousCodeLeaf = prevCodeLeaf() ?: return false
+        return previousCodeLeaf
+            .leaves(forward = true)
+            .takeWhile { it != this }
+            .none { it.isWhiteSpaceWithNewline() }
+    }
