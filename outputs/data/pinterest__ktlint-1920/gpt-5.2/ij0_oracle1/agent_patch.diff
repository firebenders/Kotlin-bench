@@ -0,0 +1,57 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.ktlint_official
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.INDENT_SIZE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.INDENT_STYLE_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.ec4j.core.model.PropertyType.IndentStyleValue.space
+import org.junit.jupiter.api.Test
+
+class AnnotationWrappingInTypeArgumentListTest {
+    private val wrappingRuleAssertThat = assertThatRule { WrappingRule() }
+
+    @Test
+    fun `Given a type argument list containing annotated type projections then wrap the type argument list and annotations`() {
+        val code =
+            """
+            val fooBar: FooBar<String, @Foo String, @Foo @Bar String, @Bar("bar") @Foo String> = FooBar()
+            """.trimIndent()
+        val formattedCode =
+            """
+            val fooBar: FooBar<
+                String,
+                @Foo String,
+                @Foo @Bar
+                String,
+                @Bar("bar")
+                @Foo
+                String
+                > = FooBar()
+            """.trimIndent()
+
+        wrappingRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .addAdditionalRuleProvider { AnnotationRule() }
+            .addAdditionalRuleProvider { IndentationRule() }
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a type argument list in which each type projection contains at most a single annotation without parameter then do not wrap`() {
+        val code =
+            """
+            val foo1: List<@Foo String> = emptyList()
+            val foo2 = emptyList<@Foo String>()
+            val foo3: Map<@Foo String, @Foo String> = emptyMap()
+            val foo4 = emptyMap<@Foo String, @Foo String>()
+            """.trimIndent()
+
+        wrappingRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .addAdditionalRuleProvider { AnnotationRule() }
+            .addAdditionalRuleProvider { IndentationRule() }
+            .hasNoLintViolations()
+    }
+}
+

