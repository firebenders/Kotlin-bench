new file mode 100644
--- /dev/null
+++ b/test_constructor_annotations.kt
@@ -0,0 +1,32 @@
+// Test file for constructor annotations wrapper issue
+annotation class Bar1
+annotation class Bar2(val value: String)
+annotation class Bar3
+annotation class Bar4
+
+// Case 1: Data class with explicit constructor - should be wrapped
+// Before:
+// data class Foo @Bar1 @Bar2("bar") @Bar3 @Bar4 constructor(private val foobar: Int) {
+// After:
+// data class Foo
+//     @Bar1
+//     @Bar2("bar")
+//     @Bar3
+//     @Bar4
+//     constructor(private val foobar: Int) {
+data class Foo @Bar1 @Bar2("bar") @Bar3 @Bar4 constructor(private val foobar: Int) {
+    fun foo(): String = "foo"
+}
+
+// Case 2: Regular class with explicit constructor - should be wrapped
+class Bar @Bar1 @Bar2("bar") constructor(val bar: String) {
+    fun bar(): String = "bar"
+}
+
+// Case 3: Class with annotations on constructor keyword but only one annotation - should NOT be wrapped
+data class Baz @Bar1 constructor(val baz: Int)
+
+// Case 4: Type projection annotations - should be wrapped
+class FooBar<T>
+val fooBar: FooBar<String, @Bar1 @Bar2("bar") @Bar3 @Bar4 String> = FooBar()
+
