@@ -0,0 +1,22 @@
+// Test for constructor annotations issue
+annotation class Bar1
+annotation class Bar2(val value: String)
+annotation class Bar3
+annotation class Bar4
+
+// Test 1: Data class with annotations before constructor
+data class Foo @Bar1 @Bar2("bar") @Bar3 @Bar4 constructor(private val foobar: Int) {
+    fun foo(): String = "foo"
+}
+
+// Test 2: Regular class with annotations before constructor
+class Bar @Bar1 @Bar2("bar") constructor(val bar: String) {
+    fun bar(): String = "bar"
+}
+
+// Test 3: Class with implicit constructor
+data class Baz @Bar1 @Bar2("bar") constructor(private val baz: Int)
+
+// Test 4: Type projection annotations
+val fooBar: FooBar<String, @Bar1 @Bar2("bar") @Bar3 @Bar4 String> = FooBar()
+

