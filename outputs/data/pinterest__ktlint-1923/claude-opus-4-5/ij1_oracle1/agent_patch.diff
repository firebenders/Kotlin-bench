+    @Test
+    fun `Issue 1904 - Given a multiline if-else-if statement with braces then else if should not be wrapped in braces`() {
+        val code =
+            """
+            val x = if (showFilter) {
+                1
+            } else if (activeTabIndex.value == 0) {
+                2
+            } else {
+                null
+            } ?: 0
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1904 - Given a multiline if-else-if statement with braces and dotted suffix then else if should not be wrapped in braces`() {
+        val code =
+            """
+            val foo = if (bar1) {
+                "bar1"
+            } else if (bar2) {
+                "bar2"
+            } else {
+                "bar3"
+            }.plus("foo")
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
