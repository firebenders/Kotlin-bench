@@ -0,0 +1,30 @@
+fun main() {
+    val showFilter = true
+    val activeTabIndex = object {
+        val value = 0
+    }
+
+    // This should NOT be reformatted - the else if should remain as is
+    val x = if (showFilter) {
+        1
+    } else if (activeTabIndex.value == 0) {
+        2
+    } else {
+        null
+    } ?: 0
+
+    // Another example from the issue discussion
+    val foo = if (bar1) {
+        "bar1"
+    } else if (bar2) {
+        "bar2"
+    } else {
+        "bar3"
+    }.plus("foo")
+
+    println("x = $x, foo = $foo")
+}
+
+val bar1 = false
+val bar2 = true
+
