+
+    @Test
+    fun `Given a multiline if-else-if statement with curly braces should not be reformatted`() {
+        val code =
+            """
+            val x = if (showFilter) {
+                1
+            } else if (activeTabIndex.value == 0) {
+                2
+            } else {
+                null
+            } ?: 0
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline if-else-if statement followed by a chained call should not be reformatted`() {
+        val code =
+            """
+            val foo = if (bar1) {
+                "bar1"
+            } else if (bar2) {
+                "bar2"
+            } else {
+                "bar3"
+            }.plus("foo")
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
 }

