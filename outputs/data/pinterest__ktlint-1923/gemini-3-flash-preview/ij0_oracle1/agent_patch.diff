@@ -0,0 +1,57 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class MultiLineIfElseRuleReproTest {
+    private val multiLineIfElseRuleAssertThat = assertThatRule { MultiLineIfElseRule() }
+
+    @Test
+    fun `Issue 1776 - else if should stay as is`() {
+        val code =
+            """
+            val x = if (showFilter) {
+                1
+            } else if (activeTabIndex.value == 0) {
+                2
+            } else {
+                null
+            } ?: 0
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1776 - else if should stay as is 2`() {
+        val code =
+            """
+            val foo = if (bar1) {
+                "bar1"
+            } else if (bar2) {
+                "bar2"
+            } else {
+                "bar3"
+            }.plus("foo")
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `else if on new line`() {
+        val code =
+            """
+            val x = if (cond) {
+                1
+            }
+            else if (cond2) {
+                2
+            } else {
+                3
+            }
+            """.trimIndent()
+        // If this fails, it means even standard else if on new line is currently broken by this rule?
+        // Or maybe it's intended to force } else if.
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

