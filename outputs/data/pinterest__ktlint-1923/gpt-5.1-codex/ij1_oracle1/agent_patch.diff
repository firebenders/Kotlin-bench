+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/MultiLineIfElseRuleElseIfRegressionTest.kt
@@ -0,0 +1,45 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class MultiLineIfElseRuleElseIfRegressionTest {
+    private val multiLineIfElseRuleAssertThat = assertThatRule { MultiLineIfElseRule() }
+
+    @Test
+    fun `Given a multiline else-if chain with an elvis operator then do not force braces`() {
+        val code =
+            """
+            fun foo(showFilter: Boolean, activeTabIndex: Int?): Int {
+                val value =
+                    if (showFilter) {
+                        1
+                    } else if ((activeTabIndex ?: 0) == 0) {
+                        2
+                    } else {
+                        null
+                    } ?: 0
+                return value
+            }
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline else-if chain followed by a dot-qualified call then do not force braces`() {
+        val code =
+            """
+            fun foo(bar1: Boolean, bar2: Boolean): String {
+                return if (bar1) {
+                    "bar1"
+                } else if (bar2) {
+                    "bar2"
+                } else {
+                    "bar3"
+                }.plus("foo")
+            }
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

