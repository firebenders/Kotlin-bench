+    @Test
+    fun `Given a multiline if-else-if-statement with braces should not be reformatted`() {
+        val code =
+            """
+            val showFilter = true
+            val activeTabIndex = object { var value = 0 }
+
+            val x = if (showFilter) {
+                1
+            } else if (activeTabIndex.value == 0) {
+                2
+            } else {
+                null
+            } ?: 0
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline if-else-if-statement with braces and method call should not be reformatted`() {
+        val code =
+            """
+            val bar1 = true
+            val bar2 = true
+            val foo = if (bar1) {
+                "bar1"
+            } else if (bar2) {
+                "bar2"
+            } else {
+                "bar3"
+            }.plus("foo")
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
