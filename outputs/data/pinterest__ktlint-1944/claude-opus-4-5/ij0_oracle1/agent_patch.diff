+
+    private fun isBlockCommentInSingleLineBlock(
+        precedingLeaf: ASTNode?,
+        followingLeaf: ASTNode?,
+    ): Boolean {
+        val actualPreceding =
+            if (precedingLeaf?.elementType == WHITE_SPACE) {
+                precedingLeaf.prevLeaf()
+            } else {
+                precedingLeaf
+            }
+        val actualFollowing =
+            if (followingLeaf?.elementType == WHITE_SPACE) {
+                followingLeaf.nextLeaf()
+            } else {
+                followingLeaf
+            }
+        return actualPreceding?.elementType == LBRACE && actualFollowing?.elementType == RBRACE
+    }
