+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class CommentWrappingRuleSingleLineBlockTest {
+    private val commentWrappingRuleAssertThat = assertThatRule { CommentWrappingRule() }
+
+    @Test
+    fun `Given a single line block containing only a block comment then do not report a violation`() {
+        val code =
+            """
+            val foo = { /* no-op */ }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a single line block containing only a block comment without spaces then do not report a violation`() {
+        val code =
+            """
+            val foo = {/* no-op */}
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an empty lambda with a block comment then do not report a violation`() {
+        val code =
+            """
+            fun foo(bar: () -> Unit) {}
+            fun test() {
+                foo { /* no-op */ }
+            }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function with a block comment inside the body then do not report a violation`() {
+        val code =
+            """
+            fun foo() { /* no-op */ }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

