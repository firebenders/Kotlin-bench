+    @Test
+    fun `Given a block comment inside a single line lambda then do not reformat`() {
+        val code =
+            """
+            val foo = { /* no-op */ }
+            val bar = { /* some comment */ println("hello") }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a block comment inside a multiline lambda then reformat normally`() {
+        val code =
+            """
+            val foo = {
+                /* some comment */ println("hello")
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            val foo = {
