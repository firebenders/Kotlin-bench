+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class CommentWrappingRuleTestSingleLineBlock {
+    private val commentWrappingRuleAssertThat = assertThatRule { CommentWrappingRule() }
+
+    @Test
+    fun `Given a single line block containing only a block comment then do not report violation`() {
+        val code =
+            """
+            val foo = { /* no-op */ }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a single line block with a block comment as a lambda parameter then do not report violation`() {
+        val code =
+            """
+            fun test() {
+                val callback = { /* empty */ }
+            }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given multiple single line blocks with block comments then do not report violations`() {
+        val code =
+            """
+            val foo = { /* no-op */ }
+            val bar = { /* comment */ }
+            val baz = { /* another comment */ }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a single line block with block comment in a function call then do not report violation`() {
+        val code =
+            """
+            fun test() {
+                someFunction { /* empty implementation */ }
+            }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a block comment between braces with newlines then still report violation`() {
+        val code =
+            """
+            val foo = { /*
+            multiline comment
+            */ }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                1,
+                13,
+                "A block comment starting on same line as another element and ending on another line before another element is disallowed",
+            )
+    }
+
+    @Test
+    fun `Given a block comment with additional code inside braces then still report violation`() {
+        val code =
+            """
+            val foo = { println("test") /* comment */ }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                1,
+                29,
+                "A block comment in between other elements on the same line is disallowed",
+            )
+    }
+}
+

