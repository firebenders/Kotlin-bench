@@ -0,0 +1,37 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class CommentWrappingRuleReproTest {
+    private val commentWrappingRuleAssertThat = assertThatRule { CommentWrappingRule() }
+
+    @Test
+    fun `Given a single line block containing a block comment then do not wrap this comment`() {
+        val code =
+            """
+            val foo = { /* no-op */ }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a single line if-statement containing a block comment then do not wrap this comment`() {
+        val code =
+            """
+            val foo = if (true) { /* no-op */ } else { /* no-op */ }
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a block comment between other elements on the same line then do wrap this comment`() {
+val code =
+            """
+            val foo = /* comment */ "bar"
+            """.trimIndent()
+        commentWrappingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(1, 11, "A block comment in between other elements on the same line is disallowed")
+    }
+}
+

