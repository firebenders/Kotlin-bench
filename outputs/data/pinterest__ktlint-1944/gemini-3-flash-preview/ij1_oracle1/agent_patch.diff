+    private fun ASTNode.isInsideSingleLineBlock(): Boolean {
+        val prevCodeLeaf = prevCodeLeaf() ?: return false
+        val nextCodeLeaf = nextCodeLeaf() ?: return false
+        return prevCodeLeaf.elementType == LBRACE &&
+            nextCodeLeaf.elementType == RBRACE &&
+            !hasNewLineInClosedRange(prevCodeLeaf, nextCodeLeaf)
+    }
