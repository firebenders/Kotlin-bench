+    private fun ASTNode.isSingleLineBlockCommentWithoutOtherCode(): Boolean {
+        val blockNode = treeParent?.takeIf { it.elementType == BLOCK } ?: return false
+        if (blockNode.textContains('\n')) {
+            return false
+        }
+        return blockNode.children().all { child ->
+            when (child.elementType) {
+                LBRACE, RBRACE -> true
+                WHITE_SPACE -> !child.textContains('\n')
+                else -> child == this
+            }
+        }
+    }
