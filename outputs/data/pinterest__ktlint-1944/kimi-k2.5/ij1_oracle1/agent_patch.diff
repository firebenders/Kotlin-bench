+    private fun ASTNode.isInsideSingleLineBlock(): Boolean {
+        // Check if the comment is inside a block (e.g. lambda, function literal)
+        val blockParent = this.parent(BLOCK, strict = false) ?: this.parent(FUNCTION_LITERAL, strict = false)
+        return if (blockParent != null) {
+            // Check if the block is a single line block (no newlines inside)
+            !blockParent.textContains('\n')
+        } else {
+            // Also check if the comment is directly inside braces without a BLOCK node
+            // This handles cases like: val foo = { /* no-op */ }
+            val prevLeaf = this.prevLeaf()
+            val nextLeaf = this.nextLeaf()
+            prevLeaf?.elementType == LBRACE && nextLeaf?.elementType == RBRACE
+        }
+    }
