+    /**
+     * Checks if a block comment is inside a single-line block.
+     * For example, in `val foo = { /* comment */ }`, the block comment is inside a single-line block.
+     */
+    private fun isBlockCommentInsideSingleLineBlock(blockCommentNode: ASTNode): Boolean {
+        val blockNode = blockCommentNode.treeParent?.takeIf { it.elementType == BLOCK } ?: return false
+
+        // Check if the entire block content is on a single line (no newlines in block content)
+        if (blockNode.textContains('\n')) {
+            return false
+        }
+
+        // The comment is inside a single-line block
+        return true
