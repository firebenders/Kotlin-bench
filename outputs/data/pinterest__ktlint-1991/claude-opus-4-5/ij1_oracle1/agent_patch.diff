diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoConsecutiveBlankLinesRuleNpeTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoConsecutiveBlankLinesRuleNpeTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoConsecutiveBlankLinesRuleNpeTest.kt
@@ -0,0 +1,71 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+/**
+ * Test for NPE fix when a class without body is followed by consecutive blank lines at end of file.
+ * See: https://github.com/pinterest/ktlint/issues/...
+ */
+class NoConsecutiveBlankLinesRuleNpeTest {
+    private val noConsecutiveBlankLinesRuleAssertThat = assertThatRule { NoConsecutiveBlankLinesRule() }
+
+    @Test
+    fun `Given a sealed class without body followed by consecutive blank lines at end of file then do not throw NPE`() {
+        val code =
+            """
+            sealed class Hello
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            sealed class Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a class without body followed by consecutive blank lines at end of file then do not throw NPE`() {
+        val code =
+            """
+            class Foo
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Foo
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an interface without body followed by consecutive blank lines at end of file then do not throw NPE`() {
+        val code =
+            """
+            interface Bar
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            interface Bar
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+}
+

