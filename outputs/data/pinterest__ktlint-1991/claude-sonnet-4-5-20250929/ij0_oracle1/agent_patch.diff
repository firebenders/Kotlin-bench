+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoConsecutiveBlankLinesRuleNPETest.kt
@@ -0,0 +1,105 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class NoConsecutiveBlankLinesRuleNPETest {
+    private val noConsecutiveBlankLinesRuleAssertThat = assertThatRule { NoConsecutiveBlankLinesRule() }
+
+    @Test
+    fun `Given a sealed class without body and consecutive blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            sealed class Hello
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            sealed class Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a class without body and consecutive blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            class Hello
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an interface without body and consecutive blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            interface Hello
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            interface Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an object without body and consecutive blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            object Hello
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            object Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a data class without body and consecutive blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            data class Hello(val name: String)
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            data class Hello(val name: String)
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+}
+

