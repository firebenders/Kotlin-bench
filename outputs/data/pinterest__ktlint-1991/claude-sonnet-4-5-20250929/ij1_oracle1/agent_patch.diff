+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoConsecutiveBlankLinesRuleNpeTest.kt
@@ -0,0 +1,105 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+/**
+ * Test to verify NPE fix for consecutive blank lines at end of file with class without body
+ * https://github.com/pinterest/ktlint/issues/xxxx
+ */
+class NoConsecutiveBlankLinesRuleNpeTest {
+    private val noConsecutiveBlankLinesRuleAssertThat = assertThatRule { NoConsecutiveBlankLinesRule() }
+
+    @Test
+    fun `Given consecutive blank lines at end of file after sealed class without body then should not throw NPE`() {
+        val code =
+            """
+            sealed class Hello
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            sealed class Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given consecutive blank lines at end of file after class without body then should not throw NPE`() {
+        val code =
+            """
+            class Hello
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given consecutive blank lines at end of file after interface without body then should not throw NPE`() {
+        val code =
+            """
+            interface Hello
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            interface Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given consecutive blank lines at end of file after data class without body then should not throw NPE`() {
+        val code =
+            """
+            data class Hello(val name: String)
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            data class Hello(val name: String)
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given three or more consecutive blank lines at end of file after class without body then should not throw NPE`() {
+        val code =
+            """
+            sealed class Hello
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            sealed class Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+}
+

