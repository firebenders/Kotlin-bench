diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoConsecutiveBlankLinesRuleReproductionTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoConsecutiveBlankLinesRuleReproductionTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/NoConsecutiveBlankLinesRuleReproductionTest.kt
@@ -0,0 +1,22 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class NoConsecutiveBlankLinesRuleReproductionTest {
+    private val noConsecutiveBlankLinesRuleAssertThat = assertThatRule { NoConsecutiveBlankLinesRule() }
+
+    @Test
+    fun `Given a class without body followed by consecutive blank lines at end of file then do not throw NPE`() {
+        val code =
+            """
+            sealed class Hello
+
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Needless blank line(s)")
+            .isFormattedAs("sealed class Hello\n")
+    }
+}
+

