+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+/**
+ * Test for NPE fix on consecutive blank lines at end of file with class without body.
+ * This test verifies that the rule handles the edge case where treeNext is null
+ * when checking if we're between a class and primary constructor.
+ */
+class NoConsecutiveBlankLinesRuleNPETest {
+    private val noConsecutiveBlankLinesRuleAssertThat = assertThatRule { NoConsecutiveBlankLinesRule() }
+
+    @Test
+    fun `Given a sealed class without body followed by blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            sealed class Hello
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            sealed class Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(2, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a class without body followed by three blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            sealed class Hello
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            sealed class Hello
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(2, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an abstract class without body followed by blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            abstract class MyAbstractClass
+
+
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            abstract class MyAbstractClass
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(2, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a data class without body followed by blank lines at EOF should not throw NPE`() {
+        val code =
+            """
+            data class User(val name: String)
+
+            """.trimIndent()
+        val formattedCode =
+            """
+            data class User(val name: String)
+
+            """.trimIndent()
+        noConsecutiveBlankLinesRuleAssertThat(code)
+            .hasLintViolation(2, 1, "Needless blank line(s)")
+            .isFormattedAs(formattedCode)
+    }
+}
+
