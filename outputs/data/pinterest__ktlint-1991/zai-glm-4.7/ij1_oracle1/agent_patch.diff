+#!/bin/bash
+
+# Create test file with the exact issue from the bug report
+cat > /tmp/dummy.kt << 'EOF'
+sealed class Hello
+
+
+
+EOF
+
+echo "Running ktlint on the test file that previously caused NPE..."
+./ktlint-cli/build/install/ktlint/bin/ktlint /tmp/dummy.kt
+
+EXIT_CODE=$?
+
+if [ $EXIT_CODE -eq 0 ]; then
+    echo "✓ SUCCESS: No NPE occurred!"
+else
+    echo "Note: Exit code $EXIT_CODE (may report violations, but should not crash with NPE)"
+fi
+
+echo ""
+echo "Test completed."
+

