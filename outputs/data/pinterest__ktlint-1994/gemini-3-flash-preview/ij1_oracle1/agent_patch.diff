+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.android_studio
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+internal class IndentationRuleReproTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Issue 1928 - Starting a line with || causes internal error from ktlint --format`() {
+        val code =
+            """
+            package com.my.lint.rules
+
+            import com.pinterest.ktlint.rule.engine.core.api.Rule
+            import com.pinterest.ktlint.rule.engine.core.api.RuleId
+            import org.jetbrains.kotlin.com.intellij.lang.ASTNode
+
+            class BreakKtlintFormatRule : Rule(
+                RuleId("my-ruleset:my-rule-id"),
+                Rule.About(maintainer = "Me", repositoryUrl = "repositoryUrl", issueTrackerUrl = "issueTrackerUrl")
+            ) {
+
+                override fun beforeVisitChildNodes(
+                    node: ASTNode,
+                    autoCorrect: Boolean,
+                    emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit
+                ) {
+
+                    if (node.text.contains("this")
+                        || node.text.contains("that")
+                    ) {
+                        emit(node.startOffset, "My violation detail", false)
+                    }
+                }
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            package com.my.lint.rules
+
+            import com.pinterest.ktlint.rule.engine.core.api.Rule
+            import com.pinterest.ktlint.rule.engine.core.api.RuleId
+            import org.jetbrains.kotlin.com.intellij.lang.ASTNode
+
+            class BreakKtlintFormatRule : Rule(
+                RuleId("my-ruleset:my-rule-id"),
+                Rule.About(maintainer = "Me", repositoryUrl = "repositoryUrl", issueTrackerUrl = "issueTrackerUrl")
+            ) {
+
+                override fun beforeVisitChildNodes(
+                    node: ASTNode,
+                    autoCorrect: Boolean,
+                    emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit
+                ) {
+
+                    if (node.text.contains("this") ||
+                        node.text.contains("that")
+                    ) {
+                        emit(node.startOffset, "My violation detail", false)
+                    }
+                }
+            }
+            """.trimIndent()
+        // It should not crash
+        indentationRuleAssertThat(code)
+            .addAdditionalRuleProvider { ChainWrappingRule() }
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to android_studio)
+            .isFormattedAs(formattedCode)
+    }
+}
+

