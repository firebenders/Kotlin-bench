diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleOrOrRegressionTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleOrOrRegressionTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleOrOrRegressionTest.kt
@@ -0,0 +1,25 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+internal class IndentationRuleOrOrRegressionTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Given an if condition where a line starts with ||`() {
+        val code =
+            """
+            fun foo(text: String) {
+                if (text.contains("this")
+                    || text.contains("that")
+                ) {
+                    // no-op
+                }
+            }
+            """.trimIndent()
+
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

