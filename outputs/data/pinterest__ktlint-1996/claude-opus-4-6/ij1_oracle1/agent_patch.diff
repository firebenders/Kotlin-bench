+    private fun ASTNode.isRawStringLiteralFunctionBodyExpression(): Boolean {
+        if (prevLeaf()?.elementType == WHITE_SPACE && prevLeaf()?.text != " ") {
+            return false
+        }
+        val eq = prevCodeLeaf()?.takeIf { it.elementType == EQ } ?: return false
+        val funNode = eq.treeParent?.takeIf { it.elementType == FUN } ?: return false
+        // Only apply the extra indent correction when the function signature spans multiple lines
+        // (i.e., there is a newline between the 'fun' keyword and the opening quotes). This ensures
+        // single-line function expressions like 'fun foo() = """..."""' are treated consistently
+        // with property declarations like 'val foo = """..."""'.
+        return funNode
+            .firstChildLeafOrSelf()
+            .leaves()
+            .takeWhile { it != this.firstChildLeafOrSelf() }
+            .any { it.isWhiteSpaceWithNewline() }
+    }
 
     private fun ASTNode.isRawStringLiteralReturnInFunctionBodyBlock() = RETURN_KEYWORD == prevCodeLeaf()?.elementType
 

