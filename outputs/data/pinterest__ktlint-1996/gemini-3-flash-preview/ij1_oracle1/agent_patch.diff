+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.MULTILINE_STRING_QUOTE
+import org.junit.jupiter.api.Test
+
+internal class IndentationRuleReproTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Issue 2003 - fun foo() = multiline string - indented`() {
+        val code =
+            """
+            fun foo() = $MULTILINE_STRING_QUOTE
+                <!--suppress XmlUnusedNamespaceDeclaration -->
+                <manifest xmlns:android="http://schemas.android.com/apk/res/android"/>
+                $MULTILINE_STRING_QUOTE.trimIndent()
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 2003 - val foo = multiline string - indented`() {
+        val code =
+            """
+            val foo = $MULTILINE_STRING_QUOTE
+                <!--suppress XmlUnusedNamespaceDeclaration -->
+                <manifest xmlns:android="http://schemas.android.com/apk/res/android"/>
+                $MULTILINE_STRING_QUOTE.trimIndent()
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 2003 - property getter = multiline string - indented`() {
+        val code =
+            """
+            val foo: String
+                get() = $MULTILINE_STRING_QUOTE
+                    <!--suppress XmlUnusedNamespaceDeclaration -->
+                    <manifest xmlns:android="http://schemas.android.com/apk/res/android"/>
+                    $MULTILINE_STRING_QUOTE.trimIndent()
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
