diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleReproduceTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleReproduceTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleReproduceTest.kt
@@ -0,0 +1,49 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import com.pinterest.ktlint.test.MULTILINE_STRING_QUOTE
+import org.junit.jupiter.api.Test
+
+class IndentationRuleReproduceTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Case 1 - Function body expression - should pass`() {
+        val code = """
+            fun foo() = $MULTILINE_STRING_QUOTE
+                <!--suppress XmlUnusedNamespaceDeclaration -->
+                <manifest xmlns:android="http://schemas.android.com/apk/res/android"/>
+            $MULTILINE_STRING_QUOTE.trimIndent()
+        """.trimIndent()
+        indentationRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Case 2 - Function return - should pass`() {
+        val code = """
+            fun foo2(): String {
+                return $MULTILINE_STRING_QUOTE
+                    <!--suppress XmlUnusedNamespaceDeclaration -->
+                    <manifest xmlns:android="http://schemas.android.com/apk/res/android"/>
+                $MULTILINE_STRING_QUOTE.trimIndent()
+            }
+        """.trimIndent()
+        indentationRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Case 4 - Property with indented closing quotes - should pass`() {
+        val code = """
+            val foo = $MULTILINE_STRING_QUOTE
+                <!--suppress XmlUnusedNamespaceDeclaration -->
+                <manifest xmlns:android="http://schemas.android.com/apk/res/android"/>
+                $MULTILINE_STRING_QUOTE.trimIndent()
+        """.trimIndent()
+        indentationRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+}
+

