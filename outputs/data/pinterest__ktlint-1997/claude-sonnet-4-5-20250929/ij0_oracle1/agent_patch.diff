+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class Issue1756Test {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Issue 1756 - Format lambda parameters on multiple lines with non-ktlint_official code style`() {
+        val code =
+            """
+            fun combine(a: Any, b: Any, c: (Any, Any) -> Unit) {
+                c(a, b)
+            }
+
+            class Foo {
+                fun foo() {
+                    combine(
+                        Any(),
+                        Any()
+                    ) { a,
+                              b ->
+                        TODO()
+                    }
+                }
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun combine(a: Any, b: Any, c: (Any, Any) -> Unit) {
+                c(a, b)
+            }
+
+            class Foo {
+                fun foo() {
+                    combine(
+                        Any(),
+                        Any()
+                    ) { a,
+                            b ->
+                        TODO()
+                    }
+                }
+            }
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.intellij_idea)
+            .hasLintViolation(11, 1, "Unexpected indentation (18) (should be 16)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1756 - Format lambda parameters on multiple lines with ktlint_official code style`() {
+        val code =
+            """
+            fun combine(a: Any, b: Any, c: (Any, Any) -> Unit) {
+                c(a, b)
+            }
+
+            class Foo {
+                fun foo() {
+                    combine(
+                        Any(),
+                        Any()
+                    ) { a,
+                              b ->
+                        TODO()
+                    }
+                }
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun combine(a: Any, b: Any, c: (Any, Any) -> Unit) {
+                c(a, b)
+            }
+
+            class Foo {
+                fun foo() {
+                    combine(
+                        Any(),
+                        Any()
+                    ) { a,
+                            b ->
+                        TODO()
+                    }
+                }
+            }
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.ktlint_official)
+            .hasLintViolation(11, 1, "Unexpected indentation (18) (should be 16)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1756 - Lambda on same line as function call with arguments should use double indent for intellij_idea`() {
+        val code =
+            """
+            fun combine(a: Any, b: Any, c: (Any, Any) -> Unit) = Unit
+
+            fun foo() {
+                combine(Any(), Any()) { a,
+                                        b ->
+                    TODO()
+                }
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun combine(a: Any, b: Any, c: (Any, Any) -> Unit) = Unit
+
+            fun foo() {
+                combine(Any(), Any()) { a,
+                        b ->
+                    TODO()
+                }
+            }
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.intellij_idea)
+            .hasLintViolation(5, 1, "Unexpected indentation (28) (should be 12)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1756 - Lambda with parameters on newline after opening brace for intellij_idea`() {
+        val code =
+            """
+            fun combine(a: Any, b: Any, c: (Any, Any) -> Unit) = Unit
+
+            fun foo() {
+                combine(
+                    Any(),
+                    Any()
+                ) {
+                        a,
+                        b ->
+                    TODO()
+                }
+            }
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to CodeStyleValue.intellij_idea)
+            .hasNoLintViolations()
+    }
+}
