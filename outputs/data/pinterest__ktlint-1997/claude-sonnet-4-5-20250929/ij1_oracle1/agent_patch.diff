+    private fun ASTNode.isFirstParameterOfFunctionLiteralPrecededByNewLine(): Boolean {
+        val valueParameterList = parent(FUNCTION_LITERAL)?.findChildByType(VALUE_PARAMETER_LIST) ?: return false
+
+        // Check if there's a newline before the parameter list
+        if (valueParameterList.prevSibling { it.textContains('\n') } != null) {
+            return true
+        }
+
+        // OR if the parameter list spans multiple lines AND the function call arguments also span multiple lines
+        // (in which case alignment calculation won't work correctly)
+        if (valueParameterList.textContains('\n')) {
+            val callExpression = parent(CALL_EXPRESSION)
+            // Check if the VALUE_ARGUMENT_LIST (function arguments before the lambda) contains newlines
+            if (callExpression?.findChildByType(VALUE_ARGUMENT_LIST)?.textContains('\n') == true) {
+                return true
+            }
+        }
+
+        return false
+    }
 
