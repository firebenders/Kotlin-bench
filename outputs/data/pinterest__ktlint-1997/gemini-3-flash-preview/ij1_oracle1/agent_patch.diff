+    private fun ASTNode.isFunctionLiteralPrecededByNewLine(): Boolean {
+        val lbrace = parent(FUNCTION_LITERAL)?.findChildByType(LBRACE) ?: return false
+        val referenceExpression = parent(CALL_EXPRESSION)?.findChildByType(REFERENCE_EXPRESSION) ?: return false
+        var leaf = lbrace.prevLeaf()
+        while (leaf != null && leaf != referenceExpression) {
+            if (leaf.isWhiteSpaceWithNewline()) {
+                return true
+            }
+            leaf = leaf.prevLeaf()
+        }
+        return false
+    }
