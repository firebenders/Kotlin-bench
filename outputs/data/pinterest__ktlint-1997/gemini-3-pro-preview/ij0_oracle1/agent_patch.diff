+    private fun ASTNode.columnOnLine(): Int {
+        var leaf = this.prevLeaf()
+        var offset = 0
+        while (leaf != null) {
+            val text = leaf.text
+            val lastNewline = text.lastIndexOf('\n')
+            if (lastNewline != -1) {
+                offset += text.length - lastNewline - 1
+                return offset
+            }
+            offset += text.length
+            leaf = leaf.prevLeaf()
+        }
+        return offset
+    }
