+            //
+            // In case of a trailing lambda, the call expression (REFERENCE_EXPRESSION) might not be on the same line as
+            // the opening brace (e.g. "foo(\n ...\n) { a,\n b ->"). In those cases, align subsequent parameters with the
+            // first parameter based on its position on the line containing the opening brace.
+            parent(FUNCTION_LITERAL)
+                ?.let { functionLiteral ->
+                    val lbraceIndent = functionLiteral.findChildByType(LBRACE)?.indent(false).orEmpty()
+                    val firstParameter =
+                        functionLiteral
+                            .findChildByType(VALUE_PARAMETER_LIST)
+                            ?.findChildByType(VALUE_PARAMETER)
+                    firstParameter
+                        ?.let {
+                            val additionalIndent = (it.column - 1 - lbraceIndent.length).coerceAtLeast(0)
+                            " ".repeat(additionalIndent)
+                        }
                 }
+                ?: parent(CALL_EXPRESSION)
+                    ?.let { callExpression ->
+                        val textBeforeFirstParameter =
+                            callExpression.findChildByType(REFERENCE_EXPRESSION)?.text +
+                                " { "
+                        " ".repeat(textBeforeFirstParameter.length)
+                    }
                 ?: indentConfig.indent.repeat(2)
         }
 

