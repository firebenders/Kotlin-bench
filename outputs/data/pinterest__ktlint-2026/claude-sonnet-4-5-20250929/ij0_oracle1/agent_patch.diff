--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyNamingRuleEdgeCasesTest.kt
@@ -0,0 +1,97 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+class PropertyNamingRuleEdgeCasesTest {
+    private val propertyNamingRuleAssertThat =
+        KtLintAssertThat.assertThatRule { PropertyNamingRule() }
+
+    @Test
+    fun `Given property with multiple annotations on getter then do not emit`() {
+        val code =
+            """
+            import android.annotation.SuppressLint
+
+            val foo @Deprecated("test") @SuppressLint("WrongConstant") get() = "bar"
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given property with annotation and modifier on getter then do not emit`() {
+        val code =
+            """
+            import android.annotation.SuppressLint
+
+            class Foo {
+                val bar @SuppressLint("WrongConstant") private get() = "baz"
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given property with getter but no annotation should follow naming rules`() {
+        val code =
+            """
+            val FOO_BAR get() = "bar"
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given top-level val without getter should emit`() {
+        val code =
+            """
+            val foo = "bar"
+            """.trimIndent()
+        @Suppress("ktlint:argument-list-wrapping", "ktlint:max-line-length")
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(1, 5, "Property name should use the screaming snake case notation when the value can not be changed")
+    }
+
+    @Test
+    fun `Given companion object property with annotation on getter should not emit`() {
+        val code =
+            """
+            import android.annotation.SuppressLint
+
+            class Foo {
+                companion object {
+                    val myProperty @SuppressLint("test") get() = "value"
+                }
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given companion object property without getter should emit`() {
+        val code =
+            """
+            class Foo {
+                companion object {
+                    val myProperty = "value"
+                }
+            }
+            """.trimIndent()
+        @Suppress("ktlint:argument-list-wrapping", "ktlint:max-line-length")
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(3, 13, "Property name should use the screaming snake case notation when the value can not be changed")
+    }
+
+    @Test
+    fun `Given property with getter on new line with annotation should not emit`() {
+        val code =
+            """
+            import android.annotation.SuppressLint
+
+            val foo
+                @SuppressLint("test")
+                get() = "bar"
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

