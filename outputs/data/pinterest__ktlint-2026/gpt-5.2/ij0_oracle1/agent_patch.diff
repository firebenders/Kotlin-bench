+    private fun ASTNode.hasCustomGetter(): Boolean {
+        val propertyAccessors = children().filter { it.elementType == PROPERTY_ACCESSOR }
+        return propertyAccessors.any { propertyAccessor ->
+            propertyAccessor.isGetterAccessor() && propertyAccessor.hasBody()
+        }
+    }
+
+    private fun ASTNode.isGetterAccessor(): Boolean =
+        children().any { it.elementType == GET_KEYWORD }
+
+    private fun ASTNode.hasBody(): Boolean =
+        children().any { it.elementType == EQ || it.elementType == BLOCK }
 
     private fun ASTNode.hasConstModifier() = hasModifier(CONST_KEYWORD)
 

