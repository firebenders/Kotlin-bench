+class Context {
+    companion object {
+        const val SYSTEM_SERVICE_AD_DELEGATE_FACTORY = "ads_delegate_factory"
+    }
+}
+
+class AdsDelegateFactory
+
+// Test case 1: Extension property with annotation and custom getter
+val Context.adsDelegateFactory @SuppressLint("WrongConstant") get() =
+    applicationContext.getSystemService(SYSTEM_SERVICE_AD_DELEGATE_FACTORY) as AdsDelegateFactory
+
+// Test case 2: Extension property with private modifier and custom getter
+val Context.adsDelegateFactory2 private get() =
+    applicationContext.getSystemService(SYSTEM_SERVICE_AD_DELEGATE_FACTORY) as AdsDelegateFactory
+
+// Test case 3: Extension property with custom getter (no annotation/modifier)
+val Context.adsDelegateFactory3 get() =
+    applicationContext.getSystemService(SYSTEM_SERVICE_AD_DELEGATE_FACTORY) as AdsDelegateFactory
+
+// Test case 4: Regular top-level val without custom getter
+val TOP_LEVEL_VAL = "test"
+
+// Test case 5: Regular top-level val with custom getter
+val TOP_LEVEL_VAL_WITH_GETTER get() = "test"
+
+@Suppress("WrongConstant")
+annotation class SuppressLint(val value: String)
+
