@@ -0,0 +1,83 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.EOL_CHAR
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.MAX_LINE_LENGTH_MARKER
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class FunctionSignatureRuleAnnotationTest {
+    private val functionSignatureRuleAssertThat = assertThatRule { FunctionSignatureRule() }
+
+    @Test
+    fun `Given a function with annotated body expression should not merge with function signature`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                                                       $EOL_CHAR
+            private fun getErrorMessage(value: String): String =
+                    @Suppress("DEPRECATION")
+                    "some-value"
+            """.trimIndent()
+
+        // The function signature rule should not suggest merging the annotation with the signature
+        // as that would violate the annotation rule
+        functionSignatureRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function with non-annotated body expression should merge with function signature when it fits`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                                                       $EOL_CHAR
+            private fun getErrorMessage(value: String): String =
+                    "some-value"
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                                                       $EOL_CHAR
+            private fun getErrorMessage(value: String): String = "some-value"
+            """.trimIndent()
+
+        // Without annotation, it should merge when it fits
+        functionSignatureRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasLintViolation(2, 53, "First line of body expression fits on same line as function signature")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 2028 - Given a function with annotated body expression should not merge with function signature`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                                                       $EOL_CHAR
+            private fun getErrorMessage(value: String): String =
+                    @Suppress("DEPRECATION")
+                    customMessage.takeUnless { it.isEmpty() } ?: DEFAULT_ERROR_MESSAGE
+            """.trimIndent()
+
+        // The function signature rule should not suggest merging the annotation with the signature
+        // This was the original issue reported in #2028
+        functionSignatureRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function with multiple annotations on body expression should not merge with function signature`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                                                       $EOL_CHAR
+            private fun getErrorMessage(value: String): String =
+                    @Suppress("DEPRECATION")
+                    @OptIn(ExperimentalApi::class)
+                    "some-value"
+            """.trimIndent()
+
+        // Should not merge even with multiple annotations
+        functionSignatureRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasNoLintViolations()
+    }
+}
+

