+    private fun List<ASTNode>.startsWithAnnotation(): Boolean =
+        this
+            .firstOrNull()
+            ?.let { firstNode ->
+                // Check if the first node itself is an annotation node
+                firstNode.elementType == ANNOTATION || firstNode.elementType == ANNOTATION_ENTRY ||
+                    // Or check if the first node is a leaf that belongs to an annotation
+                    firstNode.isPartOfAnnotation()
+            }
+            ?: false
+
+    private fun ASTNode.isPartOfAnnotation(): Boolean {
+        var current: ASTNode? = this
+        while (current != null) {
+            if (current.elementType == ANNOTATION || current.elementType == ANNOTATION_ENTRY) {
+                return true
+            }
+            // Stop if we reach a FUN node or certain other boundary nodes
+            if (current.elementType == FUN) {
+                return false
+            }
+            current = current.treeParent
+        }
+        return false
