@@ -0,0 +1,38 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.android
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class FunctionSignatureRuleReproTest {
+    private val functionSignatureRuleAssertThat = assertThatRule { FunctionSignatureRule() }
+
+    @Test
+    fun `Do not merge annotated expression with function signature`() {
+        val code =
+            """
+            private fun getErrorMessage(value: String): String =
+                @Suppress("DEPRECATION")
+                customMessage.takeUnless { it.isEmpty() } ?: String.format(DEFAULT_ERROR_MESSAGE_WITH_NO_REASON, value)
+            """.trimIndent()
+        functionSignatureRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to android)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to "100")
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Do not wrap annotated expression body if it is already on the same line`() {
+        val code =
+            """
+            fun foo() = @Suppress("DEPRECATION") bar()
+            """.trimIndent()
+        functionSignatureRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to android)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to "100")
+            .hasNoLintViolations()
+    }
+}
+

