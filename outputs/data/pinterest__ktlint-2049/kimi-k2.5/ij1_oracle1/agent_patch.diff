+    private fun ASTNode.startsWithAnnotatedExpression(): Boolean {
+        // Check if the function body expression starts with an annotated expression.
+        // This is important because merging an annotated expression with the function signature
+        // would violate the annotation rule which expects annotations to be on separate lines.
+        // The body expression is the next code sibling of the EQ node.
+        return findChildByType(EQ)
+            ?.nextCodeSibling()
+            ?.elementType == ANNOTATED_EXPRESSION
+    }
