+const val DEFAULT_ERROR_MESSAGE_WITH_NO_REASON = "Error %s"
+
+class Foo {
+    private val customMessage = ""
+    private val anotherMessage = ""
+
+    // Case 1: Annotated expression with newline (incorrectly merged)
+    private fun getErrorMessage(value: String): String =
+        @Suppress("DEPRECATION")
+        customMessage.takeUnless { it.isEmpty() } ?: String.format(DEFAULT_ERROR_MESSAGE_WITH_NO_REASON, value)
+
+    // Case 2: Simple expression (should be merged if it fits)
+    private fun getErrorMessage2(value: String): String =
+        anotherMessage.takeUnless { it.isEmpty() } ?: String.format(DEFAULT_ERROR_MESSAGE_WITH_NO_REASON, value)
+}
+

