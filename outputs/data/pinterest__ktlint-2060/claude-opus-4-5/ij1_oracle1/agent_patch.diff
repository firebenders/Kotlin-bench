@@ -229,9 +229,18 @@ public class ParameterListWrappingRule :
             LPAR -> {
                 val prevLeaf = child.prevLeaf()
                 if (prevLeaf is PsiWhiteSpace && prevLeaf.textContains('\n')) {
-                    emit(child.startOffset, errorMessage(child), true)
-                    if (autoCorrect) {
-                        prevLeaf.delete()
+                    // Check if this whitespace is part of nullable type wrapping.
+                    // In that case, the structure is: NULLABLE_TYPE -> LPAR -> WHITESPACE -> FUNCTION_TYPE -> VALUE_PARAMETER_LIST -> LPAR
+                    // The whitespace is between the outer LPAR and FUNCTION_TYPE, so we shouldn't flag the inner LPAR.
+                    val prevPrevLeaf = prevLeaf.prevLeaf()
+                    val isNullableTypeWrapping =
+                        prevPrevLeaf?.elementType == LPAR &&
+                            prevPrevLeaf.treeParent?.elementType == NULLABLE_TYPE
+                    if (!isNullableTypeWrapping) {
+                        emit(child.startOffset, errorMessage(child), true)
+                        if (autoCorrect) {
+                            prevLeaf.delete()
+                        }
                     }
                 }
             }
