--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/ParameterListWrappingRuleIssue1324Test.kt
@@ -0,0 +1,140 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.RuleProvider
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for issue 1324: Bug on parameter's class that reached maximum line
+ *
+ * When a nullable function type exceeds the max line length, the rule should:
+ * 1. Wrap the nullable type correctly
+ * 2. NOT report "Unnecessary newline before "("" for the inner function type's LPAR
+ */
+class ParameterListWrappingRuleIssue1324Test {
+    private val parameterListWrappingRuleAssertThat =
+        assertThatRule(
+            provider = { ParameterListWrappingRule() },
+            additionalRuleProviders =
+                setOf(
+                    RuleProvider { IndentationRule() },
+                ),
+        )
+
+    @Test
+    fun `Issue 1324 - Given a nullable function type property that exceeds max line length then wrap without reporting unnecessary newline`() {
+        val code =
+            """
+            val foo1: ((s1: String, s2: String, s3: String, s4: String, s5: String, s6: String) -> Unit)? = null
+            """.trimIndent()
+        val formattedCode =
+            """
+            val foo1: (
+                (s1: String, s2: String, s3: String, s4: String, s5: String, s6: String) -> Unit
+            )? = null
+            """.trimIndent()
+        parameterListWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 80)
+            .hasLintViolations(
+                LintViolation(1, 11, "Parameter of nullable type should be on a separate line (unless the type fits on a single line)"),
+                LintViolation(1, 90, """Missing newline before ")""""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1324 - Given a formatted nullable function type property then no violations should be reported`() {
+        val code =
+            """
+            val foo1: (
+                (s1: String, s2: String, s3: String, s4: String, s5: String, s6: String) -> Unit
+            )? = null
+            """.trimIndent()
+        parameterListWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 80)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1324 - Given a nullable function type in function parameter that exceeds max line length then wrap correctly`() {
+        val code =
+            """
+            fun foo(callback: ((s1: String, s2: String, s3: String, s4: String) -> Unit)?) {
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(
+                callback: (
+                    (s1: String, s2: String, s3: String, s4: String) -> Unit
+                )?
+            ) {
+            }
+            """.trimIndent()
+        parameterListWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 60)
+            .hasLintViolations(
+                LintViolation(1, 9, "Parameter should start on a newline"),
+                LintViolation(1, 19, "Parameter of nullable type should be on a separate line (unless the type fits on a single line)"),
+                LintViolation(1, 72, """Missing newline before ")""""),
+                LintViolation(1, 76, """Missing newline before ")""""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1324 - Given a properly wrapped nullable function type in function parameter then no violations should be reported`() {
+        val code =
+            """
+            fun foo(
+                callback: (
+                    (s1: String, s2: String, s3: String, s4: String) -> Unit
+                )?
+            ) {
+            }
+            """.trimIndent()
+        parameterListWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 60)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1324 - Given a local variable with nullable function type that exceeds max line length then wrap correctly`() {
+        val code =
+            """
+            fun foo() {
+                var changesListener: ((width: Double?, depth: Double?, length: Double?, area: Double?) -> Unit)? = null
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo() {
+                var changesListener: (
+                    (width: Double?, depth: Double?, length: Double?, area: Double?) -> Unit
+                )? = null
+            }
+            """.trimIndent()
+        parameterListWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 80)
+            .hasLintViolations(
+                LintViolation(2, 26, "Parameter of nullable type should be on a separate line (unless the type fits on a single line)"),
+                LintViolation(2, 99, """Missing newline before ")""""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 1324 - Given a properly wrapped local variable with nullable function type then no violations should be reported`() {
+        val code =
+            """
+            fun foo() {
+                var changesListener: (
+                    (width: Double?, depth: Double?, length: Double?, area: Double?) -> Unit
+                )? = null
+            }
+            """.trimIndent()
+        parameterListWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 80)
+            .hasNoLintViolations()
+    }
+}
+

