+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/Issue1324Test.kt
@@ -0,0 +1,54 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.RuleProvider
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class Issue1324Test {
+    private val parameterListWrappingRuleAssertThat =
+        assertThatRule(
+            provider = { ParameterListWrappingRule() },
+            additionalRuleProviders =
+                setOf(
+                    RuleProvider { IndentationRule() },
+                ),
+        )
+
+    @Test
+    fun `Issue 1324 - Unnecessary newline before open parenthesis in function type`() {
+        val code =
+            """
+            val foo1: (
+                (
+                    s1: String,
+                    s2: String,
+                    s3: String,
+                    s4: String,
+                    s5: String,
+                    s6: String
+                ) -> Unit
+            )? = null
+            """.trimIndent()
+        parameterListWrappingRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 1324 - Still reports unnecessary newline before open parenthesis in normal function`() {
+        val code =
+            """
+            fun foo
+            (
+                s1: String,
+                s2: String
+            ) {}
+            """.trimIndent()
+        parameterListWrappingRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(2, 1, "Unnecessary newline before \"(\""),
+            )
+    }
+}
+

