+// Test case for Issue 1324
+// Based on the issue description:
+// "Parameter of nullable type should be on a separate line (unless the type fits on a single line)"
+// The bug is that after auto-correction, the rule itself reports an error about "Unnecessary newline before '('"
+
+// Before formatting - single line exceeding max line length
+val foo1: ((s1: String, s2: String, s3: String, s4: String, s5: String, s6: String) -> Unit)? = null
+
+// Expected after formatting - should be acceptable to ktlint
+val foo2: (
+    (
+        s1: String,
+        s2: String,
+        s3: String,
+        s4: String,
+        s5: String,
+        s6: String
+    ) -> Unit
+)? = null
+
