+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.ElementType.BLOCK_COMMENT
+import com.pinterest.ktlint.rule.engine.core.api.ElementType.EOL_COMMENT
+import com.pinterest.ktlint.rule.engine.core.api.Rule
+import com.pinterest.ktlint.rule.engine.core.api.RuleId
+import com.pinterest.ktlint.ruleset.standard.StandardRule
+import org.jetbrains.kotlin.com.intellij.lang.ASTNode
+
+/**
+ * Detects legacy ktlint-disable/ktlint-enable directives and recommends migrating to @Suppress annotations.
+ * This rule should not be suppressed itself, even if all ktlint rules are suppressed.
+ */
+public class KtlintDirectiveToSuppressionRule :
+    StandardRule(
+        id = "ktlint-suppression-rule",
+    ) {
+
+    override fun beforeVisitChildNodes(
+        node: ASTNode,
+        autoCorrect: Boolean,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+    ) {
+        when (node.elementType) {
+            EOL_COMMENT -> handleEolComment(node, emit)
+            BLOCK_COMMENT -> handleBlockComment(node, emit)
+        }
+    }
+
+    private fun handleEolComment(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+    ) {
+        val commentText = node.text.removePrefix("//").trim()
+        val parts = commentText.split(" ").filter { it.isNotEmpty() }
+
+        if (parts.isNotEmpty() && parts[0] == "ktlint-disable") {
+            val ruleIds = parts.drop(1).map { normalizeRuleId(it) }.filter { it.isNotEmpty() }
+            val suppressValue = if (ruleIds.isEmpty()) {
+                "@Suppress(\"ktlint\")"
+            } else {
+                "@Suppress(" + ruleIds.joinToString(", ") { "\"ktlint:$it\"" } + ")"
+            }
+
+            emit(
+                node.startOffset,
+                "Replace ktlint-disable directive with $suppressValue annotation on the preceding statement",
+                false
+            )
+        }
+    }
+
+    private fun handleBlockComment(
+        node: ASTNode,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+    ) {
+        val commentText = node.text.removePrefix("/*").removeSuffix("*/").trim()
+        val parts = commentText.split(" ").filter { it.isNotEmpty() }
+
+        if (parts.isNotEmpty() && (parts[0] == "ktlint-disable" || parts[0] == "ktlint-enable")) {
+            when (parts[0]) {
+                "ktlint-disable" -> {
+                    val ruleIds = parts.drop(1).map { normalizeRuleId(it) }.filter { it.isNotEmpty() }
+                    val suppressValue = if (ruleIds.isEmpty()) {
+                        "@Suppress(\"ktlint\")"
+                    } else {
+                        "@Suppress(" + ruleIds.joinToString(", ") { "\"ktlint:$it\"" } + ")"
+                    }
+
+                    emit(
+                        node.startOffset,
+                        "Replace ktlint-disable block directive with $suppressValue annotation on the target declaration",
+                        false
+                    )
+                }
+                "ktlint-enable" -> {
+                    emit(
+                        node.startOffset,
+                        "Remove ktlint-enable directive (no longer needed with @Suppress)",
+                        false
+                    )
+                }
+            }
+        }
+    }
+
+    private fun normalizeRuleId(ruleId: String): String {
+        return when {
+            ruleId.startsWith("experimental:") -> ruleId.replace("experimental:", "standard:")
+            !ruleId.contains(":") -> "standard:$ruleId"
+            else -> ruleId
+        }
+    }
+}
+
+public val KTLINT_DIRECTIVE_TO_SUPPRESSION_RULE_ID: RuleId = KtlintDirectiveToSuppressionRule().ruleId
+

