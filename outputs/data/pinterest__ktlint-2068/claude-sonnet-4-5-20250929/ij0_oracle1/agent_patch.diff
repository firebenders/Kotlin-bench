+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class DiscouragedCommentDirectiveRuleTest {
+    private val ktLintAssertThat = assertThatRule { DiscouragedCommentDirectiveRule() }
+
+    @Test
+    fun `Given an EOL comment with ktlint-disable directive then report violation`() {
+        val code =
+            """
+            val foo = "foo" // ktlint-disable
+            """.trimIndent()
+        ktLintAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(1, 17, "The ktlint-disable directive is no longer supported. Replace with @Suppress annotation.")
+    }
+
+    @Test
+    fun `Given an EOL comment with ktlint-disable directive for specific rule then report violation`() {
+        val code =
+            """
+            val foo = "foo" // ktlint-disable standard:some-rule
+            """.trimIndent()
+        ktLintAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(1, 17, "The ktlint-disable directive is no longer supported. Replace with @Suppress annotation.")
+    }
+
+    @Test
+    fun `Given a block comment with ktlint-disable directive then report violation`() {
+        val code =
+            """
+            /* ktlint-disable */
+            val foo = "foo"
+            /* ktlint-enable */
+            """.trimIndent()
+        ktLintAssertThat(code)
+            .hasLintViolationsWithoutAutoCorrect(
+                LintViolation(1, 1, "The ktlint-disable directive is no longer supported. Replace with @Suppress annotation."),
+                LintViolation(3, 1, "The ktlint-enable directive is no longer supported. Remove this comment or replace with proper @Suppress annotation usage."),
+            )
+    }
+
+    @Test
+    fun `Given a block comment with ktlint-disable directive for specific rule then report violation`() {
+        val code =
+            """
+            /* ktlint-disable standard:some-rule */
+            val foo = "foo"
+            /* ktlint-enable standard:some-rule */
+            """.trimIndent()
+        ktLintAssertThat(code)
+            .hasLintViolationsWithoutAutoCorrect(
+                LintViolation(1, 1, "The ktlint-disable directive is no longer supported. Replace with @Suppress annotation."),
+                LintViolation(3, 1, "The ktlint-enable directive is no longer supported. Remove this comment or replace with proper @Suppress annotation usage."),
+            )
+    }
+
+    @Test
+    fun `Given normal comments without ktlint directives then do not report violations`() {
+        val code =
+            """
+            // This is a normal comment
+            val foo = "foo"
+            /* This is a block comment */
+            """.trimIndent()
+        ktLintAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a Suppress annotation then do not report violations`() {
+        val code =
+            """
+            @Suppress("ktlint")
+            val foo = "foo"
+            """.trimIndent()
+        ktLintAssertThat(code).hasNoLintViolations()
+    }
+}
