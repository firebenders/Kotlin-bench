@@ -0,0 +1,41 @@
+package com.pinterest.ktlint.rule.engine.internal.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.RuleId
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.EditorConfig
+import com.pinterest.ktlint.rule.engine.internal.FormatterTags
+import com.pinterest.ktlint.rule.engine.internal.SuppressionLocatorBuilder
+import org.jetbrains.kotlin.com.intellij.lang.ASTNode
+import org.jetbrains.kotlin.com.intellij.psi.PsiComment
+
+internal class KtlintSuppressionRule : InternalRule(
+    ruleId = RULE_ID,
+) {
+    private lateinit var formatterTags: FormatterTags
+
+    override fun beforeFirstNode(editorConfig: EditorConfig) {
+        formatterTags = FormatterTags.from(editorConfig)
+    }
+
+    override fun beforeVisitChildNodes(
+        node: ASTNode,
+        autoCorrect: Boolean,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+    ) {
+        if (node.psi is PsiComment) {
+            val suppressionHint = with(SuppressionLocatorBuilder) {
+                node.createSuppressionHintFromComment(formatterTags)
+            } ?: return
+
+            emit(
+                node.startOffset,
+                "Ktlint directive is deprecated. Replace with @Suppress annotation",
+                false
+            )
+        }
+    }
+
+    companion object {
+        val RULE_ID = RuleId("ktlint:suppression")
+    }
+}
+

