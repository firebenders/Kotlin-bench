diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleIndentTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleIndentTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleIndentTest.kt
@@ -0,0 +1,79 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.EOL_CHAR
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.MAX_LINE_LENGTH_MARKER
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests to verify that PropertyWrappingRule correctly indents values when wrapping to the next line,
+ * even without the IndentationRule being run (issue: property value not being indented when wrapped).
+ */
+internal class PropertyWrappingRuleIndentTest {
+    private val propertyWrappingRuleAssertThat = KtLintAssertThat.assertThatRule { PropertyWrappingRule() }
+
+    @Test
+    fun `Given property value that exceeds max line length then wrap with proper indentation`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                               $EOL_CHAR
+            private val deferredMessageQueueSubscription = DeferredMessageQueueSubscription(uri = ServiceBusUri("deferredQueueTestUri"))
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                               $EOL_CHAR
+            private val deferredMessageQueueSubscription =
+                DeferredMessageQueueSubscription(uri = ServiceBusUri("deferredQueueTestUri"))
+            """.trimIndent()
+        // Note: not using IndentationRule here to verify PropertyWrappingRule handles indentation correctly on its own
+        propertyWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasLintViolation(2, 47, """Missing newline before "DeferredMessageQueueSubscription(uri = ServiceBusUri("deferredQueueTestUri"))"""")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given indented property value that exceeds max line length then wrap with proper indentation`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                               $EOL_CHAR
+            class Foo {
+                private val deferredMessageQueueSubscription = DeferredMessageQueueSubscription(uri = ServiceBusUri("test"))
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                               $EOL_CHAR
+            class Foo {
+                private val deferredMessageQueueSubscription =
+                    DeferredMessageQueueSubscription(uri = ServiceBusUri("test"))
+            }
+            """.trimIndent()
+        // Note: not using IndentationRule here to verify PropertyWrappingRule handles indentation correctly on its own
+        propertyWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasLintViolation(3, 51, """Missing newline before "DeferredMessageQueueSubscription(uri = ServiceBusUri("test"))"""")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given property with type reference that exceeds max line length then wrap with proper indentation`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER      $EOL_CHAR
+            val someVariable: VeryLongTypeName
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER      $EOL_CHAR
+            val someVariable:
+                VeryLongTypeName
+            """.trimIndent()
+        // Note: not using IndentationRule here to verify PropertyWrappingRule handles indentation correctly on its own
+        propertyWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasLintViolation(2, 18, """Missing newline before "VeryLongTypeName"""")
+            .isFormattedAs(formattedCode)
+    }
+}
+

