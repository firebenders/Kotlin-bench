+
+    @Test
+    fun `Given that the call expression does not fit on the same line then wrap before the call expression and indent it without relying on IndentationRule`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                   $EOL_CHAR
+            class Bar(
+                val foooooooooooooooooTooLong: Foo = Foo(),
+            )
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                   $EOL_CHAR
+            class Bar(
+                val foooooooooooooooooTooLong: Foo =
+                    Foo(),
+            )
+            """.trimIndent()
+        // Note: no IndentationRule is added, the ParameterWrappingRule should handle indentation correctly by itself
+        parameterWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasLintViolation(3, 41, "Missing newline before \"Foo()\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
