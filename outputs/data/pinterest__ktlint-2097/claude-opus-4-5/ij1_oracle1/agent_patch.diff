diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleIndentTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleIndentTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleIndentTest.kt
@@ -0,0 +1,59 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.EOL_CHAR
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.MAX_LINE_LENGTH_MARKER
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests to verify that PropertyWrappingRule correctly indents wrapped property values
+ * even when IndentationRule is not enabled.
+ *
+ * Related issue: When property value is wrapped to next line, it should be indented with an extra level.
+ */
+internal class PropertyWrappingRuleIndentTest {
+    private val propertyWrappingRuleAssertThat = KtLintAssertThat.assertThatRule { PropertyWrappingRule() }
+
+    @Test
+    fun `Given that the value does not fit on the same line, wrap before value with proper indent without IndentationRule`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                            $EOL_CHAR
+            val aVariableWithALongName: TypeWithALongerName = TypeWithALongName(123)
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                            $EOL_CHAR
+            val aVariableWithALongName: TypeWithALongerName =
+                TypeWithALongName(123)
+            """.trimIndent()
+        // Explicitly NOT adding IndentationRule to verify that PropertyWrappingRule
+        // correctly handles indentation on its own
+        propertyWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasLintViolation(2, 50, "Missing newline before \"TypeWithALongName(123)\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given that the type does not fit on the same line as the variable name, wrap before type with proper indent without IndentationRule`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                   $EOL_CHAR
+            val aVariableWithALongerName: TypeWithALongName
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                   $EOL_CHAR
+            val aVariableWithALongerName:
+                TypeWithALongName
+            """.trimIndent()
+        // Explicitly NOT adding IndentationRule to verify that PropertyWrappingRule
+        // correctly handles indentation on its own
+        propertyWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasLintViolation(2, 30, "Missing newline before \"TypeWithALongName\"")
+            .isFormattedAs(formattedCode)
+    }
+}
+

