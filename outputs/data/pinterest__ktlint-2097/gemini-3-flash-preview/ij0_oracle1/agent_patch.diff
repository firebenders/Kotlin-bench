diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleReproTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleReproTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleReproTest.kt
@@ -0,0 +1,30 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+class PropertyWrappingRuleReproTest {
+    private val propertyWrappingRuleAssertThat = KtLintAssertThat.assertThatRule { PropertyWrappingRule() }
+
+    @Test
+    fun `Given a property with a long value that should be wrapped then it should be indented`() {
+        val code =
+            """
+            class Foo {
+                private val deferredMessageQueueSubscription = DeferredMessageQueueSubscription(uri = ServiceBusUri("deferredQueueTestUri"))
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Foo {
+                private val deferredMessageQueueSubscription =
+                    DeferredMessageQueueSubscription(uri = ServiceBusUri("deferredQueueTestUri"))
+            }
+            """.trimIndent()
+        propertyWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 100)
+            .isFormattedAs(formattedCode)
+    }
+}
+

