diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleBestEffortIndentTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleBestEffortIndentTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/PropertyWrappingRuleBestEffortIndentTest.kt
@@ -0,0 +1,34 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.EOL_CHAR
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.MAX_LINE_LENGTH_MARKER
+import org.junit.jupiter.api.Test
+
+internal class PropertyWrappingRuleBestEffortIndentTest {
+    private val propertyWrappingRuleAssertThat = KtLintAssertThat.assertThatRule { PropertyWrappingRule() }
+
+    @Test
+    fun `Given property value is wrapped then indent is kept even without indentation rule`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                             $EOL_CHAR
+            class SubjectUnderTest {
+                val deferredMessageQueueSubscription = DeferredMessageQueueSubscription(uri = ServiceBusUri("deferredQueueTestUri"))
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                             $EOL_CHAR
+            class SubjectUnderTest {
+                val deferredMessageQueueSubscription =
+                    DeferredMessageQueueSubscription(uri = ServiceBusUri("deferredQueueTestUri"))
+            }
+            """.trimIndent()
+
+        propertyWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .isFormattedAs(formattedCode)
+    }
+}
+

