+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for issue https://github.com/pinterest/ktlint/issues/2101
+ *
+ * Single-line lambda with parameter should not be wrapped
+ */
+internal class WrappingRuleIssue2101Test {
+    private val wrappingRuleAssertThat = assertThatRule { WrappingRule() }
+
+    @Test
+    fun `Given a single-line lambda with a parameter then do not report an error`() {
+        val code =
+            """
+            val foo = { size -> icon?.getBitmap(size)?.await() }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a single-line lambda with multiple parameters then do not report an error`() {
+        val code =
+            """
+            val foo = { a, b, c -> doSomething(a, b, c) }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda with parameter where the body is on the next line then do not report an error`() {
+        val code =
+            """
+            val foo = { size ->
+                icon?.getBitmap(size)?.await()
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda passed as argument with single-line body then do not report an error`() {
+        val code =
+            """
+            fun main() {
+                items.map { size -> size.toString() }
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda with multiline parameter list then format with proper indentation`() {
+        val code =
+            """
+            val foo = {
+                    a,
+                    b,
+                    c ->
+                doSomething()
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a single-line lambda exceeding max line length then do not wrap the parameter list`() {
+        val code =
+            """
+            val foo = { size -> icon?.getBitmap(size)?.await() }
+            """.trimIndent()
+        // Even if the line exceeds max_line_length, the parameter should not be wrapped
+        // to a new line with double indentation
+        wrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 30)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda with parameter on a single line with body on new line then keep as is`() {
+        val code =
+            """
+            val foo = { size ->
+                icon?.getBitmap(size)?.await()
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a function call with lambda parameter with single-line body then do not report an error`() {
+        val code =
+            """
+            fun main() {
+                doSomething { size -> icon?.getBitmap(size)?.await() }
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline expression in lambda body then do not wrap the parameter list`() {
+        val code =
+            """
+            fun main() {
+                doSomething { size ->
+                    icon?.getBitmap(size)?.await()
+                }
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a value parameter list containing destructuring declaration on last parameter in lambda`() {
+        // This tests the hasDestructuringDeclarationAsLastValueParameter check
+        val code =
+            """
+            fun main() {
+                items.map { (a, b) ->
+                    a + b
+                }
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda where body is wrapped due to line length then do not double indent parameters`() {
+        // When the body is long enough to need wrapping, the parameters should stay on the same line as {
+        val code =
+            """
+            val x = { size -> someLongFunctionName(size) }
+            """.trimIndent()
+        wrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 40)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda as middle argument in function call then do not add newline after lbrace`() {
+        // When lambda is not the only argument, wrapping might be triggered differently
+        val code =
+            """
+            fun main() {
+                foo(a, { size -> doSomething(size) }, c)
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda with multiline body but params on first line then keep params on same line`() {
+        // The parameters should stay on the same line as { even when body needs wrapping
+        val code =
+            """
+            val foo = { size ->
+                icon?.getBitmap(size)
+                    ?.await()
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a properly formatted multiline lambda with single parameter then keep format`() {
+        // When the lambda body is already on a new line, keep it that way
+        val code =
+            """
+            val foo = { size ->
+                doSomething(size)
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda in a chain call with parameter then do not add newline after lbrace`() {
+        // Lambda in a chain call should not have its parameter list wrapped
+        val code =
+            """
+            val result = items
+                .map { size -> icon?.getBitmap(size)?.await() }
+                .filter { it != null }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline chain call with lambda then do not double indent lambda params`() {
+        // Even when the overall expression is multiline, lambda params should not get extra indentation
+        val code =
+            """
+            val result = items
+                .map { size ->
+                    icon?.getBitmap(size)?.await()
+                }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a long line with lambda that exceeds max length then still keep params on same line as lbrace`() {
+        // Even when line length forces wrapping, lambda params should NOT be wrapped to new line with double indent
+        val code =
+            """
+            val result = veryLongVariableName.map { size -> icon?.getBitmap(size)?.await() }
+            """.trimIndent()
+        // This tests that we don't produce:
+        // val result = veryLongVariableName.map {
+        //         size ->
+        //     icon?.getBitmap(size)?.await()
+        // }
+        wrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 60)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given lambda with parameter whose type spans multiple lines then handle correctly`() {
+        // Complex parameter types might trigger wrapping differently
+        val code =
+            """
+            val foo = { callback: (String, Int) -> Unit ->
+                callback("test", 1)
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given lambda in parentheses as argument with newline after body then do not wrap params`() {
+        // Testing the scenario where lambda is inside parentheses and body has newline
+        val code =
+            """
+            fun test() {
+                doSomething({ size ->
+                    processSize(size)
+                })
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given lambda where body needs wrapping but params should stay on same line`() {
+        // When the lambda body becomes multiline, params should NOT be double-indented
+        val code =
+            """
+            val callback = { size ->
+                icon
+                    ?.getBitmap(size)
+                    ?.await()
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given function call with multiline first argument and lambda then lambda params should not be wrapped`() {
+        // This is likely the triggering scenario - when there's a multiline argument before the lambda,
+        // the whole argument list gets wrapped, but the lambda's internal structure should be preserved
+        val code =
+            """
+            fun test() {
+                doSomething(
+                    multilineArg
+                        .foo()
+                        .bar(),
+                    { size -> size.toString() }
+                )
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given function call with lambda then multiline argument then lambda should not be affected`() {
+        // When there's a multiline argument after the lambda
+        val code =
+            """
+            fun test() {
+                doSomething(
+                    { size -> size.toString() },
+                    multilineArg
+                        .foo()
+                        .bar()
+                )
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a lambda with parameters where arrow is already on next line then do not double wrap`() {
+        // If the arrow is already on a new line (multiline parameter list), keep as is
+        val code =
+            """
+            val foo = {
+                    a,
+                    b,
+                    c ->
+                doSomething(a, b, c)
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given lambda with single parameter on same line as lbrace then keep it that way`() {
+        // The parameter should NOT be moved to a new line with double indentation
+        // when there's no explicit multiline parameter list
+        val code =
+            """
+            val foo = { param ->
+                doSomething(param)
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

