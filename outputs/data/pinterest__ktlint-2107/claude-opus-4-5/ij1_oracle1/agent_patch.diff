+
+    @Nested
+    inner class `Issue 2101 - Given a lambda expression with a single parameter on the same line` {
+        @Test
+        fun `Given a single line lambda expression then do not wrap the parameter list`() {
+            val code =
+                """
+                val foo = { size -> icon?.getBitmap(size)?.await() }
+                """.trimIndent()
+            wrappingRuleAssertThat(code).hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a multiline lambda expression with a single line parameter list then do not wrap the arrow`() {
+            val code =
+                """
+                val foo = { size ->
+                    icon?.getBitmap(size)?.await()
+                }
+                """.trimIndent()
+            wrappingRuleAssertThat(code).hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a multiline lambda expression with multiline parameter list then do wrap the arrow`() {
+            val code =
+                """
+                val foo = {
+                        a,
+                        b,
+                        c ->
+                    doSomething()
+                }
+                """.trimIndent()
+            wrappingRuleAssertThat(code).hasNoLintViolations()
+        }
+
+        @Test
