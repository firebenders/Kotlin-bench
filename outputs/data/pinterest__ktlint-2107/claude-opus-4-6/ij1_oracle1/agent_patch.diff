+    /**
+     * A function literal with a single line parameter list should not be wrapped solely because the line exceeds the
+     * max line length. The parameter list should only be wrapped when it already is a multiline parameter list.
+     *
+     * See https://github.com/pinterest/ktlint/issues/2101 and https://github.com/pinterest/ktlint/issues/2106.
+     */
+    private fun ASTNode.isPartOfFunctionLiteralWithSingleLineParameterList(): Boolean {
+        require(elementType == VALUE_PARAMETER_LIST)
+        return treeParent?.elementType == FUNCTION_LITERAL && !textContains('\n')
+    }
