+    @Test
+    fun `Issue - Lambda parameter indentation should not be double-indented when parameters are wrapped`() {
+        val code = "{ size -> icon?.getBitmap(size)?.await() }"
+        val formattedCode =
+            """
+            {
+                size ->
+                    icon?.getBitmap(size)?.await()
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code)
+            .addAdditionalRuleProvider { IndentationRule() }
+            .hasLintViolations(
+                LintViolation(1, 2, "Missing newline after \"{\""),
+            )
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Lambda with multiple parameters should have consistent indentation`() {
+        val code = "val foo = { a, b, c -> doSomething(a, b, c) }"
+        val formattedCode =
+            """
+            val foo = {
+                a,
+                b,
+                c ->
+                doSomething(a, b, c)
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code)
+            .addAdditionalRuleProvider { IndentationRule() }
+            .hasLintViolations(
+                LintViolation(1, 12, "Missing newline after \"{\""),
+            )
+            .isFormattedAs(formattedCode)
+    }
