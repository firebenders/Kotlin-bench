--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/WrappingRuleIssue2101Test.kt
@@ -0,0 +1,67 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class WrappingRuleIssue2101Test {
+    private val wrappingRuleAssertThat = assertThatRule { WrappingRule() }
+
+    @Test
+    fun `Issue 2101 - Single line lambda with parameter should not be wrapped`() {
+        val code =
+            """
+            val x = { size -> icon?.getBitmap(size)?.await() }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 2101 - Single line lambda with single parameter should not be wrapped 2`() {
+        val code =
+            """
+            val y = { a -> doSomething(a) }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 2101 - Single line lambda with multiple parameters should not be wrapped`() {
+        val code =
+            """
+            val z = { a, b -> a + b }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Issue 2101 - Lambda without parameters with newline should still be wrapped properly`() {
+        val code =
+            """
+            val x = { doSomething()
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            val x = {
+                doSomething()
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code)
+            .hasLintViolation(1, 10, "Missing newline after \"{\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Issue 2101 - Multi-line lambda with parameter should have proper formatting`() {
+        val code =
+            """
+            val x = { size ->
+                doSomething(size)
+            }
+            """.trimIndent()
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

