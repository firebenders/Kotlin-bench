@@ -0,0 +1,35 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+internal class WrappingRuleRegressionTest {
+    private val wrappingRuleAssertThat = assertThatRule { WrappingRule() }
+
+    @Test
+    fun `Given a nested single line function literal then do not force it to multiline`() {
+        val code =
+            """
+            val supportingText = supportingText?.let {
+                { Text(supportingText) }
+            }
+            """.trimIndent()
+
+        wrappingRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a nested single line function literal with parameters then keep it on a single line`() {
+        val code =
+            """
+            val painterProvider = remember {
+                { size -> icon?.getBitmap(size)?.await() }
+            }
+            """.trimIndent()
+
+        wrappingRuleAssertThat(code)
+            .hasNoLintViolations()
+    }
+}
+

