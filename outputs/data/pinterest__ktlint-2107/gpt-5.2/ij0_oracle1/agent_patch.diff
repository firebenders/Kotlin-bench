+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+internal class WrappingRuleLambdaParameterListMaxLineLengthTest {
+    private val statementWrappingAssertThat = assertThatRule { StatementWrapping() }
+
+    @Test
+    fun `Given a multiline lambda with parameter list then insert newline after arrow rather than after lbrace`() {
+        val code =
+            """
+            val foo = { size -> icon?.getBitmap(size)
+                ?.await()
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            val foo = { size ->
+                icon?.getBitmap(size)
+                    ?.await()
+            }
+            """.trimIndent()
+
+        statementWrappingAssertThat(code)
+            .addAdditionalRuleProvider { IndentationRule() }
+            .isFormattedAs(formattedCode)
+    }
+}
+

