+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+internal class WrappingRuleFunctionLiteralRegressionTest {
+    private val wrappingRuleAssertThat = assertThatRule { WrappingRule() }
+
+    @Test
+    fun `Given a multiline lambda with explicit parameters then do not require a newline after the opening brace`() {
+        val code =
+            """
+            fun foo() {
+                val f = { size ->
+                    icon?.getBitmap(size)?.await()
+                }
+            }
+            """.trimIndent()
+
+        wrappingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
