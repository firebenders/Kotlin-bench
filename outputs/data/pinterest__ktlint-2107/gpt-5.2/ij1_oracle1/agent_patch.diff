+    private fun arrowInFunctionLiteralOnSameLineAsOpeningBrace(
+        lbrace: ASTNode,
+        rbrace: ASTNode,
+    ): ASTNode? {
+        val functionLiteral = lbrace.treeParent.takeIf { it.elementType == FUNCTION_LITERAL } ?: return null
+        // Only consider the arrow which is part of this function literal header, and ignore arrows in nested
+        // lambdas/when-entries inside the body.
+        val arrow = functionLiteral.findChildByType(ARROW) ?: return null
+
+        // Only apply this exception when the parameter list and arrow are on the same line as the opening brace.
+        // In case they are wrapped already, ktlint may still want to enforce a newline after '{'.
+        if (!noNewLineInClosedRange(lbrace, arrow)) {
+            return null
+        }
+
+        // Sanity check: the arrow must be located before the end of this block.
+        if (arrow.startOffset >= rbrace.startOffset) {
+            return null
+        }
+
+        return arrow
+    }
