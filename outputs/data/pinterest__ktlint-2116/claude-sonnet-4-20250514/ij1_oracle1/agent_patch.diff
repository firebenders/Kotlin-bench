+// Test case 1: Class with primary constructor (no explicit "constructor" keyword) and multiline super types
+// This should NOT have indented class body (current problem: body IS indented)
+class Foo(
+    val bar1: Bar,
+    val bar2: Bar,
+) : FooBar(bar1, bar2),
+    BarFoo1,
+    BarFoo2 {
+    // body should be at normal indentation level (current bug: it gets indented)
+    fun foo() = "foo"
+}
+
+// Test case 2: Class with explicit constructor and multiline super types
+// This should have indented constructor and super types, but normal class body
+class Foo2
+@Bar1 @Bar2
+constructor(
+    val bar1: Bar,
+    val bar2: Bar,
+) : FooBar(bar1, bar2),
+    BarFoo1,
+    BarFoo2 {
+    // body should be at normal indentation level
+    fun foo() = "foo"
+}
+
