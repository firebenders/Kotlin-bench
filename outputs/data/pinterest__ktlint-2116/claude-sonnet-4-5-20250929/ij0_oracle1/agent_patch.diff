+// Test case 1: Class without explicit constructor but with multiline super type list
+// This should NOT indent the body
+class Foo(
+    val bar1: Bar,
+    val bar2: Bar,
+) : FooBar(bar1, bar2),
+    BarFoo1,
+    BarFoo2 {
+    // body
+}
+
+// Test case 2: Class with explicit constructor and multiline super type list
+// The super type list should be indented at constructor level
+class Foo2
+    constructor(
+        val bar1: Bar,
+        val bar2: Bar,
+    ) : FooBar(bar1, bar2),
+        BarFoo1,
+        BarFoo2 {
+    // body
+}
+
+// Test case 3: Class with explicit constructor and annotations (from issue #1916)
+// This should indent both constructor and body
+class Foo3
+    @Bar1 @Bar2
+    constructor(
+        foo1: Foo1,
+        foo2: Foo2,
+    ) : Foobar(
+        "foobar1",
+        "foobar2",
+    ) {
+        fun foo() = "foo"
+    }
+
