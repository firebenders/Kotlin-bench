diff --git a/IndentationClassBodyTest.kt b/IndentationClassBodyTest.kt
new file mode 100644
--- /dev/null
+++ b/IndentationClassBodyTest.kt
@@ -0,0 +1,39 @@
+// Test file to reproduce the indentation issue with class body when class has multiline super type list
+// This file should NOT be modified by the fix - it's for testing the problem
+
+// Test case 1: Class with multiline super type list (no explicit constructor)
+class Foo(
+    val bar1: Bar,
+    val bar2: Bar,
+) : FooBar(bar1, bar2),
+    BarFoo1,
+    BarFoo2 {
+    // body should be at normal indentation level
+    fun foo() = "foo"
+}
+
+// Test case 2: Class with explicit constructor and multiline super type list
+class Foo
+    constructor(
+        val bar1: Bar,
+        val bar2: Bar,
+    ) : FooBar(bar1, bar2),
+    BarFoo1,
+    BarFoo2 {
+    // body should be at normal indentation level
+    fun foo() = "bar"
+}
+
+// Test case 3: Class with annotations and explicit constructor (from #1916 - should work correctly)
+class Foo
+@Bar1 @Bar2
+constructor(
+    foo1: Foo1,
+    foo2: Foo2,
+) : Foobar(
+    "foobar1",
+    "foobar2",
+) {
+    fun foo() = "foo"
+}
+

