diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleIsExpressionAndPrefixExpressionTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleIsExpressionAndPrefixExpressionTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleIsExpressionAndPrefixExpressionTest.kt
@@ -0,0 +1,194 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Nested
+import org.junit.jupiter.api.Test
+
+class IndentationRuleIsExpressionAndPrefixExpressionTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Nested
+    inner class `Given an is-expression` {
+        @Test
+        fun `Given a multiline is-expression as part of an assignment then the type reference should be indented`() {
+            val code =
+                """
+                fun foo(any: Any) =
+                    any is
+                    Foo
+                """.trimIndent()
+            val formattedCode =
+                """
+                fun foo(any: Any) =
+                    any is
+                        Foo
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+                .isFormattedAs(formattedCode)
+        }
+
+        @Test
+        fun `Given a multiline negated is-expression as part of an assignment then the type reference should be indented`() {
+            val code =
+                """
+                fun foo(any: Any) =
+                    any !is
+                    Foo
+                """.trimIndent()
+            val formattedCode =
+                """
+                fun foo(any: Any) =
+                    any !is
+                        Foo
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+                .isFormattedAs(formattedCode)
+        }
+
+        @Test
+        fun `Given a correctly indented is-expression then no violation is reported`() {
+            val code =
+                """
+                fun foo(any: Any) =
+                    any is
+                        Foo
+                """.trimIndent()
+            indentationRuleAssertThat(code).hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given an is-expression on a single line then no violation is reported`() {
+            val code =
+                """
+                fun foo(any: Any) = any is Foo
+                """.trimIndent()
+            indentationRuleAssertThat(code).hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a multiline is-expression in a return statement`() {
+            val code =
+                """
+                fun foo(any: Any): Boolean {
+                    return any is
+                    Foo
+                }
+                """.trimIndent()
+            val formattedCode =
+                """
+                fun foo(any: Any): Boolean {
+                    return any is
+                        Foo
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+                .isFormattedAs(formattedCode)
+        }
+    }
+
+    @Nested
+    inner class `Given a prefix-expression` {
+        @Test
+        fun `Given a multiline prefix-expression with increment as part of an assignment then the operand should be indented`() {
+            val code =
+                """
+                fun foo(any: Int) =
+                    ++
+                    any
+                """.trimIndent()
+            val formattedCode =
+                """
+                fun foo(any: Int) =
+                    ++
+                        any
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+                .isFormattedAs(formattedCode)
+        }
+
+        @Test
+        fun `Given a multiline prefix-expression with decrement as part of an assignment then the operand should be indented`() {
+            val code =
+                """
+                fun foo(any: Int) =
+                    --
+                    any
+                """.trimIndent()
+            val formattedCode =
+                """
+                fun foo(any: Int) =
+                    --
+                        any
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+                .isFormattedAs(formattedCode)
+        }
+
+        @Test
+        fun `Given a multiline prefix-expression with negation as part of an assignment then the operand should be indented`() {
+            val code =
+                """
+                fun foo(any: Boolean) =
+                    !
+                    any
+                """.trimIndent()
+            val formattedCode =
+                """
+                fun foo(any: Boolean) =
+                    !
+                        any
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+                .isFormattedAs(formattedCode)
+        }
+
+        @Test
+        fun `Given a correctly indented prefix-expression then no violation is reported`() {
+            val code =
+                """
+                fun foo(any: Int) =
+                    ++
+                        any
+                """.trimIndent()
+            indentationRuleAssertThat(code).hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a prefix-expression on a single line then no violation is reported`() {
+            val code =
+                """
+                fun foo(any: Int) = ++any
+                """.trimIndent()
+            indentationRuleAssertThat(code).hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given a multiline prefix-expression in a return statement`() {
+            val code =
+                """
+                fun foo(any: Int): Int {
+                    return ++
+                    any
+                }
+                """.trimIndent()
+            val formattedCode =
+                """
+                fun foo(any: Int): Int {
+                    return ++
+                        any
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+                .isFormattedAs(formattedCode)
+        }
+    }
+}
+

