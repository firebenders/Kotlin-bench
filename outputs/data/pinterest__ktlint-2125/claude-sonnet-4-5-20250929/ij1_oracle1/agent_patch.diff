diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleIsAndPrefixExpressionTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleIsAndPrefixExpressionTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleIsAndPrefixExpressionTest.kt
@@ -0,0 +1,125 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for IS_EXPRESSION and PREFIX_EXPRESSION indentation.
+ * Issue: Indent IS_EXPRESSION and PREFIX_EXPRESSION
+ */
+internal class IndentationRuleIsAndPrefixExpressionTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Given a multiline IS_EXPRESSION in function expression body with correct indentation`() {
+        val code =
+            """
+            fun foo(any: Any) =
+                any is
+                    Foo
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline IS_EXPRESSION in function expression body with incorrect indentation`() {
+        val code =
+            """
+            fun foo(any: Any) =
+                any is
+                Foo
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(any: Any) =
+                any is
+                    Foo
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a multiline NOT_IS expression with correct indentation`() {
+        val code =
+            """
+            fun foo(any: Any) =
+                any !is
+                    Foo
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline NOT_IS expression with incorrect indentation`() {
+        val code =
+            """
+            fun foo(any: Any) =
+                any !is
+                Foo
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(any: Any) =
+                any !is
+                    Foo
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a multiline PREFIX_EXPRESSION with correct indentation`() {
+        val code =
+            """
+            fun foo(any: Int) =
+                ++
+                    42
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline PREFIX_EXPRESSION with incorrect indentation`() {
+        val code =
+            """
+            fun foo(any: Int) =
+                ++
+                42
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(any: Int) =
+                ++
+                    42
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .hasLintViolation(3, 1, "Unexpected indentation (4) (should be 8)")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a PREFIX_EXPRESSION with minus operator with correct indentation`() {
+        val code =
+            """
+            fun foo() =
+                -
+                    42
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a PREFIX_EXPRESSION with exclamation operator with correct indentation`() {
+        val code =
+            """
+            fun foo(value: Boolean) =
+                !
+                    value
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

