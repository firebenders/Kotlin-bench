--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/IndentationRuleIsAndPrefixExpressionTest.kt
@@ -0,0 +1,45 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+internal class IndentationRuleIsAndPrefixExpressionTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Test
+    fun `Given a multiline is-expression then indent the type reference as continuation`() {
+        val code =
+            """
+            fun foo(any: Any) =
+                any is
+                Foo
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(any: Any) =
+                any is
+                    Foo
+            """.trimIndent()
+
+        indentationRuleAssertThat(code).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a multiline prefix-expression then indent the operand as continuation`() {
+        val code =
+            """
+            fun foo(any: Int) =
+                ++
+                42
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo(any: Int) =
+                ++
+                    42
+            """.trimIndent()
+
+        indentationRuleAssertThat(code).isFormattedAs(formattedCode)
+    }
+}
+

