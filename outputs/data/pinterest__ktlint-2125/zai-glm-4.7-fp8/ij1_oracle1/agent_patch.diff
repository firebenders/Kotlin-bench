+    private fun visitIsOrPrefixExpression(node: ASTNode) {
+        // IS_EXPRESSION and PREFIX_EXPRESSION need special handling for continuation lines
+        // Example:
+        //   fun foo(any: Any) =
+        //       any is
+        //           Foo
+        //   fun foo(any: Int) =
+        //       ++
+        //           42
+        val lastChild = node.lastChildLeafOrSelf()
+        node
+            .findChildByType(OPERATION_REFERENCE)
+            ?.takeIf { it != lastChild }
+            ?.let { operationReference ->
+                // Start indent context from the operation reference onward
+                // This indents the right-hand side (e.g., the type check or operand)
+                startIndentContext(
+                    fromAstNode = operationReference,
+                    toAstNode = lastChild,
+                )
+            }
+        startIndentContext(node)
+    }
