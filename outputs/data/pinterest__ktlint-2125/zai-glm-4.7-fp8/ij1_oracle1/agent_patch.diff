+    @Test
+    fun `Given a multiline is expression`() {
+        val code =
+            """
+            class Foo
+            class Bar
+
+            // Incorrectly formatted - should be fixed
+            fun foo1(any: Any): Boolean = any is
+            Foo
+            // Incorrectly formatted - should be fixed
+            fun foo2(any: Any): Boolean =
+                any is
+                Bar
+            // Correctly formatted
+            fun foo3(any: Any): Boolean =
+                any is
+                    Foo
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Foo
+            class Bar
+
+            // Incorrectly formatted - should be fixed
+            fun foo1(any: Any): Boolean =
+                any is
+                    Foo
+            // Incorrectly formatted - should be fixed
+            fun foo2(any: Any): Boolean =
+                any is
+                    Bar
+            // Correctly formatted
+            fun foo3(any: Any): Boolean =
+                any is
+                    Foo
+            """.trimIndent()
