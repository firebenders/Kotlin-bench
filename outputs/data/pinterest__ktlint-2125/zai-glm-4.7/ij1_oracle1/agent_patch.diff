+    @Test
+    fun `Given a multiline IS_EXPRESSION`() {
+        val code =
+            """
+            class Foo
+
+            fun foo(any: Any) = any is
+                Foo
+            """.trimIndent()
+        indentationRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a multiline IS_EXPRESSION with incorrect indentation`() {
+        val code =
+            """
+            class Foo
+
+            fun foo(any: Any) =
+                any is
+                Foo
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Foo
+
+            fun foo(any: Any) =
+                any is
+                    Foo
+            """.trimIndent()
+        indentationRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(5, 1, "Unexpected indentation (4) (should be 8)"),
+            ).isFormattedAs(formattedCode)
+    }
+
