+// Verification test for IS_EXPRESSION and PREFIX_EXPRESSION indentation
+
+class Foo
+class Bar
+
+// IS_EXPRESSION test case 1: multiline 'is' expression
+fun isExpressionTest1(any: Any) = any is
+    Foo
+
+// IS_EXPRESSION test case 2: another example
+fun isExpressionTest2(any: Any) = any is
+    Bar
+
+// PREFIX_EXPRESSION test case 1: multiline prefix expression
+fun prefixExpressionTest1(x: Int) = ++
+    42
+
+// PREFIX_EXPRESSION test case 2: another example
+fun prefixExpressionTest2(x: Int) = --
+    100
+
+// Combined test
+fun testCombine(any: Any, x: Int) = (any is
+    Foo) && (++
+    x)
+

