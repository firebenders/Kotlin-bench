+    private fun removeUnexpectedSpacingAround(
+        node: ASTNode,
+        autoCorrect: Boolean,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+    ) {
+        val prevSibling = node.prevSibling()
+        val unexpectedSpacingBefore = prevSibling.isWhiteSpace()
+        val nextSibling = node.nextSibling()
+        val unexpectedSpacingAfter = nextSibling.isWhiteSpace()
+        when {
+            unexpectedSpacingBefore && unexpectedSpacingAfter -> {
+                emit(prevSibling!!.startOffset, "Unexpected spacing around \":\"", true)
+                if (autoCorrect) {
+                    prevSibling.treeParent.removeChild(prevSibling)
+                    nextSibling!!.treeParent.removeChild(nextSibling)
+                }
+            }
+            unexpectedSpacingBefore -> {
+                emit(prevSibling!!.startOffset, "Unexpected spacing before \":\"", true)
+                if (autoCorrect) {
+                    prevSibling.treeParent.removeChild(prevSibling)
+                }
+            }
+            unexpectedSpacingAfter -> {
+                emit(nextSibling!!.startOffset, "Unexpected spacing after \":\"", true)
+                if (autoCorrect) {
+                    nextSibling.treeParent.removeChild(nextSibling)
+                }
+            }
+        }
+    }
+
     private inline val ASTNode.removeSpacingBefore: Boolean
         get() =
             psi

diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundColonInAnnotationRuleTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundColonInAnnotationRuleTest.kt
