+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class SpacingAroundColonAnnotationSimpleTest {
+    private val spacingAroundColonRuleAssertThat = assertThatRule { SpacingAroundColonRule() }
+
+    @Test
+    fun `Given an annotation with spacing before the colon then a violation should be reported and fixed`() {
+        val code =
+            """
+            @file :JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 7, "Unexpected spacing before \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation with spacing after the colon then a violation should be reported and fixed`() {
+        val code =
+            """
+            @file: JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 7, "Unexpected spacing after \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation with spacing before and after the colon then violations should be reported and fixed`() {
+        val code =
+            """
+            @file : JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                com.pinterest.ktlint.test.LintViolation(1, 7, "Unexpected spacing before \":\""),
+                com.pinterest.ktlint.test.LintViolation(1, 8, "Unexpected spacing after \":\""),
+            ).isFormattedAs(formattedCode)
+    }
+}
+

