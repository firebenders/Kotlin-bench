@@ -0,0 +1,88 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class SpacingAroundColonAnnotationRuleTest {
+    private val spacingAroundColonRuleAssertThat = assertThatRule { SpacingAroundColonRule() }
+
+    @Test
+    fun `Given an annotation with spacing around the colon then remove it`() {
+        val code =
+            """
+            @file : JvmName("Foo")
+            class A {
+                @set : [Inject]
+                var x = 1
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            class A {
+                @set:[Inject]
+                var x = 1
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 7, "Unexpected spacing around \":\""),
+                LintViolation(3, 10, "Unexpected spacing around \":\""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation with newline around the colon then remove it`() {
+        val code =
+            """
+            @file
+            :JvmName("Foo")
+            class A {
+                @set
+                :
+                [Inject]
+                var x = 1
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            class A {
+                @set:[Inject]
+                var x = 1
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 6, "Unexpected newline before \":\""),
+                LintViolation(5, 5, "Unexpected spacing around \":\""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation with comment around the colon then keep the comment`() {
+        val code =
+            """
+            @file/*comment*/ : JvmName("Foo")
+            class A {
+                @set : /*comment*/[Inject]
+                var x = 1
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file/*comment*/:JvmName("Foo")
+            class A {
+                @set:/*comment*/[Inject]
+                var x = 1
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 18, "Unexpected spacing around \":\""),
+                LintViolation(3, 10, "Unexpected spacing around \":\""),
+            ).isFormattedAs(formattedCode)
+    }
+}
+

