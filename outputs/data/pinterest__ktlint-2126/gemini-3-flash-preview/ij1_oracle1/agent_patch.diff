diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundColonAnnotationRuleTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundColonAnnotationRuleTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundColonAnnotationRuleTest.kt
@@ -0,0 +1,108 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class SpacingAroundColonAnnotationRuleTest {
+    private val spacingAroundColonRuleAssertThat = assertThatRule { SpacingAroundColonRule() }
+
+    @Test
+    fun `Given an annotation with space before colon`() {
+        val code =
+            """
+            @file :JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 7, "Unexpected spacing before \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation with space after colon`() {
+        val code =
+            """
+            @file: JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 7, "Unexpected spacing after \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation with space before and after colon`() {
+        val code =
+            """
+            @file : JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 7, "Unexpected spacing before \":\""),
+                LintViolation(1, 8, "Unexpected spacing after \":\"")
+            )
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation with newline before colon`() {
+        val code =
+            """
+            @file
+            :JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 6, "Unexpected newline before \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given an annotation with a colon in its argument then do not remove the spacing around that colon`() {
+        val code =
+            """
+            @Ann(arg = object : Foo {})
+            val foo = "foo"
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an annotation entry with space before and after colon`() {
+        val code =
+            """
+            class Example {
+                @set : [Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Example {
+                @set:[Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(2, 10, "Unexpected spacing before \":\""),
+                LintViolation(2, 11, "Unexpected spacing after \":\"")
+            )
+            .isFormattedAs(formattedCode)
+    }
+}
