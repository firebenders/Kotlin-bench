+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundColonRuleAnnotationTest.kt
@@ -0,0 +1,62 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class SpacingAroundColonRuleAnnotationTest {
+    private val spacingAroundColonRuleAssertThat = assertThatRule { SpacingAroundColonRule() }
+
+    @Test
+    fun `Given annotation use-site targets with spacing before the colon`() {
+        val code =
+            """
+            @file :JvmName("Foo")
+            class Example {
+                @set :[Inject VisibleForTesting]
+                lateinit var collaborator: Collaborator
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            class Example {
+                @set:[Inject VisibleForTesting]
+                lateinit var collaborator: Collaborator
+            }
+            """.trimIndent()
+
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 7, "Unexpected spacing before \":\""),
+                LintViolation(3, 10, "Unexpected spacing before \":\""),
+            ).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given annotation use-site targets with spacing after the colon`() {
+        val code =
+            """
+            @file: JvmName("Foo")
+            class Example {
+                @set: [Inject VisibleForTesting]
+                lateinit var collaborator: Collaborator
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            class Example {
+                @set:[Inject VisibleForTesting]
+                lateinit var collaborator: Collaborator
+            }
+            """.trimIndent()
+
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 7, "Unexpected spacing after \":\""),
+                LintViolation(3, 10, "Unexpected spacing after \":\""),
+            ).isFormattedAs(formattedCode)
+}
+}
+

