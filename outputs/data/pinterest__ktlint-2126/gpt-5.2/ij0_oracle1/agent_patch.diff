@@ -0,0 +1,54 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class SpacingAroundColonRuleAnnotationSpacingTest {
+    private val spacingAroundColonRuleAssertThat = assertThatRule { SpacingAroundColonRule() }
+
+    @Test
+    fun `Given annotation use-site targets with spacing around colon then remove the spacing`() {
+        val code =
+            """
+            @file :JvmName("Foo")
+            @file: JvmName("Foo")
+            @file : JvmName("Foo")
+            class Example {
+                @set :[Inject VisibleForTesting]
+                var foo: Int = 0
+                @set: [Inject VisibleForTesting]
+                var bar: Int = 0
+                @set : [Inject VisibleForTesting]
+                var baz: Int = 0
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            @file:JvmName("Foo")
+            @file:JvmName("Foo")
+            class Example {
+                @set:[Inject VisibleForTesting]
+                var foo: Int = 0
+                @set:[Inject VisibleForTesting]
+                var bar: Int = 0
+                @set:[Inject VisibleForTesting]
+                var baz: Int = 0
+            }
+            """.trimIndent()
+
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 7, "Unexpected spacing before \":\""),
+                LintViolation(2, 7, "Unexpected spacing after \":\""),
+                LintViolation(3, 7, "Unexpected spacing before \":\""),
+                LintViolation(3, 8, "Unexpected spacing after \":\""),
+                LintViolation(5, 10, "Unexpected spacing before \":\""),
+                LintViolation(7, 10, "Unexpected spacing after \":\""),
+                LintViolation(9, 10, "Unexpected spacing before \":\""),
+                LintViolation(9, 11, "Unexpected spacing after \":\""),
+            ).isFormattedAs(formattedCode)
+}
+}
+

