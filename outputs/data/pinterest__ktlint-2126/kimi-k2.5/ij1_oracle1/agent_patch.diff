--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/SpacingAroundColonRuleAnnotationTest.kt
@@ -0,0 +1,202 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class SpacingAroundColonRuleAnnotationTest {
+    private val spacingAroundColonRuleAssertThat = assertThatRule { SpacingAroundColonRule() }
+
+    @Test
+    fun `Given valid annotation use-site targets without spacing`() {
+        // https://kotlinlang.org/docs/annotations.html#annotation-use-site-targets
+        val code =
+            """
+            @file:JvmName("Foo")
+            class Example(@field:Ann val foo: String, @get:Ann val bar: String)
+            class Example {
+                @set:[Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            fun @receiver:Fancy String.myExtension() { }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given annotation with spacing before colon`() {
+        val code =
+            """
+            @file :JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 7, "Unexpected spacing before \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given annotation with spacing after colon`() {
+        val code =
+            """
+            @file: JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 6, "Unexpected spacing after \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given annotation with spacing around colon`() {
+        val code =
+            """
+            @file : JvmName("Foo")
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 7, "Unexpected spacing around \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given annotation entry with spacing before colon`() {
+        val code =
+            """
+            class Example(@field :Ann val foo: String)
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Example(@field:Ann val foo: String)
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 22, "Unexpected spacing before \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given annotation entry with spacing after colon`() {
+        val code =
+            """
+            class Example(@field: Ann val foo: String)
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Example(@field:Ann val foo: String)
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 21, "Unexpected spacing after \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given annotation entry with spacing around colon`() {
+        val code =
+            """
+            class Example(@field : Ann val foo: String)
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Example(@field:Ann val foo: String)
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(1, 22, "Unexpected spacing around \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given set annotation use-site target with spacing before colon`() {
+        val code =
+            """
+            class Example {
+                @set :[Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Example {
+                @set:[Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(2, 10, "Unexpected spacing before \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given set annotation use-site target with spacing after colon`() {
+        val code =
+            """
+            class Example {
+                @set: [Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Example {
+                @set:[Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(2, 9, "Unexpected spacing after \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given set annotation use-site target with spacing around colon`() {
+        val code =
+            """
+            class Example {
+                @set : [Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class Example {
+                @set:[Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolation(2, 10, "Unexpected spacing around \":\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given multiple annotations with spacing issues`() {
+        val code =
+            """
+            @file :JvmName("Foo")
+            @file : Suppress("unused")
+            class Example(@field :Ann val foo: String, @get: Ann val bar: String)
+            """.trimIndent()
+        val formattedCode =
+            """
+            @file:JvmName("Foo")
+            @file:Suppress("unused")
+            class Example(@field:Ann val foo: String, @get:Ann val bar: String)
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 7, "Unexpected spacing before \":\""),
+                LintViolation(2, 7, "Unexpected spacing around \":\""),
+                LintViolation(3, 22, "Unexpected spacing before \":\""),
+                LintViolation(3, 48, "Unexpected spacing after \":\""),
+            ).isFormattedAs(formattedCode)
+    }
+}
+

