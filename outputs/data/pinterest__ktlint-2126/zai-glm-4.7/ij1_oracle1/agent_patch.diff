@@ -0,0 +1,89 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+class SpacingAroundColonRuleAnnotationTest {
+    private val spacingAroundColonRuleAssertThat = assertThatRule { SpacingAroundColonRule() }
+
+    @Test
+    fun `Given annotation use-site targets with correct spacing`() {
+        val code =
+            """
+            @file:JvmName("Foo")
+            class Example(@field:Ann val foo: String, @get:Ann val bar: String)
+            class Example {
+                @set:[Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            fun @receiver:Fancy String.myExtension() { }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given annotation use-site targets with spacing before colon`() {
+        val code =
+            """
+            @file :JvmName("Foo")
+            class Example(@field :Ann val foo: String, @get :Ann val bar: String)
+            class Example {
+                @set :[Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 7, "Unexpected spacing before \":\""),
+                LintViolation(2, 22, "Unexpected spacing before \":\""),
+                LintViolation(2, 49, "Unexpected spacing before \":\""),
+                LintViolation(4, 10, "Unexpected spacing before \":\""),
+            )
+    }
+
+    @Test
+    fun `Given annotation use-site targets with spacing after colon`() {
+        val code =
+            """
+            @file: JvmName("Foo")
+            class Example(@field: Ann val foo: String, @get: Ann val bar: String)
+            class Example {
+                @set: [Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 6, "Unexpected spacing after \":\""),
+                LintViolation(2, 21, "Unexpected spacing after \":\""),
+                LintViolation(2, 48, "Unexpected spacing after \":\""),
+                LintViolation(4, 9, "Unexpected spacing after \":\""),
+            )
+    }
+
+    @Test
+    fun `Given annotation use-site targets with spacing on both sides of colon`() {
+        val code =
+            """
+            @file : JvmName("Foo")
+            class Example(@field : Ann val foo: String, @get : Ann val bar: String)
+            class Example {
+                @set : [Inject VisibleForTesting]
+                public var collaborator: Collaborator
+            }
+            """.trimIndent()
+        spacingAroundColonRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(1, 7, "Unexpected spacing before \":\""),
+                LintViolation(1, 7, "Unexpected spacing after \":\""),
+                LintViolation(2, 22, "Unexpected spacing before \":\""),
+                LintViolation(2, 22, "Unexpected spacing after \":\""),
+                LintViolation(2, 50, "Unexpected spacing before \":\""),
+                LintViolation(2, 50, "Unexpected spacing after \":\""),
+                LintViolation(4, 10, "Unexpected spacing before \":\""),
+                LintViolation(4, 10, "Unexpected spacing after \":\""),
+            )
+    }
+}
+

