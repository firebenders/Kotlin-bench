+            }
+        }
+
+        // Check for spacing after the colon
+        val nextSibling = node.nextSibling()
+        if (nextSibling != null && nextSibling.isWhiteSpace()) {
+            emit(node.startOffset, "Unexpected spacing after \":\"", true)
+            if (autoCorrect) {
+                node.treeParent.removeChild(nextSibling)
+            }
