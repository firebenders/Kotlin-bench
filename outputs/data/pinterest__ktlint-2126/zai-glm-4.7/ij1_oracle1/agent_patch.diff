+    private fun emitAnnotationSpacingViolations(
+        node: ASTNode,
+        autoCorrect: Boolean,
+        emit: (offset: Int, errorMessage: String, canBeAutoCorrected: Boolean) -> Unit,
+    ) {
+        // Check for spacing before the colon
+        val prevSibling = node.prevSibling()
+        if (prevSibling != null && prevSibling.isWhiteSpace()) {
+            emit(node.startOffset, "Unexpected spacing before \":\"", true)
+            if (autoCorrect) {
