@@ -0,0 +1,156 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.intellij_idea
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.ktlint_official
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Nested
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for consistent parenthesized expression indentation.
+ *
+ * This addresses the issue where parenthesized expressions inside if-else blocks
+ * had inconsistent indentation - the closing ")" was unexpectedly indented compared
+ * to how the if statement's own parentheses were handled.
+ *
+ * For ktlint_official code style, the closing ")" should align with the opening "(".
+ */
+internal class ParenthesizedExpressionIndentationTest {
+    private val indentationRuleAssertThat = assertThatRule { IndentationRule() }
+
+    @Nested
+    inner class `Given a parenthesized expression inside an if-else block` {
+        @Test
+        fun `Given ktlint_official code style, the closing paren should align with opening paren`() {
+            val code =
+                """
+                fun test() {
+                    val pass = if (condition1) {
+                        (
+                            condition2
+                        )
+                    } else {
+                        condition3
+                    }
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given intellij_idea code style, the closing paren is indented (default behavior)`() {
+            val code =
+                """
+                fun test() {
+                    val pass = if (condition1) {
+                        (
+                            condition2
+                            )
+                    } else {
+                        condition3
+                    }
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to intellij_idea)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given ktlint_official code style with multiline if condition, parenthesized expression should be consistent`() {
+            val code =
+                """
+                fun test() {
+                    if (
+                        condition1
+                    ) {
+                        (
+                            condition2
+                        )
+                    } else {
+                        condition3
+                    }
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given ktlint_official code style with nested parenthesized expressions`() {
+            val code =
+                """
+                fun test() {
+                    val result = if (condition1) {
+                        (
+                            (
+                                nestedCondition
+                            )
+                        )
+                    } else {
+                        other
+                    }
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given ktlint_official code style, parenthesized expression outside if should also have aligned closing paren`() {
+            val code =
+                """
+                fun test() {
+                    val result =
+                        (
+                            someExpression
+                        )
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given ktlint_official code style with parenthesized expression in when branch`() {
+            val code =
+                """
+                fun test() {
+                    val result = when {
+                        condition -> (
+                            value
+                        )
+                        else -> other
+                    }
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasNoLintViolations()
+        }
+
+        @Test
+        fun `Given ktlint_official code style with parenthesized expression in lambda body`() {
+            val code =
+                """
+                fun test() {
+                    items.forEach {
+                        (
+                            someExpression
+                        )
+                    }
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasNoLintViolations()
+        }
+    }
+}
+

