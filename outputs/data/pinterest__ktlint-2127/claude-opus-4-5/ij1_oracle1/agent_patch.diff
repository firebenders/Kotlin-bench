+        @Test
+        fun `Issue 1210 - Given a parenthesized expression inside an if-else body with block`() {
+            val code =
+                """
+                val pass = if (condition1) {
+                    (
+                        condition2
+                    )
+                } else {
+                    condition3
+                }
+                """.trimIndent()
+            indentationRuleAssertThat(code)
+                .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+                .hasNoLintViolations()
+        }
+
