+    private fun visitParenthesized(node: ASTNode) {
+        if (codeStyle == ktlint_official) {
+            // In ktlint_official code style, the opening and closing parentheses should be aligned with each other.
+            // This allows:
+            //     val foo = if (condition) {
+            //         (
+            //             expression
+            //         )
+            //     }
+            // instead of the IDEA quirk:
+            //     val foo = if (condition) {
+            //         (
+            //                 expression
+            //             )
+            //     }
+            // This behavior matches how if-condition parentheses are handled:
+            //     if (
+            //         condition
+            //     ) { ... }
+            if (node.isInsideIfBody()) {
+                startIndentContext(
+                    fromAstNode = node,
+                    firstChildIndent = "",
+                    lastChildIndent = "",
+                )
+                return
+            }
+        } else {
+            // For non-ktlint_official code styles, maintain IDEA formatter compatibility by only skipping
+            // the indent context when PARENTHESIZED is a direct child of THEN/ELSE (without BLOCK wrapper).
+            if (node.treeParent.treeParent.elementType == IF) {
+                return
+            }
+        }
+        startIndentContext(node)
+    }
+
+    private fun ASTNode.isInsideIfBody(): Boolean =
+        parent { it.elementType == THEN || it.elementType == ELSE }
+            ?.parent(IF) != null
