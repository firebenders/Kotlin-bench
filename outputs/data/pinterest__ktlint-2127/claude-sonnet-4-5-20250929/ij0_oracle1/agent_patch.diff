+    private fun ASTNode.isParenthesizedInIfThenOrElseBlock(): Boolean {
+        // Check if this PARENTHESIZED node is inside a THEN or ELSE block of an IF statement
+        val blockParent = treeParent
+        if (blockParent.elementType == BLOCK) {
+            val thenOrElseParent = blockParent.treeParent
+            if (thenOrElseParent?.elementType == THEN || thenOrElseParent?.elementType == ELSE) {
+                // Check if this THEN or ELSE is part of an IF statement
+                return thenOrElseParent.treeParent?.elementType == IF
+            }
+        }
+        return false
+    }
