diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/MissingWhitespaceBeforeFunctionBodyIssueTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/MissingWhitespaceBeforeFunctionBodyIssueTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/MissingWhitespaceBeforeFunctionBodyIssueTest.kt
@@ -0,0 +1,160 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.ktlint_official
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import com.pinterest.ktlint.test.LintViolation
+import org.junit.jupiter.api.Test
+
+/**
+ * Test for issue: Missing whitespace before function body is inserted in wrong place in AST.
+ *
+ * Given code without space before function body block, ktlint was not able to format the code
+ * correctly in 3 runs because the whitespace was being inserted in the wrong position in the AST.
+ *
+ * Multiple rules (curly-spacing, function-start-of-body-spacing, function-signature) were all
+ * detecting the same error, and the fix was being applied incorrectly, causing format to fail
+ * to resolve all violations in 3 consecutive runs.
+ */
+class MissingWhitespaceBeforeFunctionBodyIssueTest {
+    private val functionStartOfBodySpacingRuleAssertThat = assertThatRule { FunctionStartOfBodySpacingRule() }
+    private val spacingAroundCurlyRuleAssertThat = assertThatRule { SpacingAroundCurlyRule() }
+    private val functionSignatureRuleAssertThat = assertThatRule { FunctionSignatureRule() }
+
+    @Test
+    fun `Given a function in a class with missing space before body block, then FunctionStartOfBodySpacingRule should correctly format`() {
+        val code =
+            """
+            class UampNotificationManager(
+                private val context: Context,
+                sessionToken: MediaSessionCompat.Token,
+                notificationListener: PlayerNotificationManager.NotificationListener,
+            ) {
+                fun showNotificationForPlayer(player: Player){
+                    notificationManager.setPlayer(player)
+                }
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class UampNotificationManager(
+                private val context: Context,
+                sessionToken: MediaSessionCompat.Token,
+                notificationListener: PlayerNotificationManager.NotificationListener,
+            ) {
+                fun showNotificationForPlayer(player: Player) {
+                    notificationManager.setPlayer(player)
+                }
+            }
+            """.trimIndent()
+        functionStartOfBodySpacingRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .hasLintViolation(6, 50, "Expected a single white space before start of function body")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function in a class with missing space before body block, then SpacingAroundCurlyRule should correctly format`() {
+        val code =
+            """
+            class UampNotificationManager(
+                private val context: Context,
+                sessionToken: MediaSessionCompat.Token,
+                notificationListener: PlayerNotificationManager.NotificationListener,
+            ) {
+                fun showNotificationForPlayer(player: Player){
+                    notificationManager.setPlayer(player)
+                }
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class UampNotificationManager(
+                private val context: Context,
+                sessionToken: MediaSessionCompat.Token,
+                notificationListener: PlayerNotificationManager.NotificationListener,
+            ) {
+                fun showNotificationForPlayer(player: Player) {
+                    notificationManager.setPlayer(player)
+                }
+            }
+            """.trimIndent()
+        spacingAroundCurlyRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .hasLintViolation(6, 50, "Missing spacing before \"{\"")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function in a class with missing space before body block, when multiple rules run together then format should succeed`() {
+        val code =
+            """
+            class UampNotificationManager(
+                private val context: Context,
+                sessionToken: MediaSessionCompat.Token,
+                notificationListener: PlayerNotificationManager.NotificationListener,
+            ) {
+                fun showNotificationForPlayer(player: Player){
+                    notificationManager.setPlayer(player)
+                }
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            class UampNotificationManager(
+                private val context: Context,
+                sessionToken: MediaSessionCompat.Token,
+                notificationListener: PlayerNotificationManager.NotificationListener,
+            ) {
+                fun showNotificationForPlayer(player: Player) {
+                    notificationManager.setPlayer(player)
+                }
+            }
+            """.trimIndent()
+        // When multiple rules run together, the format should succeed without requiring multiple passes
+        functionStartOfBodySpacingRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .addAdditionalRuleProvider { SpacingAroundCurlyRule() }
+            .addAdditionalRuleProvider { FunctionSignatureRule() }
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a simple function with missing space before body block then format should succeed`() {
+        val code =
+            """
+            fun foo(){
+                // do something
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo() {
+                // do something
+            }
+            """.trimIndent()
+        functionStartOfBodySpacingRuleAssertThat(code)
+            .hasLintViolation(1, 10, "Expected a single white space before start of function body")
+            .isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Given a function with return type and missing space before body block then format should succeed`() {
+        val code =
+            """
+            fun bar(): String{
+                return "some-result"
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun bar(): String {
+                return "some-result"
+            }
+            """.trimIndent()
+        functionStartOfBodySpacingRuleAssertThat(code)
+            .hasLintViolation(1, 18, "Expected a single white space before start of function body")
+            .isFormattedAs(formattedCode)
+    }
+}
+

