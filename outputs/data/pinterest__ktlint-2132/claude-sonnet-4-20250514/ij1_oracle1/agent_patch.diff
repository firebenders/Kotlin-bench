diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/FunctionBodyWhitespaceConflictTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/FunctionBodyWhitespaceConflictTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/FunctionBodyWhitespaceConflictTest.kt
@@ -0,0 +1,91 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.RuleProvider
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+/**
+ * Integration test to verify that the conflict between multiple rules inserting
+ * whitespace before function body blocks has been resolved.
+ *
+ * This was reported as an issue where FunctionStartOfBodySpacingRule, SpacingAroundCurlyRule,
+ * and FunctionSignatureRule were all trying to insert whitespace at the same location,
+ * causing format to not converge in 3 consecutive runs.
+ */
+class FunctionBodyWhitespaceConflictTest {
+
+    private val ruleSetAssertThat = assertThatRule(
+        provider = { FunctionSignatureRule() },
+        additionalRuleProviders = setOf(
+            RuleProvider { FunctionStartOfBodySpacingRule() },
+            RuleProvider { SpacingAroundCurlyRule() }
+        )
+    )
+
+    @Test
+    fun `Function with missing whitespace before body block should format correctly in one pass`() {
+        val code = """
+            class UampNotificationManager(
+                private val context: Context,
+                sessionToken: MediaSessionCompat.Token,
+                notificationListener: PlayerNotificationManager.NotificationListener,
+            ) {
+                fun showNotificationForPlayer(player: Player){
+                    notificationManager.setPlayer(player)
+                }
+            }
+        """.trimIndent()
+
+        val formattedCode = """
+            class UampNotificationManager(
+                private val context: Context,
+                sessionToken: MediaSessionCompat.Token,
+                notificationListener: PlayerNotificationManager.NotificationListener,
+            ) {
+                fun showNotificationForPlayer(player: Player) {
+                    notificationManager.setPlayer(player)
+                }
+            }
+        """.trimIndent()
+
+        // This should format correctly without requiring multiple passes
+        // Previously this would fail with "Format was not able to resolve all violations
+        // which (theoretically) can be autocorrected in 3 consecutive runs of format"
+        ruleSetAssertThat(code).isFormattedAs(formattedCode)
+    }
+
+    @Test
+    fun `Various function body whitespace scenarios should format correctly`() {
+        val code = """
+            fun foo(){
+                return 1
+            }
+
+            fun bar()  {
+                return 2
+            }
+
+            fun baz()
+            {
+                return 3
+            }
+        """.trimIndent()
+
+        val formattedCode = """
+            fun foo() {
+                return 1
+            }
+
+            fun bar() {
+                return 2
+            }
+
+            fun baz() {
+                return 3
+            }
+        """.trimIndent()
+
+        ruleSetAssertThat(code).isFormattedAs(formattedCode)
+    }
+}
+

