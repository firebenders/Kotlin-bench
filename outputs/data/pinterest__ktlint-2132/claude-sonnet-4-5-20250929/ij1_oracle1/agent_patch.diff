+private fun noIntermediateCodeElements(
+    from: ASTNode,
+    to: ASTNode,
+): Boolean {
+    var current = from.nextLeaf()
+    while (current != null && current != to) {
+        if (current.elementType != WHITE_SPACE && !current.isPartOfComment()) {
+            return false
+        }
+        current = current.nextLeaf()
+    }
+    return current == to
+}
