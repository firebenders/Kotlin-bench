+private fun insertWhitespaceBetweenLeaves(
+    leftLeaf: ASTNode,
+    rightLeaf: ASTNode,
+    text: String,
+) {
+    val commonParent = lowestCommonAncestor(leftLeaf, rightLeaf)
+    val rightChild = rightLeaf.childOf(commonParent)
+    PsiWhiteSpaceImpl(text).also { psiWhiteSpace ->
+        commonParent.addChild(psiWhiteSpace, rightChild)
+    }
+}
+
+private fun ASTNode.childOf(ancestor: ASTNode): ASTNode {
+    var current = this
+    while (current.treeParent != null && current.treeParent != ancestor) {
+        current = current.treeParent
+    }
+    return current
+}
+
+private fun lowestCommonAncestor(
+    left: ASTNode,
+    right: ASTNode,
+): ASTNode {
+    val leftAncestors = generateSequence(left) { it.treeParent }.toSet()
+    var current: ASTNode? = right
+    while (current != null && current !in leftAncestors) {
+        current = current.treeParent
+    }
+    return requireNotNull(current) { "Nodes do not share a common ancestor" }
+}
