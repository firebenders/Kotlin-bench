+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.MAX_LINE_LENGTH_PROPERTY
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+/**
+ * Test for the issue: "Endless loop in wrapping binary expression after elvis operator"
+ * https://github.com/pinterest/ktlint/issues/2296
+ *
+ * When a line ends with `?:` and the right-hand side expression is long enough that wrapping
+ * after the elvis operator would still exceed max line length (because ChainWrappingRule will
+ * move `?:` to the start of the next line), ktlint should not try to auto-correct as it
+ * would result in an endless loop.
+ */
+class BinaryExpressionWrappingElvisIssueTest {
+    private val binaryExpressionWrappingRuleAssertThat = KtLintAssertThat.assertThatRule { BinaryExpressionWrappingRule() }
+
+    @Test
+    fun `Given a binary expression with elvis operator where right-hand side exceeds max line length when wrapped`() {
+        // When the right-hand side is so long that even when placed on a new line with "?: " prefix,
+        // it would still exceed max line length, wrapping should not be auto-corrected to avoid an
+        // endless loop with ChainWrappingRule.
+        // Line: "    foobar ?: throw Exception()" = 31 chars
+        // After ChainWrappingRule: "        ?: throw Exception()" = 28 chars
+        // With max_line_length = 27, wrapped line still exceeds, so auto-correct would fail.
+        val code =
+            """
+            val foo =
+                foobar ?: throw Exception()
+            """.trimIndent()
+        binaryExpressionWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 27)
+            .hasLintViolationWithoutAutoCorrect(2, 12, "Line is exceeding max line length")
+    }
+
+    @Test
+    fun `Given a binary expression with elvis operator where right-hand side fits when wrapped`() {
+        // When the right-hand side is short enough that it fits when placed on a new line
+        // with "?: " prefix, wrapping should be auto-corrected.
+        // Line: "    foobar ?: throw Exception()" = 31 chars
+        // After ChainWrappingRule: "        ?: throw Exception()" = 28 chars
+        // With max_line_length = 30, the original exceeds but wrapped fits.
+        val code =
+            """
+            val foo =
+                foobar ?: throw Exception()
+            """.trimIndent()
+        val formattedCode =
+            """
+            val foo =
+                foobar ?:
+                    throw Exception()
+            """.trimIndent()
+        binaryExpressionWrappingRuleAssertThat(code)
+            .withEditorConfigOverride(MAX_LINE_LENGTH_PROPERTY to 30)
+            .hasLintViolation(2, 14, "Line is exceeding max line length. Break line after operator in binary expression")
+            .isFormattedAs(formattedCode)
+    }
+}
+

