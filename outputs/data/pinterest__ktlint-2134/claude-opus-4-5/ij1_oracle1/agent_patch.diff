+    @Test
+    fun `Given an elvis expression for which the right hand side expression exceeds the max line length then wrap before the elvis operator`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                          $EOL_CHAR
+            val foo =
+                bar ?: throw UnsupportedOperationException("foobar")
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                          $EOL_CHAR
+            val foo =
+                bar
+                    ?: throw UnsupportedOperationException("foobar")
+            """.trimIndent()
+        binaryExpressionWrappingRuleAssertThat(code)
+            .addAdditionalRuleProvider { ChainWrappingRule() }
+            .setMaxLineLength()
+            .hasLintViolation(3, 9, "Line is exceeding max line length. Break line before operator in binary expression")
+            .isFormattedAs(formattedCode)
+    }
+
