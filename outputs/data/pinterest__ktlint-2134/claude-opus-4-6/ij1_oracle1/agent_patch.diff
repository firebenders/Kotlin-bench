+    private fun wrappingOfElvisOperatorCausesInfiniteLoop(operationReference: ASTNode): Boolean {
+        if (operationReference.firstChildNode?.elementType != ELVIS) {
+            return false
+        }
+        // When the binary expression is wrapped at the elvis operator, the chain-wrapping rule will move the elvis operator
+        // to the beginning of the next line (as a line may not end with an elvis operator). If the resulting line still
+        // exceeds the max line length, wrapping and chain-wrapping will keep undoing each other, causing an infinite loop.
+        val indent = operationReference.indent(includeNewline = false)
+        val indentLength = indent.length + indentConfig.indent.length
+        val rightHandSideExpression = operationReference.nextCodeSibling() ?: return false
+        // After chain-wrapping, the line will be: <indent><extra-indent>?: <right-hand-side-first-line>
+        // Only consider the first line of the right-hand side expression as multi-line expressions would be split across
+        // multiple lines.
+        val rightHandSideFirstLineLength = rightHandSideExpression.text.substringBefore('\n').length
+        val lineLength = indentLength + "?: ".length + rightHandSideFirstLineLength
+        return lineLength > maxLineLength
+    }
