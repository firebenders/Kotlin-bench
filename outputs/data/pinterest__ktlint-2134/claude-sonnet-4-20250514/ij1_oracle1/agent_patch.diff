             .hasLintViolationWithoutAutoCorrect(3, 17, "Line is exceeding max line length")
     }
+
+    @Test
+    fun `Given binary expression after elvis operator that exceeds max line length, should not autocorrect to avoid endless loop`() {
+        val code =
+            """
+            val foo =
+                bar
+                    ?:
+                    throw UnsupportedOperationException("xxxxxxxxxxx")
+            """.trimIndent()
+
+        // With max line length of 60, the line containing the throw statement would exceed the limit.
+                // The binary expression wrapping rule should detect this but should not attempt to autocorrect
+        // after the elvis operator to avoid infinite loops with the chain wrapping rule
+        binaryExpressionWrappingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(3, 9, "Line is exceeding max line length")
+    }
+
+    @Test
+    fun `Given a property with elvis operator and long expression matching original issue`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                           $EOL_CHAR
+            val foo =
+                bar
+                    ?:
+                    throw UnsupportedOperationException("xxxxxxxxxxx")
+            """.trimIndent()
+
+        // This test specifically addresses the endless loop issue from GitHub issue.
+        // The line with the throw statement exceeds the max line length marker (60 chars).
+        // Previously this would cause an endless loop because BinaryExpressionWrappingRule
+        // would wrap after ?:, but ChainWrappingRule would move ?: to beginning of next line.
+        binaryExpressionWrappingRuleAssertThat(code)
+            .addAdditionalRuleProvider { ChainWrappingRule() }
+            .setMaxLineLength()
+            .hasLintViolationWithoutAutoCorrect(3, 9, "Line is exceeding max line length")
+    }
+
+    @Test
+    fun `Given a regular binary expression (not elvis), wrapping should still work normally`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                         $EOL_CHAR
+            val bar =
+                leftHandSideExpression && rightHandSideExpression
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                         $EOL_CHAR
+            val bar =
+                leftHandSideExpression &&
+                    rightHandSideExpression
+            """.trimIndent()
+        // Ensure regular binary expressions still work correctly after the elvis fix
+        binaryExpressionWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .hasLintViolation(3, 30, "Line is exceeding max line length. Break line after operator in binary expression")
+            .isFormattedAs(formattedCode)
+    }
 }

