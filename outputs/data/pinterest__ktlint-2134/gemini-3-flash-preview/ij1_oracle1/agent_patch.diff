diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/BinaryExpressionWrappingRuleElvisTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/BinaryExpressionWrappingRuleElvisTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/BinaryExpressionWrappingRuleElvisTest.kt
@@ -0,0 +1,32 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.EOL_CHAR
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.MAX_LINE_LENGTH_MARKER
+import org.junit.jupiter.api.Test
+
+class BinaryExpressionWrappingRuleElvisTest {
+    private val binaryExpressionWrappingRuleAssertThat = KtLintAssertThat.assertThatRule { BinaryExpressionWrappingRule() }
+
+    @Test
+    fun `Issue 2133 - Endless loop in wrapping binary expression after elvis operator`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                  $EOL_CHAR
+            val foo = bar ?: throw UnsupportedOperationException("xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx")
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                  $EOL_CHAR
+            val foo =
+                bar
+                    ?: throw UnsupportedOperationException("xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx")
+            """.trimIndent()
+        // This test case only checks BinaryExpressionWrappingRule in isolation.
+        // It verifies that it now wraps BEFORE the elvis operator, which prevents the loop with ChainWrappingRule.
+        binaryExpressionWrappingRuleAssertThat(code)
+            .setMaxLineLength()
+            .isFormattedAs(formattedCode)
+    }
+}
+

