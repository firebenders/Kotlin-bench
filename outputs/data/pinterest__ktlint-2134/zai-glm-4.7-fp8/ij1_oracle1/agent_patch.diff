+    @Test
+    fun `Given a property with elvis operator exceeding max line length`() {
+        val code =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                           $EOL_CHAR
+            val foo =
+                bar
+                    ?:
+                    throw UnsupportedOperationException("xxxxxxxxxxx")
+            """.trimIndent()
+        val formattedCode =
+            """
+            // $MAX_LINE_LENGTH_MARKER                                           $EOL_CHAR
+            val foo =
+                bar ?:
+                    throw UnsupportedOperationException("xxxxxxxxxxx")
+            """.trimIndent()
+        // The elvis operator is kept on the same line, but the right-hand side expression is indented.
