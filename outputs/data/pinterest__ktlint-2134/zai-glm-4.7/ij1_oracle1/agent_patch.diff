+    /**
+     * Checks whether wrapping should be avoided after an elvis operator.
+     *
+     * When the right-hand side of an elvis operator is already on a new line, wrapping after the operator
+     * would cause the line to end with the elvis operator. This creates an endless loop because:
+     * 1. BinaryExpressionWrappingRule wraps after the elvis operator
+     * 2. ChainWrappingRule detects the line ending with elvis operator and moves it to the next line
+     * 3. This causes the line to exceed max_line_length again
+     * 4. BinaryExpressionWrappingRule wraps again
+     * 5. Endless loop
+     */
+    private fun shouldNotWrapAfterElvisOperator(operationReference: ASTNode): Boolean {
+        // Check if this is an elvis operator
+        if (operationReference.firstChildLeafOrSelf().elementType != ELVIS) {
+            return false
+        }
+
+        // Check if the right-hand side is already on a new line
+        val nextSibling = operationReference.nextSibling() ?: return false
+        val nextSiblingFirstLeaf = nextSibling.firstChildLeafOrSelf()
+
+        // Look for whitespace before the next sibling
+        var node: ASTNode? = nextSiblingFirstLeaf
+        while (node != null && node != operationReference) {
+            if (node.textContains('\n')) {
+                // The right-hand side is already on a new line, so wrapping after the elvis operator
+                // would cause the line to end with the elvis operator
+                return true
+            }
+            node = node.prevLeaf()
+        }
+
+        return false
+    }
