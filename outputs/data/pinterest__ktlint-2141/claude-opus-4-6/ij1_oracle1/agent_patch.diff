+     * Determines whether a property has a mutable type. A property is considered mutable when:
+     * - It has an explicit type annotation that is a known mutable collection type (e.g., MutableMap, MutableList), or
+     * - It is initialized with a known mutable collection factory function (e.g., mutableMapOf, mutableListOf)
+     *
+     * Per https://developer.android.com/kotlin/style-guide#constant_names, mutable collection properties should not
+     * use SCREAMING_SNAKE_CASE even if declared as `val` in objects or at top-level.
+     */
+    private fun ASTNode.isMutableProperty(): Boolean {
+        // Check explicit type reference: val foo: MutableMap<K, V> = ...
+        findChildByType(TYPE_REFERENCE)
+            ?.let { typeReference ->
