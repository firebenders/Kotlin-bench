+    @Test
+    fun `Given mutable collection property in object then allow camelCase naming`() {
+        val code =
+            """
+            object Foo {
+                val someMap: MutableMap<String, Int> = mutableMapOf()
+                val SOME_LIST: MutableList<String> = mutableListOf() // Should be camelCase
+                val anotherSet: MutableSet<Int> = mutableSetOf()
+                val collection: MutableCollection<String> = mutableListOf()
+            }
+            """.trimIndent()
+        @Suppress("ktlint:standard:argument-list-wrapping", "ktlint:standard:max-line-length")
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(3, 9, "Property name should start with a lowercase letter and use camel case")
+    }
+
+    @Test
+    fun `Given immutable values in object then require SCREAMING_SNAKE_CASE`() {
+        val code =
+            """
+            object Foo {
+                val SOME_CONSTANT = "constant"
+                val IMMUTABLE_LIST: List<String> = listOf("a", "b")
+                val someVariable = "should be screaming case"
+            }
+            """.trimIndent()
+        @Suppress("ktlint:standard:argument-list-wrapping", "ktlint:standard:max-line-length")
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(4, 9, "Property name should use the screaming snake case notation when the value can not be changed")
