+    private fun ASTNode.isMutableCollection(): Boolean {
+        val typeReference = findChildByType(TYPE_REFERENCE) ?: return false
+        val typeText = typeReference.text
+        // Check if the direct type (not nested generics) is a mutable collection type
+        // These types are mutable even when declared as val, so they should not use screaming snake case
+        // Extract the main type name (before any generic parameters)
+        val mainTypeName = typeText.substringBefore('<').trim()
+        // Check if it's a mutable collection type (with or without package qualifier)
+        return mainTypeName == "MutableCollection" ||
+            mainTypeName == "MutableList" ||
+            mainTypeName == "MutableSet" ||
+            mainTypeName == "MutableMap" ||
+            mainTypeName == "MutableIterable" ||
+            mainTypeName.endsWith(".MutableCollection") ||
+            mainTypeName.endsWith(".MutableList") ||
+            mainTypeName.endsWith(".MutableSet") ||
+            mainTypeName.endsWith(".MutableMap") ||
+            mainTypeName.endsWith(".MutableIterable")
+    }
