+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+class PropertyNamingRuleMutableCollectionTest {
+    private val propertyNamingRuleAssertThat =
+        KtLintAssertThat.assertThatRule { PropertyNamingRule() }
+
+    @Test
+    fun `Given a mutable collection property in an object then do not emit`() {
+        val code =
+            """
+            object Foo {
+                val someMap: MutableMap<String, String> = mutableMapOf()
+                val someList: MutableList<String> = mutableListOf()
+                val someSet: MutableSet<String> = mutableSetOf()
+                val someArrayList: ArrayList<String> = arrayListOf()
+                val someHashMap: HashMap<String, String> = hashMapOf()
+                val someHashSet: HashSet<String> = hashSetOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a mutable collection property at top level then do not emit`() {
+        val code =
+            """
+            val someMap: MutableMap<String, String> = mutableMapOf()
+            val someList: MutableList<String> = mutableListOf()
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a mutable collection property with inferred type in an object then do not emit`() {
+        val code =
+            """
+            object Foo {
+                val someMap = mutableMapOf<String, String>()
+                val someList = mutableListOf<String>()
+                val someSet = mutableSetOf<String>()
+                val someArrayList = arrayListOf<String>()
+                val someHashMap = hashMapOf<String, String>()
+                val someHashSet = hashSetOf<String>()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a mutable collection property with inferred type and comment in an object then do not emit`() {
+        val code =
+            """
+            object Foo {
+                val someMap = // comment
+                    mutableMapOf<String, String>()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

