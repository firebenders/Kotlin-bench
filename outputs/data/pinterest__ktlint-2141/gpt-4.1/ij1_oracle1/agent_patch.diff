-                        property.isObjectValue() -> {
+                    property.hasConstModifier() || property.isTopLevelValue() -> {
                         visitConstProperty(identifier, emit)
                     }
+                    property.isObjectValue() -> {
+                        // Additional checks for mutability
+                        val typeReference = property.children().find { it.elementType.toString().contains("TYPE") }
+                        val isVar = property.text.startsWith("var ")
+                        val typeText = typeReference?.text ?: ""
+                        val isMutableCollection = typeText.startsWith("MutableList") || typeText.startsWith("MutableMap") || typeText.startsWith("MutableSet")
+                        if (isVar || isMutableCollection) {
+                            visitNonConstProperty(identifier, emit)
+                        } else {
+                            visitConstProperty(identifier, emit)
+                        }
+                    }
                     else -> {
