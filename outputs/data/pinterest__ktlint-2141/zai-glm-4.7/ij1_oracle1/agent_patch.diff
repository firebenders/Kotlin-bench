+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat
+import org.junit.jupiter.api.Test
+
+/**
+ * Tests for the fix that ensures mutable collection property names inside objects
+ * use lower camel case instead of SCREAMING_SNAKE_CASE.
+ *
+ * See: https://developer.android.com/kotlin/style-guide#non-constant_names
+ */
+class PropertyNamingRuleMutableCollectionTest {
+    private val propertyNamingRuleAssertThat =
+        KtLintAssertThat.assertThatRule { PropertyNamingRule() }
+
+    @Test
+    fun `Given an object with MutableMap property using lower camel case then do not emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val someMap: MutableMap<SomeKey, SomeValue> = mutableMapOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an object with MutableMap property using SCREAMING_SNAKE_CASE then do emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val SOME_MAP: MutableMap<SomeKey, SomeValue> = mutableMapOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                2,
+                9,
+                "Property name should start with a lowercase letter and use camel case",
+            )
+    }
+
+    @Test
+    fun `Given an object with MutableList property using lower camel case then do not emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val someList: MutableList<String> = mutableListOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an object with MutableList property using SCREAMING_SNAKE_CASE then do emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val SOME_LIST: MutableList<String> = mutableListOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                2,
+                9,
+                "Property name should start with a lowercase letter and use camel case",
+            )
+    }
+
+    @Test
+    fun `Given an object with MutableSet property using lower camel case then do not emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val someSet: MutableSet<Int> = mutableSetOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an object with MutableSet property using SCREAMING_SNAKE_CASE then do emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val SOME_SET: MutableSet<Int> = mutableSetOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                2,
+                9,
+                "Property name should start with a lowercase letter and use camel case",
+            )
+    }
+
+    @Test
+    fun `Given an object with immutable Map property using lower camel case then do emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val someMap: Map<SomeKey, SomeValue> = mapOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                2,
+                9,
+                "Property name should use the screaming snake case notation when the value can not be changed",
+            )
+    }
+
+    @Test
+    fun `Given an object with immutable Map property using SCREAMING_SNAKE_CASE then do not emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val SOME_MAP: Map<SomeKey, SomeValue> = mapOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an object with immutable List property using lower camel case then do emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val someList: List<String> = listOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                2,
+                9,
+                "Property name should use the screaming snake case notation when the value can not be changed",
+            )
+    }
+
+    @Test
+    fun `Given an object with immutable List property using SCREAMING_SNAKE_CASE then do not emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val SOME_LIST: List<String> = listOf()
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a companion object with MutableMap property using lower camel case then do not emit`() {
+        val code =
+            """
+            class Foo {
+                companion object {
+                    val someMap: MutableMap<SomeKey, SomeValue> = mutableMapOf()
+                }
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a companion object with MutableMap property using SCREAMING_SNAKE_CASE then do emit`() {
+        val code =
+            """
+            class Foo {
+                companion object {
+                    val SOME_MAP: MutableMap<SomeKey, SomeValue> = mutableMapOf()
+                }
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                3,
+                13,
+                "Property name should start with a lowercase letter and use camel case",
+            )
+    }
+
+    @Test
+    fun `Given top-level val with MutableMap using lower camel case then do not emit`() {
+        val code =
+            """
+            val someMap: MutableMap<String, String> = mutableMapOf()
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given top-level val with MutableMap using SCREAMING_SNAKE_CASE then do emit`() {
+        val code =
+            """
+            val SOME_MAP: MutableMap<String, String> = mutableMapOf()
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code)
+            .hasLintViolationWithoutAutoCorrect(
+                1,
+                5,
+                "Property name should start with a lowercase letter and use camel case",
+            )
+    }
+
+    @Test
+    fun `Given object with non-mutable collection type using SCREAMING_SNAKE_CASE then do not emit`() {
+        val code =
+            """
+            object DumObjectName {
+                val COUNT: Int = 42
+            }
+            """.trimIndent()
+        propertyNamingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

