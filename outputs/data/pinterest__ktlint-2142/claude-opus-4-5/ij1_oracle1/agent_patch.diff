+    private val multiLineIfElseRuleAssertThat = assertThatRule { MultiLineIfElseRule() }
+
+    @Test
+    fun `Given an if-else statement with an empty THEN block should not cause a crash`() {
+        // Regression test for: https://github.com/pinterest/ktlint/issues/XXX
+        // An empty THEN block (e.g., "else if (condition) else") should not cause
+        // a NullPointerException when firstChildNode is null
+        val code =
+            """
+            fun foo() {
+                if ("a" == "b") {
+                } else if ("b" == "c") else {
+                }
+            }
+            """.trimIndent()
