+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a standalone if with empty THEN block followed by else should not crash`() {
+        // Another variation where the THEN block is completely empty
+        val code =
