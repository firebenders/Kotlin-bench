+    @Test
+    fun `Given an if-else statement with an empty THEN block should not throw exception`() {
+        // Syntactically valid (but useless) Kotlin code that used to cause an NPE
+        // https://github.com/pinterest/ktlint/issues/2078
+        val code =
+            """
+            fun foo() {
+                if ("a" == "b") {
+                } else if ("b" == "c") else {
+                }
+            }
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .hasNoLintViolations()
+    }
 }
