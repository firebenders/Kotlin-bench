@@ -0,0 +1,41 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class IfElseBracingRuleEmptyThenTest {
+    private val ifElseBracingRuleAssertThat = assertThatRule { IfElseBracingRule() }
+
+    @Test
+    fun `Given an if-else statement with an empty THEN block should not cause a crash`() {
+        // Regression test for: https://github.com/pinterest/ktlint/issues/XXX
+        // An empty THEN block (e.g., "else if (condition) else") should not cause
+        // a NullPointerException when firstChildNode is null
+        val code =
+            """
+            fun foo() {
+                if ("a" == "b") {
+                } else if ("b" == "c") else {
+                }
+            }
+            """.trimIndent()
+        // The rule should not crash on this malformed but valid Kotlin code
+        ifElseBracingRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given a standalone if with empty THEN block followed by else should not crash`() {
+        // Another variation where the THEN block is completely empty
+        val code =
+            """
+            fun foo() {
+                if (true) else {
+                    println("else")
+                }
+            }
+            """.trimIndent()
+        // The rule should not crash on this malformed but valid Kotlin code
+        ifElseBracingRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

