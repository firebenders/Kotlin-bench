+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/MultiLineIfElseRuleTestRepro.kt
@@ -0,0 +1,33 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class MultiLineIfElseRuleTestRepro {
+    private val multiLineIfElseRuleAssertThat = assertThatRule { MultiLineIfElseRule() }
+
+    @Test
+    fun `Given an if-else statement with empty THEN block`() {
+        val code =
+            """
+            fun foo() {
+                if ("a" == "b") {
+                } else if ("b" == "c") else {
+                }
+            }
+            """.trimIndent()
+        val formattedCode = listOf(
+            "fun foo() {",
+            "    if (\"a\" == \"b\") {",
+            "    } else if (\"b\" == \"c\") {",
+            "        ",
+            "    } else {",
+            "    }",
+            "}"
+        ).joinToString("\n")
+
+        multiLineIfElseRuleAssertThat(code)
+            .isFormattedAs(formattedCode)
+    }
+}
+

