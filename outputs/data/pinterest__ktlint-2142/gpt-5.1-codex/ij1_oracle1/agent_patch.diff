diff --git a/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/MultiLineIfElseRuleRegressionTest.kt b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/MultiLineIfElseRuleRegressionTest.kt
new file mode 100644
--- /dev/null
+++ b/ktlint-ruleset-standard/src/test/kotlin/com/pinterest/ktlint/ruleset/standard/rules/MultiLineIfElseRuleRegressionTest.kt
@@ -0,0 +1,42 @@
+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CODE_STYLE_PROPERTY
+import com.pinterest.ktlint.rule.engine.core.api.editorconfig.CodeStyleValue.ktlint_official
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class MultiLineIfElseRuleRegressionTest {
+    private val multiLineIfElseRuleAssertThat = assertThatRule { MultiLineIfElseRule() }
+    private val ifElseBracingRuleAssertThat = assertThatRule { IfElseBracingRule() }
+
+    @Test
+    fun `Given an else-if statement in which the then-branch is empty then multiline-if-else rule does not crash`() {
+        val code =
+            """
+            fun subject() {
+                if ("a" == "b") {
+                } else if ("b" == "c") else {
+                }
+            }
+            """.trimIndent()
+
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an else-if statement in which the then-branch is empty then if-else-bracing rule does not crash`() {
+        val code =
+            """
+            fun subject() {
+                if ("a" == "b") {
+                } else if ("b" == "c") else {
+                }
+            }
+            """.trimIndent()
+
+        ifElseBracingRuleAssertThat(code)
+            .withEditorConfigOverride(CODE_STYLE_PROPERTY to ktlint_official)
+            .hasNoLintViolations()
+    }
+}
+

