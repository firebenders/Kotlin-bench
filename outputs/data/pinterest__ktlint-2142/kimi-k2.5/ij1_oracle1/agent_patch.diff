+package com.pinterest.ktlint.ruleset.standard.rules
+
+import com.pinterest.ktlint.test.KtLintAssertThat.Companion.assertThatRule
+import org.junit.jupiter.api.Test
+
+class MultiLineIfElseRuleEmptyBlockTest {
+    private val multiLineIfElseRuleAssertThat = assertThatRule { MultiLineIfElseRule() }
+
+    @Test
+    fun `Given an if-else statement with empty THEN block`() {
+        // This is the issue from the bug report - empty THEN block should not crash
+        val code =
+            """
+            fun test() {
+                if ("a" == "b") {
+                } else if ("b" == "c") else {
+                }
+            }
+            """.trimIndent()
+        // Just verify it doesn't crash - the code is valid Kotlin (though unusual)
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an if statement with empty THEN block only`() {
+        val code =
+            """
+            fun test() {
+                if (true) {
+                }
+            }
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an if-else statement with empty ELSE block`() {
+        val code =
+            """
+            fun test() {
+                if (true) {
+                    doSomething()
+                } else {
+                }
+            }
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+}
+

