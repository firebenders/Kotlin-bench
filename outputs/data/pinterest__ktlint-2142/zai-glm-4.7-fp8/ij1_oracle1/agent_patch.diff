+
+    @Test
+    fun `Given an if-else statement with an empty THEN block`() {
+        val code =
+            """
+            fun foo() {
+                if ("a" == "b") {
+                } else if ("b" == "c") else {
+                }
+            }
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code).hasNoLintViolations()
+    }
+
+    @Test
+    fun `Given an if-else statement with empty THEN block and no braces on multiline`() {
+        val code =
+            """
+            fun foo() {
+                if ("a" == "b")
+                else
+                    println("c")
+            }
+            """.trimIndent()
+        val formattedCode =
+            """
+            fun foo() {
+                if ("a" == "b") {
+                } else {
+                    println("c")
+                }
+            }
+            """.trimIndent()
+        multiLineIfElseRuleAssertThat(code)
+            .hasLintViolations(
+                LintViolation(3, 9, "Missing { ... }"),
+                LintViolation(4, 9, "Missing { ... }"),
+            ).isFormattedAs(formattedCode)
+    }
