+import com.pinterest.ktlint.rule.engine.api.KtLintRuleEngine
+import com.pinterest.ktlint.rule.engine.api.EditorConfig
+import com.pinterest.ktlint.ruleset.standard.StandardRuleSetProvider
+
+fun main() {
+    val code = """
+if ("a" == "b") {
+} else if ("b" == "c") else {
+}
+    """.trimIndent()
+
+    println("Testing code:")
+    println(code)
+    println()
+
+    try {
+        val ruleEngine = KtLintRuleEngine(
+            ruleSets = listOf(StandardRuleSetProvider().get()),
+            editorConfig = EditorConfig.DEFAULT_EDITOR_CONFIG,
+            format = false
+        )
+
+        println("Running ktlint...")
+        val lintErrors = ruleEngine.lint("Test.kt", code)
+        println("Success! No crash occurred.")
+        println("Lint errors: ${lintErrors.size}")
+        lintErrors.forEach { println("  - ${it.line}:${it.col}: ${it.message}") }
+    } catch (e: Exception) {
+        println("Error occurred:")
+        e.printStackTrace()
+    }
+}
+

