+        // Each label must start and end with alphanumeric character
+        private val VALID_HOSTNAME_PATTERN = Regex("^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?(\\.[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?)*$")
