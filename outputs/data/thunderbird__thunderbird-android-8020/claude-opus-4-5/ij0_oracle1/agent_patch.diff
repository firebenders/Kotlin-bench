+
+    /**
+     * Checks if the hostname part of the address contains invalid characters.
+     * According to RFC 5321, the domain part must be a valid hostname consisting
+     * of alphanumeric characters, hyphens, and dots.
+     */
+    private fun Address.hasInvalidHostname(): Boolean {
+        val hostname = hostname ?: return false
+        return !VALID_HOSTNAME_PATTERN.matches(hostname)
+    }
