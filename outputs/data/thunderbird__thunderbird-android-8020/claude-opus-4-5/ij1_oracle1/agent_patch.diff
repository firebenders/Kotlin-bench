@@ -25,6 +26,20 @@ internal class UserInputEmailAddressParser {
 
     private fun Address.isIncomplete() = hostname.isNullOrBlank()
 
+    /**
+     * Checks if the hostname contains characters that are invalid for a domain name according to RFC 5321.
+     * Valid hostnames can only contain alphanumeric characters, hyphens, dots, and brackets (for IP literals).
+     */
+    private fun Address.hasInvalidHostname(): Boolean {
+        val host = hostname ?: return false
+        // Check for invalid characters in hostname
+        // Valid characters are: alphanumeric, hyphen, dot, and brackets (for IP address literals)
+        // Also reject hostnames that end with a dot or hyphen
+        return !host.matches(Regex("^[a-zA-Z0-9.\\-\\[\\]:]+$")) ||
+            host.endsWith(".") ||
+            host.endsWith("-")
+    }
+
     private fun Address.isNonAsciiAddress() = !CharsetUtil.isASCII(address)
 }
 

