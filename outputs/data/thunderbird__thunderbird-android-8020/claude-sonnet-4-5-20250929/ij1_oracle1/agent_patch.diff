@@ -26,6 +27,70 @@ internal class UserInputEmailAddressParser {
     private fun Address.isIncomplete() = hostname.isNullOrBlank()
 
     private fun Address.isNonAsciiAddress() = !CharsetUtil.isASCII(address)
+
+    /**
+     * Validates that the email address conforms to RFC-5321 syntax.
+     * Checks both local part (before @) and domain part (after @).
+     */
+    private fun Address.isValidRfc5321Address(): Boolean {
+        val emailAddress = address ?: return false
+
+        val atIndex = emailAddress.lastIndexOf('@')
+        if (atIndex == -1) return false
+
+        val localPart = emailAddress.substring(0, atIndex)
+        val domainPart = emailAddress.substring(atIndex + 1)
+
+        return isValidLocalPart(localPart) && isValidDomainPart(domainPart)
+    }
+
+    /**
+     * Validates the local part (before @) of an email address.
+     * According to RFC-5321, the local part can contain letters, digits, and special characters:
+     * ! # $ % & ' * + - / = ? ^ _ ` { | } ~
+     * and also . (dot) if it's not the first or last character and doesn't appear consecutively.
+     */
+    private fun isValidLocalPart(localPart: String): Boolean {
+        if (localPart.isEmpty()) return false
+
+        // Check if it's a quoted string (allows more flexibility)
+        if (localPart.startsWith("\"") && localPart.endsWith("\"")) {
+            return localPart.length >= 2
+        }
+
+        // For unquoted local parts, validate characters
+        val validChars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!#$%&'*+-/=?^_`{|}~."
+        return localPart.all { it in validChars }
+    }
+
+    /**
+     * Validates the domain part (after @) of an email address.
+     * According to RFC-5321, the domain part can only contain letters, digits, hyphens, and dots.
+     * Each label (part between dots) must start and end with an alphanumeric character.
+     */
+    private fun isValidDomainPart(domainPart: String): Boolean {
+        if (domainPart.isEmpty()) return false
+
+        // Check for invalid characters in domain
+        val validChars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789.-"
+        if (!domainPart.all { it in validChars }) {
+            return false
+        }
+
+        // Split by dots and validate each label
+        val labels = domainPart.split('.')
+        if (labels.isEmpty()) return false
+
+        for (label in labels) {
+            if (label.isEmpty()) return false
+            if (label.startsWith('-') || label.endsWith('-')) return false
+            if (!label.all { it.isLetterOrDigit() || it == '-' }) return false
+        }
+
+        return true
+    }
 }
 
 internal class NonAsciiEmailAddressException(message: String) : Exception(message)
+
+internal class InvalidEmailAddressException(message: String) : Exception(message)

