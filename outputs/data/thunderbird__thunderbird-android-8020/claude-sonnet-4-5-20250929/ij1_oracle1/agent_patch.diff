@@ -0,0 +1,101 @@
+package com.fsck.k9.view
+
+import assertk.assertFailure
+import assertk.assertThat
+import assertk.assertions.containsExactly
+import assertk.assertions.isInstanceOf
+import com.fsck.k9.mail.Address
+import kotlin.test.Test
+
+class UserInputEmailAddressParserInvalidAddressTest {
+    private val parser = UserInputEmailAddressParser()
+
+    @Test
+    fun `email address with trailing slash should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@gmail.com/")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    @Test
+    fun `email address with trailing double slash should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@gmail.com//")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    @Test
+    fun `email address with trailing path should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@gmail.com/path")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    @Test
+    fun `email address with space in domain should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@gmail .com")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    @Test
+    fun `email address with invalid character in domain should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@gmail#com")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    @Test
+    fun `email address with special characters in domain should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@domain!example.com")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    @Test
+    fun `email address with consecutive dots in domain should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@gmail..com")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    @Test
+    fun `email address with leading hyphen in domain label should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@-gmail.com")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    @Test
+    fun `email address with trailing hyphen in domain label should throw InvalidEmailAddressException`() {
+        assertFailure {
+            parser.parse("test@gmail-.com")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+
+    // Valid email addresses that should NOT throw exceptions
+    @Test
+    fun `email address with slash in local part should be valid`() {
+        val addresses = parser.parse("test/user@gmail.com")
+        assertThat(addresses).containsExactly(Address("test/user@gmail.com"))
+    }
+
+    @Test
+    fun `simple valid email address should be accepted`() {
+        val addresses = parser.parse("test@gmail.com")
+        assertThat(addresses).containsExactly(Address("test@gmail.com"))
+    }
+
+    @Test
+    fun `email address with hyphen in domain should be valid`() {
+        val addresses = parser.parse("test@gmail-domain.com")
+        assertThat(addresses).containsExactly(Address("test@gmail-domain.com"))
+    }
+
+    @Test
+    fun `email address with subdomain should be valid`() {
+        val addresses = parser.parse("test@mail.example.com")
+        assertThat(addresses).containsExactly(Address("test@mail.example.com"))
+    }
+}
+

