+package com.fsck.k9.view
+
+import assertk.assertFailure
+import assertk.assertions.isInstanceOf
+import kotlin.test.Test
+
+/**
+ * Test for the specific issue where recipient addresses ending with '/'
+ * were not being validated properly (e.g., xxx@gmail.com/).
+ *
+ * This test verifies that such addresses now throw an InvalidEmailAddressException
+ * instead of being sent and failing later.
+ */
+class UserInputEmailAddressParserIssueTest {
+    private val parser = UserInputEmailAddressParser()
+
+    @Test
+    fun `issue - email address ending with slash should be rejected before sending`() {
+        // This is the exact scenario from the issue report
+        assertFailure {
+            parser.parse("xxx@gmail.com/")
+        }.isInstanceOf<InvalidEmailAddressException>()
+    }
+}
