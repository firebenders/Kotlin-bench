+package com.fsck.k9.view
+
+import assertk.assertThat
+import assertk.assertions.isEmpty
+import assertk.assertions.containsExactly
+import com.fsck.k9.mail.Address
+import kotlin.test.Test
+
+/**
+ * Test cases for invalid email address validation.
+ * These tests verify that email addresses with invalid characters in the domain part
+ * (like trailing slashes) are rejected.
+ */
+class UserInputEmailAddressParserInvalidAddressTest {
+    private val parser = UserInputEmailAddressParser()
+
+    @Test
+    fun `email address with trailing slash should be rejected`() {
+        val addresses = parser.parse("xxx@gmail.com/")
+
+        assertThat(addresses).isEmpty()
+    }
+
+    @Test
+    fun `email address with trailing slash in angle brackets should be rejected`() {
+        val addresses = parser.parse("<xxx@gmail.com/>")
+
+        assertThat(addresses).isEmpty()
+    }
+
+    @Test
+    fun `email address with slash in middle of domain should be rejected`() {
+        val addresses = parser.parse("user@gm/ail.com")
+
+        assertThat(addresses).isEmpty()
+    }
+
+    @Test
+    fun `email address with backslash in domain should be rejected`() {
+        val addresses = parser.parse("user@gmail\\.com")
+
+        assertThat(addresses).isEmpty()
+    }
+
+    @Test
+    fun `email address with space in domain should be rejected`() {
+        val addresses = parser.parse("user@gmail .com")
+
+        assertThat(addresses).isEmpty()
+    }
+
+    @Test
+    fun `email address with less than in domain should be rejected`() {
+        val addresses = parser.parse("user@gmail<.com")
+
+        assertThat(addresses).isEmpty()
+    }
+
+    @Test
+    fun `email address with greater than in domain should be rejected`() {
+        val addresses = parser.parse("user@gmail>.com")
+
+        assertThat(addresses).isEmpty()
+    }
+
+    @Test
+    fun `valid email address should be accepted`() {
+        val addresses = parser.parse("user@gmail.com")
+
+        assertThat(addresses).containsExactly(Address("user@gmail.com"))
+    }
+
+    @Test
+    fun `valid email address with hyphen in domain should be accepted`() {
+        val addresses = parser.parse("user@my-domain.com")
+
+        assertThat(addresses).containsExactly(Address("user@my-domain.com"))
+    }
+
+    @Test
+    fun `valid email address with IPv6 literal should be accepted`() {
+        val addresses = parser.parse("user@[IPv6:2001:db8::1]")
+
+        assertThat(addresses).containsExactly(Address("user@[IPv6:2001:db8::1]"))
+    }
+
+    @Test
+    fun `valid email address with dots in domain should be accepted`() {
+        val addresses = parser.parse("user@sub.domain.example.com")
+
+        assertThat(addresses).containsExactly(Address("user@sub.domain.example.com"))
+    }
+
+    @Test
+    fun `valid email address with digits in domain should be accepted`() {
+        val addresses = parser.parse("user@example123.com")
+
+        assertThat(addresses).containsExactly(Address("user@example123.com"))
+    }
+
+    @Test
+    fun `valid email address with plus in local part should be accepted`() {
+        val addresses = parser.parse("user+tag@gmail.com")
+
+        assertThat(addresses).containsExactly(Address("user+tag@gmail.com"))
+    }
+
+    @Test
+    fun `valid email address with dot in local part should be accepted`() {
+        val addresses = parser.parse("first.last@gmail.com")
+
+        assertThat(addresses).containsExactly(Address("first.last@gmail.com"))
+    }
+}
+
