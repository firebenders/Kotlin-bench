@@ -26,6 +27,39 @@ internal class UserInputEmailAddressParser {
     private fun Address.isIncomplete() = hostname.isNullOrBlank()
 
     private fun Address.isNonAsciiAddress() = !CharsetUtil.isASCII(address)
+
+    /**
+     * Validates that the email address conforms to RFC 5321.
+     * The local part (before @) can contain various characters, but the domain part (after @)
+     * must be a valid hostname consisting of letters, digits, hyphens, and dots.
+     */
+    private fun Address.isValidEmailAddress(): Boolean {
+        val addressString = address ?: return false
+        val atIndex = addressString.lastIndexOf('@')
+        if (atIndex == -1 || atIndex == addressString.length - 1) return false
+
+        val domain = addressString.substring(atIndex + 1)
+
+        // Domain cannot be empty
+        if (domain.isEmpty()) return false
+
+        // Domain cannot contain characters that are invalid in hostnames
+        // Valid characters for domain: a-z, A-Z, 0-9, -, ., and brackets for IPv6 literals
+        // Invalid characters include: /, \, space, <, >, etc.
+        for (char in domain) {
+            when {
+                char.isLetterOrDigit() -> continue
+                char == '-' || char == '.' -> continue
+                char == '[' || char == ']' || char == ':' -> {
+                    // Allow IPv6 literals like [IPv6:2001:db8::1]
+                    continue
+                }
+                else -> return false
+            }
+        }
+
+        return true
+    }
 }
 
 internal class NonAsciiEmailAddressException(message: String) : Exception(message)

