+package com.fsck.k9.helper
+
+import app.k9mail.core.android.common.contact.ContactRepository
+import app.k9mail.core.android.testing.RobolectricTest
+import assertk.assertThat
+import assertk.assertions.isEqualTo
+import assertk.assertions.startsWith
+import com.fsck.k9.CoreResourceProvider
+import com.fsck.k9.mail.Address
+import org.junit.Test
+import org.mockito.kotlin.doReturn
+import org.mockito.kotlin.mock
+import org.mockito.kotlin.stub
+
+class MessageHelperRecipientDisplayTest : RobolectricTest() {
+
+    private val contactRepository: ContactRepository = mock()
+    private val resourceProvider: CoreResourceProvider = mock {
+        on { contactDisplayNamePrefix() } doReturn "To:"
+        on { contactUnknownRecipient() } doReturn "<Unknown Recipient>"
+    }
+
+    private val messageHelper = MessageHelper(resourceProvider, contactRepository)
+
+    @Test
+    fun `getRecipientDisplayNames should have space between prefix and address`() {
+        val addresses = arrayOf(Address("test@example.com"))
+
+        val result = messageHelper.getRecipientDisplayNames(addresses)
+
+        assertThat(result.toString()).isEqualTo("To: test@example.com")
+    }
+
+    @Test
+    fun `getRecipientDisplayNames should have space between prefix and personal name`() {
+        val addresses = arrayOf(Address("test@example.com", "Test User"))
+
+        val result = messageHelper.getRecipientDisplayNames(addresses)
+
+        assertThat(result.toString()).isEqualTo("To: Test User")
+    }
+
+    @Test
+    fun `getRecipientDisplayNames should have space between prefix and multiple recipients`() {
+        val addresses = arrayOf(
+            Address("test1@example.com", "User One"),
+            Address("test2@example.com", "User Two"),
+        )
+
+        val result = messageHelper.getRecipientDisplayNames(addresses)
+
+        assertThat(result.toString()).isEqualTo("To: User One,User Two")
+    }
+
+    @Test
+    fun `getRecipientDisplayNames with null addresses should return unknown recipient`() {
+        val result = messageHelper.getRecipientDisplayNames(null)
+
+        assertThat(result.toString()).isEqualTo("<Unknown Recipient>")
+    }
+
+    @Test
+    fun `getRecipientDisplayNames with empty addresses should return unknown recipient`() {
+        val result = messageHelper.getRecipientDisplayNames(emptyArray())
+
+        assertThat(result.toString()).isEqualTo("<Unknown Recipient>")
+    }
+
+    @Test
+    fun `getRecipientDisplayNames prefix should be followed by space`() {
+        val addresses = arrayOf(Address("any@email.com"))
+
+        val result = messageHelper.getRecipientDisplayNames(addresses)
+
+        assertThat(result.toString()).startsWith("To: ")
+    }
+}
+
