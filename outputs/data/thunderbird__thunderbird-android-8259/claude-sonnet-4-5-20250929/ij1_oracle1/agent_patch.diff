+package com.fsck.k9.helper
+
+import app.k9mail.core.android.common.contact.Contact
+import app.k9mail.core.android.common.contact.ContactRepository
+import app.k9mail.core.android.testing.RobolectricTest
+import app.k9mail.core.common.mail.EmailAddress
+import assertk.assertThat
+import assertk.assertions.contains
+import assertk.assertions.isEqualTo
+import assertk.assertions.startsWith
+import com.fsck.k9.TestCoreResourceProvider
+import com.fsck.k9.mail.Address
+import org.junit.Test
+
+/**
+ * Test class for MessageHelper.getRecipientDisplayNames method.
+ * Specifically tests the fix for the missing space between "To:" and recipient addresses.
+ */
+class MessageHelperRecipientDisplayNamesTest : RobolectricTest() {
+
+    private class StubContactRepository : ContactRepository {
+        override fun getContactFor(emailAddress: EmailAddress): Contact? = null
+        override fun hasContactFor(emailAddress: EmailAddress): Boolean = false
+        override fun hasAnyContactFor(emailAddresses: List<EmailAddress>): Boolean = false
+    }
+
+    private fun createMessageHelper(): MessageHelper {
+        val contactRepository = StubContactRepository()
+        val resourceProvider = TestCoreResourceProvider()
+        return MessageHelper(resourceProvider, contactRepository)
+    }
+
+    @Test
+    fun getRecipientDisplayNames_withSingleRecipient_shouldHaveSpaceAfterPrefix() {
+        val messageHelper = createMessageHelper()
+        val address = Address("test@example.com", "Test User")
+        val addresses = arrayOf(address)
+
+        val result = messageHelper.getRecipientDisplayNames(addresses).toString()
+
+        assertThat(result).startsWith("To: ")
+        assertThat(result).isEqualTo("To: Test User")
+    }
+
+    @Test
+    fun getRecipientDisplayNames_withSingleRecipientNoPersonal_shouldHaveSpaceAfterPrefix() {
+        val messageHelper = createMessageHelper()
+        val address = Address("test@example.com")
+        val addresses = arrayOf(address)
+
+        val result = messageHelper.getRecipientDisplayNames(addresses).toString()
+
+        assertThat(result).startsWith("To: ")
+        assertThat(result).isEqualTo("To: test@example.com")
+    }
+
+    @Test
+    fun getRecipientDisplayNames_withMultipleRecipients_shouldHaveSpaceAfterPrefix() {
+        val messageHelper = createMessageHelper()
+        val address1 = Address("test1@example.com", "Test User 1")
+        val address2 = Address("test2@example.com", "Test User 2")
+        val addresses = arrayOf(address1, address2)
+
+        val result = messageHelper.getRecipientDisplayNames(addresses).toString()
+
+        assertThat(result).startsWith("To: ")
+        assertThat(result).contains("Test User 1")
+        assertThat(result).contains("Test User 2")
+        assertThat(result).isEqualTo("To: Test User 1,Test User 2")
+    }
+
+    @Test
+    fun getRecipientDisplayNames_withNullAddresses_shouldReturnUnknownRecipient() {
+        val messageHelper = createMessageHelper()
+        val result = messageHelper.getRecipientDisplayNames(null).toString()
+
+        assertThat(result).isEqualTo("<Unknown Recipient>")
+    }
+
+    @Test
+    fun getRecipientDisplayNames_withEmptyAddresses_shouldReturnUnknownRecipient() {
+        val messageHelper = createMessageHelper()
+        val addresses = emptyArray<Address>()
+
+        val result = messageHelper.getRecipientDisplayNames(addresses).toString()
+
+        assertThat(result).isEqualTo("<Unknown Recipient>")
+    }
+
+    @Test
+    fun getRecipientDisplayNames_verifyNoDoubleSpacing() {
+        val messageHelper = createMessageHelper()
+        val address = Address("test@example.com", "User")
+        val addresses = arrayOf(address)
+
+        val result = messageHelper.getRecipientDisplayNames(addresses).toString()
+
+        // Verify there's exactly one space between "To:" and the recipient
+        assertThat(result).isEqualTo("To: User")
+        // Verify there's no double space
+        assertThat(result.contains("  ")).isEqualTo(false)
+    }
+}
+
