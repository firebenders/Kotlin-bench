diff --git a/legacy/core/src/test/java/com/fsck/k9/helper/MessageHelperRecipientDisplayNamesTest.kt b/legacy/core/src/test/java/com/fsck/k9/helper/MessageHelperRecipientDisplayNamesTest.kt
