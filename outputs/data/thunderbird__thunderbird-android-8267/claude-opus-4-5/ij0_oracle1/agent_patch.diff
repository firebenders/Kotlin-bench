+        upgradeFolderSelection(settings, "draftsFolderName", "draftsFolderSelection");
+        upgradeFolderSelection(settings, "sentFolderName", "sentFolderSelection");
+        upgradeFolderSelection(settings, "spamFolderName", "spamFolderSelection");
+        upgradeFolderSelection(settings, "trashFolderName", "trashFolderSelection");
+    }
+
+    private void upgradeFolderSelection(Map<String, Object> settings, String folderNameKey, String folderSelectionKey) {
+        String folderName = (String) settings.get(folderNameKey);
+        if (folderName != null && !folderName.isEmpty()) {
+            settings.put(folderSelectionKey, FOLDER_SELECTION_MANUAL);
+        }
     }
