+            outgoing = testServer(),
+            settings = mapOf(
+                "draftsFolderName" to null,
+                "draftsFolderSelection" to "AUTOMATIC",
+            ),
+            identities = emptyList(),
+            folders = emptyList(),
+        )
+
+        val result = upgrader.upgrade(account)
+
+        assertThat(result.settings["draftsFolderSelection"]).isEqualTo("AUTOMATIC")
+    }
+
+    @Test
+    fun `upgrade should not change AUTOMATIC when folder name is empty`() {
+        val account = ValidatedSettings.Account(
+            uuid = "test-uuid",
+            name = "Test Account",
+            incoming = testServer(),
+            outgoing = testServer(),
+            settings = mapOf(
+                "draftsFolderName" to "",
+                "draftsFolderSelection" to "AUTOMATIC",
+            ),
+            identities = emptyList(),
+            folders = emptyList(),
+        )
+
+        val result = upgrader.upgrade(account)
+
+        assertThat(result.settings["draftsFolderSelection"]).isEqualTo("AUTOMATIC")
+    }
+
+    @Test
+    fun `upgrade should handle all special folder types`() {
+        val account = ValidatedSettings.Account(
+            uuid = "test-uuid",
+            name = "Test Account",
+            incoming = testServer(),
+            outgoing = testServer(),
+            settings = mapOf(
+                "archiveFolderName" to "Archive",
+                "archiveFolderSelection" to "AUTOMATIC",
+                "draftsFolderName" to "Drafts",
+                "draftsFolderSelection" to "AUTOMATIC",
+                "sentFolderName" to "Sent",
+                "sentFolderSelection" to "AUTOMATIC",
+                "spamFolderName" to "Spam",
+                "spamFolderSelection" to "AUTOMATIC",
+                "trashFolderName" to "Trash",
+                "trashFolderSelection" to "AUTOMATIC",
+            ),
+            identities = emptyList(),
+            folders = emptyList(),
+        )
+
+        val result = upgrader.upgrade(account)
