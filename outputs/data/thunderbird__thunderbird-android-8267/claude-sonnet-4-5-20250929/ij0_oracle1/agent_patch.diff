+        assertThat(result.settings["archiveFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(result.settings["draftsFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(result.settings["sentFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(result.settings["spamFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(result.settings["trashFolderSelection"]).isEqualTo("MANUAL")
