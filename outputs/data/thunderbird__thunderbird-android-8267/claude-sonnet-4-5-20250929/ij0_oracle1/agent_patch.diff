+package com.fsck.k9.preferences.migration
+
+import assertk.assertThat
+import assertk.assertions.isEqualTo
+import com.fsck.k9.preferences.createPreferencesDatabase
+import kotlin.test.Test
+import org.junit.After
+import org.junit.runner.RunWith
+import org.robolectric.RobolectricTestRunner
+
+@RunWith(RobolectricTestRunner::class)
+class StorageMigrationTo26Test {
+    private val database = createPreferencesDatabase()
+    private val migrationHelper = DefaultStorageMigrationHelper()
+
+    @After
+    fun tearDown() {
+        database.close()
+    }
+
+    @Test
+    fun `fixFolderSelectionSettings should change AUTOMATIC to MANUAL when folder name is configured`() {
+        // Set up account with configured folder names but AUTOMATIC selection
+        migrationHelper.insertValue(database, "accountUuids", "test-uuid")
+        migrationHelper.insertValue(database, "test-uuid.draftsFolderName", "Drafts")
+        migrationHelper.insertValue(database, "test-uuid.draftsFolderSelection", "AUTOMATIC")
+        migrationHelper.insertValue(database, "test-uuid.sentFolderName", "Sent")
+        migrationHelper.insertValue(database, "test-uuid.sentFolderSelection", "AUTOMATIC")
+
+        val migration = StorageMigrationTo26(database, migrationHelper)
+        migration.fixFolderSelectionSettings()
+
+        assertThat(migrationHelper.readValue(database, "test-uuid.draftsFolderSelection")).isEqualTo("MANUAL")
+        assertThat(migrationHelper.readValue(database, "test-uuid.sentFolderSelection")).isEqualTo("MANUAL")
+    }
+
+    @Test
+    fun `fixFolderSelectionSettings should not change MANUAL selection`() {
+        // Set up account with configured folder names and MANUAL selection
+        migrationHelper.insertValue(database, "accountUuids", "test-uuid")
+        migrationHelper.insertValue(database, "test-uuid.draftsFolderName", "Drafts")
+        migrationHelper.insertValue(database, "test-uuid.draftsFolderSelection", "MANUAL")
+
+        val migration = StorageMigrationTo26(database, migrationHelper)
+        migration.fixFolderSelectionSettings()
+
+        assertThat(migrationHelper.readValue(database, "test-uuid.draftsFolderSelection")).isEqualTo("MANUAL")
+    }
+
+    @Test
+    fun `fixFolderSelectionSettings should not change AUTOMATIC when folder name is not configured`() {
+        // Set up account without configured folder name
+        migrationHelper.insertValue(database, "accountUuids", "test-uuid")
+        migrationHelper.insertValue(database, "test-uuid.draftsFolderSelection", "AUTOMATIC")
+
+        val migration = StorageMigrationTo26(database, migrationHelper)
+        migration.fixFolderSelectionSettings()
+
+        assertThat(migrationHelper.readValue(database, "test-uuid.draftsFolderSelection")).isEqualTo("AUTOMATIC")
+    }
+
+    @Test
+    fun `fixFolderSelectionSettings should handle empty folder name`() {
+        // Set up account with empty folder name
+        migrationHelper.insertValue(database, "accountUuids", "test-uuid")
+        migrationHelper.insertValue(database, "test-uuid.draftsFolderName", "")
+        migrationHelper.insertValue(database, "test-uuid.draftsFolderSelection", "AUTOMATIC")
+
+        val migration = StorageMigrationTo26(database, migrationHelper)
+        migration.fixFolderSelectionSettings()
+
+        assertThat(migrationHelper.readValue(database, "test-uuid.draftsFolderSelection")).isEqualTo("AUTOMATIC")
+    }
+
+    @Test
+    fun `fixFolderSelectionSettings should handle multiple accounts`() {
+        // Set up two accounts
+        migrationHelper.insertValue(database, "accountUuids", "uuid1,uuid2")
+        migrationHelper.insertValue(database, "uuid1.draftsFolderName", "Drafts")
+        migrationHelper.insertValue(database, "uuid1.draftsFolderSelection", "AUTOMATIC")
+        migrationHelper.insertValue(database, "uuid2.sentFolderName", "Sent")
+        migrationHelper.insertValue(database, "uuid2.sentFolderSelection", "AUTOMATIC")
+
+        val migration = StorageMigrationTo26(database, migrationHelper)
+        migration.fixFolderSelectionSettings()
+
+        assertThat(migrationHelper.readValue(database, "uuid1.draftsFolderSelection")).isEqualTo("MANUAL")
+        assertThat(migrationHelper.readValue(database, "uuid2.sentFolderSelection")).isEqualTo("MANUAL")
+    }
+}
