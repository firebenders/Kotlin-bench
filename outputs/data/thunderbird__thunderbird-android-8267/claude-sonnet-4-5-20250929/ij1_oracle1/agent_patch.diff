+package com.fsck.k9.preferences.upgrader
+
+import assertk.assertThat
+import assertk.assertions.isEqualTo
+import kotlin.test.Test
+
+/**
+ * Integration test to verify that folder assignments are correctly imported from K-9.
+ *
+ * This test reproduces the bug described in the issue where folder assignments were
+ * not correctly imported and all folders were marked with "automatic" instead of
+ * preserving the manual assignments from K-9.
+ */
+class FolderAssignmentImportTest {
+    private val upgrader = AccountSettingsUpgraderTo54()
+
+    @Test
+    fun `folder selections should be MANUAL when folders were configured in old K-9 version`() {
+        // Simulate importing from K-9 version 53 (before folder selections were added)
+        // with some folders configured
+        val importedSettings = mutableMapOf<String, Any?>(
+            "archiveFolderName" to "Archive",
+            "draftsFolderName" to "Drafts",
+            "sentFolderName" to "Sent",
+            "spamFolderName" to "Junk",
+            "trashFolderName" to "Trash",
+        )
+
+        // Run the upgrader (simulating upgrade to version 54)
+        upgrader.upgrade(importedSettings)
+
+        // Verify that folder selections are set to MANUAL for configured folders
+        assertThat(importedSettings["archiveFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(importedSettings["draftsFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(importedSettings["sentFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(importedSettings["spamFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(importedSettings["trashFolderSelection"]).isEqualTo("MANUAL")
+    }
+
+    @Test
+    fun `folder selections should be AUTOMATIC when folders were not configured in old K-9 version`() {
+        // Simulate importing from K-9 version 53 with no folders configured
+        val importedSettings = mutableMapOf<String, Any?>(
+            "archiveFolderName" to null,
+            "draftsFolderName" to null,
+            "sentFolderName" to null,
+            "spamFolderName" to null,
+            "trashFolderName" to null,
+        )
+
+        // Run the upgrader
+        upgrader.upgrade(importedSettings)
+
+        // Verify that folder selections are set to AUTOMATIC for unconfigured folders
+        assertThat(importedSettings["archiveFolderSelection"]).isEqualTo("AUTOMATIC")
+        assertThat(importedSettings["draftsFolderSelection"]).isEqualTo("AUTOMATIC")
+        assertThat(importedSettings["sentFolderSelection"]).isEqualTo("AUTOMATIC")
+        assertThat(importedSettings["spamFolderSelection"]).isEqualTo("AUTOMATIC")
+        assertThat(importedSettings["trashFolderSelection"]).isEqualTo("AUTOMATIC")
+    }
+
+    @Test
+    fun `folder selections should be correct for mixed configured and unconfigured folders`() {
+        // Simulate importing from K-9 version 53 with some folders configured
+        val importedSettings = mutableMapOf<String, Any?>(
+            "archiveFolderName" to "Archive",
+            "draftsFolderName" to null,  // Not configured in K-9
+            "sentFolderName" to "Sent",
+            "spamFolderName" to null,     // Not configured in K-9
+            "trashFolderName" to "Deleted Items",
+        )
+
+        // Run the upgrader
+        upgrader.upgrade(importedSettings)
+
+        // Verify that folder selections match the configuration state
+        assertThat(importedSettings["archiveFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(importedSettings["draftsFolderSelection"]).isEqualTo("AUTOMATIC")
+        assertThat(importedSettings["sentFolderSelection"]).isEqualTo("MANUAL")
+        assertThat(importedSettings["spamFolderSelection"]).isEqualTo("AUTOMATIC")
+        assertThat(importedSettings["trashFolderSelection"]).isEqualTo("MANUAL")
+    }
+}
+
