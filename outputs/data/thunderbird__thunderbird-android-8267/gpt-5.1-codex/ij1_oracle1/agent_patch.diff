+
+    override fun messageHeaderDate() = "Date"
+
+    override fun messageHeaderSubject() = "Subject"
+
+    override fun messageHeaderSeparator() = ":"
+
+    override fun noSubject() = "(no subject)"
+
+    override fun userAgent() = ""
+
+    override fun replyHeader(sender: String) = "Re: $sender"
+
+    override fun replyHeader(sender: String, sentDate: String) = "Re: $sender $sentDate"
+
+    override fun searchUnifiedInboxTitle() = ""
+
+    override fun searchUnifiedInboxDetail() = ""
+
+    override val iconPushNotification: Int = 0
+
