+    private fun resolveSpecialFolderSelection(
+        storage: Storage,
+        selectionKey: String,
+        importedFolderName: String?,
+        storedSelection: SpecialFolderSelection,
+    ): SpecialFolderSelection {
+        if (storedSelection == SpecialFolderSelection.MANUAL) return storedSelection
+
+        val selectionPersisted = storage.contains(selectionKey)
+        val hasImportedFolder = !importedFolderName.isNullOrEmpty()
+
+        return if (!selectionPersisted && hasImportedFolder) {
+            SpecialFolderSelection.MANUAL
+        } else {
+            storedSelection
+        }
+    }
