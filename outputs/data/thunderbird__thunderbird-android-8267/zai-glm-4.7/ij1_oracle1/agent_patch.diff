+    private fun resolveSpecialFolderAssignments(account: Account) {
+        // Convert folder server IDs from imported settings to actual folder IDs
+        account.importedDraftsFolder?.let { folderServerId ->
+            val folderId = folderRepository.getFolderId(account, folderServerId)
+            if (folderId != null) {
+                account.setDraftsFolderId(folderId, SpecialFolderSelection.MANUAL)
+                Timber.d("Resolved drafts folder: '$folderServerId' -> ID: $folderId")
+            }
+        }
+
+        account.importedSentFolder?.let { folderServerId ->
+            val folderId = folderRepository.getFolderId(account, folderServerId)
+            if (folderId != null) {
+                account.setSentFolderId(folderId, SpecialFolderSelection.MANUAL)
+                Timber.d("Resolved sent folder: '$folderServerId' -> ID: $folderId")
+            }
+        }
+
+        account.importedTrashFolder?.let { folderServerId ->
+            val folderId = folderRepository.getFolderId(account, folderServerId)
+            if (folderId != null) {
+                account.setTrashFolderId(folderId, SpecialFolderSelection.MANUAL)
+                Timber.d("Resolved trash folder: '$folderServerId' -> ID: $folderId")
+            }
+        }
+
+        account.importedArchiveFolder?.let { folderServerId ->
+            val folderId = folderRepository.getFolderId(account, folderServerId)
+            if (folderId != null) {
+                account.setArchiveFolderId(folderId, SpecialFolderSelection.MANUAL)
+                Timber.d("Resolved archive folder: '$folderServerId' -> ID: $folderId")
+            }
+        }
+
+        account.importedSpamFolder?.let { folderServerId ->
+            val folderId = folderRepository.getFolderId(account, folderServerId)
+            if (folderId != null) {
+                account.setSpamFolderId(folderId, SpecialFolderSelection.MANUAL)
+                Timber.d("Resolved spam folder: '$folderServerId' -> ID: $folderId")
+            }
+        }
+
+        account.importedAutoExpandFolder?.let { folderServerId ->
+            val folderId = folderRepository.getFolderId(account, folderServerId)
+            if (folderId != null) {
+                account.autoExpandFolderId = folderId
+                account.importedAutoExpandFolder = null
+                Timber.d("Resolved auto-expand folder: '$folderServerId' -> ID: $folderId")
+            }
+        }
+
+        // Save the updated account with resolved folder assignments
+        preferences.saveAccount(account)
+    }
