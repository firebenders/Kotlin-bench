 /**
  * Configures the unified inbox after an account has been added.
+ *
+ * Enables the unified inbox automatically when adding the second account.
+ * Does not modify the setting when adding third or subsequent accounts to respect user preferences.
  */
 class UnifiedInboxConfigurator(
     private val accountManager: AccountManager,
 ) {
     fun configureUnifiedInbox() {
-        if (accountManager.getAccounts().size > 1) {
