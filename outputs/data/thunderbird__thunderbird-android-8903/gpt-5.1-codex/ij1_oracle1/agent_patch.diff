@@ -10,8 +10,16 @@ class UnifiedInboxConfigurator(
     private val accountManager: AccountManager,
 ) {
     fun configureUnifiedInbox() {
-        if (accountManager.getAccounts().size > 1) {
+        if (K9.isUnifiedInboxConfigured) {
+            return
+        }
+
+        val finishedAccountCount = accountManager.getAccounts().count { it.isFinishedSetup }
+        val hasMultipleFinishedAccounts = finishedAccountCount > 1
+
