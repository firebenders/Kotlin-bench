+    ): ReaderTag {
+        val tagSlug = ReaderUtils.sanitizeWithDashes(promptIdTag(tagUrl))
+        // The endpoint must contain "/read/tags/" for isTagTopic() to return true,
+        // which ensures the correct sort column (date_tagged) is used for pagination.
+        val endpoint = String.format(TAG_ENDPOINT_FORMAT, tagSlug)
