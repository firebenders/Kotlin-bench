+    private fun handleTrafficDeepLink(pathSegments: List<String>, length: Int): NavigateAction {
+        // URLs like /stats/traffic, /stats/traffic/$site, /stats/traffic/$granularity/$site
+        return when (length) {
+            2 -> OpenStatsForTimeframe(StatsTimeframe.TRAFFIC) // /stats/traffic
+            3 -> {
+                val param = pathSegments[2]
+                val site = param.toSite()
+                if (site != null) {
+                    // /stats/traffic/$site
+                    OpenStatsForSiteAndTimeframe(site, StatsTimeframe.TRAFFIC)
+                } else {
+                    // /stats/traffic/$granularity - treat granularity as traditional timeframe for traffic
+                    val granularityTimeframe = param.toStatsTimeframe()
+                    OpenStatsForTimeframe(granularityTimeframe ?: StatsTimeframe.TRAFFIC)
+                }
+            }
+            4 -> {
+                // /stats/traffic/$granularity/$site
+                val granularityParam = pathSegments[2]
+                val site = pathSegments[3].toSite()
+                val granularityTimeframe = granularityParam.toStatsTimeframe()
+
+                when {
+                    site != null && granularityTimeframe != null ->
+                        OpenStatsForSiteAndTimeframe(site, granularityTimeframe)
+                    site != null ->
+                        OpenStatsForSiteAndTimeframe(site, StatsTimeframe.TRAFFIC)
+                    else ->
+                        OpenStatsForTimeframe(StatsTimeframe.TRAFFIC)
+                }
+            }
+            else -> OpenStatsForTimeframe(StatsTimeframe.TRAFFIC)
+        }
+    }
