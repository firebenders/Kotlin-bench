+    private data class StatsDeepLinkData(val site: SiteModel?, val timeframe: StatsTimeframe?)
+
+    private fun getStatsSegments(uri: UriWrapper): List<String> {
+        val offset = if (uri.host == STATS_PATH) 0 else 1
+        return uri.pathSegments.drop(offset)
+    }
+
+    private fun parseStatsSegments(segments: List<String>): StatsDeepLinkData {
+        if (segments.isEmpty()) return StatsDeepLinkData(null, null)
+
+        return when (segments.first()) {
+            "traffic" -> parseTrafficSegments(segments)
+            "subscribers" -> StatsDeepLinkData(segments.getOrNull(1)?.toSite(), StatsTimeframe.SUBSCRIBERS)
+            else -> parseDefaultSegments(segments)
+        }
+    }
+
+    private fun parseTrafficSegments(segments: List<String>): StatsDeepLinkData {
+        if (segments.size == 1) return StatsDeepLinkData(null, StatsTimeframe.TRAFFIC)
+
+        val granularity = segments[1].toGranularTimeframe()
+        return if (granularity != null) {
+            StatsDeepLinkData(segments.getOrNull(2)?.toSite(), granularity)
+        } else {
+            StatsDeepLinkData(segments[1].toSite(), StatsTimeframe.TRAFFIC)
+        }
+    }
+
+    private fun parseDefaultSegments(segments: List<String>): StatsDeepLinkData {
+        if (segments.size == 1) {
+            val timeframe = segments[0].toStatsTimeframe()
+            return StatsDeepLinkData(if (timeframe == null) segments[0].toSite() else null, timeframe)
+        }
+        val timeframe = segments.getOrNull(segments.size - 2)?.toStatsTimeframe()
+        val site = segments.lastOrNull()?.toSite()
+        return StatsDeepLinkData(site, timeframe)
+    }
